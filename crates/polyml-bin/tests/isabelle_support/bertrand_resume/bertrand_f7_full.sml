  in Thm.implies_elim inst hForall end;
fun add_Sr4_at (mt,nt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0), ctermV4 mt),(("n",0), ctermV4 nt)] add_Suc_right_v4);
fun le_suc_self4_at nt =
  let
    val aeq = add_Sr4_at (nt, ZeroC);     (* oeq (add n (Suc 0))(Suc (add n 0)) *)
    val a0  = add0r4_at nt;               (* oeq (add n 0) n *)
    val s   = Suc_cong OF [a0];           (* oeq (Suc (add n 0))(Suc n) *)
    val rhs = oeq_trans OF [aeq, s];      (* oeq (add n (Suc 0))(Suc n) *)
    val eqn = oeq_sym OF [rhs];           (* oeq (Suc n)(add n (Suc 0)) *)
  in le_intro4 (nt, suc nt, suc ZeroC) eqn end;
fun prime2_gt1_4 p hPrime = conjunct1_4 (lt (suc ZeroC) p, mkForall (ppAbs p)) hPrime;
fun prime2_pos_4 p hPrime =
  let val gt1 = prime2_gt1_4 p hPrime          (* le 2 p *)
      val le12 = le_suc_self4_at (suc ZeroC)   (* le 1 2 *)
  in le_trans4_at (suc ZeroC, suc (suc ZeroC), p) le12 gt1 end;
fun prime2_div_4 (p,d) hPrime hdvd =   (* prime2 p -> dvd d p -> Disj (oeq d 1)(oeq d p) *)
  let val faThm = conjunct2_4 (lt (suc ZeroC) p, mkForall (ppAbs p)) hPrime  (* Forall (ppAbs p) *)
      val impAt = allE_4 (ppAbs p) d faThm   (* Imp (dvd d p)(Disj (oeq d 1)(oeq d p)) *)
  in mp_4 (dvd d p, mkDisj (oeq d (suc ZeroC))(oeq d p)) impAt hdvd end;
fun vp_additive_4 (pT,aT,bT) hPr hap hbp =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("p",0), ctermV4 pT),(("a",0), ctermV4 aT),(("b",0), ctermV4 bT)] vp_additive_v4)
  in ((inst OF [hPr]) OF [hap]) OF [hbp] end;
fun vp_pow_self_4 (pT,kT) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 pT),(("k",0), ctermV4 kT)] vp_pow_self_v4)
  in inst OF [hPr] end;
fun vp_step_ndvd_4 (pT, mT) hPr hpos hndvd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 pT), (("m",0), ctermV4 mT)] vp_step_ndvd_v4)
  in ((inst OF [hPr]) OF [hpos]) OF [hndvd] end;
fun euclid_4 (pT,aT,bT) hP hD =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("p",0), ctermV4 pT),(("a",0), ctermV4 aT),(("b",0), ctermV4 bT)] euclid_lemma_v4)
  in (inst OF [hP]) OF [hD] end;

(* div_mod on ctxtV4 *)
fun div_mod_eq_4 (aT, pT) hpos =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("a",0), ctermV4 aT), (("p",0), ctermV4 pT)] div_mod_eq_v4)
  in Thm.implies_elim inst hpos end;
fun rmod_lt_4 (aT, pT) hpos =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("a",0), ctermV4 aT), (("p",0), ctermV4 pT)] rmod_lt_v4)
  in Thm.implies_elim inst hpos end;
fun div_mod_unique_4 (q1T,q2T,r1T,r2T,bT) hEQ hLT1 hLT2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("q1",0), ctermV4 q1T),(("q2",0), ctermV4 q2T),(("r1",0), ctermV4 r1T),(("r2",0), ctermV4 r2T),(("b",0), ctermV4 bT)] div_mod_unique_v4)
  in ((inst OF [hEQ]) OF [hLT1]) OF [hLT2] end;
fun add_left_cancel4 (mT,aT,bT) h = (beta_norm (Drule.infer_instantiate ctxtV4
        [(("m",0), ctermV4 mT),(("a",0), ctermV4 aT),(("b",0), ctermV4 bT)] add_left_cancel_v4)) OF [h];
(* rdiv_mult_exact on ctxtV4 : lt 0 p ==> dvd p m ==> oeq m (mult p (rdiv m p)) *)
fun rdiv_mult_exact_4 (pT, mT) hpos hdvd =
  let
    val divEq = div_mod_eq_4 (mT, pT) hpos;
    val rlt   = rmod_lt_4 (mT, pT) hpos;
    val PabsK = Abs("k", natT, oeq mT (mult pT (Bound 0)))
    val goalC = oeq mT (mult pT (rdiv mT pT))
    fun body kF (hk : thm) =
      let
        val mk0 = oeq_trans OF [hk, oeq_sym OF [add0r4_at (mult pT kF)]];
        val eqA = oeq_trans OF [oeq_sym OF [divEq], mk0];
        val uniq  = div_mod_unique_4 (rdiv mT pT, kF, rmod mT pT, ZeroC, pT) eqA rlt hpos;
        val eqQ   = conjunct1_4 (oeq (rdiv mT pT) kF, oeq (rmod mT pT) ZeroC) uniq;
        val g = oeq_trans OF [hk, mult_cong_r4 (pT, kF, rdiv mT pT) (oeq_sym OF [eqQ])];
      in g end;
  in exE_elim4 (PabsK, goalC) hdvd "k_rme4" body end;
fun strong_induct_4 (Pabs, kT) hStep =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("P",0), ctermV4 Pabs),(("k",0), ctermV4 kT)] strong_induct_v4)
  in Thm.implies_elim inst hStep end;
fun nat_induct_4 (Pabs, kT) =
  beta_norm (Drule.infer_instantiate ctxtV4 [(("P",0), ctermV4 Pabs),(("k",0), ctermV4 kT)] nat_induct_v4);
fun prime_divisor_exists_4 nT hle =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0), ctermV4 nT)] prime_divisor_exists_v4)
  in inst OF [hle] end;

val () = out "F4_F_HELPERS_OK\n";

(* ============================================================================
   cpf_mult : lt 0 a ==> lt 0 b ==> oeq (cpf B (mult a b))(mult (cpf B a)(cpf B b))
   by nat_induct on B.
   ============================================================================ *)
val () = out "F4_CPFMULT_BEGIN\n";

(* mult rearrange : oeq (mult (mult W X)(mult Y Z))(mult (mult W Y)(mult X Z)) *)
fun mult_swap_inner4 (W,X,Y,Z) =
  let
    (* (WX)(YZ) = W(X(YZ)) [assoc] = W((XY)Z) [assoc inside] = W((YX)Z) [comm] = W(Y(XZ)) [assoc] = (WY)(XZ) [assoc] *)
    val s1 = multassoc4_at (W, X, mult Y Z)                 (* (WX)(YZ) = W (X (YZ)) *)
    val xyz1 = oeq_sym OF [multassoc4_at (X, Y, Z)]         (* X(YZ) = (XY)Z *)
    val s2 = mult_cong_r4 (W, mult X (mult Y Z), mult (mult X Y) Z) xyz1  (* W(X(YZ)) = W((XY)Z) *)
    val xy_yx = multcomm4_at (X, Y)                         (* XY = YX *)
    val s3 = mult_cong_r4 (W, mult (mult X Y) Z, mult (mult Y X) Z)
               (mult_cong_l4 (mult X Y, mult Y X, Z) xy_yx) (* W((XY)Z) = W((YX)Z) *)
    val yxz = multassoc4_at (Y, X, Z)                       (* (YX)Z = Y(XZ) *)
    val s4 = mult_cong_r4 (W, mult (mult Y X) Z, mult Y (mult X Z)) yxz  (* W((YX)Z) = W(Y(XZ)) *)
    val s5 = oeq_sym OF [multassoc4_at (W, Y, mult X Z)]    (* W(Y(XZ)) = (WY)(XZ) *)
  in oeq_trans OF [s1, oeq_trans OF [s2, oeq_trans OF [s3, oeq_trans OF [s4, s5]]]] end;

val cpf_mult =
  let
    val aF = Free("a", natT); val bF = Free("b", natT); val BF = Free("B_cm", natT)
    val ha = Thm.assume (ctermV4 (jT (lt ZeroC aF)))   (* 0 < a *)
    val hb = Thm.assume (ctermV4 (jT (lt ZeroC bF)))   (* 0 < b *)
    val zCM = Free("z_cm", natT)
    val Pabs = Term.lambda zCM (oeq (cpf zCM (mult aF bF))(mult (cpf zCM aF)(cpf zCM bF)))
    val ind = nat_induct_4 (Pabs, BF)
    (* BASE B=0 : cpf 0 (ab) = 1 ; mult (cpf 0 a)(cpf 0 b) = 1*1 = 1 *)
    val base =
      let
        val c0ab = cpf0_at (mult aF bF)        (* oeq (cpf 0 (ab)) 1 *)
        val c0a  = cpf0_at aF                    (* oeq (cpf 0 a) 1 *)
        val c0b  = cpf0_at bF                    (* oeq (cpf 0 b) 1 *)
        (* mult (cpf 0 a)(cpf 0 b) = mult 1 1 = 1 *)
        val rhs1 = oeq_trans OF [mult_cong_l4 (cpf ZeroC aF, suc ZeroC, cpf ZeroC bF) c0a,
                     oeq_trans OF [mult_cong_r4 (suc ZeroC, cpf ZeroC bF, suc ZeroC) c0b, mult1l4_at (suc ZeroC)]]
                   (* oeq (mult (cpf 0 a)(cpf 0 b)) 1 *)
        (* goal : oeq (cpf 0 (ab))(mult (cpf 0 a)(cpf 0 b)) :  both = 1 *)
      in oeq_trans OF [c0ab, oeq_sym OF [rhs1]] end;
    val xF = Free("x_cm", natT)
    val ihP = jT (oeq (cpf xF (mult aF bF))(mult (cpf xF aF)(cpf xF bF)))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = oeq (cpf (suc xF)(mult aF bF))(mult (cpf (suc xF) aF)(cpf (suc xF) bF))
    val em = ex_middle_4 (prime2 xF)
    val casePrime =
      let
        val hpr = Thm.assume (ctermV4 (jT (prime2 xF)))
        (* cpf (Suc x)(ab) = cpf x (ab) * pow x (vp x (ab)) *)
        val L0 = cpf_sp_at (xF, mult aF bF) hpr      (* oeq (cpf (Suc x)(ab))(mult (cpf x (ab))(pow x (vp x (ab)))) *)
        (* vp x (ab) = vp x a + vp x b *)
        val vadd = vp_additive_4 (xF, aF, bF) hpr ha hb   (* oeq (vp x (ab))(add (vp x a)(vp x b)) *)
        (* pow x (vp x (ab)) = pow x (vp x a + vp x b) = pow x (vp x a) * pow x (vp x b) *)
        val powe = pow_cong_e4 (xF, vp xF (mult aF bF), add (vp xF aF)(vp xF bF)) vadd
                   (* oeq (pow x (vp x (ab)))(pow x (add (vp x a)(vp x b))) *)
        val powsplit = powadd4_at (xF, vp xF aF, vp xF bF)   (* oeq (pow x (vp x a + vp x b))(mult (pow x (vp x a))(pow x (vp x b))) *)
        val powfull = oeq_trans OF [powe, powsplit]
                      (* oeq (pow x (vp x (ab)))(mult (pow x (vp x a))(pow x (vp x b))) *)
        (* cpf x (ab) = cpf x a * cpf x b [IH] *)
        (* L0 RHS = mult (cpf x (ab))(pow x (vp x (ab)))
              -> mult (mult (cpf x a)(cpf x b))(mult (pow x (vp x a))(pow x (vp x b))) *)
        val W = cpf xF aF; val Y = cpf xF bF
        val Xp = pow xF (vp xF aF); val Zp = pow xF (vp xF bF)
        val rwL = mult_cong_l4 (cpf xF (mult aF bF), mult W Y, pow xF (vp xF (mult aF bF))) IH
                  (* oeq (mult (cpf x (ab))(pow x (vp x (ab))))(mult (mult W Y)(pow x (vp x (ab)))) *)
        val rwR = mult_cong_r4 (mult W Y, pow xF (vp xF (mult aF bF)), mult Xp Zp) powfull
                  (* oeq (mult (mult W Y)(pow x (vp x (ab))))(mult (mult W Y)(mult Xp Zp)) *)
        val rw = oeq_trans OF [L0, oeq_trans OF [rwL, rwR]]
                 (* oeq (cpf (Suc x)(ab))(mult (mult W Y)(mult Xp Zp)) *)
        (* rearrange (WY)(XpZp) -> (WXp)(YZp) *)
        val swap = mult_swap_inner4 (W, Y, Xp, Zp)   (* oeq (mult (mult W Y)(mult Xp Zp))(mult (mult W Xp)(mult Y Zp)) *)
        val rw2 = oeq_trans OF [rw, swap]   (* oeq (cpf (Suc x)(ab))(mult (mult W Xp)(mult Y Zp)) *)
        (* cpf (Suc x) a = mult (cpf x a)(pow x (vp x a)) = mult W Xp [cpf_sp] *)
        val cSa = cpf_sp_at (xF, aF) hpr   (* oeq (cpf (Suc x) a)(mult W Xp) *)
        val cSb = cpf_sp_at (xF, bF) hpr   (* oeq (cpf (Suc x) b)(mult Y Zp) *)
        (* goal RHS mult (cpf(Suc x) a)(cpf(Suc x) b) -> mult (mult W Xp)(mult Y Zp) *)
        val grhs = oeq_trans OF [mult_cong_l4 (cpf (suc xF) aF, mult W Xp, cpf (suc xF) bF) cSa,
                     mult_cong_r4 (mult W Xp, cpf (suc xF) bF, mult Y Zp) cSb]
                   (* oeq (mult (cpf(Suc x) a)(cpf(Suc x) b))(mult (mult W Xp)(mult Y Zp)) *)
        val g = oeq_trans OF [rw2, oeq_sym OF [grhs]]   (* oeq (cpf(Suc x)(ab))(mult (cpf(Suc x) a)(cpf(Suc x) b)) *)
      in Thm.implies_intr (ctermV4 (jT (prime2 xF))) g end;
    val caseNonPrime =
      let
        val hnp = Thm.assume (ctermV4 (jT (neg (prime2 xF))))
        val Lab = cpf_sn_at (xF, mult aF bF) hnp   (* oeq (cpf (Suc x)(ab))(cpf x (ab)) *)
        val La  = cpf_sn_at (xF, aF) hnp           (* oeq (cpf (Suc x) a)(cpf x a) *)
        val Lb  = cpf_sn_at (xF, bF) hnp           (* oeq (cpf (Suc x) b)(cpf x b) *)
        (* goal RHS -> mult (cpf x a)(cpf x b) *)
        val grhs = oeq_trans OF [mult_cong_l4 (cpf (suc xF) aF, cpf xF aF, cpf (suc xF) bF) La,
                     mult_cong_r4 (cpf xF aF, cpf (suc xF) bF, cpf xF bF) Lb]
                   (* oeq (mult (cpf(Suc x) a)(cpf(Suc x) b))(mult (cpf x a)(cpf x b)) *)
        val g = oeq_trans OF [Lab, oeq_trans OF [IH, oeq_sym OF [grhs]]]
                (* oeq (cpf(Suc x)(ab))(mult (cpf(Suc x) a)(cpf(Suc x) b)) *)
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 xF)))) g end;
    val stepC = disjE_4 (prime2 xF, neg (prime2 xF), goalStep) em casePrime caseNonPrime
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
    val res = Thm.implies_elim (Thm.implies_elim ind base) step
    val d2 = Thm.implies_intr (ctermV4 (jT (lt ZeroC bF))) res
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC aF))) d2
  in varify d1 end;
val () = out ("cpf_mult 0hyp=" ^ Bool.toString (zhV4 cpf_mult) ^ "\n");
val i_cpf_mult =
  let val aVz = Var(("a",0),natT); val bVz = Var(("b",0),natT); val BVz = Var(("B_cm",0),natT)
  in Logic.mk_implies (jT (lt ZeroC aVz),
       Logic.mk_implies (jT (lt ZeroC bVz),
         jT (oeq (cpf BVz (mult aVz bVz))(mult (cpf BVz aVz)(cpf BVz bVz))))) end;
val r_cm = (Thm.prop_of cpf_mult) aconv i_cpf_mult;
val () = out ("cpf_mult aconv=" ^ Bool.toString r_cm ^ "\n");
val () = if zhV4 cpf_mult andalso r_cm then out "CPF_MULT_OK\n" else out "CPF_MULT_FAIL\n";
fun cpf_mult_4 (Bt,at,bt) ha hb =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("a",0), ctermV4 at),(("b",0), ctermV4 bt),(("B_cm",0), ctermV4 Bt)] (varify cpf_mult))
  in (inst OF [ha]) OF [hb] end;
val () = out "F4_CPFMULT_DONE\n";

(* ============================================================================
   cpf_prime : prime2 q ==> lt q B ==> oeq (cpf B q) q.
   Via : cpf_below (B<=q => cpf B q = 1) + cpf_succ_q (cpf (Suc q) q = q)
         + cpf_stab (cpf (Suc q + k) q = q).
   ============================================================================ *)
val () = out "F4_CPFPRIME_BEGIN\n";

(* helper : prime2 q ==> lt 0 b ==> lt b q ==> ~(dvd b q)
   (b prime-range below q ; q prime ; b|q => b=1 or b=q ; b>=1.. actually use 1<b? we have lt 0 b => b>=1.
    But b=1 divides everything! Need b>1.  We'll apply only at prime b, so caller supplies prime2 b => b>1.) *)
(* gt: prime2 q ==> prime2 b ==> lt b q ==> ~(dvd b q) *)
fun bprime_lt_not_dvd (qT, bT) hqPr hbPr hlt =
  let
    val hd = Thm.assume (ctermV4 (jT (dvd bT qT)))         (* dvd b q *)
    val dj = prime2_div_4 (qT, bT) hqPr hd                 (* Disj (oeq b 1)(oeq b q) *)
    (* case b=1 : but prime2 b => 1<b => le 2 b ; oeq b 1 => le 2 1 => false *)
    val caseB1 =
      let val hb1 = Thm.assume (ctermV4 (jT (oeq bT (suc ZeroC))))   (* b = 1 *)
          val gt1 = prime2_gt1_4 bT hbPr                              (* le 2 b *)
          val le21 = le_cong_r4 (suc (suc ZeroC), bT, suc ZeroC) hb1 gt1  (* le 2 1 = le (Suc(Suc 0))(Suc 0) *)
          (* le (Suc(Suc 0))(Suc 0) -> le (Suc 0) 0 [strip Suc? use lt_irrefl style: le 2 1 means 1<1? no.
             le (Suc 1)(1) = lt 1 1 -> lt_irrefl *)
          val ff = (lt_irrefl4_at (suc ZeroC)) OF [le21]
      in Thm.implies_intr (ctermV4 (jT (oeq bT (suc ZeroC)))) ff end;
    (* case b=q : oeq b q ; lt b q = le (Suc b) q ; rewrite q->b : le (Suc b) b = lt b b -> false *)
    val caseBq =
      let val hbq = Thm.assume (ctermV4 (jT (oeq bT qT)))   (* b = q *)
          val ltbb = le_cong_r4 (suc bT, qT, bT) (oeq_sym OF [hbq]) hlt  (* le (Suc b) b = lt b b *)
          val ff = (lt_irrefl4_at bT) OF [ltbb]
      in Thm.implies_intr (ctermV4 (jT (oeq bT qT))) ff end;
    val ff = disjE_4 (oeq bT (suc ZeroC), oeq bT qT, oFalseC) dj caseB1 caseBq  (* oFalse *)
    val negMeta = Thm.implies_intr (ctermV4 (jT (dvd bT qT))) ff
  in impI_4 (dvd bT qT, oFalseC) negMeta end;    (* neg (dvd b q) *)

(* cpf_below : prime2 q ==> le B q ==> oeq (cpf B q)(Suc Zero).  nat_induct on B. *)
val cpf_below =
  let
    val qF = Free("q", natT); val BF = Free("B_cb", natT)
    val hqPr = Thm.assume (ctermV4 (jT (prime2 qF)))
    val lt0q = prime2_pos_4 qF hqPr
    val zCB = Free("z_cb", natT)
    val Pabs = Term.lambda zCB (mkImp (le zCB qF)(oeq (cpf zCB qF)(suc ZeroC)))
    val ind = nat_induct_4 (Pabs, BF)
    (* base B=0 : le 0 q => cpf 0 q = 1.  cpf 0 q = 1 unconditionally. *)
    val base =
      let val c0 = cpf0_at qF                       (* oeq (cpf 0 q) 1 *)
          val meta = Thm.implies_intr (ctermV4 (jT (le ZeroC qF))) c0   (* jT(le 0 q) ==> jT(oeq (cpf 0 q) 1) *)
      in impI_4 (le ZeroC qF, oeq (cpf ZeroC qF)(suc ZeroC)) meta end;  (* jT (Imp (le 0 q)(oeq (cpf 0 q) 1)) *)
    val xF = Free("x_cb", natT)
    val ihP = jT (mkImp (le xF qF)(oeq (cpf xF qF)(suc ZeroC)))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = mkImp (le (suc xF) qF)(oeq (cpf (suc xF) qF)(suc ZeroC))
    val stepBody =
      let
        val hStepLe = Thm.assume (ctermV4 (jT (le (suc xF) qF)))   (* le (Suc x) q = lt x q *)
        (* le x q : from le (Suc x) q, le x (Suc x), trans *)
        val le_x_Sx = le_suc_self4_at xF                          (* le x (Suc x) *)
        val le_x_q  = le_trans4_at (xF, suc xF, qF) le_x_Sx hStepLe  (* le x q *)
        val ihAt = mp_4 (le xF qF, oeq (cpf xF qF)(suc ZeroC)) IH le_x_q  (* oeq (cpf x q) 1 *)
        val em = ex_middle_4 (prime2 xF)
        val casePr =
          let val hpr = Thm.assume (ctermV4 (jT (prime2 xF)))
              val L = cpf_sp_at (xF, qF) hpr     (* oeq (cpf (Suc x) q)(mult (cpf x q)(pow x (vp x q))) *)
              (* ~dvd x q : x prime, lt x q (=hStepLe), q prime *)
              val ndvd = bprime_lt_not_dvd (qF, xF) hqPr hpr hStepLe   (* neg (dvd x q) *)
              val vpx0 = vp_step_ndvd_4 (xF, qF) hpr lt0q ndvd        (* oeq (vp x q) 0 *)
              (* pow x (vp x q) = pow x 0 = 1 *)
              val pe = pow_cong_e4 (xF, vp xF qF, ZeroC) vpx0          (* oeq (pow x (vp x q))(pow x 0) *)
              val p0 = pow04_at xF                                      (* oeq (pow x 0) 1 *)
              val powis1 = oeq_trans OF [pe, p0]                        (* oeq (pow x (vp x q)) 1 *)
              (* mult (cpf x q)(pow x (vp x q)) = mult 1 1 = 1 *)
              val r1 = mult_cong_l4 (cpf xF qF, suc ZeroC, pow xF (vp xF qF)) ihAt   (* -> mult 1 (pow...) *)
              val r2 = mult_cong_r4 (suc ZeroC, pow xF (vp xF qF), suc ZeroC) powis1 (* -> mult 1 1 *)
              val r3 = mult1l4_at (suc ZeroC)                          (* mult 1 1 = 1 *)
              val rhs = oeq_trans OF [r1, oeq_trans OF [r2, r3]]        (* oeq (mult (cpf x q)(pow x (vp x q))) 1 *)
              val g = oeq_trans OF [L, rhs]                            (* oeq (cpf (Suc x) q) 1 *)
          in Thm.implies_intr (ctermV4 (jT (prime2 xF))) g end;
        val caseNp =
          let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 xF))))
              val L = cpf_sn_at (xF, qF) hnp     (* oeq (cpf (Suc x) q)(cpf x q) *)
              val g = oeq_trans OF [L, ihAt]     (* oeq (cpf (Suc x) q) 1 *)
          in Thm.implies_intr (ctermV4 (jT (neg (prime2 xF)))) g end;
        val gStep = disjE_4 (prime2 xF, neg (prime2 xF), oeq (cpf (suc xF) qF)(suc ZeroC)) em casePr caseNp
        val meta = Thm.implies_intr (ctermV4 (jT (le (suc xF) qF))) gStep
      in impI_4 (le (suc xF) qF, oeq (cpf (suc xF) qF)(suc ZeroC)) meta end;
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepBody)
    val res = Thm.implies_elim (Thm.implies_elim ind base) step   (* jT (Imp (le B q)(oeq (cpf B q) 1)) *)
    val d1 = Thm.implies_intr (ctermV4 (jT (prime2 qF))) res
  in varify d1 end;
val () = out ("cpf_below 0hyp=" ^ Bool.toString (zhV4 cpf_below) ^ "\n");
val i_cpf_below =
  let val qVz = Var(("q",0),natT); val BVz = Var(("B_cb",0),natT)
  in Logic.mk_implies (jT (prime2 qVz), jT (mkImp (le BVz qVz)(oeq (cpf BVz qVz)(suc ZeroC)))) end;
val r_cb = (Thm.prop_of cpf_below) aconv i_cpf_below;
val () = out ("cpf_below aconv=" ^ Bool.toString r_cb ^ "\n");
val () = if zhV4 cpf_below andalso r_cb then out "CPF_BELOW_OK\n" else out "CPF_BELOW_FAIL\n";
fun cpf_below_4 (Bt,qt) hqPr hle =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("q",0), ctermV4 qt),(("B_cb",0), ctermV4 Bt)] (varify cpf_below))
  in mp_4 (le Bt qt, oeq (cpf Bt qt)(suc ZeroC)) (inst OF [hqPr]) hle end;
val () = out "F4_CPFBELOW_DONE\n";

(* ============================================================================
   cpf_succ_q : prime2 q ==> oeq (cpf (Suc q) q) q.
   ============================================================================ *)
val () = out "F4_CPFSUCCQ_BEGIN\n";

val cpf_succ_q =
  let
    val qF = Free("q", natT)
    val hqPr = Thm.assume (ctermV4 (jT (prime2 qF)))
    val lt0q = prime2_pos_4 qF hqPr
    (* cpf (Suc q) q = mult (cpf q q)(pow q (vp q q)) *)
    val L = cpf_sp_at (qF, qF) hqPr      (* oeq (cpf (Suc q) q)(mult (cpf q q)(pow q (vp q q))) *)
    (* cpf q q = 1  [cpf_below at q, le q q] *)
    val cbq = cpf_below_4 (qF, qF) hqPr (le_refl4_at qF)   (* oeq (cpf q q) 1 *)
    (* vp q q = 1 :  q = pow q (Suc 0) ; vp q (pow q (Suc 0)) = Suc 0 *)
    val q_is_pow = (let val p0 = pow04_at qF                (* oeq (pow q 0) 1 *)
                        val pS = powSuc4_at (qF, ZeroC)      (* oeq (pow q (Suc 0))(mult q (pow q 0)) *)
                        val r  = oeq_trans OF [pS, oeq_trans OF [mult_cong_r4 (qF, pow qF ZeroC, suc ZeroC) p0, mult1r4_at qF]]
                    in r end)   (* oeq (pow q (Suc 0)) q *)
    val vpps = vp_pow_self_4 (qF, suc ZeroC) hqPr           (* oeq (vp q (pow q (Suc 0)))(Suc 0) *)
    (* vp q q = vp q (pow q (Suc 0)) [cong sym q_is_pow] = Suc 0 *)
    val vqq1 = (let val zF = Free("zvqq", natT)
                    val Pb = Term.lambda zF (oeq (vp qF zF)(suc ZeroC))
                in substPred4 (Pb, pow qF (suc ZeroC), qF) q_is_pow vpps end)   (* oeq (vp q q)(Suc 0) *)
    (* pow q (vp q q) = pow q (Suc 0) = q *)
    val powqq = oeq_trans OF [pow_cong_e4 (qF, vp qF qF, suc ZeroC) vqq1, q_is_pow]  (* oeq (pow q (vp q q)) q *)
    (* mult (cpf q q)(pow q (vp q q)) = mult 1 q = q *)
    val r1 = mult_cong_l4 (cpf qF qF, suc ZeroC, pow qF (vp qF qF)) cbq   (* -> mult 1 (pow q (vp q q)) *)
    val r2 = mult_cong_r4 (suc ZeroC, pow qF (vp qF qF), qF) powqq        (* -> mult 1 q *)
    val r3 = mult1l4_at qF                                                 (* mult 1 q = q *)
    val rhs = oeq_trans OF [r1, oeq_trans OF [r2, r3]]                     (* oeq (mult (cpf q q)(pow q (vp q q))) q *)
    val g = oeq_trans OF [L, rhs]    (* oeq (cpf (Suc q) q) q *)
    val d1 = Thm.implies_intr (ctermV4 (jT (prime2 qF))) g
  in varify d1 end;
val () = out ("cpf_succ_q 0hyp=" ^ Bool.toString (zhV4 cpf_succ_q) ^ "\n");
val i_cpf_succ_q = let val qVz = Var(("q",0),natT) in Logic.mk_implies (jT (prime2 qVz), jT (oeq (cpf (suc qVz) qVz) qVz)) end;
val r_csq = (Thm.prop_of cpf_succ_q) aconv i_cpf_succ_q;
val () = out ("cpf_succ_q aconv=" ^ Bool.toString r_csq ^ "\n");
val () = if zhV4 cpf_succ_q andalso r_csq then out "CPF_SUCCQ_OK\n" else out "CPF_SUCCQ_FAIL\n";
fun cpf_succ_q_4 qt hqPr = (beta_norm (Drule.infer_instantiate ctxtV4 [(("q",0), ctermV4 qt)] (varify cpf_succ_q))) OF [hqPr];
val () = out "F4_CPFSUCCQ_DONE\n";

(* ============================================================================
   cpf_stab : prime2 q ==> oeq (cpf (add (Suc q) k) q)(cpf (Suc q) q).  nat_induct on k.
   ============================================================================ *)
val () = out "F4_CPFSTAB_BEGIN\n";

(* helper : prime2 q ==> lt q c ==> ~(dvd c q)  (c > q, q prime, so c != 1 and c != q) *)
fun gt_not_dvd (qT, cT) hqPr hlt =     (* hlt : lt q c *)
  let
    val hd = Thm.assume (ctermV4 (jT (dvd cT qT)))     (* dvd c q *)
    val dj = prime2_div_4 (qT, cT) hqPr hd             (* Disj (oeq c 1)(oeq c q) *)
    (* c=1 : lt q c => le (Suc q) 1 ; q>=2 so Suc q >= 3 ; le 3.. 1 false. Actually q>=1 (prime), Suc q>=2, le 2 1 false.
       From hlt : le (Suc q) c ; oeq c 1 => le (Suc q) 1 = lt q 1 ; q>=1 => le 1 q (lt0q) ; le (Suc q) 1 and le 1 q:
       le (Suc q) 1, and le 1 (Suc q) [le_suc_self], trans le (Suc q)(Suc q)? no.
       Simpler: oeq c 1, hlt: le (Suc q) c -> le (Suc q) 1.  q>=1 so le 1 q (prime2_pos) -> le 2 (Suc q) [suc mono on le 1 q].
       le 2 (Suc q) and le (Suc q) 1 -> le 2 1 -> lt 1 1 -> false. *)
    val lt0q = prime2_pos_4 qT hqPr                    (* le 1 q *)
    val caseC1 =
      let val hc1 = Thm.assume (ctermV4 (jT (oeq cT (suc ZeroC))))   (* c = 1 *)
          val leSq1 = le_cong_r4 (suc qT, cT, suc ZeroC) hc1 hlt      (* le (Suc q) 1 *)
          val le2Sq = le_suc_mono4_at (suc ZeroC, qT) lt0q            (* le 2 (Suc q) *)
          val le21 = le_trans4_at (suc (suc ZeroC), suc qT, suc ZeroC) le2Sq leSq1  (* le 2 1 = lt 1 1 *)
          val ff = (lt_irrefl4_at (suc ZeroC)) OF [le21]
      in Thm.implies_intr (ctermV4 (jT (oeq cT (suc ZeroC)))) ff end;
    val caseCq =
      let val hcq = Thm.assume (ctermV4 (jT (oeq cT qT)))   (* c = q *)
          val ltqq = le_cong_r4 (suc qT, cT, qT) hcq hlt     (* le (Suc q) q = lt q q *)
          val ff = (lt_irrefl4_at qT) OF [ltqq]
      in Thm.implies_intr (ctermV4 (jT (oeq cT qT))) ff end;
    val ff = disjE_4 (oeq cT (suc ZeroC), oeq cT qT, oFalseC) dj caseC1 caseCq
    val negMeta = Thm.implies_intr (ctermV4 (jT (dvd cT qT))) ff
  in impI_4 (dvd cT qT, oFalseC) negMeta end;

val cpf_stab =
  let
    val qF = Free("q", natT); val kF = Free("k_st", natT)
    val hqPr = Thm.assume (ctermV4 (jT (prime2 qF)))
    val lt0q = prime2_pos_4 qF hqPr
    val zST = Free("z_st", natT)
    val Pabs = Term.lambda zST (oeq (cpf (add (suc qF) zST) qF)(cpf (suc qF) qF))
    val ind = nat_induct_4 (Pabs, kF)
    (* base k=0 : cpf (add (Suc q) 0) q = cpf (Suc q) q [add_0_right] *)
    val base =
      let val a0 = add0r4_at (suc qF)    (* oeq (add (Suc q) 0)(Suc q) *)
          val g = cpf_cong_m4 (add (suc qF) ZeroC, suc qF, suc qF) (oeqrefl4_at (suc qF))  (* trivial *)
          (* actually cpf (add (Suc q) 0) q -> cpf (Suc q) q via cong on FIRST arg of cpf. need cpf_cong on b. *)
          val g2 = (let val zF = Free("zb_st0", natT)
                        val Pb = Term.lambda zF (oeq (cpf (add (suc qF) ZeroC) qF)(cpf zF qF))
                    in substPred4 (Pb, add (suc qF) ZeroC, suc qF) a0 (oeqrefl4_at (cpf (add (suc qF) ZeroC) qF)) end)
                   (* oeq (cpf (add (Suc q) 0) q)(cpf (Suc q) q) *)
      in g2 end;
    val xF = Free("x_st", natT)
    val ihP = jT (oeq (cpf (add (suc qF) xF) qF)(cpf (suc qF) qF))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = oeq (cpf (add (suc qF)(suc xF)) qF)(cpf (suc qF) qF)
    (* add (Suc q)(Suc x) = Suc (add (Suc q) x) [add_Suc_right] ; let c = add (Suc q) x *)
    val cTm = add (suc qF) xF
    val aSr = add_Sr4_at (suc qF, xF)   (* oeq (add (Suc q)(Suc x))(Suc (add (Suc q) x)) *)
    (* cpf (add (Suc q)(Suc x)) q = cpf (Suc c) q [cong] *)
    val cpfRw = (let val zF = Free("zb_sts", natT)
                     val Pb = Term.lambda zF (oeq (cpf (add (suc qF)(suc xF)) qF)(cpf zF qF))
                 in substPred4 (Pb, add (suc qF)(suc xF), suc cTm) aSr (oeqrefl4_at (cpf (add (suc qF)(suc xF)) qF)) end)
                (* oeq (cpf (add (Suc q)(Suc x)) q)(cpf (Suc c) q) *)
    (* lt q c : q < Suc q <= Suc q + x = c.  le (Suc q) c via le_add (c = Suc q + x) *)
    val lt_q_c = le_add4_at (suc qF, xF)   (* le (Suc q)(add (Suc q) x) = lt q c *)
    val em = ex_middle_4 (prime2 cTm)
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 cTm)))
          val L = cpf_sp_at (cTm, qF) hpr     (* oeq (cpf (Suc c) q)(mult (cpf c q)(pow c (vp c q))) *)
          val ndvd = gt_not_dvd (qF, cTm) hqPr lt_q_c   (* neg (dvd c q) *)
          val vpc0 = vp_step_ndvd_4 (cTm, qF) hpr lt0q ndvd  (* oeq (vp c q) 0 *)
          val pe = pow_cong_e4 (cTm, vp cTm qF, ZeroC) vpc0   (* oeq (pow c (vp c q))(pow c 0) *)
          val p0 = pow04_at cTm                                (* oeq (pow c 0) 1 *)
          val powis1 = oeq_trans OF [pe, p0]                   (* oeq (pow c (vp c q)) 1 *)
          (* mult (cpf c q)(pow c (vp c q)) = mult (cpf c q) 1 = cpf c q *)
          val r1 = mult_cong_r4 (cpf cTm qF, pow cTm (vp cTm qF), suc ZeroC) powis1  (* -> mult (cpf c q) 1 *)
          val r2 = mult1r4_at (cpf cTm qF)                     (* mult (cpf c q) 1 = cpf c q *)
          val Lc = oeq_trans OF [L, oeq_trans OF [r1, r2]]     (* oeq (cpf (Suc c) q)(cpf c q) *)
          (* cpf (Suc c) q = cpf c q = cpf (add (Suc q) x) q = cpf (Suc q) q [IH] *)
          val g = oeq_trans OF [cpfRw, oeq_trans OF [Lc, IH]]  (* oeq (cpf (add (Suc q)(Suc x)) q)(cpf (Suc q) q) *)
      in Thm.implies_intr (ctermV4 (jT (prime2 cTm))) g end;
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 cTm))))
          val L = cpf_sn_at (cTm, qF) hnp   (* oeq (cpf (Suc c) q)(cpf c q) *)
          val g = oeq_trans OF [cpfRw, oeq_trans OF [L, IH]]
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 cTm)))) g end;
    val stepC = disjE_4 (prime2 cTm, neg (prime2 cTm), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
    val res = Thm.implies_elim (Thm.implies_elim ind base) step
    val d1 = Thm.implies_intr (ctermV4 (jT (prime2 qF))) res
  in varify d1 end;
val () = out ("cpf_stab 0hyp=" ^ Bool.toString (zhV4 cpf_stab) ^ "\n");
val i_cpf_stab =
  let val qVz = Var(("q",0),natT); val kVz = Var(("k_st",0),natT)
  in Logic.mk_implies (jT (prime2 qVz), jT (oeq (cpf (add (suc qVz) kVz) qVz)(cpf (suc qVz) qVz))) end;
val r_cst = (Thm.prop_of cpf_stab) aconv i_cpf_stab;
val () = out ("cpf_stab aconv=" ^ Bool.toString r_cst ^ "\n");
val () = if zhV4 cpf_stab andalso r_cst then out "CPF_STAB_OK\n" else out "CPF_STAB_FAIL\n";
fun cpf_stab_4 (qt,kt) hqPr = (beta_norm (Drule.infer_instantiate ctxtV4 [(("q",0), ctermV4 qt),(("k_st",0), ctermV4 kt)] (varify cpf_stab))) OF [hqPr];
val () = out "F4_CPFSTAB_DONE\n";

(* ============================================================================
   cpf_prime : prime2 q ==> lt q B ==> oeq (cpf B q) q.
   From lt q B : B = add (Suc q) k for some k ; cpf B q = cpf (add (Suc q) k) q
     = cpf (Suc q) q [cpf_stab] = q [cpf_succ_q].
   ============================================================================ *)
val () = out "F4_CPFPRIME_FINAL_BEGIN\n";

val cpf_prime =
  let
    val qF = Free("q", natT); val BF = Free("B_cp", natT)
    val hqPr = Thm.assume (ctermV4 (jT (prime2 qF)))
    val hltB = Thm.assume (ctermV4 (jT (lt qF BF)))   (* lt q B = le (Suc q) B = Ex k. oeq B (add (Suc q) k) *)
    val csq = cpf_succ_q_4 qF hqPr                     (* oeq (cpf (Suc q) q) q *)
    val goalC = oeq (cpf BF qF) qF
    (* exE on hltB (le (Suc q) B) : witness k with oeq B (add (Suc q) k) *)
    val PabsK = Abs("k", natT, oeq BF (add (suc qF)(Bound 0)))
    fun body kF (hk : thm) =    (* hk : oeq B (add (Suc q) k) *)
      let
        (* cpf B q = cpf (add (Suc q) k) q [cong on first arg] *)
        val cpfRw = (let val zF = Free("zb_cpf", natT)
                         val Pb = Term.lambda zF (oeq (cpf BF qF)(cpf zF qF))
                     in substPred4 (Pb, BF, add (suc qF) kF) hk (oeqrefl4_at (cpf BF qF)) end)
                    (* oeq (cpf B q)(cpf (add (Suc q) k) q) *)
        val stab = cpf_stab_4 (qF, kF) hqPr   (* oeq (cpf (add (Suc q) k) q)(cpf (Suc q) q) *)
        val g = oeq_trans OF [cpfRw, oeq_trans OF [stab, csq]]   (* oeq (cpf B q) q *)
      in g end
    val concl = exE_elim4 (PabsK, goalC) hltB "k_cpf" body
    val d2 = Thm.implies_intr (ctermV4 (jT (lt qF BF))) concl
    val d1 = Thm.implies_intr (ctermV4 (jT (prime2 qF))) d2
  in varify d1 end;
val () = out ("cpf_prime 0hyp=" ^ Bool.toString (zhV4 cpf_prime) ^ "\n");
val i_cpf_prime =
  let val qVz = Var(("q",0),natT); val BVz = Var(("B_cp",0),natT)
  in Logic.mk_implies (jT (prime2 qVz), Logic.mk_implies (jT (lt qVz BVz), jT (oeq (cpf BVz qVz) qVz))) end;
val r_cp = (Thm.prop_of cpf_prime) aconv i_cpf_prime;
val () = out ("cpf_prime aconv=" ^ Bool.toString r_cp ^ "\n");
val () = if zhV4 cpf_prime andalso r_cp then out "CPF_PRIME_OK\n" else out "CPF_PRIME_FAIL\n";
fun cpf_prime_4 (Bt,qt) hqPr hlt =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("q",0), ctermV4 qt),(("B_cp",0), ctermV4 Bt)] (varify cpf_prime))
  in (inst OF [hqPr]) OF [hlt] end;
val () = out "F4_CPFPRIME_FINAL_DONE\n";

(* ============================================================================
   fact_prime_pow : lt 0 m ==> lt m B ==> oeq m (cpf B m).   strong induction on m.
   ============================================================================ *)
val () = out "F4_FPP_BEGIN\n";

(* wire extra order/mult lemmas onto ctxtV4 *)
val dvd_le_v4 = varify dvd_le;
fun dvd_le_4 (dT,nT) hdvd hnz =     (* hdvd : dvd d n ; hnz : (jT(oeq n 0) ==> jT oFalse) ; -> le d n *)
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("d",0), ctermV4 dT),(("n",0), ctermV4 nT)] dvd_le_v4)
  in Thm.implies_elim (Thm.implies_elim inst hdvd) hnz end;
val mult_le_mono_v4 = varify mult_le_mono;
fun mult_le_mono_4 (cT,jT_,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("c",0), ctermV4 cT),(("j",0), ctermV4 jT_),(("k",0), ctermV4 kT)] mult_le_mono_v4)) h;
val le_add_mono_v4 = varify le_add_mono;
fun le_add_mono_4 (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("a",0), ctermV4 aT),(("b",0), ctermV4 bT),(("c",0), ctermV4 cT)] le_add_mono_v4)) h;

(* mult numeral helpers on V4 : mult (Suc 0) x = x ; mult (Suc(Suc 0)) x = add x x *)
fun multSuc4_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0), ctermV4 mt),(("n",0), ctermV4 nt)] mult_Suc_v4);
fun add_Suc4_at (mt,nt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0), ctermV4 mt),(("n",0), ctermV4 nt)] add_Suc_v4);

(* lt 0 (rdiv m q) : from m = q*(m/q) and lt 0 m ; if m/q=0 then m=q*0=0 contra. *)
fun rdiv_pos_4 (qT, mT) hqPr hm0 hdvd =
  let
    val lt0q = prime2_pos_4 qT hqPr
    val mEq  = rdiv_mult_exact_4 (qT, mT) lt0q hdvd   (* oeq m (mult q (rdiv m q)) *)
    (* disj_zero_or_suc on rdiv m q *)
    val dz = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 (rdiv mT qT))] disj_zero_or_suc_v4)
             (* Disj (oeq (rdiv m q) 0)(Ex w. oeq (rdiv m q)(Suc w)) *)
    val goalC = lt ZeroC (rdiv mT qT)
    val caseZ =
      let val hz = Thm.assume (ctermV4 (jT (oeq (rdiv mT qT) ZeroC)))   (* rdiv = 0 *)
          (* m = q * rdiv = q * 0 = 0 ; but lt 0 m = le 1 m ; m=0 -> le 1 0 -> false *)
          val mq0 = oeq_trans OF [mEq, oeq_trans OF [mult_cong_r4 (qT, rdiv mT qT, ZeroC) hz, mult0r4_at qT]]
                    (* oeq m 0 *)
          val le10 = le_cong_r4 (suc ZeroC, mT, ZeroC) mq0 hm0   (* le 1 0 = lt 0 0 *)
          val ff = (lt_irrefl4_at ZeroC) OF [le10]
          val anyg = oFalse_elim_4 (lt ZeroC (rdiv mT qT)) OF [ff]
      in Thm.implies_intr (ctermV4 (jT (oeq (rdiv mT qT) ZeroC))) anyg end;
    val PabsW = Abs("w", natT, oeq (rdiv mT qT)(suc (Bound 0)))
    val caseS =
      let val hex = Thm.assume (ctermV4 (jT (mkEx PabsW)))
          fun body wF (hw : thm) =   (* hw : oeq (rdiv m q)(Suc w) *)
            let (* lt 0 (rdiv) = le 1 (rdiv) ; rdiv = Suc w ; le 1 (Suc w) ; rewrite *)
                val le0w = le_zero4_at wF                       (* le 0 w *)
                val le1Sw = le_suc_mono4_at (ZeroC, wF) le0w    (* le 1 (Suc w) *)
                val g = le_cong_r4 (suc ZeroC, suc wF, rdiv mT qT) (oeq_sym OF [hw]) le1Sw  (* le 1 (rdiv) *)
            in g end
          val g = exE_elim4 (PabsW, goalC) hex "w_rp" body
      in Thm.implies_intr (ctermV4 (jT (mkEx PabsW))) g end;
  in disjE_4 (oeq (rdiv mT qT) ZeroC, mkEx PabsW, goalC) dz caseZ caseS end;

(* lt (rdiv m q) m : m = q*(m/q) >= 2*(m/q) = (m/q)+(m/q) > (m/q) since (m/q)>0 *)
fun rdiv_lt_4 (qT, mT) hqPr hm0 hdvd =
  let
    val lt0q = prime2_pos_4 qT hqPr
    val gt1q = prime2_gt1_4 qT hqPr            (* le 2 q *)
    val mEq  = rdiv_mult_exact_4 (qT, mT) lt0q hdvd   (* oeq m (mult q (rdiv m q)) *)
    val rpos = rdiv_pos_4 (qT, mT) hqPr hm0 hdvd      (* le 1 (rdiv m q) *)
    val dP = rdiv mT qT
    (* mult_le_mono2 : le 2 q, le rdiv rdiv -> le (2*rdiv)(q*rdiv) *)
    val mlm = mult_le_mono2_4_at (suc (suc ZeroC), qT, dP, dP) gt1q (le_refl4_at dP)
              (* le (mult 2 rdiv)(mult q rdiv) *)
    (* 2*rdiv = rdiv + rdiv : (Suc(Suc 0))*x = x + (Suc 0)*x = x + (x + 0*x) = x + x *)
    val ms2 = multSuc4_at (suc ZeroC, dP)     (* oeq (mult 2 rdiv)(add rdiv (mult 1 rdiv)) *)
    val ms1 = multSuc4_at (ZeroC, dP)         (* oeq (mult 1 rdiv)(add rdiv (mult 0 rdiv)) *)
    val m0r = mult04_at dP                     (* oeq (mult 0 rdiv) 0 *)
    val s1  = oeq_trans OF [ms1, oeq_trans OF [add_cong_r4 (dP, mult ZeroC dP, ZeroC) m0r, add0r4_at dP]]  (* mult 1 rdiv = rdiv *)
    val two_rdiv = oeq_trans OF [ms2, add_cong_r4 (dP, mult (suc ZeroC) dP, dP) s1]   (* oeq (mult 2 rdiv)(add rdiv rdiv) *)
    val le_dd_qrd = (let val zF = Free("zld4",natT) val Pabs = Term.lambda zF (le zF (mult qT dP))
                     in substPred4 (Pabs, mult (suc (suc ZeroC)) dP, add dP dP) two_rdiv mlm end)  (* le (rdiv+rdiv)(q*rdiv) *)
    val le_dd_m = (let val zF = Free("zlm4",natT) val Pabs = Term.lambda zF (le (add dP dP) zF)
                   in substPred4 (Pabs, mult qT dP, mT) (oeq_sym OF [mEq]) le_dd_qrd end)   (* le (rdiv+rdiv) m *)
    (* lt rdiv (rdiv+rdiv) : le 1 rdiv -> le (1+rdiv)(rdiv+rdiv) [le_add_mono] ; 1+rdiv = Suc rdiv *)
    val lam = le_add_mono_4 (suc ZeroC, dP, dP) rpos   (* le (add 1 rdiv)(add rdiv rdiv) *)
    val s0r = oeq_trans OF [add_Suc4_at (ZeroC, dP), Suc_cong OF [add04_at dP]]   (* oeq (add 1 rdiv)(Suc rdiv) *)
    val lt_d_dd = (let val zF = Free("zsd4",natT) val Pabs = Term.lambda zF (le zF (add dP dP))
                   in substPred4 (Pabs, add (suc ZeroC) dP, suc dP) s0r lam end)  (* le (Suc rdiv)(rdiv+rdiv) = lt rdiv (rdiv+rdiv) *)
    val g = le_trans4_at (suc dP, add dP dP, mT) lt_d_dd le_dd_m   (* le (Suc rdiv) m = lt rdiv m *)
  in g end
and mult_le_mono2_4_at (aT,bT,cT,dT) hab hcd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("a",0), ctermV4 aT),(("b",0), ctermV4 bT),(("c",0), ctermV4 cT),(("d",0), ctermV4 dT)] (varify mult_le_mono2))
  in Thm.implies_elim (Thm.implies_elim inst hab) hcd end;

val () = out "F4_FPP_HELPERS_OK\n";

(* cpf_one : oeq (cpf B (Suc Zero))(Suc Zero).  nat_induct on B.
   each prime b : vp b 1 = 0 (b does not divide 1) ; factor b^0 = 1. *)
val cpf_one =
  let
    val BF = Free("B_c1", natT)
    val oneN = suc ZeroC
    val zC1 = Free("z_c1", natT)
    val Pabs = Term.lambda zC1 (oeq (cpf zC1 oneN)(suc ZeroC))
    val ind = nat_induct_4 (Pabs, BF)
    val base = cpf0_at oneN     (* oeq (cpf 0 1) 1 *)
    val xF = Free("x_c1", natT)
    val ihP = jT (oeq (cpf xF oneN)(suc ZeroC))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = oeq (cpf (suc xF) oneN)(suc ZeroC)
    val em = ex_middle_4 (prime2 xF)
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 xF)))
          val L = cpf_sp_at (xF, oneN) hpr     (* oeq (cpf (Suc x) 1)(mult (cpf x 1)(pow x (vp x 1))) *)
          (* ~dvd x 1 : x prime so x>1 ; dvd x 1 -> x|1 -> x=1 (only divisor of 1 is 1).. use: dvd x 1 -> le x 1 [dvd_le, 1!=0] -> le 2 1 false *)
          val ndvd =
            let val hd = Thm.assume (ctermV4 (jT (dvd xF oneN)))
                val nz = Thm.implies_intr (ctermV4 (jT (oeq oneN ZeroC)))
                           ((beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0), ctermV4 ZeroC)] Suc_neq_Zero_v4)) OF [Thm.assume (ctermV4 (jT (oeq oneN ZeroC)))])
                         (* (oeq 1 0 ==> oFalse) *)
                val lex1 = dvd_le_4 (xF, oneN) hd nz    (* le x 1 *)
                val gt1x = prime2_gt1_4 xF hpr           (* le 2 x *)
                val le21 = le_trans4_at (suc (suc ZeroC), xF, oneN) gt1x lex1   (* le 2 1 = lt 1 1 *)
                val ff = (lt_irrefl4_at oneN) OF [le21]
                val negMeta = Thm.implies_intr (ctermV4 (jT (dvd xF oneN))) ff
            in impI_4 (dvd xF oneN, oFalseC) negMeta end;   (* neg (dvd x 1) *)
          val lt01 = le_refl4_at (suc ZeroC)   (* le 1 1 = lt 0 1 *)
          val vpx0 = vp_step_ndvd_4 (xF, oneN) hpr lt01 ndvd   (* oeq (vp x 1) 0 *)
          val powis1 = oeq_trans OF [pow_cong_e4 (xF, vp xF oneN, ZeroC) vpx0, pow04_at xF]  (* oeq (pow x (vp x 1)) 1 *)
          val r1 = mult_cong_l4 (cpf xF oneN, suc ZeroC, pow xF (vp xF oneN)) IH
          val r2 = mult_cong_r4 (suc ZeroC, pow xF (vp xF oneN), suc ZeroC) powis1
          val r3 = mult1l4_at (suc ZeroC)
          val rhs = oeq_trans OF [r1, oeq_trans OF [r2, r3]]   (* oeq (mult (cpf x 1)(pow x (vp x 1))) 1 *)
          val g = oeq_trans OF [L, rhs]
      in Thm.implies_intr (ctermV4 (jT (prime2 xF))) g end;
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 xF))))
          val L = cpf_sn_at (xF, oneN) hnp
          val g = oeq_trans OF [L, IH]
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 xF)))) g end;
    val stepC = disjE_4 (prime2 xF, neg (prime2 xF), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
  in varify (Thm.implies_elim (Thm.implies_elim ind base) step) end;
val () = out ("cpf_one 0hyp=" ^ Bool.toString (zhV4 cpf_one) ^ "\n");
val i_cpf_one = let val BVz = Var(("B_c1",0),natT) in jT (oeq (cpf BVz (suc ZeroC))(suc ZeroC)) end;
val r_c1 = (Thm.prop_of cpf_one) aconv i_cpf_one;
val () = out ("cpf_one aconv=" ^ Bool.toString r_c1 ^ "\n");
val () = if zhV4 cpf_one andalso r_c1 then out "CPF_ONE_OK\n" else out "CPF_ONE_FAIL\n";
fun cpf_one_4 Bt = beta_norm (Drule.infer_instantiate ctxtV4 [(("B_c1",0), ctermV4 Bt)] (varify cpf_one));
val () = out "F4_CPFONE_DONE\n";

(* ============================================================================
   fact_prime_pow : lt 0 m ==> lt m B ==> oeq m (cpf B m).  strong induction on m.
   ============================================================================ *)
val fact_prime_pow =
  let
    val BF = Free("B_fpp", natT); val mF = Free("m_fpp", natT)
    (* P m := lt 0 m ==> lt m B ==> oeq m (cpf B m) *)
    val zFP = Free("z_fpp", natT)
    val Pabs = Term.lambda zFP (mkImp (lt ZeroC zFP)(mkImp (lt zFP BF)(oeq zFP (cpf BF zFP))))
    (* strong_induct step : !!m. (!!m'. lt m' m ==> P m') ==> P m *)
    val mF2 = Free("m2_fpp", natT)
    val ihm = Free("mih_fpp", natT)
    val Gprop = Logic.all ihm (Logic.mk_implies (jT (lt ihm mF2), jT (Term.betapply (Pabs, ihm))))
    val Hthm  = Thm.assume (ctermV4 Gprop)   (* strong IH *)
    (* prove P m2 = jT (Imp (lt 0 m2)(Imp (lt m2 B)(oeq m2 (cpf B m2)))) *)
    val hm0  = Thm.assume (ctermV4 (jT (lt ZeroC mF2)))
    val hmB  = Thm.assume (ctermV4 (jT (lt mF2 BF)))
    (* m2 = 1 or m2 >= 2 : disj_zero_or_suc on m2 ; lt 0 m2 rules out 0 ; then case on the predecessor *)
    val dz = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 mF2)] disj_zero_or_suc_v4)
             (* Disj (oeq m2 0)(Ex w. oeq m2 (Suc w)) *)
    val goalInner = oeq mF2 (cpf BF mF2)
    val caseM0 =
      let val hz = Thm.assume (ctermV4 (jT (oeq mF2 ZeroC)))
          val le10 = le_cong_r4 (suc ZeroC, mF2, ZeroC) hz hm0   (* le 1 0 *)
          val ff = (lt_irrefl4_at ZeroC) OF [le10]
          val anyg = oFalse_elim_4 goalInner OF [ff]
      in Thm.implies_intr (ctermV4 (jT (oeq mF2 ZeroC))) anyg end;
    val PabsW = Abs("w", natT, oeq mF2 (suc (Bound 0)))
    val caseMS =
      let val hex = Thm.assume (ctermV4 (jT (mkEx PabsW)))
          fun bodyW wF (hw : thm) =   (* hw : oeq m2 (Suc w) *)
            let
              (* w = 0 (m2=1) or w = Suc j (m2 = Suc(Suc j) >= 2) *)
              val dzw = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 wF)] disj_zero_or_suc_v4)
              val caseW0 =
                let val hw0 = Thm.assume (ctermV4 (jT (oeq wF ZeroC)))   (* w = 0 *)
                    (* m2 = Suc 0 = 1 ; cpf B 1 = 1 [cpf_one] ; oeq m2 (cpf B m2) : m2=1, cpf B m2 = cpf B 1 = 1 = m2 *)
                    val m2is1 = oeq_trans OF [hw, Suc_cong OF [hw0]]   (* oeq m2 (Suc 0) *)
                    val cpfB1 = cpf_one_4 BF                            (* oeq (cpf B 1) 1 *)
                    (* cpf B m2 = cpf B 1 [cong m2->1] = 1 = m2 *)
                    val cpfBm2 = (let val zF = Free("zbm", natT) val Pb = Term.lambda zF (oeq (cpf BF mF2)(cpf BF zF))
                                  in substPred4 (Pb, mF2, suc ZeroC) m2is1 (oeqrefl4_at (cpf BF mF2)) end)
                                 (* oeq (cpf B m2)(cpf B 1) *)
                    val cpfBm2_1 = oeq_trans OF [cpfBm2, cpfB1]   (* oeq (cpf B m2) 1 *)
                    val g = oeq_trans OF [m2is1, oeq_sym OF [cpfBm2_1]]   (* oeq m2 (cpf B m2) *)
                in Thm.implies_intr (ctermV4 (jT (oeq wF ZeroC))) g end;
              val PabsJ = Abs("j", natT, oeq wF (suc (Bound 0)))
              val caseWS =
                let val hexj = Thm.assume (ctermV4 (jT (mkEx PabsJ)))
                    fun bodyJ jF (hj : thm) =   (* hj : oeq w (Suc j) ; so m2 = Suc(Suc j) *)
                      let
                        val m2is = oeq_trans OF [hw, Suc_cong OF [hj]]   (* oeq m2 (Suc(Suc j)) *)
                        (* le 2 m2 : le 2 (Suc(Suc j)) via le 0 j -> le_suc_mono twice ; then rewrite Suc(Suc j) -> m2 *)
                        val le0j = le_zero4_at jF                        (* le 0 j *)
                        val le1Sj = le_suc_mono4_at (ZeroC, jF) le0j     (* le 1 (Suc j) *)
                        val le2SSj = le_suc_mono4_at (suc ZeroC, suc jF) le1Sj   (* le 2 (Suc(Suc j)) *)
                        val le2m2 = le_cong_r4 (suc (suc ZeroC), suc (suc jF), mF2) (oeq_sym OF [m2is]) le2SSj  (* le 2 m2 *)
                        (* prime_divisor_exists at m2 : Ex q. prime2 q /\ dvd q m2 *)
                        val pde = prime_divisor_exists_4 mF2 le2m2   (* Ex q. Conj (prime2 q)(dvd q m2) *)
                        val PabsQ = resultBodyAbs mF2   (* %p. Conj (prime2 p)(dvd p m2) *)
                        fun bodyQ qF (hq : thm) =   (* hq : Conj (prime2 q)(dvd q m2) *)
                          let
                            val hqPr = conjunct1_4 (prime2 qF, dvd qF mF2) hq   (* prime2 q *)
                            val hdvd = conjunct2_4 (prime2 qF, dvd qF mF2) hq   (* dvd q m2 *)
                            val lt0q = prime2_pos_4 qF hqPr
                            val mEq = rdiv_mult_exact_4 (qF, mF2) lt0q hdvd   (* oeq m2 (mult q (rdiv m2 q)) *)
                            val dP = rdiv mF2 qF
                            val dPpos = rdiv_pos_4 (qF, mF2) hqPr hm0 hdvd     (* le 1 dP = lt 0 dP *)
                            val dPlt  = rdiv_lt_4 (qF, mF2) hqPr hm0 hdvd      (* lt dP m2 = le (Suc dP) m2 *)
                            (* lt dP B : le (Suc dP) m2 ; le m2 (Suc m2) ; le (Suc m2) B [hmB] ; chain *)
                            val le_SdP_Sm2 = le_trans4_at (suc dP, mF2, suc mF2) dPlt (le_suc_self4_at mF2)  (* le (Suc dP)(Suc m2) *)
                            val dPltB = le_trans4_at (suc dP, suc mF2, BF) le_SdP_Sm2 hmB   (* le (Suc dP) B = lt dP B *)
                            (* IH at dP *)
                            val ihImp = Thm.implies_elim (Thm.forall_elim (ctermV4 dP) Hthm) dPlt  (* jT (P dP) *)
                            (* P dP = Imp (lt 0 dP)(Imp (lt dP B)(oeq dP (cpf B dP))) *)
                            val ihStep1 = mp_4 (lt ZeroC dP, mkImp (lt dP BF)(oeq dP (cpf BF dP))) ihImp dPpos
                            val ihAtdP  = mp_4 (lt dP BF, oeq dP (cpf BF dP)) ihStep1 dPltB   (* oeq dP (cpf B dP) *)
                            (* lt q B : le q m2 [dvd_le] ; le (Suc q)(Suc m2) ; trans with hmB *)
                            val m2nz = Thm.implies_intr (ctermV4 (jT (oeq mF2 ZeroC)))
                                         (let val hmz = Thm.assume (ctermV4 (jT (oeq mF2 ZeroC)))
                                              val le10 = le_cong_r4 (suc ZeroC, mF2, ZeroC) hmz hm0
                                          in (lt_irrefl4_at ZeroC) OF [le10] end)   (* (oeq m2 0 ==> oFalse) *)
                            val le_q_m2 = dvd_le_4 (qF, mF2) hdvd m2nz       (* le q m2 *)
                            val le_Sq_Sm2 = le_suc_mono4_at (qF, mF2) le_q_m2  (* le (Suc q)(Suc m2) *)
                            val lt_q_B = le_trans4_at (suc qF, suc mF2, BF) le_Sq_Sm2 hmB  (* le (Suc q) B = lt q B *)
                            val cpfBq = cpf_prime_4 (BF, qF) hqPr lt_q_B    (* oeq (cpf B q) q *)
                            (* cpf B m2 = cpf B (q*dP) [cong m2 -> q*dP via mEq] = cpf B q * cpf B dP [cpf_mult] = q * dP = m2 *)
                            val cpfBm2_rw = (let val zF = Free("zcbm", natT) val Pb = Term.lambda zF (oeq (cpf BF mF2)(cpf BF zF))
                                             in substPred4 (Pb, mF2, mult qF dP) mEq (oeqrefl4_at (cpf BF mF2)) end)
                                            (* oeq (cpf B m2)(cpf B (q*dP)) *)
                            val cmult = cpf_mult_4 (BF, qF, dP) lt0q dPpos   (* oeq (cpf B (q*dP))(mult (cpf B q)(cpf B dP)) *)
                            (* mult (cpf B q)(cpf B dP) = mult q dP [rewrite both] *)
                            val mrw = oeq_trans OF [mult_cong_l4 (cpf BF qF, qF, cpf BF dP) cpfBq,
                                        mult_cong_r4 (qF, cpf BF dP, dP) (oeq_sym OF [ihAtdP])]
                                      (* oeq (mult (cpf B q)(cpf B dP))(mult q dP) *)
                            val cpfBm2_qdP = oeq_trans OF [cpfBm2_rw, oeq_trans OF [cmult, mrw]]  (* oeq (cpf B m2)(mult q dP) *)
                            (* mult q dP = m2 [sym mEq] *)
                            val cpfBm2_m2 = oeq_trans OF [cpfBm2_qdP, oeq_sym OF [mEq]]   (* oeq (cpf B m2) m2 *)
                            val g = oeq_sym OF [cpfBm2_m2]   (* oeq m2 (cpf B m2) *)
                          in g end
                        val gQ = exE_elim4 (PabsQ, goalInner) pde "q_fpp" bodyQ
                      in gQ end
                in Thm.implies_intr (ctermV4 (jT (mkEx PabsJ)))
                     (exE_elim4 (PabsJ, goalInner) (Thm.assume (ctermV4 (jT (mkEx PabsJ)))) "j_fpp" bodyJ) end;
              val gW = disjE_4 (oeq wF ZeroC, mkEx PabsJ, goalInner) dzw caseW0 caseWS
            in gW end
          val g = exE_elim4 (PabsW, goalInner) hex "w_fpp" bodyW
      in Thm.implies_intr (ctermV4 (jT (mkEx PabsW))) g end;
    val innerConcl = disjE_4 (oeq mF2 ZeroC, mkEx PabsW, goalInner) dz caseM0 caseMS
    (* discharge the two object hyps to build P m2 = Imp(lt 0 m2)(Imp(lt m2 B)(...)) *)
    val pm2 = impI_4 (lt ZeroC mF2, mkImp (lt mF2 BF)(oeq mF2 (cpf BF mF2)))
                (Thm.implies_intr (ctermV4 (jT (lt ZeroC mF2)))
                  (impI_4 (lt mF2 BF, oeq mF2 (cpf BF mF2))
                    (Thm.implies_intr (ctermV4 (jT (lt mF2 BF))) innerConcl)))
    val stepFn = Thm.forall_intr (ctermV4 mF2) (Thm.implies_intr (ctermV4 Gprop) pm2)
    val resP = strong_induct_4 (Pabs, mF) stepFn   (* jT (P m) = jT (Imp (lt 0 m)(Imp (lt m B)(oeq m (cpf B m)))) *)
    (* strip the two object implications back to a meta/conditional theorem with hyps, then re-discharge as object impls again?
       We want the final lemma as : prime-free conditional  prime?  no:  lt 0 m ==> lt m B ==> oeq m (cpf B m).
       resP is jT(Imp(lt 0 m)(Imp(lt m B)(...))). Apply mp with assumptions, then implies_intr (meta). *)
    val hm0f = Thm.assume (ctermV4 (jT (lt ZeroC mF)))
    val hmBf = Thm.assume (ctermV4 (jT (lt mF BF)))
    val s1 = mp_4 (lt ZeroC mF, mkImp (lt mF BF)(oeq mF (cpf BF mF))) resP hm0f
    val s2 = mp_4 (lt mF BF, oeq mF (cpf BF mF)) s1 hmBf   (* oeq m (cpf B m) *)
    val d2 = Thm.implies_intr (ctermV4 (jT (lt mF BF))) s2
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC mF))) d2
  in varify d1 end;
val () = out ("fact_prime_pow 0hyp=" ^ Bool.toString (zhV4 fact_prime_pow) ^ "\n");
val i_fact_prime_pow =
  let val mVz = Var(("m_fpp",0),natT); val BVz = Var(("B_fpp",0),natT)
  in Logic.mk_implies (jT (lt ZeroC mVz),
       Logic.mk_implies (jT (lt mVz BVz), jT (oeq mVz (cpf BVz mVz)))) end;
val r_fpp = (Thm.prop_of fact_prime_pow) aconv i_fact_prime_pow;
val () = out ("fact_prime_pow aconv=" ^ Bool.toString r_fpp ^ "\n");
val () = if zhV4 fact_prime_pow andalso r_fpp then out "PRIME_FACT_OK\n" else out "PRIME_FACT_FAIL\n";
val () = out "F4_FPP_DONE\n";

(* ============================================================================
   Specialization helpers + cpf_binom (the clean B = Suc(C(2n,n)) instance).
   ============================================================================ *)
val () = out "F4_SPEC_BEGIN\n";

fun fact_prime_pow_4 (Bt, mt) hm0 hmB =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4
        [(("m_fpp",0), ctermV4 mt),(("B_fpp",0), ctermV4 Bt)] (varify fact_prime_pow))
  in (inst OF [hm0]) OF [hmB] end;
fun lt_self_succ4 mt = le_refl4_at (suc mt);   (* le (Suc m)(Suc m) = lt m (Suc m) *)

val cpf_binom =
  let
    val nF = Free("n", natT)
    val twoN = add nF nF
    val cb = binom twoN nF
    val hpos = Thm.assume (ctermV4 (jT (lt ZeroC cb)))
    val ltSelf = lt_self_succ4 cb
    val g = fact_prime_pow_4 (suc cb, cb) hpos ltSelf     (* oeq cb (cpf (Suc cb) cb) *)
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC cb))) g
  in varify d1 end;
val () = out ("cpf_binom 0hyp=" ^ Bool.toString (zhV4 cpf_binom) ^ "\n");
val i_cpf_binom =
  let val nVz = Var(("n",0),natT)
      val cb = binom (add nVz nVz) nVz
  in Logic.mk_implies (jT (lt ZeroC cb), jT (oeq cb (cpf (suc cb) cb))) end;
val r_cpfb = (Thm.prop_of cpf_binom) aconv i_cpf_binom;
val () = out ("cpf_binom aconv=" ^ Bool.toString r_cpfb ^ "\n");
val () = if zhV4 cpf_binom andalso r_cpfb then out "CPF_BINOM_OK\n" else out "CPF_BINOM_FAIL\n";
val () = out "F4_SPEC_DONE\n";

(* ============================================================================
   cpf_tele : given (!!b. le K b ==> prime2 b ==> oeq (vp b m) 0),
     oeq (cpf (add K j) m)(cpf K m).   nat_induct on j.
   ============================================================================ *)
val () = out "F4_TELE_BEGIN\n";

(* vp_zero_above onto ctxtV4 *)
val vp_zero_above_v4 = varify vp_zero_above;
fun vp_zero_above_4 (pt,nt) hPr hn0 hgt =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 pt),(("n",0), ctermV4 nt)] vp_zero_above_v4)
  in ((inst OF [hPr]) OF [hn0]) OF [hgt] end;

(* the telescoping, with the vp-zero hypothesis as a meta-universal Hvp *)
fun cpf_tele_build (KT, mT, jT_, Hvp) =
  (* Hvp : !!b. jT(le KT b) ==> jT(prime2 b) ==> jT(oeq (vp b mT) 0) ;
     returns : oeq (cpf (add KT jT_) mT)(cpf KT mT) *)
  let
    val zTL = Free("z_tl", natT)
    val Pabs = Term.lambda zTL (oeq (cpf (add KT zTL) mT)(cpf KT mT))
    val ind = nat_induct_4 (Pabs, jT_)
    (* base j=0 : cpf (add K 0) m = cpf K m via add_0_right cong on first arg *)
    val base =
      let val a0 = add0r4_at KT   (* oeq (add K 0) K *)
          val zF = Free("zbtl", natT) val Pb = Term.lambda zF (oeq (cpf (add KT ZeroC) mT)(cpf zF mT))
      in substPred4 (Pb, add KT ZeroC, KT) a0 (oeqrefl4_at (cpf (add KT ZeroC) mT)) end;
    val xF = Free("x_tl", natT)
    val ihP = jT (oeq (cpf (add KT xF) mT)(cpf KT mT))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = oeq (cpf (add KT (suc xF)) mT)(cpf KT mT)
    val cTm = add KT xF
    val aSr = add_Sr4_at (KT, xF)   (* oeq (add K (Suc x))(Suc (add K x)) *)
    val cpfRw = (let val zF = Free("zbtls", natT) val Pb = Term.lambda zF (oeq (cpf (add KT (suc xF)) mT)(cpf zF mT))
                 in substPred4 (Pb, add KT (suc xF), suc cTm) aSr (oeqrefl4_at (cpf (add KT (suc xF)) mT)) end)
                (* oeq (cpf (add K (Suc x)) m)(cpf (Suc c) m) *)
    val le_K_c = le_add4_at (KT, xF)   (* le K (add K x) = le K c *)
    val em = ex_middle_4 (prime2 cTm)
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 cTm)))
          val L = cpf_sp_at (cTm, mT) hpr     (* oeq (cpf (Suc c) m)(mult (cpf c m)(pow c (vp c m))) *)
          (* vp c m = 0 via Hvp at c : need le K c (le_K_c) and prime2 c (hpr) *)
          val vpc0 = Thm.implies_elim (Thm.implies_elim (Thm.forall_elim (ctermV4 cTm) Hvp) le_K_c) hpr  (* oeq (vp c m) 0 *)
          val powis1 = oeq_trans OF [pow_cong_e4 (cTm, vp cTm mT, ZeroC) vpc0, pow04_at cTm]   (* oeq (pow c (vp c m)) 1 *)
          val r1 = mult_cong_r4 (cpf cTm mT, pow cTm (vp cTm mT), suc ZeroC) powis1   (* -> mult (cpf c m) 1 *)
          val r2 = mult1r4_at (cpf cTm mT)   (* mult (cpf c m) 1 = cpf c m *)
          val Lc = oeq_trans OF [L, oeq_trans OF [r1, r2]]   (* oeq (cpf (Suc c) m)(cpf c m) *)
          val g = oeq_trans OF [cpfRw, oeq_trans OF [Lc, IH]]   (* oeq (cpf (add K (Suc x)) m)(cpf K m) *)
      in Thm.implies_intr (ctermV4 (jT (prime2 cTm))) g end;
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 cTm))))
          val L = cpf_sn_at (cTm, mT) hnp
          val g = oeq_trans OF [cpfRw, oeq_trans OF [L, IH]]
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 cTm)))) g end;
    val stepC = disjE_4 (prime2 cTm, neg (prime2 cTm), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

val () = out "F4_TELE_HELPER_OK\n";

(* ============================================================================
   cpf_binom_2n : lt 0 n ==> lt 0 (binom 2n n)
                    ==> oeq (binom (add n n) n)(cpf (Suc (add n n))(binom (add n n) n)).
   binom(2n,n) = cpf (Suc cb) cb [cpf_binom] = cpf (Suc twoN) cb [telescope, since for
   every prime b >= Suc twoN, b > 2n, vp b cb = 0].  Need Suc cb = add (Suc twoN) k.
   ============================================================================ *)
val () = out "F4_CB2N_BEGIN\n";

val cpf_binom_2n =
  let
    val nF = Free("n", natT)
    val twoN = add nF nF
    val cb = binom twoN nF
    val hn0  = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
    val hpos = Thm.assume (ctermV4 (jT (lt ZeroC cb)))   (* lt 0 (binom 2n n) *)
    (* cpf_binom (varify) : lt 0 cb ==> oeq cb (cpf (Suc cb) cb) *)
    val cbEq = (beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0), ctermV4 nF)] (varify cpf_binom))) OF [hpos]
               (* oeq cb (cpf (Suc cb) cb) *)
    (* le (Suc twoN)(Suc cb) : twoN < cb? need le twoN cb i.e. 2n <= binom(2n,n).  Hmm — is 2n <= C(2n,n)?
       Yes for n>=1 (C(2n,n) >= 2n).  But proving it is extra.  Alternative: we don't need twoN <= cb;
       we need Suc cb = add (Suc twoN) k for some k, i.e. le (Suc twoN)(Suc cb) i.e. le twoN cb.
       If instead cb < twoN ... can't happen for n>=1.  To avoid proving 2n<=C(2n,n), note the telescope
       works in EITHER direction is false; we genuinely need le (Suc twoN)(Suc cb).
       We obtain le twoN cb from cb_lower / binom bounds? Simpler: use le (Suc twoN)(Suc cb) as a HYP. *)
    val hle = Thm.assume (ctermV4 (jT (le (suc twoN)(suc cb))))   (* Suc twoN <= Suc cb *)
    (* exE on hle : Suc cb = add (Suc twoN) k *)
    val PabsK = Abs("k", natT, oeq (suc cb)(add (suc twoN)(Bound 0)))
    val goalC = oeq cb (cpf (suc twoN) cb)
    fun body kF (hk : thm) =   (* hk : oeq (Suc cb)(add (Suc twoN) k) *)
      let
        (* Hvp : !!b. le (Suc twoN) b ==> prime2 b ==> oeq (vp b cb) 0
           because b >= Suc twoN > 2n, so 2n < b, vp_zero_above. *)
        val bF = Free("b_tl", natT)
        val Hvp = Thm.forall_intr (ctermV4 bF)
                    (Thm.implies_intr (ctermV4 (jT (le (suc twoN) bF)))
                      (Thm.implies_intr (ctermV4 (jT (prime2 bF)))
                        (let val hleb = Thm.assume (ctermV4 (jT (le (suc twoN) bF)))   (* Suc twoN <= b = lt twoN b *)
                             val hprb = Thm.assume (ctermV4 (jT (prime2 bF)))
                         in vp_zero_above_4 (bF, nF) hprb hn0 hleb end)))   (* oeq (vp b cb) 0 *)
        (* telescope : cpf (add (Suc twoN) k) cb = cpf (Suc twoN) cb *)
        val tele = cpf_tele_build (suc twoN, cb, kF, Hvp)   (* oeq (cpf (add (Suc twoN) k) cb)(cpf (Suc twoN) cb) *)
        (* cpf (Suc cb) cb = cpf (add (Suc twoN) k) cb [cong on first arg via hk] *)
        val cpfRw = (let val zF = Free("zcb2", natT) val Pb = Term.lambda zF (oeq (cpf (suc cb) cb)(cpf zF cb))
                     in substPred4 (Pb, suc cb, add (suc twoN) kF) hk (oeqrefl4_at (cpf (suc cb) cb)) end)
                    (* oeq (cpf (Suc cb) cb)(cpf (add (Suc twoN) k) cb) *)
        (* cb = cpf (Suc cb) cb [cbEq] = cpf (add (Suc twoN) k) cb [cpfRw] = cpf (Suc twoN) cb [tele] *)
        val g = oeq_trans OF [cbEq, oeq_trans OF [cpfRw, tele]]   (* oeq cb (cpf (Suc twoN) cb) *)
      in g end
    val concl = exE_elim4 (PabsK, goalC) hle "k_cb2" body
    val d3 = Thm.implies_intr (ctermV4 (jT (le (suc twoN)(suc cb)))) concl
    val d2 = Thm.implies_intr (ctermV4 (jT (lt ZeroC cb))) d3
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) d2
  in varify d1 end;
val () = out ("cpf_binom_2n 0hyp=" ^ Bool.toString (zhV4 cpf_binom_2n) ^ "\n");
val i_cpf_binom_2n =
  let val nVz = Var(("n",0),natT)
      val twoN = add nVz nVz
      val cb = binom twoN nVz
  in Logic.mk_implies (jT (lt ZeroC nVz),
       Logic.mk_implies (jT (lt ZeroC cb),
         Logic.mk_implies (jT (le (suc twoN)(suc cb)),
           jT (oeq cb (cpf (suc twoN) cb))))) end;
val r_cb2n = (Thm.prop_of cpf_binom_2n) aconv i_cpf_binom_2n;
val () = out ("cpf_binom_2n aconv=" ^ Bool.toString r_cb2n ^ "\n");
val () = if zhV4 cpf_binom_2n andalso r_cb2n then out "CPF_BINOM_2N_OK\n" else out "CPF_BINOM_2N_FAIL\n";
val () = out "F4_CB2N_DONE\n";

