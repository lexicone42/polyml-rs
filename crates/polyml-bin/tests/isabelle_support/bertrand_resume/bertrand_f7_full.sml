val () = out "F3C_FINALE_BEGIN\n";

(* soundness probes : kernel must REJECT shape-weakened variants *)
val s_fsplit_cond =   (* fact_split must keep prime2 p (drop it -> different prop) *)
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in not ((Thm.prop_of fact_split) aconv
            (jT (oeq (fact NVz)(mult (pfree pVz NVz)(mprod pVz (rdiv NVz pVz)))))) end;
val s_legrec_cond =   (* legendre_rec must keep prime2 p *)
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in not ((Thm.prop_of legendre_rec) aconv
            (jT (oeq (vp pVz (fact NVz))(add (rdiv NVz pVz)(vp pVz (fact (rdiv NVz pVz))))))) end;
val s_pco_cond =      (* pfree_coprime must keep prime2 p *)
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in not ((Thm.prop_of pfree_coprime) aconv (jT (neg (dvd pVz (pfree pVz NVz))))) end;
val () = out ("PROBE fact_split-conditional=" ^ Bool.toString s_fsplit_cond
            ^ " legendre_rec-conditional=" ^ Bool.toString s_legrec_cond
            ^ " pfree_coprime-conditional=" ^ Bool.toString s_pco_cond ^ "\n");

(* axiom audit : only ex_middle classical ; pfree recursion conservative (3 axioms) *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtV3
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nPfree = length (List.filter (fn s => String.isSubstring "pfree" s) names)
    val nVp    = length (List.filter (fn s => String.isSubstring "vp_step" s) names)
    val nMprod = length (List.filter (fn s => String.isSubstring "mprod" s) names)
    val nRdiv  = length (List.filter (fn s => String.isSubstring "div_mod_eq" s
                                          orelse String.isSubstring "rmod_lt" s) names)
  in out ("F3C_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " pfree_axioms=" ^ Int.toString nPfree
          ^ " vp_recursion_axioms=" ^ Int.toString nVp
          ^ " mprod_axioms=" ^ Int.toString nMprod
          ^ " rdiv_axioms=" ^ Int.toString nRdiv ^ "\n") end;

val f3c_bank =
  zhV3 pfree_pos andalso r_pfp
  andalso zhV3 fact_split andalso r_fsplit andalso s_fsplit_cond
