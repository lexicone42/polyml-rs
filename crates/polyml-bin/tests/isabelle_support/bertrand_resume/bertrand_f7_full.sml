(* le_add_sub onto V4 *)
val le_add_sub_v4 = varify le_add_sub;
fun le_add_sub_4 (kT,nT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("k",0), ctermV4 kT),(("n",0), ctermV4 nT)] le_add_sub_v4)) h;

(* le_s_ssq : le s (mult s s)   by cases on s. *)
fun le_s_ssq sT =
  let val dz = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0), ctermV4 sT)] disj_zero_or_suc_v4)
              (* Disj (oeq s 0)(Ex w. oeq s (Suc w)) *)
      val goalC = le sT (mult sT sT)
      val caseZ =
        let val hz = Thm.assume (ctermV4 (jT (oeq sT ZeroC)))   (* s=0 *)
            (* le 0 (mult 0 0) : le 0 anything via le_zero4 ; then rewrite first arg 0->s *)
            val le0 = le_zero4_at (mult sT sT)   (* le 0 (mult s s) *)
            val g = le_cong_l4 (ZeroC, sT, mult sT sT) (oeq_sym OF [hz]) le0  (* le s (mult s s) *)
        in Thm.implies_intr (ctermV4 (jT (oeq sT ZeroC))) g end
      val PabsW = Abs("w", natT, oeq sT (suc (Bound 0)))
      val caseS =
        let val hex = Thm.assume (ctermV4 (jT (mkEx PabsW)))
            fun body wF (hw : thm) =   (* hw : oeq s (Suc w) *)
              let (* mult s s ; with s=Suc w : mult (Suc w)(Suc w) = add (Suc w)(mult w (Suc w)) ; le (Suc w)(add (Suc w) X) *)
                  val msuc = multSuc4_at (wF, suc wF)   (* oeq (mult (Suc w)(Suc w))(add (Suc w)(mult w (Suc w))) *)
                  val leadd = le_add4_at (suc wF, mult wF (suc wF))  (* le (Suc w)(add (Suc w)(mult w (Suc w))) *)
                  val le1 = le_cong_r4 (suc wF, add (suc wF)(mult wF (suc wF)), mult (suc wF)(suc wF)) (oeq_sym OF [msuc]) leadd
                            (* le (Suc w)(mult (Suc w)(Suc w)) *)
                  (* rewrite (Suc w) -> s on both sides via hw sym *)
                  val le2 = le_cong_l4 (suc wF, sT, mult (suc wF)(suc wF)) (oeq_sym OF [hw]) le1  (* le s (mult (Suc w)(Suc w)) *)
                  (* rewrite mult (Suc w)(Suc w) -> mult s s : two cong steps *)
                  val mfix1 = mult_cong_l4 (suc wF, sT, suc wF) (oeq_sym OF [hw])  (* oeq (mult (Suc w)(Suc w))(mult s (Suc w)) *)
                  val mfix2 = mult_cong_r4 (sT, suc wF, sT) (oeq_sym OF [hw])      (* oeq (mult s (Suc w))(mult s s) *)
                  val mfix  = oeq_trans OF [mfix1, mfix2]                          (* oeq (mult (Suc w)(Suc w))(mult s s) *)
                  val g = le_cong_r4 (sT, mult (suc wF)(suc wF), mult sT sT) mfix le2
              in g end
            val g = exE_elim4 (PabsW, goalC) hex "w_ssq" body
        in Thm.implies_intr (ctermV4 (jT (mkEx PabsW))) g end
  in disjE_4 (oeq sT ZeroC, mkEx PabsW, goalC) dz caseZ caseS end;

