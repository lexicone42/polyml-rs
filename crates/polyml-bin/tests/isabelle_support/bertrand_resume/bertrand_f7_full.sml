val div_mod_unique_v3 = varify div_mod_unique;
fun div_mod_unique_3 (q1T,q2T,r1T,r2T,bT) hEQ hLT1 hLT2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("q1",0), ctermV3 q1T),(("q2",0), ctermV3 q2T),(("r1",0), ctermV3 r1T),(("r2",0), ctermV3 r2T),(("b",0), ctermV3 bT)] div_mod_unique_v3)
  in ((inst OF [hEQ]) OF [hLT1]) OF [hLT2] end;
(* rdiv_mult_exact on ctxtV3 : lt 0 p ==> dvd p m ==> oeq m (mult p (rdiv m p)) *)
fun rdiv_mult_exact_3 (pT, mT) hpos hdvd =
  let
    val divEq = div_mod_eq_3 (mT, pT) hpos;
    val rlt   = rmod_lt_3 (mT, pT) hpos;
    val PabsK = Abs("k", natT, oeq mT (mult pT (Bound 0)))
    val goalC = oeq mT (mult pT (rdiv mT pT))
    fun body kF (hk : thm) =
      let
        val mk0 = oeq_trans OF [hk, oeq_sym OF [add0r3_at (mult pT kF)]];
        val eqA = oeq_trans OF [oeq_sym OF [divEq], mk0];
        val uniq  = div_mod_unique_3 (rdiv mT pT, kF, rmod mT pT, ZeroC, pT) eqA rlt hpos;
        val eqQ   = conjunct1_3 (oeq (rdiv mT pT) kF, oeq (rmod mT pT) ZeroC) uniq;
        val g = oeq_trans OF [hk, mult_cong_r3 (pT, kF, rdiv mT pT) (oeq_sym OF [eqQ])];
      in g end;
  in exE_elim3 (PabsK, goalC) hdvd "k_rme3" body end;

val () = out "F3C_SETUP_OK\n";

(* ============================================================================
   (PF) pfree_pos + fact_split.
   ============================================================================ *)
val () = out "F3C_PF_BEGIN\n";

(* pfree_pos : lt 0 (pfree p N)   by nat_induct on N. *)
val pfree_pos =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val zPF = Free("z_pfp", natT)
    val Pabs = Term.lambda zPF (lt ZeroC (pfree pF zPF))
    val ind = beta_norm (Drule.infer_instantiate ctxtV3 [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 NF)] nat_induct_v3)
    (* base : lt 0 (pfree p 0) ; pfree p 0 = 1 ; lt 0 1 = le 1 1 *)
    val pf0 = pfree03_at pF                 (* oeq (pfree p 0)(Suc 0) *)
    val le11 = le_refl3_at (suc ZeroC)
    val base = (let val zF = Free("zpfpb",natT)
                    val Pb = Term.lambda zF (le (suc ZeroC) zF)
                in substPred3 (Pb, suc ZeroC, pfree pF ZeroC) (oeq_sym OF [pf0]) le11 end);  (* lt 0 (pfree p 0) *)
    val xF = Free("x", natT)
    val ihP = jT (lt ZeroC (pfree pF xF))
    val IH = Thm.assume (ctermV3 ihP)       (* le 1 (pfree p x) *)
    val goalStep = lt ZeroC (pfree pF (suc xF))
    (* le 1 (Suc x) : le 0 x via le_add ; le_suc_mono *)
    val le0x = (let val la = le_add3_at (ZeroC, xF)          (* le 0 (add 0 x) *)
                    val a0 = add03_at xF                       (* oeq (add 0 x) x *)
                in (let val zF = Free("zl0x3",natT)
                        val Pb = Term.lambda zF (le ZeroC zF)
                    in substPred3 (Pb, add ZeroC xF, xF) a0 la end) end);   (* le 0 x *)
    val le1Sx = le_suc_mono3_at (ZeroC, xF) le0x;            (* le 1 (Suc x) *)
    val em = ex_middle_3 (dvd pF (suc xF))                   (* Disj (dvd p (Suc x))(neg (dvd p (Suc x))) *)
    val caseDvd =
      let val hd = Thm.assume (ctermV3 (jT (dvd pF (suc xF))))
          val pe = pfree_dvd3_at (pF, xF) hd                 (* oeq (pfree p (Suc x))(pfree p x) *)
          (* lt 0 (pfree p (Suc x)) : rewrite pfree p x -> pfree p (Suc x) in IH (sym pe) *)
          val g = (let val zF = Free("zpfd",natT)
                       val Pb = Term.lambda zF (le (suc ZeroC) zF)
                   in substPred3 (Pb, pfree pF xF, pfree pF (suc xF)) (oeq_sym OF [pe]) IH end);
      in Thm.implies_intr (ctermV3 (jT (dvd pF (suc xF)))) g end;
    val caseNdvd =
      let val hnd = Thm.assume (ctermV3 (jT (neg (dvd pF (suc xF)))))
          val pe = pfree_ndvd3_at (pF, xF) hnd               (* oeq (pfree p (Suc x))(mult (Suc x)(pfree p x)) *)
          val mlm = mult_le_mono2_3_at (suc ZeroC, suc xF, suc ZeroC, pfree pF xF) le1Sx IH;  (* le (1*1)((Suc x)*(pfree p x)) *)
          val m11 = mult1l3_at (suc ZeroC)
          val lt0prod = (let val zF = Free("zpfn",natT)
                             val Pb = Term.lambda zF (le zF (mult (suc xF)(pfree pF xF)))
                         in substPred3 (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end);  (* le 1 ((Suc x)*(pfree p x)) *)
          val g = (let val zF = Free("zpfn2",natT)
                       val Pb = Term.lambda zF (le (suc ZeroC) zF)
                   in substPred3 (Pb, mult (suc xF)(pfree pF xF), pfree pF (suc xF)) (oeq_sym OF [pe]) lt0prod end);
      in Thm.implies_intr (ctermV3 (jT (neg (dvd pF (suc xF))))) g end;
    val stepC = disjE_3 (dvd pF (suc xF), neg (dvd pF (suc xF)), goalStep) em caseDvd caseNdvd;
    val step = Thm.forall_intr (ctermV3 xF) (Thm.implies_intr (ctermV3 ihP) stepC)
  in varify (Thm.implies_elim (Thm.implies_elim ind base) step) end;
val () = out ("pfree_pos 0hyp=" ^ Bool.toString (zhV3 pfree_pos) ^ "\n");
val i_pfree_pos = let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in jT (lt ZeroC (pfree pVz NVz)) end;
val r_pfp = (Thm.prop_of pfree_pos) aconv i_pfree_pos;
val () = out ("pfree_pos aconv=" ^ Bool.toString r_pfp ^ "\n");
val () = if zhV3 pfree_pos andalso r_pfp then out "PFREE_POS_OK\n" else out "PFREE_POS_FAIL\n";
val pfree_pos_v3 = varify pfree_pos;
fun pfree_pos_3 (pt,nt) = beta_norm (Drule.infer_instantiate ctxtV3 [(("p",0), ctermV3 pt),(("N",0), ctermV3 nt)] pfree_pos_v3);

(* helper : rdiv 0 p = 0  (from div_mod_unique : 0 = p*0+0) *)
fun rdiv_zero_3 pT hpos =
  let
    val divEq = div_mod_eq_3 (ZeroC, pT) hpos;       (* oeq 0 (add (mult p (rdiv 0 p))(rmod 0 p)) *)
    val rlt   = rmod_lt_3 (ZeroC, pT) hpos;          (* lt (rmod 0 p) p *)
    (* 0 = p*0 + 0 :  add (mult p 0) 0 = mult p 0 = 0 ; sym *)
    val p0    = mult0r3_at pT                         (* oeq (mult p 0) 0 *)
    val addr0 = add0r3_at (mult pT ZeroC)             (* oeq (add (mult p 0) 0)(mult p 0) *)
    val rep0f = oeq_trans OF [addr0, p0];             (* oeq (add (mult p 0) 0) 0 *)
    val rep0  = oeq_sym OF [rep0f];                   (* oeq 0 (add (mult p 0) 0) *)
    val eqA  = oeq_trans OF [oeq_sym OF [divEq], rep0];   (* oeq (add (mult p (rdiv 0 p))(rmod 0 p))(add (mult p 0) 0) *)
    val uniq = div_mod_unique_3 (rdiv ZeroC pT, ZeroC, rmod ZeroC pT, ZeroC, pT) eqA rlt hpos;
    val g = conjunct1_3 (oeq (rdiv ZeroC pT) ZeroC, oeq (rmod ZeroC pT) ZeroC) uniq;  (* oeq (rdiv 0 p) 0 *)
  in g end;

(* fact_split : prime2 p ==> oeq (fact N)(mult (pfree p N)(mprod p (rdiv N p)))  by nat_induct on N. *)
val fact_split =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val lt0p = prime2_pos_3 pF hPr
    val zPF = Free("z_fs", natT)
    fun rhs nt = mult (pfree pF nt)(mprod pF (rdiv nt pF))
    val Pabs = Term.lambda zPF (oeq (fact zPF)(rhs zPF))
    val ind = beta_norm (Drule.infer_instantiate ctxtV3 [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 NF)] nat_induct_v3)
    (* BASE N=0 : fact 0 = 1 ; rhs 0 = pfree p 0 * mprod p (rdiv 0 p) = 1 * mprod p 0 = 1*1 = 1 *)
    val base =
      let
        val f0  = fact03_at ()                  (* oeq (fact 0)(Suc 0) *)
        val pf0 = pfree03_at pF                  (* oeq (pfree p 0)(Suc 0) *)
        val rd0 = rdiv_zero_3 pF lt0p            (* oeq (rdiv 0 p) 0 *)
        (* mprod p (rdiv 0 p) -> mprod p 0 [cong rd0] -> 1 [mprod_0] *)
        val mprd_rw = (let val zF = Free("zmr",natT)
                           val Pb = Term.lambda zF (oeq (mprod pF (rdiv ZeroC pF))(mprod pF zF))
                       in substPred3 (Pb, rdiv ZeroC pF, ZeroC) rd0 (oeqrefl3_at (mprod pF (rdiv ZeroC pF))) end);
                       (* oeq (mprod p (rdiv 0 p))(mprod p 0) *)
        val mp0 = mprod03_at pF                  (* oeq (mprod p 0)(Suc 0) *)
        val mprd1 = oeq_trans OF [mprd_rw, mp0]; (* oeq (mprod p (rdiv 0 p))(Suc 0) *)
        (* rhs 0 = pfree p 0 * mprod p (rdiv 0 p) ; rewrite both to 1 ; 1*1=1 *)
        val rhsRw = oeq_trans OF [mult_cong_l3 (pfree pF ZeroC, suc ZeroC, mprod pF (rdiv ZeroC pF)) pf0,
                                  oeq_trans OF [mult_cong_r3 (suc ZeroC, mprod pF (rdiv ZeroC pF), suc ZeroC) mprd1,
                                               mult1l3_at (suc ZeroC)]];   (* oeq (rhs 0)(Suc 0) *)
        val g = oeq_trans OF [f0, oeq_sym OF [rhsRw]];   (* oeq (fact 0)(rhs 0) *)
      in g end;
    val xF = Free("x", natT)
    val ihP = jT (oeq (fact xF)(rhs xF))
    val IH = Thm.assume (ctermV3 ihP)        (* fact x = pfree p x * mprod p (rdiv x p) *)
    val goalStep = oeq (fact (suc xF))(rhs (suc xF))
    val fS = factSuc3_at xF                  (* oeq (fact (Suc x))(mult (Suc x)(fact x)) *)
    val em = ex_middle_3 (dvd pF (suc xF))
    (* ---- CASE p | Suc x ---- *)
    val caseDvd =
      let
        val hd = Thm.assume (ctermV3 (jT (dvd pF (suc xF))))
        val rstep = rdiv_step_dvd_3 (pF, xF) lt0p hd     (* oeq (rdiv (Suc x) p)(Suc (rdiv x p)) *)
        val pe    = pfree_dvd3_at (pF, xF) hd            (* oeq (pfree p (Suc x))(pfree p x) *)
        (* Suc x = p * rdiv(Suc x)p [rdiv_mult_exact] ; rewrite rdiv(Suc x)p -> Suc(rdiv x p) *)
        val sxEx  = rdiv_mult_exact_3 (pF, suc xF) lt0p hd  (* oeq (Suc x)(mult p (rdiv (Suc x) p)) *)
        val sxP   = oeq_trans OF [sxEx, mult_cong_r3 (pF, rdiv (suc xF) pF, suc (rdiv xF pF)) rstep];
                    (* oeq (Suc x)(mult p (Suc (rdiv x p))) *)
        (* mprod p (rdiv (Suc x) p) = mprod p (Suc (rdiv x p)) [cong rstep]
                                    = (p * Suc(rdiv x p)) * mprod p (rdiv x p) [mprod_Suc]
                                    = (Suc x) * mprod p (rdiv x p)  [sym sxP] *)
        val mprd_rw1 = (let val zF = Free("zmd1",natT)
                            val Pb = Term.lambda zF (oeq (mprod pF (rdiv (suc xF) pF))(mprod pF zF))
                        in substPred3 (Pb, rdiv (suc xF) pF, suc (rdiv xF pF)) rstep (oeqrefl3_at (mprod pF (rdiv (suc xF) pF))) end);
                       (* oeq (mprod p (rdiv (Suc x) p))(mprod p (Suc (rdiv x p))) *)
        val mpSuc = mprodSuc3_at (pF, rdiv xF pF)   (* oeq (mprod p (Suc (rdiv x p)))(mult (mult p (Suc(rdiv x p)))(mprod p (rdiv x p))) *)
        val mprd_rw2 = oeq_trans OF [mprd_rw1, mpSuc];   (* oeq (mprod p (rdiv (Suc x) p))((p*Suc(rdiv x p))*mprod p (rdiv x p)) *)
        (* (p*Suc(rdiv x p)) = Suc x [sym sxP] *)
        val mprd_rw3 = oeq_trans OF [mprd_rw2, mult_cong_l3 (mult pF (suc (rdiv xF pF)), suc xF, mprod pF (rdiv xF pF)) (oeq_sym OF [sxP])];
                       (* oeq (mprod p (rdiv (Suc x) p))((Suc x)*mprod p (rdiv x p)) *)
        (* rhs (Suc x) = pfree p (Suc x) * mprod p (rdiv (Suc x) p)
                       = pfree p x * ((Suc x)*mprod p (rdiv x p))  [pe, mprd_rw3] *)
        val M = mprod pF (rdiv xF pF)
        val rhsSucRw = oeq_trans OF [mult_cong_l3 (pfree pF (suc xF), pfree pF xF, mprod pF (rdiv (suc xF) pF)) pe,
                                     mult_cong_r3 (pfree pF xF, mprod pF (rdiv (suc xF) pF), mult (suc xF) M) mprd_rw3];
                       (* oeq (rhs (Suc x))(pfree p x * ((Suc x)*M)) *)
        (* fact (Suc x) = (Suc x)*fact x = (Suc x)*(pfree p x * M) [IH] *)
        val factSucRw = oeq_trans OF [fS, mult_cong_r3 (suc xF, fact xF, mult (pfree pF xF) M) IH];
                        (* oeq (fact (Suc x))((Suc x)*(pfree p x * M)) *)
        (* CA : (Suc x)*(pfree p x * M) = pfree p x * ((Suc x)*M)
                = (Suc x * pfree p x)*M [assoc sym] = (pfree p x * Suc x)*M [comm] = pfree p x*(Suc x*M) [assoc] *)
        val A = suc xF; val B = pfree pF xF; val C = M
        val r1 = oeq_sym OF [multassoc3_at (A, B, C)]      (* oeq (A*(B*C))((A*B)*C) *)
        val r2 = mult_cong_l3 (mult A B, mult B A, C) (multcomm3_at (A, B))   (* oeq ((A*B)*C)((B*A)*C) *)
        val r3 = multassoc3_at (B, A, C)                  (* oeq ((B*A)*C)(B*(A*C)) *)
        val ca = oeq_trans OF [r1, oeq_trans OF [r2, r3]];  (* oeq (A*(B*C))(B*(A*C)) *)
        val g = oeq_trans OF [factSucRw, oeq_trans OF [ca, oeq_sym OF [rhsSucRw]]];  (* oeq (fact (Suc x))(rhs (Suc x)) *)
      in Thm.implies_intr (ctermV3 (jT (dvd pF (suc xF)))) g end;
    (* ---- CASE ~ p | Suc x ---- *)
    val caseNdvd =
      let
        val hnd = Thm.assume (ctermV3 (jT (neg (dvd pF (suc xF)))))
        val rstep = rdiv_step_ndvd_3 (pF, xF) lt0p hnd   (* oeq (rdiv (Suc x) p)(rdiv x p) *)
        val pe    = pfree_ndvd3_at (pF, xF) hnd          (* oeq (pfree p (Suc x))(mult (Suc x)(pfree p x)) *)
        val M = mprod pF (rdiv xF pF)
        (* mprod p (rdiv (Suc x) p) = mprod p (rdiv x p) = M  [cong rstep] *)
        val mprd_rw = (let val zF = Free("zmn",natT)
                           val Pb = Term.lambda zF (oeq (mprod pF (rdiv (suc xF) pF))(mprod pF zF))
                       in substPred3 (Pb, rdiv (suc xF) pF, rdiv xF pF) rstep (oeqrefl3_at (mprod pF (rdiv (suc xF) pF))) end);
                      (* oeq (mprod p (rdiv (Suc x) p)) M *)
        (* rhs (Suc x) = pfree p (Suc x) * mprod p (rdiv (Suc x) p)
                       = ((Suc x)*pfree p x) * M  [pe, mprd_rw] *)
        val rhsSucRw = oeq_trans OF [mult_cong_l3 (pfree pF (suc xF), mult (suc xF)(pfree pF xF), mprod pF (rdiv (suc xF) pF)) pe,
                                     mult_cong_r3 (mult (suc xF)(pfree pF xF), mprod pF (rdiv (suc xF) pF), M) mprd_rw];
                       (* oeq (rhs (Suc x))(((Suc x)*pfree p x)*M) *)
        (* fact (Suc x) = (Suc x)*(pfree p x * M) [IH] *)
        val factSucRw = oeq_trans OF [fS, mult_cong_r3 (suc xF, fact xF, mult (pfree pF xF) M) IH];
        (* assoc : (Suc x)*(pfree p x * M) = ((Suc x)*pfree p x)*M *)
        val A = suc xF; val B = pfree pF xF; val C = M
        val asc = oeq_sym OF [multassoc3_at (A, B, C)];   (* oeq (A*(B*C))((A*B)*C) *)
        val g = oeq_trans OF [factSucRw, oeq_trans OF [asc, oeq_sym OF [rhsSucRw]]];
      in Thm.implies_intr (ctermV3 (jT (neg (dvd pF (suc xF))))) g end;
    val stepC = disjE_3 (dvd pF (suc xF), neg (dvd pF (suc xF)), goalStep) em caseDvd caseNdvd;
    val step = Thm.forall_intr (ctermV3 xF) (Thm.implies_intr (ctermV3 ihP) stepC)
    val body = Thm.implies_elim (Thm.implies_elim ind base) step
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) body
  in varify d1 end;
val () = out ("fact_split 0hyp=" ^ Bool.toString (zhV3 fact_split) ^ "\n");
val i_fact_split =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       jT (oeq (fact NVz)(mult (pfree pVz NVz)(mprod pVz (rdiv NVz pVz))))) end;
val r_fsplit = (Thm.prop_of fact_split) aconv i_fact_split;
val () = out ("fact_split aconv=" ^ Bool.toString r_fsplit ^ "\n");
val () = if zhV3 fact_split andalso r_fsplit then out "FACT_SPLIT_OK\n" else out "FACT_SPLIT_FAIL\n";
val fact_split_v3 = varify fact_split;
fun fact_split_3 (pt,nt) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("p",0), ctermV3 pt),(("N",0), ctermV3 nt)] fact_split_v3)
  in inst OF [hPr] end;
val () = out "F3C_PF_DONE\n";

(* ============================================================================
   (CO) pfree_coprime : prime2 p ==> ~(dvd p (pfree p N))  ; then vp p (pfree p N) = 0.
   ============================================================================ *)
val () = out "F3C_CO_BEGIN\n";

val dvd_le_v3 = varify dvd_le;
fun dvd_le_3 (dT, nT) hdvd hnzMeta =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("d",0), ctermV3 dT),(("n",0), ctermV3 nT)] dvd_le_v3)
  in Thm.implies_elim (Thm.implies_elim inst hdvd) hnzMeta end;

(* nonzero-meta for Suc t : oeq (Suc t) 0 ==> oFalse *)
fun suc_nz_meta3 t =
  let val hz = Thm.assume (ctermV3 (jT (oeq (suc t) ZeroC)))
      val ff = (Suc_neq_Zero3_at t) OF [hz]
  in Thm.implies_intr (ctermV3 (jT (oeq (suc t) ZeroC))) ff end;

(* pfree_coprime : prime2 p ==> ~(dvd p (pfree p N))  by nat_induct on N. *)
val pfree_coprime =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val gt1  = prime2_gt1_3 pF hPr            (* lt 1 p = le 2 p *)
    val zPF = Free("z_pco", natT)
    val Pabs = Term.lambda zPF (neg (dvd pF (pfree pF zPF)))
    val ind = beta_norm (Drule.infer_instantiate ctxtV3 [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 NF)] nat_induct_v3)
    (* BASE N=0 : ~(dvd p (pfree p 0)).  assume dvd p (pfree p 0) ; pfree p 0 = Suc 0 ; dvd p (Suc 0) ;
       dvd_le -> le p (Suc 0) ; with le 2 p -> le 2 1 = lt 1 1 -> false *)
    val base =
      let
        val pf0 = pfree03_at pF                 (* oeq (pfree p 0)(Suc 0) *)
        val hd  = Thm.assume (ctermV3 (jT (dvd pF (pfree pF ZeroC))))
        val hd1 = dvd_cong_r3 (pF, pfree pF ZeroC, suc ZeroC) pf0 hd;  (* dvd p (Suc 0) *)
        val lep1 = dvd_le_3 (pF, suc ZeroC) hd1 (suc_nz_meta3 ZeroC);  (* le p (Suc 0) *)
        val le21 = le_trans3_at (suc (suc ZeroC), pF, suc ZeroC) gt1 lep1;  (* le 2 1 = lt 1 1 *)
        val ff = (lt_irrefl3_at (suc ZeroC)) OF [le21];   (* oFalse *)
        val g = impI_3 (dvd pF (pfree pF ZeroC), oFalseC)
                  (Thm.implies_intr (ctermV3 (jT (dvd pF (pfree pF ZeroC)))) ff);
      in g end;
    val xF = Free("x", natT)
    val ihP = jT (neg (dvd pF (pfree pF xF)))
    val IH = Thm.assume (ctermV3 ihP)            (* ~(dvd p (pfree p x)) *)
    val goalStep = neg (dvd pF (pfree pF (suc xF)))
    val em = ex_middle_3 (dvd pF (suc xF))
    val caseDvd =
      let
        val hd = Thm.assume (ctermV3 (jT (dvd pF (suc xF))))
        val pe = pfree_dvd3_at (pF, xF) hd       (* oeq (pfree p (Suc x))(pfree p x) *)
        (* ~(dvd p (pfree p (Suc x))) : assume dvd p (pfree p (Suc x)) ; rewrite -> dvd p (pfree p x) ; IH false *)
        val hdS = Thm.assume (ctermV3 (jT (dvd pF (pfree pF (suc xF)))))
        val hdx = dvd_cong_r3 (pF, pfree pF (suc xF), pfree pF xF) pe hdS;  (* dvd p (pfree p x) *)
        val ff = mp_3 (dvd pF (pfree pF xF), oFalseC) IH hdx;
        val ndS = impI_3 (dvd pF (pfree pF (suc xF)), oFalseC)
                    (Thm.implies_intr (ctermV3 (jT (dvd pF (pfree pF (suc xF))))) ff);
      in Thm.implies_intr (ctermV3 (jT (dvd pF (suc xF)))) ndS end;
    val caseNdvd =
      let
        val hnd = Thm.assume (ctermV3 (jT (neg (dvd pF (suc xF)))))
        val pe = pfree_ndvd3_at (pF, xF) hnd     (* oeq (pfree p (Suc x))(mult (Suc x)(pfree p x)) *)
        (* assume dvd p (pfree p (Suc x)) ; rewrite -> dvd p ((Suc x)*(pfree p x)) ; euclid -> dvd p (Suc x) (contra hnd) or dvd p (pfree p x) (contra IH) *)
        val hdS = Thm.assume (ctermV3 (jT (dvd pF (pfree pF (suc xF)))))
        val hdP = dvd_cong_r3 (pF, pfree pF (suc xF), mult (suc xF)(pfree pF xF)) pe hdS;  (* dvd p ((Suc x)*(pfree p x)) *)
        val disj = euclid_3 (pF, suc xF, pfree pF xF) hPr hdP;   (* Disj (dvd p (Suc x))(dvd p (pfree p x)) *)
        val cA = let val hda = Thm.assume (ctermV3 (jT (dvd pF (suc xF))))
                     val ff = mp_3 (dvd pF (suc xF), oFalseC) hnd hda
                 in Thm.implies_intr (ctermV3 (jT (dvd pF (suc xF)))) ff end;
        val cB = let val hdb = Thm.assume (ctermV3 (jT (dvd pF (pfree pF xF))))
                     val ff = mp_3 (dvd pF (pfree pF xF), oFalseC) IH hdb
                 in Thm.implies_intr (ctermV3 (jT (dvd pF (pfree pF xF)))) ff end;
        val ff = disjE_3 (dvd pF (suc xF), dvd pF (pfree pF xF), oFalseC) disj cA cB;
        val ndS = impI_3 (dvd pF (pfree pF (suc xF)), oFalseC)
                    (Thm.implies_intr (ctermV3 (jT (dvd pF (pfree pF (suc xF))))) ff);
      in Thm.implies_intr (ctermV3 (jT (neg (dvd pF (suc xF))))) ndS end;
    val stepC = disjE_3 (dvd pF (suc xF), neg (dvd pF (suc xF)), goalStep) em caseDvd caseNdvd;
    val step = Thm.forall_intr (ctermV3 xF) (Thm.implies_intr (ctermV3 ihP) stepC)
    val body = Thm.implies_elim (Thm.implies_elim ind base) step
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) body
  in varify d1 end;
val () = out ("pfree_coprime 0hyp=" ^ Bool.toString (zhV3 pfree_coprime) ^ "\n");
val i_pfree_coprime =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in Logic.mk_implies (jT (prime2 pVz), jT (neg (dvd pVz (pfree pVz NVz)))) end;
val r_pco = (Thm.prop_of pfree_coprime) aconv i_pfree_coprime;
val () = out ("pfree_coprime aconv=" ^ Bool.toString r_pco ^ "\n");
val () = if zhV3 pfree_coprime andalso r_pco then out "PFREE_COPRIME_OK\n" else out "PFREE_COPRIME_FAIL\n";
val pfree_coprime_v3 = varify pfree_coprime;
fun pfree_coprime_3 (pt,nt) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("p",0), ctermV3 pt),(("N",0), ctermV3 nt)] pfree_coprime_v3)
  in inst OF [hPr] end;

(* vp p (pfree p N) = 0  from vp_step_ndvd (~dvd) + pfree_pos (>0). *)
val pfree_vp_zero =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val nd   = pfree_coprime_3 (pF, NF) hPr        (* ~(dvd p (pfree p N)) *)
    val pos  = pfree_pos_3 (pF, NF)                (* lt 0 (pfree p N) *)
    val g    = vp_step_ndvd_3 (pF, pfree pF NF) hPr pos nd;   (* oeq (vp p (pfree p N)) 0 *)
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) g
  in varify d1 end;
val () = out ("pfree_vp_zero 0hyp=" ^ Bool.toString (zhV3 pfree_vp_zero) ^ "\n");
val i_pfree_vp_zero =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in Logic.mk_implies (jT (prime2 pVz), jT (oeq (vp pVz (pfree pVz NVz)) ZeroC)) end;
val r_pvz = (Thm.prop_of pfree_vp_zero) aconv i_pfree_vp_zero;
val () = out ("pfree_vp_zero aconv=" ^ Bool.toString r_pvz ^ "\n");
val () = if zhV3 pfree_vp_zero andalso r_pvz then out "PFREE_VP_ZERO_OK\n" else out "PFREE_VP_ZERO_FAIL\n";
val pfree_vp_zero_v3 = varify pfree_vp_zero;
val () = out "F3C_CO_DONE\n";

(* ============================================================================
   (L) legendre_rec : prime2 p ==> oeq (vp p (fact N))(add (rdiv N p)(vp p (fact (rdiv N p)))).
   ============================================================================ *)
val () = out "F3C_L_BEGIN\n";

(* pow_pos on ctxtV3 : lt 0 p ==> lt 0 (pow p k)  by nat_induct on k. *)
fun pow_pos_3 (pT, kT) hPos =
  let
    val zPF = Free("z_pp3", natT)
    val Pabs = Term.lambda zPF (lt ZeroC (pow pT zPF))
    val ind = beta_norm (Drule.infer_instantiate ctxtV3 [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 kT)] nat_induct_v3)
    val p0 = pow03_at pT       (* oeq (pow p 0)(Suc 0) *)
    val le11 = le_refl3_at (suc ZeroC)
    val base = (let val zF = Free("zpb3",natT)
                    val Pb = Term.lambda zF (le (suc ZeroC) zF)
                in substPred3 (Pb, suc ZeroC, pow pT ZeroC) (oeq_sym OF [p0]) le11 end);
    val xF = Free("x", natT)
    val ihP = jT (lt ZeroC (pow pT xF))
    val IH = Thm.assume (ctermV3 ihP)
    val pS = powSuc3_at (pT, xF)      (* oeq (pow p (Suc x))(mult p (pow p x)) *)
    val mlm = mult_le_mono2_3_at (suc ZeroC, pT, suc ZeroC, pow pT xF) hPos IH;
    val m11 = mult1l3_at (suc ZeroC)
    val lt0prod = (let val zF = Free("zps3",natT)
                       val Pb = Term.lambda zF (le zF (mult pT (pow pT xF)))
                   in substPred3 (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end);
    val stepC = (let val zF = Free("zss3",natT)
                     val Pb = Term.lambda zF (le (suc ZeroC) zF)
                 in substPred3 (Pb, mult pT (pow pT xF), pow pT (suc xF)) (oeq_sym OF [pS]) lt0prod end);
    val step = Thm.forall_intr (ctermV3 xF) (Thm.implies_intr (ctermV3 ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

(* vp_cong : oeq m m' ==> oeq (vp p m)(vp p m')  (oeq_subst on %z. vp p z) *)
fun vp_cong_3 (pT, mT, mpT) hmm =
  let val zF = Free("z_vpc", natT)
      val Pabs = Term.lambda zF (oeq (vp pT mT)(vp pT zF))
  in substPred3 (Pabs, mT, mpT) hmm (oeqrefl3_at (vp pT mT)) end;

(* mprod_pos : lt 0 p ==> lt 0 (mprod p Q)  (mprod_closed + pow_pos + fact_pos) *)
fun mprod_pos_3 (pT, QT) hPos =
  let
    val mc = mprod_closed_3 (pT, QT)        (* oeq (mprod p Q)(mult (pow p Q)(fact Q)) *)
    val pp = pow_pos_3 (pT, QT) hPos        (* le 1 (pow p Q) *)
    val fp = fact_pos_3 QT                   (* le 1 (fact Q) *)
    val mlm = mult_le_mono2_3_at (suc ZeroC, pow pT QT, suc ZeroC, fact QT) pp fp;  (* le (1*1)((pow p Q)*(fact Q)) *)
    val m11 = mult1l3_at (suc ZeroC)
    val le1prod = (let val zF = Free("zmpp",natT)
                       val Pb = Term.lambda zF (le zF (mult (pow pT QT)(fact QT)))
                   in substPred3 (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end);  (* le 1 ((pow p Q)*(fact Q)) *)
    val g = (let val zF = Free("zmpp2",natT)
                 val Pb = Term.lambda zF (le (suc ZeroC) zF)
             in substPred3 (Pb, mult (pow pT QT)(fact QT), mprod pT QT) (oeq_sym OF [mc]) le1prod end);  (* lt 0 (mprod p Q) *)
  in g end;

val legendre_rec =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val lt0p = prime2_pos_3 pF hPr
    val Q    = rdiv NF pF                      (* N/p *)
    val A    = pfree pF NF                     (* the coprime part *)
    val B    = mprod pF Q                      (* the multiples part *)
    (* fact_split : fact N = A * B *)
    val fsplit = fact_split_3 (pF, NF) hPr     (* oeq (fact N)(mult A B) *)
    val Apos = pfree_pos_3 (pF, NF)            (* lt 0 A *)
    val Bpos = mprod_pos_3 (pF, Q) lt0p        (* lt 0 B *)
    (* vp(fact N) = vp(A*B) [cong] = vp A + vp B [vp_additive] *)
    val vpFactAB = vp_cong_3 (pF, fact NF, mult A B) fsplit;   (* oeq (vp p (fact N))(vp p (A*B)) *)
    val vpAddAB  = vp_additive_3 (pF, A, B) hPr Apos Bpos;     (* oeq (vp p (A*B))(add (vp p A)(vp p B)) *)
    val vpA0     = (let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("p",0), ctermV3 pF),(("N",0), ctermV3 NF)] pfree_vp_zero_v3)
                    in inst OF [hPr] end);                      (* oeq (vp p A) 0 *)
    (* mprod_closed : B = pow p Q * fact Q *)
    val mc = mprod_closed_3 (pF, Q)            (* oeq B (mult (pow p Q)(fact Q)) *)
    val powpos = pow_pos_3 (pF, Q) lt0p        (* lt 0 (pow p Q) *)
    val factQpos = fact_pos_3 Q                (* lt 0 (fact Q) *)
    (* vp B = vp (pow p Q * fact Q) [cong] = vp(pow p Q) + vp(fact Q) [vp_additive] = Q + vp(fact Q) [vp_pow_self] *)
    val vpBcong = vp_cong_3 (pF, B, mult (pow pF Q)(fact Q)) mc;  (* oeq (vp p B)(vp p (pow p Q * fact Q)) *)
    val vpBadd  = vp_additive_3 (pF, pow pF Q, fact Q) hPr powpos factQpos;  (* oeq (vp p (pow p Q*fact Q))(add (vp p (pow p Q))(vp p (fact Q))) *)
    val vpPowQ  = vp_pow_self_3 (pF, Q) hPr;   (* oeq (vp p (pow p Q)) Q *)
    (* vp(pow p Q) + vp(fact Q) = Q + vp(fact Q) [cong on add left] *)
    val vpBaddQ = oeq_trans OF [vpBadd, add_cong_l3 (vp pF (pow pF Q), Q, vp pF (fact Q)) vpPowQ];
                  (* oeq (vp p (pow p Q*fact Q))(add Q (vp p (fact Q))) *)
    val vpB = oeq_trans OF [vpBcong, vpBaddQ];  (* oeq (vp p B)(add Q (vp p (fact Q))) *)
    (* vp A + vp B = 0 + (Q + vp(fact Q)) [cong both] *)
    val sumRw = oeq_trans OF [add_cong_l3 (vp pF A, ZeroC, vp pF B) vpA0,
                              add_cong_r3 (ZeroC, vp pF B, add Q (vp pF (fact Q))) vpB];
                (* oeq (add (vp p A)(vp p B))(add 0 (add Q (vp p (fact Q)))) *)
    val add0rw = add03_at (add Q (vp pF (fact Q)));   (* oeq (add 0 (add Q (vp p (fact Q))))(add Q (vp p (fact Q))) *)
    val sumFinal = oeq_trans OF [sumRw, add0rw];   (* oeq (add (vp p A)(vp p B))(add Q (vp p (fact Q))) *)
    (* chain : vp(fact N) = vp(A*B) = vp A + vp B = Q + vp(fact Q) *)
    val g = oeq_trans OF [vpFactAB, oeq_trans OF [vpAddAB, sumFinal]];
            (* oeq (vp p (fact N))(add (rdiv N p)(vp p (fact (rdiv N p)))) *)
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) g
  in varify d1 end;
val () = out ("legendre_rec 0hyp=" ^ Bool.toString (zhV3 legendre_rec) ^ "\n");
val i_legendre_rec =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       jT (oeq (vp pVz (fact NVz))(add (rdiv NVz pVz)(vp pVz (fact (rdiv NVz pVz)))))) end;
val r_legrec = (Thm.prop_of legendre_rec) aconv i_legendre_rec;
val () = out ("legendre_rec aconv=" ^ Bool.toString r_legrec ^ "\n");
val () = if zhV3 legendre_rec andalso r_legrec then out "LEGENDRE_REC_OK\n" else out "LEGENDRE_REC_FAIL\n";
val legendre_rec_v3 = varify legendre_rec;
fun legendre_rec_3 (pt,nt) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("p",0), ctermV3 pt),(("N",0), ctermV3 nt)] legendre_rec_v3)
  in inst OF [hPr] end;
val () = out "F3C_L_DONE\n";

(* ============================================================================
   (B-algebraic) vp_binom_split : prime2 p ==>
       oeq (vp p (fact (add n n)))(add (vp p (binom (add n n) n))(add (vp p (fact n))(vp p (fact n))))
   From binom_fact at (2n,n): binom(2n,n) * (fact n * fact n) = fact(2n)   [sub(2n) n = n]
   then vp_additive twice (all factors > 0).
   This is the algebraic heart that converts the factorial valuation into the
   binomial valuation; the Legendre-sum bound (vp_le) consumes it.
   ============================================================================ *)
val () = out "F3C_B_BEGIN\n";

val binom_fact_v3 = varify binom_fact;
fun binom_fact_3 (nT,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("n",0), ctermV3 nT),(("k",0), ctermV3 kT)] binom_fact_v3)) h;
val binom_pos_v3 = varify binom_pos;
fun binom_pos_3 (nT,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("n",0), ctermV3 nT),(("k",0), ctermV3 kT)] binom_pos_v3)) h;
val sub_add_l_v3 = varify sub_add_l;
fun subaddl_3 (kt,jt) = beta_norm (Drule.infer_instantiate ctxtV3 [(("k",0), ctermV3 kt),(("j",0), ctermV3 jt)] sub_add_l_v3);

fun Bf3 nt kt = mult (binom nt kt)(mult (fact kt)(fact (sub nt kt)));

val vp_binom_split =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val twoN = add nF nF
    val len2n = le_add3_at (nF, nF)                (* le n (add n n) *)
    (* binom_fact : oeq (Bf (2n) n)(fact (2n)) *)
    val bf = binom_fact_3 (twoN, nF) len2n;        (* oeq (mult (binom 2n n)(mult (fact n)(fact (sub 2n n))))(fact 2n) *)
    (* sub (2n) n = n :  sub (add n n) n = n  [sub_add_l] *)
    val subEq = subaddl_3 (nF, nF);                (* oeq (sub (add n n) n) n *)
    (* rewrite fact (sub 2n n) -> fact n inside Bf, then in bf *)
    val factSubRw = (let val zF = Free("zfsb",natT)
                         val Pb = Term.lambda zF (oeq (fact (sub twoN nF))(fact zF))
                     in substPred3 (Pb, sub twoN nF, nF) subEq (oeqrefl3_at (fact (sub twoN nF))) end);
                    (* oeq (fact (sub 2n n))(fact n) *)
    (* Bf (2n) n = binom(2n,n) * (fact n * fact (sub 2n n)) ; rewrite -> binom(2n,n)*(fact n*fact n) *)
    val C = binom twoN nF
    val innerRw = mult_cong_r3 (fact nF, fact (sub twoN nF), fact nF) factSubRw;  (* oeq (fact n * fact(sub 2n n))(fact n * fact n) *)
    val BfRw = mult_cong_r3 (C, mult (fact nF)(fact (sub twoN nF)), mult (fact nF)(fact nF)) innerRw;
               (* oeq (Bf (2n) n)(C * (fact n * fact n)) *)
    (* so : oeq (C*(fact n*fact n))(fact 2n)  =  sym BfRw trans bf *)
    val prodEq = oeq_trans OF [oeq_sym OF [BfRw], bf];   (* oeq (mult C (mult (fact n)(fact n)))(fact 2n) *)
    (* positivity *)
    val Cpos   = binom_pos_3 (twoN, nF) len2n;     (* lt 0 C *)
    val fnpos  = fact_pos_3 nF;                    (* lt 0 (fact n) *)
    (* fact n * fact n > 0 *)
    val ffpos =
      let val mlm = mult_le_mono2_3_at (suc ZeroC, fact nF, suc ZeroC, fact nF) fnpos fnpos
          val m11 = mult1l3_at (suc ZeroC)
      in (let val zF = Free("zff",natT) val Pb = Term.lambda zF (le zF (mult (fact nF)(fact nF)))
          in substPred3 (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end) end;  (* lt 0 (fact n * fact n) *)
    (* vp (C * (fact n * fact n)) = vp C + vp (fact n * fact n)  [vp_additive] *)
    val vpProd = vp_additive_3 (pF, C, mult (fact nF)(fact nF)) hPr Cpos ffpos;  (* oeq (vp p (C*(fn*fn)))(add (vp p C)(vp p (fn*fn))) *)
    (* vp (fact n * fact n) = vp (fact n) + vp (fact n) *)
    val vpFF = vp_additive_3 (pF, fact nF, fact nF) hPr fnpos fnpos;  (* oeq (vp p (fn*fn))(add (vp p fn)(vp p fn)) *)
    (* vp (fact 2n) = vp (C*(fn*fn)) [cong sym prodEq] *)
    val vpFact2n = vp_cong_3 (pF, fact twoN, mult C (mult (fact nF)(fact nF))) (oeq_sym OF [prodEq]);
                   (* oeq (vp p (fact 2n))(vp p (C*(fn*fn))) *)
    (* assemble : vp(fact 2n) = vp C + (vp fn + vp fn) *)
    val rhs2 = add_cong_r3 (vp pF C, vp pF (mult (fact nF)(fact nF)), add (vp pF (fact nF))(vp pF (fact nF))) vpFF;
               (* oeq (add (vp C)(vp (fn*fn)))(add (vp C)(add (vp fn)(vp fn))) *)
    val g = oeq_trans OF [vpFact2n, oeq_trans OF [vpProd, rhs2]];
            (* oeq (vp p (fact 2n))(add (vp p (binom 2n n))(add (vp p (fact n))(vp p (fact n)))) *)
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) g
  in varify d1 end;
val () = out ("vp_binom_split 0hyp=" ^ Bool.toString (zhV3 vp_binom_split) ^ "\n");
val i_vp_binom_split =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       jT (oeq (vp pVz (fact (add nVz nVz)))
               (add (vp pVz (binom (add nVz nVz) nVz))(add (vp pVz (fact nVz))(vp pVz (fact nVz)))))) end;
val r_vbs = (Thm.prop_of vp_binom_split) aconv i_vp_binom_split;
val () = out ("vp_binom_split aconv=" ^ Bool.toString r_vbs ^ "\n");
val () = if zhV3 vp_binom_split andalso r_vbs then out "VP_BINOM_SPLIT_OK\n" else out "VP_BINOM_SPLIT_FAIL\n";
val vp_binom_split_v3 = varify vp_binom_split;
val () = out "F3C_B_DONE\n";

(* ============================================================================
   (LE-keystone) nested_floor : lt 0 a ==> lt 0 b ==>
        oeq (rdiv (rdiv N a) b)(rdiv N (mult a b))
   The iterated-floor identity  (N/a)/b = N/(a*b).  Proof: write
     N = a*q1 + r1 (r1<a),  q1 = b*q2 + r2 (r2<b) ; then
     N = (a*b)*q2 + (a*r2 + r1)  with  a*r2 + r1 < a*b ,
   so div_mod_unique at divisor a*b gives  N/(a*b) = q2 = (N/a)/b.
   ============================================================================ *)
val () = out "F3C_NESTED_BEGIN\n";

val mult_le_mono_v3 = varify mult_le_mono;
fun mult_le_mono_3 (cT,jT_,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("c",0), ctermV3 cT),(("j",0), ctermV3 jT_),(("k",0), ctermV3 kT)] mult_le_mono_v3)) h;
val le_add_mono_v3 = varify le_add_mono;
fun le_add_mono_3 (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("a",0), ctermV3 aT),(("b",0), ctermV3 bT),(("c",0), ctermV3 cT)] le_add_mono_v3)) h;
(* left_distrib : oeq (mult x (add m n))(add (mult x m)(mult x n))  vars x,m,n *)
fun ldist_3 (xt,mt,nt) = beta_norm (Drule.infer_instantiate ctxtV3
        [(("x",0), ctermV3 xt),(("m",0), ctermV3 mt),(("n",0), ctermV3 nt)] left_distrib_v3);

val nested_floor =
  let
    val aF = Free("a", natT); val bF = Free("b", natT); val NF = Free("N", natT)
    val hap = Thm.assume (ctermV3 (jT (lt ZeroC aF)))        (* lt 0 a *)
    val hbp = Thm.assume (ctermV3 (jT (lt ZeroC bF)))        (* lt 0 b *)
    val q1 = rdiv NF aF; val r1 = rmod NF aF
    val q2 = rdiv q1 bF; val r2 = rmod q1 bF
    val ab = mult aF bF
    (* div_mod reps *)
    val divN  = div_mod_eq_3 (NF, aF) hap     (* oeq N (add (mult a q1) r1) *)
    val r1lt  = rmod_lt_3 (NF, aF) hap        (* lt r1 a = le (Suc r1) a *)
    val divq1 = div_mod_eq_3 (q1, bF) hbp     (* oeq q1 (add (mult b q2) r2) *)
    val r2lt  = rmod_lt_3 (q1, bF) hbp        (* lt r2 b = le (Suc r2) b *)
    (* N = a*(b*q2 + r2) + r1  : rewrite q1 in (a*q1) *)
    val mq1 = mult_cong_r3 (aF, q1, add (mult bF q2) r2) divq1;   (* oeq (mult a q1)(mult a (add (mult b q2) r2)) *)
    val divN1 = oeq_trans OF [divN, add_cong_l3 (mult aF q1, mult aF (add (mult bF q2) r2), r1) mq1];
                (* oeq N (add (mult a (add (mult b q2) r2)) r1) *)
    (* a*(b*q2 + r2) = a*(b*q2) + a*r2  [left_distrib] *)
    val ld = ldist_3 (aF, mult bF q2, r2);    (* oeq (mult a (add (mult b q2) r2))(add (mult a (mult b q2))(mult a r2)) *)
    val divN2 = oeq_trans OF [divN1, add_cong_l3 (mult aF (add (mult bF q2) r2), add (mult aF (mult bF q2))(mult aF r2), r1) ld];
                (* oeq N (add (add (mult a (mult b q2))(mult a r2)) r1) *)
    (* a*(b*q2) = (a*b)*q2  [assoc] *)
    val asc = oeq_sym OF [multassoc3_at (aF, bF, q2)];   (* oeq (mult a (mult b q2))(mult (mult a b) q2) *)
    val divN3 = oeq_trans OF [divN2,
                  add_cong_l3 (add (mult aF (mult bF q2))(mult aF r2), add (mult ab q2)(mult aF r2), r1)
                    (add_cong_l3 (mult aF (mult bF q2), mult ab q2, mult aF r2) asc)];
                (* oeq N (add (add (mult (a*b) q2)(mult a r2)) r1) *)
    (* re-associate : (X + Y) + r1 = X + (Y + r1)  where X = (a*b)*q2, Y = a*r2 *)
    val reassoc = addassoc3_at (mult ab q2, mult aF r2, r1);   (* oeq (add (add X Y) r1)(add X (add Y r1)) *)
    val Nrep = oeq_trans OF [divN3, reassoc];   (* oeq N (add (mult (a*b) q2)(add (mult a r2) r1)) *)
    (* remainder bound : lt (a*r2 + r1)(a*b)  ==  le (Suc(a*r2 + r1))(a*b) *)
    (* r2 < b : witness w with b = Suc r2 + w *)
    val PabsW = Abs("w", natT, oeq bF (add (suc r2) (Bound 0)))
    val remGoal = le (suc (add (mult aF r2) r1)) ab
    fun remBody wF (hw : thm) =      (* hw : oeq b (add (Suc r2) w) *)
      let
        (* a*b = a*(Suc r2 + w) = a*Suc r2 + a*w  [cong + left_distrib] *)
        val abcong = mult_cong_r3 (aF, bF, add (suc r2) wF) hw;   (* oeq (a*b)(a*(Suc r2 + w)) *)
        val ldw = ldist_3 (aF, suc r2, wF);   (* oeq (a*(Suc r2 + w))(add (a*Suc r2)(a*w)) *)
        val abEq = oeq_trans OF [abcong, ldw];   (* oeq (a*b)(add (mult a (Suc r2))(mult a w)) *)
        (* a*Suc r2 = a + a*r2  [mult_Suc_right] *)
        val msr = multSr3_at (aF, r2);    (* oeq (mult a (Suc r2))(add a (mult a r2)) *)
        val abEq2 = oeq_trans OF [abEq, add_cong_l3 (mult aF (suc r2), add aF (mult aF r2), mult aF wF) msr];
                    (* oeq (a*b)(add (add a (mult a r2))(mult a w)) *)
        (* le (a*r2 + a)(a*b) :  a*r2 + a = a + a*r2 [comm] <= (a + a*r2) + a*w [le_add] = a*b [sym abEq2] *)
        val le_step1 = le_add3_at (add aF (mult aF r2), mult aF wF);   (* le (a + a*r2)((a+a*r2)+a*w) *)
        val le_step2 = (let val zF = Free("zls",natT) val Pb = Term.lambda zF (le (add aF (mult aF r2)) zF)
                        in substPred3 (Pb, add (add aF (mult aF r2))(mult aF wF), ab) (oeq_sym OF [abEq2]) le_step1 end);
                       (* le (a + a*r2)(a*b) *)
        val comm_ar2_a = addcomm3_at (mult aF r2, aF);   (* oeq (add (mult a r2) a)(add a (mult a r2)) *)
        val le_ar2a = (let val zF = Free("zla",natT) val Pb = Term.lambda zF (le zF ab)
                       in substPred3 (Pb, add aF (mult aF r2), add (mult aF r2) aF) (oeq_sym OF [comm_ar2_a]) le_step2 end);
                      (* le (a*r2 + a)(a*b) *)
        (* le (Suc(a*r2 + r1))(a*r2 + a) :  from le (Suc r1) a  by le_add_mono with c=a*r2 then comm + addSr *)
        (* le (Suc r1) a -> le (add (Suc r1)(a*r2))(add a (a*r2)) *)
        val lam = le_add_mono_3 (suc r1, aF, mult aF r2) r1lt;   (* le (add (Suc r1)(a*r2))(add a (a*r2)) *)
        (* comm LHS : add (Suc r1)(a*r2) = add (a*r2)(Suc r1) = Suc(a*r2 + r1) *)
        val commL = addcomm3_at (suc r1, mult aF r2);   (* oeq (add (Suc r1)(a*r2))(add (a*r2)(Suc r1)) *)
        val sucL = addSr3_at (mult aF r2, r1);   (* oeq (add (a*r2)(Suc r1))(Suc(add (a*r2) r1)) *)
        val lhsEq = oeq_trans OF [commL, sucL];   (* oeq (add (Suc r1)(a*r2))(Suc(a*r2 + r1)) *)
        (* comm RHS : add a (a*r2) = add (a*r2) a *)
        val commR = addcomm3_at (aF, mult aF r2);   (* oeq (add a (a*r2))(add (a*r2) a) *)
        val lam2 = (let val zF = Free("zlam1",natT) val Pb = Term.lambda zF (le zF (add aF (mult aF r2)))
                    in substPred3 (Pb, add (suc r1)(mult aF r2), suc (add (mult aF r2) r1)) lhsEq lam end);
                   (* le (Suc(a*r2 + r1))(add a (a*r2)) *)
        val lam3 = (let val zF = Free("zlam2",natT) val Pb = Term.lambda zF (le (suc (add (mult aF r2) r1)) zF)
                    in substPred3 (Pb, add aF (mult aF r2), add (mult aF r2) aF) commR lam2 end);
                   (* le (Suc(a*r2 + r1))(a*r2 + a) *)
        val g = le_trans3_at (suc (add (mult aF r2) r1), add (mult aF r2) aF, ab) lam3 le_ar2a;
                (* le (Suc(a*r2 + r1))(a*b) *)
      in g end;
    val remLt = exE_elim3 (PabsW, remGoal) r2lt "w_nf" remBody;   (* le (Suc(a*r2 + r1))(a*b) = lt (a*r2+r1)(a*b) *)
    (* div_mod_unique : N = (a*b)*q2 + (a*r2+r1), with lt (a*r2+r1)(a*b) and lt r2 ... ;
       compare with div_mod_eq for N at divisor (a*b) : N = (a*b)*(rdiv N (a*b)) + rmod N (a*b)
       Use div_mod_unique_3 (q1':=rdiv N (a*b), q2':=q2, r1':=rmod N (a*b), r2':=(a*r2+r1), b:=a*b) on
         EQ : (a*b)*(rdiv N (a*b)) + rmod N (a*b) = (a*b)*q2 + (a*r2+r1)
       giving rdiv N (a*b) = q2. *)
    val abpos =
      let val mlm = mult_le_mono2_3_at (suc ZeroC, aF, suc ZeroC, bF) hap hbp   (* le (1*1)(a*b) *)
          val m11 = mult1l3_at (suc ZeroC)
      in (let val zF = Free("zabp",natT) val Pb = Term.lambda zF (le zF ab)
          in substPred3 (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end) end;   (* lt 0 (a*b) *)
    val divNab = div_mod_eq_3 (NF, ab) abpos;   (* oeq N (add (mult (a*b)(rdiv N (a*b)))(rmod N (a*b))) *)
    val rabLt  = rmod_lt_3 (NF, ab) abpos;      (* lt (rmod N (a*b))(a*b) *)
    (* EQ : (a*b)*(rdiv N(a*b)) + rmod N(a*b)  =  (a*b)*q2 + (a*r2+r1)  : (sym divNab) trans Nrep *)
    val EQ = oeq_trans OF [oeq_sym OF [divNab], Nrep];
    val uniq = div_mod_unique_3 (rdiv NF ab, q2, rmod NF ab, add (mult aF r2) r1, ab) EQ rabLt remLt;
               (* Conj (oeq (rdiv N (a*b)) q2)(oeq (rmod N (a*b))(a*r2+r1)) *)
    val eqQ = conjunct1_3 (oeq (rdiv NF ab) q2, oeq (rmod NF ab)(add (mult aF r2) r1)) uniq;  (* oeq (rdiv N (a*b)) q2 *)
    (* goal : oeq (rdiv (rdiv N a) b)(rdiv N (a*b)) = oeq q2 (rdiv N (a*b)) = sym eqQ *)
    val g = oeq_sym OF [eqQ];
    val d1 = Thm.implies_intr (ctermV3 (jT (lt ZeroC bF))) g
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC aF))) d1
  in varify d2 end;
val () = out ("nested_floor 0hyp=" ^ Bool.toString (zhV3 nested_floor) ^ "\n");
val i_nested_floor =
  let val aVz = Var(("a",0),natT); val bVz = Var(("b",0),natT); val NVz = Var(("N",0),natT)
  in Logic.mk_implies (jT (lt ZeroC aVz),
       Logic.mk_implies (jT (lt ZeroC bVz),
         jT (oeq (rdiv (rdiv NVz aVz) bVz)(rdiv NVz (mult aVz bVz))))) end;
val r_nf = (Thm.prop_of nested_floor) aconv i_nested_floor;
val () = out ("nested_floor aconv=" ^ Bool.toString r_nf ^ "\n");
val () = if zhV3 nested_floor andalso r_nf then out "NESTED_FLOOR_OK\n" else out "NESTED_FLOOR_FAIL\n";
val nested_floor_v3 = varify nested_floor;
val () = out "F3C_NESTED_DONE\n";

(* ============================================================================
   (LE-step1) legendre_sum_rem : prime2 p ==>
     oeq (vp p (fact N))
         (add (sumf (%i. rdiv N (pow p (Suc i))) L)
              (vp p (fact (rdiv N (pow p (Suc L))))))
   by nat_induct on L (N,p fixed).  IH gives vp(fact N) = RHS(L) ; the step shows
   RHS(L) = RHS(Suc L) via legendre_rec (unfold the remainder) + nested_floor
   (rdiv (rdiv N (p^(Suc L))) p = rdiv N (p^(Suc(Suc L)))) + sumf_Suc + assoc.
   ============================================================================ *)
val () = out "F3C_LESUM_BEGIN\n";

val sumf_0_v3   = varify sumf_0_ax;
val sumf_Suc_v3 = varify sumf_Suc_ax;
fun sumf0_3 fT       = beta_norm (Drule.infer_instantiate ctxtV3 [(("f",0), ctermV3 fT)] sumf_0_v3);
fun sumfSuc_3 (fT,nt)= beta_norm (Drule.infer_instantiate ctxtV3 [(("f",0), ctermV3 fT),(("n",0), ctermV3 nt)] sumf_Suc_v3);
fun nested_floor_3 (aT,bT,NT) hap hbp =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3 [(("a",0), ctermV3 aT),(("b",0), ctermV3 bT),(("N",0), ctermV3 NT)] nested_floor_v3)
  in (inst OF [hap]) OF [hbp] end;

(* pow p (Suc 0) = p  :  pow p (Suc 0) = p * pow p 0 = p * 1 = p *)
fun pow_one_3 pT =
  let val pS = powSuc3_at (pT, ZeroC)     (* oeq (pow p (Suc 0))(mult p (pow p 0)) *)
      val p0 = pow03_at pT                 (* oeq (pow p 0)(Suc 0) *)
      val m1 = mult_cong_r3 (pT, pow pT ZeroC, suc ZeroC) p0;  (* oeq (mult p (pow p 0))(mult p (Suc 0)) *)
      val m1r= mult1r3_at pT               (* oeq (mult p (Suc 0)) p *)
  in oeq_trans OF [pS, oeq_trans OF [m1, m1r]] end;   (* oeq (pow p (Suc 0)) p *)

val legendre_sum_rem =
  let
    val pF = Free("p", natT); val NF = Free("N", natT); val LF = Free("L", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val lt0p = prime2_pos_3 pF hPr
    val iB = Free("i_les", natT)
    val fAbs = Term.lambda iB (rdiv NF (pow pF (suc iB)))     (* %i. rdiv N (pow p (Suc i)) *)
    fun term_at it = rdiv NF (pow pF (suc it))               (* fAbs $ it (beta) *)
    fun rhs lt = add (sumf fAbs lt)(vp pF (fact (rdiv NF (pow pF (suc lt)))))
    val zL = Free("z_les", natT)
    val Pabs = Term.lambda zL (oeq (vp pF (fact NF))(rhs zL))
    val ind = beta_norm (Drule.infer_instantiate ctxtV3 [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 LF)] nat_induct_v3)
    (* BASE L=0 : vp(fact N) = sumf f 0 + vp(fact(rdiv N (pow p (Suc 0)))) *)
    val base =
      let
        (* legendre_rec : vp(fact N) = rdiv N p + vp(fact(rdiv N p)) *)
        val lr = legendre_rec_3 (pF, NF) hPr;     (* oeq (vp p (fact N))(add (rdiv N p)(vp p (fact (rdiv N p)))) *)
        (* pow p (Suc 0) = p ; so rdiv N (pow p (Suc 0)) = rdiv N p  (rewrite p -> pow p (Suc 0)) *)
        val p1 = pow_one_3 pF;                    (* oeq (pow p (Suc 0)) p *)
        (* build rdiv N (pow p (Suc 0)) = rdiv N p via cong on 2nd arg using p1 *)
        val rd_eq = (let val zF = Free("zrd2",natT)
                         val Pb = Term.lambda zF (oeq (rdiv NF (pow pF (suc ZeroC)))(rdiv NF zF))
                     in substPred3 (Pb, pow pF (suc ZeroC), pF) p1 (oeqrefl3_at (rdiv NF (pow pF (suc ZeroC)))) end);
                    (* oeq (rdiv N (pow p (Suc 0)))(rdiv N p) *)
        (* RHS(0) = sumf f 0 + vp(fact(rdiv N (pow p (Suc 0)))) ; sumf f 0 = f 0 = rdiv N (pow p (Suc 0)) *)
        val sf0 = sumf0_3 fAbs;                   (* oeq (sumf f 0)(f 0) *)
        val sf0b = beta_norm sf0;                 (* oeq (sumf f 0)(rdiv N (pow p (Suc 0))) *)
        (* legendre rhs in terms of pow : add (rdiv N (pow p (Suc 0)))(vp(fact(rdiv N (pow p (Suc 0))))) *)
        (* lr : vp(fact N) = add (rdiv N p)(vp(fact(rdiv N p))) ;
           rewrite rdiv N p -> rdiv N (pow p (Suc 0)) in both spots (sym rd_eq) *)
        val lr1 = oeq_trans OF [lr, add_cong_l3 (rdiv NF pF, rdiv NF (pow pF (suc ZeroC)), vp pF (fact (rdiv NF pF))) (oeq_sym OF [rd_eq])];
                  (* vp(fact N) = add (rdiv N (pow p (Suc 0)))(vp(fact(rdiv N p))) *)
        val vpfeq = vp_cong_3 (pF, fact (rdiv NF pF), fact (rdiv NF (pow pF (suc ZeroC))))
                      ((let val zF = Free("zfc",natT)
                            val Pb = Term.lambda zF (oeq (fact (rdiv NF pF))(fact zF))
                        in substPred3 (Pb, rdiv NF pF, rdiv NF (pow pF (suc ZeroC))) (oeq_sym OF [rd_eq]) (oeqrefl3_at (fact (rdiv NF pF))) end));
                    (* oeq (vp p (fact(rdiv N p)))(vp p (fact(rdiv N (pow p (Suc 0))))) *)
        val lr2 = oeq_trans OF [lr1, add_cong_r3 (rdiv NF (pow pF (suc ZeroC)), vp pF (fact (rdiv NF pF)), vp pF (fact (rdiv NF (pow pF (suc ZeroC))))) vpfeq];
                  (* vp(fact N) = add (rdiv N (pow p (Suc 0)))(vp(fact(rdiv N (pow p (Suc 0))))) *)
        (* now rewrite (rdiv N (pow p (Suc 0))) -> (sumf f 0) [sym sf0b] in the add's left *)
        val g = oeq_trans OF [lr2, add_cong_l3 (rdiv NF (pow pF (suc ZeroC)), sumf fAbs ZeroC, vp pF (fact (rdiv NF (pow pF (suc ZeroC))))) (oeq_sym OF [sf0b])];
                (* vp(fact N) = add (sumf f 0)(vp(fact(rdiv N (pow p (Suc 0))))) = rhs 0 *)
      in g end;
    (* STEP *)
    val xF = Free("x", natT)
    val ihP = jT (oeq (vp pF (fact NF))(rhs xF))
    val IH = Thm.assume (ctermV3 ihP)        (* vp(fact N) = RHS(x) *)
    (* Lev x = pow p (Suc x) ; M = rdiv N (Lev x) ; legendre_rec at M : vp(fact M) = rdiv M p + vp(fact(rdiv M p)) *)
    val Levx = pow pF (suc xF)
    val M    = rdiv NF Levx
    val lrM  = legendre_rec_3 (pF, M) hPr;     (* oeq (vp p (fact M))(add (rdiv M p)(vp p (fact (rdiv M p)))) *)
    (* Levx > 0 *)
    val Levx_pos = pow_pos_3 (pF, suc xF) lt0p;   (* lt 0 (pow p (Suc x)) *)
    (* nested_floor : rdiv (rdiv N (Levx)) p = rdiv N (mult Levx p) *)
    val nf = nested_floor_3 (Levx, pF, NF) Levx_pos lt0p;   (* oeq (rdiv (rdiv N Levx) p)(rdiv N (mult Levx p)) *)
    (* mult Levx p = pow p (Suc(Suc x)) :  pow p (Suc(Suc x)) = mult p (pow p (Suc x)) = mult Levx p [comm] *)
    val pSS = powSuc3_at (pF, suc xF);         (* oeq (pow p (Suc(Suc x)))(mult p (pow p (Suc x))) *)
    val pSS2 = oeq_trans OF [pSS, multcomm3_at (pF, pow pF (suc xF))];  (* oeq (pow p (Suc(Suc x)))(mult Levx p) *)
    (* so rdiv N (mult Levx p) = rdiv N (pow p (Suc(Suc x))) [rewrite mult Levx p -> pow p (Suc(Suc x))] *)
    val rdivLev2 = (let val zF = Free("zrl",natT)
                        val Pb = Term.lambda zF (oeq (rdiv NF (mult Levx pF))(rdiv NF zF))
                    in substPred3 (Pb, mult Levx pF, pow pF (suc (suc xF))) (oeq_sym OF [pSS2]) (oeqrefl3_at (rdiv NF (mult Levx pF))) end);
                   (* oeq (rdiv N (mult Levx p))(rdiv N (pow p (Suc(Suc x)))) *)
    (* rdiv M p = rdiv (rdiv N Levx) p = rdiv N (mult Levx p) = rdiv N (pow p (Suc(Suc x))) *)
    val rdMp_eq = oeq_trans OF [nf, rdivLev2];  (* oeq (rdiv M p)(rdiv N (pow p (Suc(Suc x)))) *)
    (* rewrite lrM : vp(fact M) = add (rdiv N (pow p (Suc(Suc x))))(vp(fact(rdiv N (pow p (Suc(Suc x)))))) *)
    val NewIdx = pow pF (suc (suc xF))
    val lrM1 = oeq_trans OF [lrM, add_cong_l3 (rdiv M pF, rdiv NF NewIdx, vp pF (fact (rdiv M pF))) rdMp_eq];
               (* vp(fact M) = add (rdiv N NewIdx)(vp(fact(rdiv M p))) *)
    val vpfM = vp_cong_3 (pF, fact (rdiv M pF), fact (rdiv NF NewIdx))
                 ((let val zF = Free("zfM",natT)
                       val Pb = Term.lambda zF (oeq (fact (rdiv M pF))(fact zF))
                   in substPred3 (Pb, rdiv M pF, rdiv NF NewIdx) rdMp_eq (oeqrefl3_at (fact (rdiv M pF))) end));
               (* oeq (vp(fact(rdiv M p)))(vp(fact(rdiv N NewIdx))) *)
    val lrM2 = oeq_trans OF [lrM1, add_cong_r3 (rdiv NF NewIdx, vp pF (fact (rdiv M pF)), vp pF (fact (rdiv NF NewIdx))) vpfM];
               (* vp(fact M) = add (rdiv N NewIdx)(vp(fact(rdiv N NewIdx))) *)
    (* RHS(x) = sumf f x + vp(fact M) ; rewrite vp(fact M) -> add (rdiv N NewIdx)(vp(fact(rdiv N NewIdx))) *)
    val Sx = sumf fAbs xF
    val rhsX_rw = add_cong_r3 (Sx, vp pF (fact M), add (rdiv NF NewIdx)(vp pF (fact (rdiv NF NewIdx)))) lrM2;
                  (* oeq (RHS x)(add (sumf f x)(add (rdiv N NewIdx)(vp(fact(rdiv N NewIdx))))) *)
    (* re-associate : Sx + (a + b) = (Sx + a) + b  [assoc sym] where a = rdiv N NewIdx, b = vp(fact(rdiv N NewIdx)) *)
    val aT = rdiv NF NewIdx; val bT = vp pF (fact (rdiv NF NewIdx))
    val asc = oeq_sym OF [addassoc3_at (Sx, aT, bT)];   (* oeq (add Sx (add a b))(add (add Sx a) b) *)
    val rhsX_rw2 = oeq_trans OF [rhsX_rw, asc];   (* oeq (RHS x)(add (add Sx a) b) *)
    (* sumf_Suc : sumf f (Suc x) = add (sumf f x)(f (Suc x)) = add Sx (rdiv N NewIdx) = add Sx a *)
    val sfS = sumfSuc_3 (fAbs, xF);            (* oeq (sumf f (Suc x))(add (sumf f x)(f (Suc x))) *)
    val sfSb = beta_norm sfS;                   (* oeq (sumf f (Suc x))(add Sx (rdiv N (pow p (Suc(Suc x))))) = add Sx a *)
    (* add Sx a -> sumf f (Suc x)  [sym sfSb] in (add (add Sx a) b) *)
    val rhsX_rw3 = oeq_trans OF [rhsX_rw2, add_cong_l3 (add Sx aT, sumf fAbs (suc xF), bT) (oeq_sym OF [sfSb])];
                   (* oeq (RHS x)(add (sumf f (Suc x))(vp(fact(rdiv N NewIdx)))) = RHS (Suc x) *)
    (* chain : vp(fact N) = RHS(x) [IH] = RHS(Suc x) *)
    val stepC = oeq_trans OF [IH, rhsX_rw3];
    val step = Thm.forall_intr (ctermV3 xF) (Thm.implies_intr (ctermV3 ihP) stepC)
    val body = Thm.implies_elim (Thm.implies_elim ind base) step
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) body
  in varify d1 end;
val () = out ("legendre_sum_rem 0hyp=" ^ Bool.toString (zhV3 legendre_sum_rem) ^ "\n");
val i_legendre_sum_rem =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT); val LVz = Var(("L",0),natT)
      val iB = Free("i_les", natT)
      val fAbs = Term.lambda iB (rdiv NVz (pow pVz (suc iB)))
  in Logic.mk_implies (jT (prime2 pVz),
       jT (oeq (vp pVz (fact NVz))
               (add (sumf fAbs LVz)(vp pVz (fact (rdiv NVz (pow pVz (suc LVz)))))))) end;
val r_lsr = (Thm.prop_of legendre_sum_rem) aconv i_legendre_sum_rem;
val () = out ("legendre_sum_rem aconv=" ^ Bool.toString r_lsr ^ "\n");
val () = if zhV3 legendre_sum_rem andalso r_lsr then out "LEGENDRE_SUM_REM_OK\n" else out "LEGENDRE_SUM_REM_FAIL\n";
val () = out "F3C_LESUM_DONE\n";

(* ============================================================================
   F3c — FINALE.  Stages closed this fleet (each 0-hyp + aconv on ctxtV3):
     (PF) pfree_pos, fact_split      [FACT_SPLIT_OK]
     (CO) pfree_coprime, pfree_vp_zero  [PFREE_COPRIME_OK / PFREE_VP_ZERO_OK]
