(* ============================================================================
   (F01)  floor01 : lt 0 q ==> Disj (oeq (tflo n q) 0)(oeq (tflo n q) (Suc 0))
     where tflo n q := sub (rdiv (add n n) q)(add (rdiv n q)(rdiv n q)).
