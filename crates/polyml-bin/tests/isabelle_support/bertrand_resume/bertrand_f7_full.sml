(* ============================================================================
   BERTRAND F5 — delta 8 : the un-refined product bound (CBND-family), closed.
     cb_prodbound : lt 0 n ==> lt 0 (binom 2n n)
        ==> Ex s. (le (mult s s)(2n) /\ lt (2n)(mult (Suc s)(Suc s)))
                  /\ le (binom 2n n) (mult (pow (2n)(Suc s))(pow 4 (2n)))
   i.e.  C(2n,n) <= (2n)^(Suc s) * 4^(2n)  with s = floor_sqrt(2n).
   ============================================================================ *)
val () = out "F5_D8_BEGIN\n";

val fourC4 = suc (suc (suc (suc ZeroC)));   (* 4 *)

(* Suc_inj on V4 *)
val Suc_inj_v4 = varify Suc_inj_ax;
fun Suc_inj4 (aT,bT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4 [(("a",0),ctermV4 aT),(("b",0),ctermV4 bT)] Suc_inj_v4)) h;

(* cb_prodbound : produces, under lt 0 n and lt 0 cb, the existential bound. *)
val cb_prodbound =
  let
    val nF = Free("n_cbp", natT)
    val twoN = add nF nF
    val R = binom twoN nF
    val hn0  = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
    val hcb0 = Thm.assume (ctermV4 (jT (lt ZeroC R)))
    (* floor_sqrt at 2n : ?s. le (s*s)(2n) /\ lt (2n)((Suc s)^2) *)
    val fs = beta_norm (Drule.infer_instantiate ctxtV4 [(("N_fs",0), ctermV4 twoN)] floor_sqrt)
             (* Ex (\s. le (s*s)(2n) /\ lt (2n)((Suc s)^2)) *)
    val fsBodyAbs = Term.lambda (Free("s",natT))
        (mkConj (le (mult (Free("s",natT))(Free("s",natT))) twoN)
                (lt twoN (mult (suc (Free("s",natT)))(suc (Free("s",natT))))))
    (* final existential conclusion : ?s. (le (s*s)(2n) /\ lt (2n)((Suc s)^2)) /\ le R (mult (pow (2n)(Suc s))(pow 4 (2n))) *)
    fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                            (le R (mult (pow twoN (suc sT))(pow fourC4 twoN)))
    val outAbs = Term.lambda (Free("s_out", natT)) (outBody (Free("s_out", natT)))
    val goalC = mkEx outAbs
    fun body sF (hs : thm) =     (* hs : le (s*s)(2n) /\ lt (2n)((Suc s)^2) *)
      let
        val sq  = mult sF sF
        val sqS = mult (suc sF)(suc sF)
        val hSqle = conjunct1_4 (le sq twoN, lt twoN sqS) hs   (* le (s*s)(2n) *)
        val hSsq  = conjunct2_4 (le sq twoN, lt twoN sqS) hs   (* lt (2n)((Suc s)^2) *)
        val K = suc sF
        (* le s (2n) : le s (s*s) [le_s_ssq] ; le (s*s)(2n) [hSqle] ; trans *)
        val le_s_2n = le_trans4_at (sF, sq, twoN) (le_s_ssq sF) hSqle   (* le s (2n) *)
        val le_K_S2n = le_suc_mono4_at (sF, twoN) le_s_2n              (* le (Suc s)(Suc 2n) *)
        (* j = sub (Suc 2n)(Suc s) ; add (Suc s) j = Suc 2n *)
        val jVal = sub (suc twoN) K
        val addEq = le_add_sub_4 (K, suc twoN) le_K_S2n   (* oeq (add (Suc s) j)(Suc 2n) *)
        (* Hsq + UI2 at j : le (cpf (add K j) R)(mult (cpf K R)(primorial (add s j))) *)
        val Hsq = build_Hsq (sF, nF) hn0 hSsq
        val ui = cpf_upper_tele (jVal, sF, nF) Hsq   (* le (cpf (add K j) R)(mult (cpf K R)(primorial (add s j))) *)
        (* rewrite (add K j) -> (Suc 2n) on LHS via addEq (cong on cpf first arg) *)
        val cpfRw = (let val zc = Free("zcbp", natT) val Pc = Term.lambda zc (oeq (cpf (add K jVal) R)(cpf zc R))
                     in substPred4 (Pc, add K jVal, suc twoN) addEq (oeqrefl4_at (cpf (add K jVal) R)) end)
                    (* oeq (cpf (add K j) R)(cpf (Suc 2n) R) *)
        val ui2 = le_cong_l4 (cpf (add K jVal) R, cpf (suc twoN) R, mult (cpf K R)(primorial (add sF jVal))) cpfRw ui
                  (* le (cpf (Suc 2n) R)(mult (cpf K R)(primorial (add s j))) *)
        (* add s j = 2n : from addEq (add (Suc s) j = Suc 2n) and add_Suc (add (Suc s) j = Suc(add s j)) -> Suc(add s j)=Suc 2n -> add s j = 2n *)
        val aSk_j = add_Suc_at4 (sF, jVal)   (* oeq (add (Suc s) j)(Suc(add s j)) *)
        val sucEq = oeq_trans OF [oeq_sym OF [aSk_j], addEq]   (* oeq (Suc(add s j))(Suc 2n) *)
        (* Suc injective : need add s j = 2n.  We rewrite primorial (add s j) using Suc-injectivity?
           Easier: rewrite primorial(add s j) -> primorial(2n) needs oeq (add s j)(2n).
           From sucEq : Suc(add s j) = Suc 2n.  Use a Suc-injective lemma. *)
        (* Suc_inj : oeq (Suc a)(Suc b) ==> oeq a b. *)
        val addsj_2n = Suc_inj4 (add sF jVal, twoN) sucEq    (* oeq (add s j)(2n) *)
        (* rewrite RHS primorial (add s j) -> primorial (2n) *)
        val primRw = (let val zp = Free("zppr", natT) val Pp = Term.lambda zp (oeq (primorial (add sF jVal))(primorial zp))
                      in substPred4 (Pp, add sF jVal, twoN) addsj_2n (oeqrefl4_at (primorial (add sF jVal))) end)
                     (* oeq (primorial (add s j))(primorial (2n)) *)
        val ui3 = le_cong_r4 (cpf (suc twoN) R, mult (cpf K R)(primorial (add sF jVal)), mult (cpf K R)(primorial twoN))
                    (mult_cong_r4 (cpf K R, primorial (add sF jVal), primorial twoN) primRw) ui2
                  (* le (cpf (Suc 2n) R)(mult (cpf K R)(primorial (2n))) *)
        (* C = cpf (Suc 2n) R via cpf_binom_2n : needs lt 0 n, lt 0 cb, le (Suc 2n)(Suc cb) *)
        val le2ncb = le_2n_cb nF hn0   (* le (2n)(R) *)
        val leS2ncb = le_suc_mono4_at (twoN, R) le2ncb   (* le (Suc 2n)(Suc R) *)
        val cbEq = cpf_binom_2n_4 nF hn0 hcb0 leS2ncb   (* oeq R (cpf (Suc 2n) R) *)
        (* le R (mult (cpf K R)(primorial 2n)) : rewrite ui3's LHS cpf(Suc 2n) R -> R via cbEq sym *)
        val leA = le_cong_l4 (cpf (suc twoN) R, R, mult (cpf K R)(primorial twoN)) (oeq_sym OF [cbEq]) ui3
                  (* le R (mult (cpf K R)(primorial 2n)) *)
        (* cpf K R = cpf (Suc s) R <= (2n)^(Suc s) [LO] *)
        val loK = cpf_pow_bound (K, nF) hn0   (* le (cpf K R)(pow (2n) K) *)
        (* primorial 2n <= 4^(2n) [primorial_bound] *)
        val pb = primorial_bound_4 twoN   (* le (primorial (2n))(pow 4 (2n)) *)
        (* mult_le_mono2 : le (cpf K R)(pow 2n K), le (primorial 2n)(pow 4 2n)
                        -> le (mult (cpf K R)(primorial 2n))(mult (pow 2n K)(pow 4 2n)) *)
        val mlm = mult_le_mono2_4_at (cpf K R, pow twoN K, primorial twoN, pow fourC4 twoN) loK pb
                  (* le (mult (cpf K R)(primorial 2n))(mult (pow 2n K)(pow 4 2n)) *)
        val leB = le_trans4_at (R, mult (cpf K R)(primorial twoN), mult (pow twoN K)(pow fourC4 twoN)) leA mlm
                  (* le R (mult (pow 2n (Suc s))(pow 4 2n)) *)
        (* package the existential body : conj of (hs) and leB *)
        val cjInner = conjI_4 (le sq twoN, lt twoN sqS) hSqle hSsq
        val cjFull  = conjI_4 (mkConj (le sq twoN)(lt twoN sqS), le R (mult (pow twoN K)(pow fourC4 twoN))) cjInner leB
        val ex = exI_4 (outAbs, sF) cjFull
      in ex end
    val concl = exE_elim4 (fsBodyAbs, goalC) fs "s_fs" body
    val d2 = Thm.implies_intr (ctermV4 (jT (lt ZeroC R))) concl
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) d2
  in varify d1 end;

val () = out ("cb_prodbound 0hyp=" ^ Bool.toString (zhV4 cb_prodbound) ^ "\n");
val () = out ("cb_prodbound : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of cb_prodbound) ^ "\n");
val () = if zhV4 cb_prodbound then out "CB_PRODBOUND_OK\n" else out "CB_PRODBOUND_FAIL\n";

val () = out "F5_D8_DONE\n";
(* probe : lt 2n (mult 3 (Suc (rdiv 2n 3)))   [2n < 3*(2n/3 + 1)] *)
val () = out "F5_D9PROBE_BEGIN\n";

(* le 1 3 = lt 0 3 *)
val lt0_3 = le_suc_mono4_at (ZeroC, suc (suc ZeroC)) (le_zero4_at (suc (suc ZeroC)));  (* le 1 3 *)

fun two_n_lt_3_succ_div nT =
  let
    val twoN = add nT nT
    val three = suc (suc (suc ZeroC))
    val q = rdiv twoN three
    val r = rmod twoN three
    (* div_mod_eq : 2n = 3*q + r ; rmod_lt : r < 3 *)
    val dme = div_mod_eq_4 (twoN, three) lt0_3   (* oeq 2n (add (mult 3 q) r) *)
    val rlt = rmod_lt_4 (twoN, three) lt0_3      (* lt r 3 = le (Suc r) 3 *)
    (* want : lt 2n (mult 3 (Suc q)) = le (Suc 2n)(mult 3 (Suc q))
       mult 3 (Suc q) = 3*q + 3 [mult_Suc_right : mult 3 (Suc q) = add 3 (mult 3 q)] ... that's 3 + 3q.
       3*(Suc q) = add 3 (mult 3 q). We want add (mult 3 q) 3 form; commute. *)
    val mSr = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 three),(("m",0),ctermV4 q)] mult_Suc_right_v4_)
              (* oeq (mult 3 (Suc q))(add 3 (mult 3 q)) *)
    val mComm = addcomm4_at (three, mult three q)   (* oeq (add 3 (mult 3 q))(add (mult 3 q) 3) *)
    val m3Sq = oeq_trans OF [mSr, mComm]            (* oeq (mult 3 (Suc q))(add (mult 3 q) 3) *)
    (* le (Suc 2n)(add (mult 3 q) 3) :
       2n = 3q + r ; Suc 2n = Suc(3q + r) = add (3q) (Suc r) [add_Suc_right sym]
       le (Suc r) 3 [rlt] -> le (add (3q)(Suc r))(add (3q) 3) [le_add congruence on 2nd arg]
       and Suc 2n = add (3q)(Suc r). *)
    (* Suc 2n = Suc(add (3q) r) [Suc_cong dme] = add (3q)(Suc r) [add_Suc_right sym] *)
    val sucDme = Suc_cong OF [dme]   (* oeq (Suc 2n)(Suc (add (mult 3 q) r)) *)
    val aSr2 = add_Sr4_at (mult three q, r)   (* oeq (add (mult 3 q)(Suc r))(Suc(add (mult 3 q) r)) *)
    val suc2n_eq = oeq_trans OF [sucDme, oeq_sym OF [aSr2]]   (* oeq (Suc 2n)(add (mult 3 q)(Suc r)) *)
    (* le (add (mult 3 q)(Suc r))(add (mult 3 q) 3) : add_le_mono on 2nd arg.
       le_add_mono : le a b -> le (add a c)(add b c).  We need 2nd-arg mono: le (Suc r) 3 -> le (add (3q)(Suc r))(add (3q) 3).
       Use le_add_mono with commute, or a 2nd-arg version.  le_add_mono_4 (a,b,c) h : le a b -> le (add a c)(add b c).
       For 2nd arg: le (Suc r) 3 -> le (add (3q)(Suc r))(add (3q) 3):
         add (3q)(Suc r) = add (Suc r)(3q) [comm]; le (add (Suc r)(3q))(add 3 (3q)) [le_add_mono (Suc r,3,3q)];
         add 3 (3q) = add (3q) 3 [comm]. *)
    val leAddMono = le_add_mono_4 (suc r, three, mult three q) rlt   (* le (add (Suc r)(mult 3 q))(add 3 (mult 3 q)) *)
    val cm1 = addcomm4_at (mult three q, suc r)   (* oeq (add (3q)(Suc r))(add (Suc r)(3q)) *)
    val cm2 = addcomm4_at (three, mult three q)   (* oeq (add 3 (3q))(add (3q) 3) *)
    val le1 = le_cong_l4 (add (suc r)(mult three q), add (mult three q)(suc r), add three (mult three q)) (oeq_sym OF [cm1]) leAddMono
              (* le (add (3q)(Suc r))(add 3 (3q)) *)
    val le2 = le_cong_r4 (add (mult three q)(suc r), add three (mult three q), add (mult three q) three) cm2 le1
              (* le (add (3q)(Suc r))(add (3q) 3) *)
    (* now le (Suc 2n)(add (3q) 3) via suc2n_eq, then -> le (Suc 2n)(mult 3 (Suc q)) via m3Sq sym *)
    val le3 = le_cong_l4 (add (mult three q)(suc r), suc twoN, add (mult three q) three) (oeq_sym OF [suc2n_eq]) le2
              (* le (Suc 2n)(add (3q) 3) *)
    val g = le_cong_r4 (suc twoN, add (mult three q) three, mult three (suc q)) (oeq_sym OF [m3Sq]) le3
            (* le (Suc 2n)(mult 3 (Suc q)) = lt 2n (mult 3 (Suc(rdiv 2n 3))) *)
  in g end;

val () = out ("two_n_lt_3_succ_div banked : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of (two_n_lt_3_succ_div (Free("n_chk",natT)))) ^ "\n");
val () = out "F5_RDIV3_INFRA_OK\n";
(* ============================================================================
   BERTRAND F5 — FINALE.  Bank floor_sqrt + LO + UI2 + un-refined CBND
   (CB_PRODBOUND), soundness probes, axiom audit.
   The 2n/3-refined CBND + threshold contradiction + small-n chain are the
   documented remaining work (the Erdos growth-inequality is the hard step).
   ============================================================================ *)
val () = out "F5_FINALE_BEGIN\n";

(* ---- bank the components ---- *)
val r_fsq_final  = (Thm.prop_of floor_sqrt) aconv i_floor_sqrt;

(* cpf_pow_bound (LO) — restate + check.  Build over Frees, discharge, varify. *)
val lo_thm =
  let val nF = Free("n_lo", natT) val BF = Free("B_lo", natT)
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val body = cpf_pow_bound (BF, nF) hn0   (* le (cpf B R)(pow 2n B) *)
  in varify (Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) body) end;
val i_lo =
  let val nVz = Var(("n_lo",0),natT) val BVz = Var(("B_lo",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz
  in Logic.mk_implies (jT (lt ZeroC nVz), jT (le (cpf BVz R)(pow twoN BVz))) end;
val r_lo = (Thm.prop_of lo_thm) aconv i_lo;
val () = out ("LO (cpf_pow_bound) 0hyp=" ^ Bool.toString (zhV4 lo_thm) ^ " aconv=" ^ Bool.toString r_lo ^ "\n");
val () = if zhV4 lo_thm andalso r_lo then out "CB_LOWER_PROD_OK\n" else out "CB_LOWER_PROD_FAIL\n";

(* cb_prodbound (CBND, un-refined) : already 0-hyp.  Restate interface. *)
val i_cb_prodbound =
  let val nVz = Var(("n_cbp",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz
      fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                              (le R (mult (pow twoN (suc sT))(pow fourC4 twoN)))
  in Logic.mk_implies (jT (lt ZeroC nVz),
       Logic.mk_implies (jT (lt ZeroC R),
         jT (mkEx (Term.lambda (Free("s_out",natT)) (outBody (Free("s_out",natT))))))) end;
val r_cbp = (Thm.prop_of cb_prodbound) aconv i_cb_prodbound;
val () = out ("CBND (cb_prodbound) 0hyp=" ^ Bool.toString (zhV4 cb_prodbound) ^ " aconv=" ^ Bool.toString r_cbp ^ "\n");
val () = if zhV4 cb_prodbound andalso r_cbp then out "CB_PRODBOUND_FINAL_OK\n" else out "CB_PRODBOUND_FINAL_FAIL\n";

(* ---- soundness probes : kernel must REJECT false variants ---- *)
(* floor_sqrt must carry the strict upper bound (replacing lt by le must NOT be aconv) *)
val s_fsq_strict =
  let val NV = Var(("N_fs",0),natT)
      val bad = jT (mkEx (Term.lambda (Free("s",natT))
            (mkConj (le (mult (Free("s",natT))(Free("s",natT))) NV)
                    (le NV (mult (suc (Free("s",natT)))(suc (Free("s",natT))))))))  (* le instead of lt *)
  in not ((Thm.prop_of floor_sqrt) aconv bad) end;
val () = out ("PROBE floor_sqrt-strict-upper=" ^ Bool.toString s_fsq_strict ^ "\n");
(* cb_prodbound must keep the 4-exponent (pow 3 instead of pow 4 must not be aconv) *)
val s_cbp_four =
  let val nVz = Var(("n_cbp",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz
      fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                              (le R (mult (pow twoN (suc sT))(pow (suc (suc (suc ZeroC))) twoN)))  (* pow 3 *)
      val bad = Logic.mk_implies (jT (lt ZeroC nVz),
                  Logic.mk_implies (jT (lt ZeroC R),
                    jT (mkEx (Term.lambda (Free("s_out",natT)) (outBody (Free("s_out",natT)))))))
  in not ((Thm.prop_of cb_prodbound) aconv bad) end;
val () = out ("PROBE cb_prodbound-keeps-4=" ^ Bool.toString s_cbp_four ^ "\n");

(* ---- axiom audit on ctxtV4 ---- *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtV4
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nClassical = length (List.filter (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names)
  in out ("F5_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " classical_count=" ^ Int.toString nClassical ^ "\n") end;

(* ---- the F5 bank ---- *)
val f5_bank =
  zhV4 floor_sqrt andalso r_fsq_final
  andalso zhV4 lo_thm andalso r_lo
  andalso zhV4 cb_prodbound andalso r_cbp
  andalso s_fsq_strict andalso s_cbp_four;
val () = if f5_bank then out "BERTRAND_F5_CBND_OK\n" else out "BERTRAND_F5_CBND_PARTIAL\n";
val () = out "F5_FINALE_DONE\n";

(* ---- bertrand status : the threshold contradiction + small-n chain remain ---- *)
val () = out "BERTRAND_NOT_CLOSED__threshold_growth_and_2n3_refinement_pending\n";


(* ============================================================================
   BERTRAND F6 — the 4^(2n/3) REFINEMENT of the central-binomial product bound.
     Goal: cb_refined : lt 0 n ==> lt 0 R ==> H ==>
              Ex s. (s*s<=2n /\ 2n<(Suc s)^2)
                    /\ (le s (rdiv 2n 3) ==> le R (mult (pow 2n (Suc s))(pow 4 (rdiv 2n 3))))
     where H = ~(Ex p. prime2 p /\ lt n p /\ le p 2n)   [no prime in (n,2n]],
     R = binom 2n n, and the exponent on 4 is rdiv 2n 3 = floor(2n/3).
   Built on the F5 base (ctxtV4); reuses cpf_tele_build / cpf_upper_tele /
   empty_interval / vp_zero_above / sqrt_split / primorial_bound / cpf_binom_2n /
   cpf_pow_bound (LO) / le_2n_cb / floor_sqrt / two_n_lt_3_succ_div.
   ============================================================================ *)
val () = out "F6_BEGIN\n";

(* H-body builder : prime2 p /\ (lt n p /\ le p 2n) *)
fun H_body (nT, pT) = mkConj (prime2 pT)(mkConj (lt nT pT)(le pT (add nT nT)));
fun H_abs nT = Term.lambda (Free("p_H", natT)) (H_body (nT, Free("p_H", natT)));
fun H_prop nT = jT (neg (mkEx (H_abs nT)));

val three3 = threeNum;   (* 3 *)

(* ----------------------------------------------------------------------------
   (TV) TAIL-VANISH.
     Build the Hvp meta-hypothesis : for every prime b with Suc(2n/3) <= b,
     vp b R = 0, by the three sub-cases:
        2n/3 < b <= n         -> empty_interval
        n < b <= 2n           -> H (contradiction : b is a prime in (n,2n])
        b > 2n                -> vp_zero_above
   Then telescope cpf (Suc 2n) R = cpf (Suc(2n/3)) R via cpf_tele_build.
   Requires (parameters): hn0 (lt 0 n), the floor witness s + hSsq (2n<(Suc s)^2),
   the guard hGuard (le s (2n/3)), and hH (H).
   ---------------------------------------------------------------------------- *)

(* The per-b vp-zero fact under the four hyps, abstracted as Hvp = !!b. le (Suc(2n/3)) b ==> prime2 b ==> oeq (vp b R) 0. *)
fun build_Hvp_tail (sT, nT) hn0 hSsq hGuard hH =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    val q3   = rdiv twoN three3
    val Kt   = suc q3            (* Suc(2n/3) — the telescope start of the TAIL *)
    val bF   = Free("b_tv", natT)
    (* twoN < 3*(Suc(2n/3))  [two_n_lt_3_succ_div] *)
    val h2n3S = two_n_lt_3_succ_div nT     (* le (Suc 2n)(mult 3 (Suc(2n/3))) = lt 2n (mult 3 (Suc(2n/3))) *)
    (* assume le (Suc(2n/3)) b  and  prime2 b ; prove oeq (vp b R) 0 *)
    val hKb = Thm.assume (ctermV4 (jT (le Kt bF)))     (* Suc(2n/3) <= b *)
    val hpr = Thm.assume (ctermV4 (jT (prime2 bF)))    (* prime2 b *)
    (* ---- lt 2n (mult 3 b) : 2n < 3*(Suc(2n/3)) <= 3*b ---- *)
    val le3S3b = mult_le_mono_4 (three3, Kt, bF) hKb   (* le (mult 3 (Suc(2n/3)))(mult 3 b) *)
    val lt2n3b = le_trans4_at (suc twoN, mult three3 Kt, mult three3 bF) h2n3S le3S3b   (* le (Suc 2n)(mult 3 b) = lt 2n (mult 3 b) *)
    (* ---- lt 2n (mult b b) : 2n < (Suc s)^2 <= b^2  (uses guard s<=2n/3 and Suc(2n/3)<=b) ---- *)
    (* le (Suc s)(Suc(2n/3)) [guard, Suc-mono] ; le (Suc(2n/3)) b [hKb] ; trans -> le (Suc s) b *)
    val leSsKt = le_suc_mono4_at (sT, q3) hGuard       (* le (Suc s)(Suc(2n/3)) *)
    val leSsb  = le_trans4_at (suc sT, Kt, bF) leSsKt hKb   (* le (Suc s) b *)
    val leSsq_bb = mult_le_mono2_4_at (suc sT, bF, suc sT, bF) leSsb leSsb  (* le ((Suc s)*(Suc s))(b*b) *)
    val lt2nbb = le_trans4_at (suc twoN, mult (suc sT)(suc sT), mult bF bF) hSsq leSsq_bb  (* le (Suc 2n)(b*b) = lt 2n (b*b) *)
    (* ---- case split on lt n b (i.e. n < b ?) ---- *)
    (* nlt_le_4 (d,c) hneg : neg (lt d c) ==> le c d.  So:
         neg (lt n b) -> le b n  (b<=n, empty_interval window)
         neg (lt 2n b) -> le b 2n (n<b<=2n, H contradiction) *)
    val goalC = oeq (vp bF R) ZeroC
    val emN = ex_middle_4 (lt nT bF)     (* Disj (lt n b)(neg (lt n b)) *)
    (* case b <= n : neg (lt n b) -> le b n -> empty_interval *)
    val caseLeN =
      let val hnlt = Thm.assume (ctermV4 (jT (neg (lt nT bF))))   (* ~(n<b) *)
          val hben = nlt_le_4 (nT, bF) hnlt                        (* le b n *)
          val g = empty_interval_4 (bF, nT) hpr hn0 hben lt2n3b lt2nbb   (* oeq (vp b R) 0 *)
      in Thm.implies_intr (ctermV4 (jT (neg (lt nT bF)))) g end
    (* case n < b : sub-split on lt 2n b *)
    val caseGtN =
      let val hltnb = Thm.assume (ctermV4 (jT (lt nT bF)))   (* n < b *)
          val emT = ex_middle_4 (lt twoN bF)                 (* Disj (lt 2n b)(neg (lt 2n b)) *)
          (* case b > 2n : vp_zero_above *)
          val caseGt2n =
            let val hlt2nb = Thm.assume (ctermV4 (jT (lt twoN bF)))   (* 2n < b *)
                val g = vp_zero_above_4 (bF, nT) hpr hn0 hlt2nb        (* oeq (vp b R) 0 *)
            in Thm.implies_intr (ctermV4 (jT (lt twoN bF))) g end
          (* case b <= 2n : neg (lt 2n b) -> le b 2n -> H contradiction (n<b<=2n prime) *)
          val caseLe2n =
            let val hnlt2 = Thm.assume (ctermV4 (jT (neg (lt twoN bF))))   (* ~(2n<b) *)
                val hbe2n = nlt_le_4 (twoN, bF) hnlt2                        (* le b 2n *)
                val cjInner = conjI_4 (lt nT bF, le bF twoN) hltnb hbe2n   (* (lt n b /\ le b 2n) *)
                val cjFull  = conjI_4 (prime2 bF, mkConj (lt nT bF)(le bF twoN)) hpr cjInner  (* prime2 b /\ (lt n b /\ le b 2n) *)
                val exW     = exI_4 (H_abs nT, bF) cjFull              (* jT (Ex p. H_body) *)
                val ff      = mp_4 (mkEx (H_abs nT), oFalseC) hH exW   (* oFalse *)
                val g       = oFalse_elim_4 goalC OF [ff]              (* oeq (vp b R) 0 *)
            in Thm.implies_intr (ctermV4 (jT (neg (lt twoN bF)))) g end
          val g = disjE_4 (lt twoN bF, neg (lt twoN bF), goalC) emT caseGt2n caseLe2n
      in Thm.implies_intr (ctermV4 (jT (lt nT bF))) g end
    val vpzero = disjE_4 (lt nT bF, neg (lt nT bF), goalC) emN caseGtN caseLeN   (* oeq (vp b R) 0 *)
    (* package as Hvp : !!b. le (Suc(2n/3)) b ==> prime2 b ==> oeq (vp b R) 0 *)
    val body2 = Thm.implies_intr (ctermV4 (jT (le Kt bF)))
                  (Thm.implies_intr (ctermV4 (jT (prime2 bF))) vpzero)
  in Thm.forall_intr (ctermV4 bF) body2 end;

(* smoke build_Hvp_tail over Frees : gate the marker on the conclusion's shape. *)
val hvp_tail_ok =
  let val sF = Free("s_tvsm", natT) val nF = Free("n_tvsm", natT)
      val twoN = add nF nF val q3 = rdiv twoN three3 val R = binom twoN nF val Kt = suc q3
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val hSsq = Thm.assume (ctermV4 (jT (lt twoN (mult (suc sF)(suc sF)))))
      val hGuard = Thm.assume (ctermV4 (jT (le sF q3)))
      val hH = Thm.assume (ctermV4 (H_prop nF))
      val th = build_Hvp_tail (sF, nF) hn0 hSsq hGuard hH
      val bF = Free("b_tv", natT)
      val want = Logic.all bF (Logic.mk_implies (jT (le Kt bF),
                   Logic.mk_implies (jT (prime2 bF), jT (oeq (vp bF R) ZeroC))))
      val () = out ("build_Hvp_tail smoke : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n")
  in (Thm.prop_of th) aconv want end;

val () = if hvp_tail_ok then out "F6_HVP_TAIL_OK\n" else out "F6_HVP_TAIL_FAIL\n";

(* tail-vanish : cpf (Suc 2n) R = cpf (Suc(2n/3)) R.
   Telescope cpf_tele_build from Kt = Suc(2n/3) up to Suc 2n.
   add Kt jtail = Suc 2n where jtail = sub (Suc 2n) Kt, valid since Kt <= Suc 2n
   (i.e. 2n/3 <= 2n, always). *)
fun tail_vanish (sT, nT) hn0 hSsq hGuard hH =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    val q3   = rdiv twoN three3
    val Kt   = suc q3
    val Hvp  = build_Hvp_tail (sT, nT) hn0 hSsq hGuard hH   (* !!b. le Kt b ==> prime2 b ==> oeq (vp b R) 0 *)
    (* le Kt (Suc 2n) : le (2n/3)(2n) ; rdiv_le_self ? Use 2n/3 <= 2n via rdiv bound. *)
    (* le q3 twoN : rdiv 2n 3 <= 2n.  We have div_mod_eq : 2n = 3*q3 + r ; so q3 <= 3*q3 <= 2n. *)
    val le_q3_2n =
      let
        val dme = div_mod_eq_4 (twoN, three3) lt0_3   (* oeq 2n (add (mult 3 q3) r) *)
        (* q3 <= mult 3 q3 : le q3 (mult 3 q3).  mult 3 q3 = add q3 (add q3 q3)? Easier: le q3 (mult 3 q3) via le_mult?
           Use : le q3 (add (mult 3 q3) r) [le_add: le a (add a c)] composed with q3 <= mult 3 q3.
           le q3 (mult 3 q3) : mult 3 q3 = add q3 (mult 2 q3) [mult_Suc]; le q3 (add q3 X) [le_add]. *)
        val m3 = multSuc4_at (suc (suc ZeroC), q3)   (* oeq (mult 3 q3)(add q3 (mult 2 q3)) *)
        val le_q3_3q3_raw = le_add4_at (q3, mult (suc (suc ZeroC)) q3)   (* le q3 (add q3 (mult 2 q3)) *)
        val le_q3_3q3 = le_cong_r4 (q3, add q3 (mult (suc (suc ZeroC)) q3), mult three3 q3) (oeq_sym OF [m3]) le_q3_3q3_raw  (* le q3 (mult 3 q3) *)
        val r4 = rmod twoN three3
        val le_3q3_2n = le_cong_r4 (mult three3 q3, add (mult three3 q3) r4, twoN) (oeq_sym OF [dme]) (le_add4_at (mult three3 q3, r4))  (* le (mult 3 q3) 2n *)
      in le_trans4_at (q3, mult three3 q3, twoN) le_q3_3q3 le_3q3_2n end   (* le q3 2n *)
    val le_Kt_S2n = le_suc_mono4_at (q3, twoN) le_q3_2n   (* le (Suc(2n/3))(Suc 2n) *)
    val jtail = sub (suc twoN) Kt
    val addEq = le_add_sub_4 (Kt, suc twoN) le_Kt_S2n   (* oeq (add Kt jtail)(Suc 2n) *)
    val tele = cpf_tele_build (Kt, R, jtail, Hvp)   (* oeq (cpf (add Kt jtail) R)(cpf Kt R) *)
    (* rewrite (add Kt jtail) -> Suc 2n on LHS via addEq (cong on cpf first arg) *)
    val cpfRw = (let val zc = Free("ztv", natT) val Pc = Term.lambda zc (oeq (cpf (add Kt jtail) R)(cpf zc R))
                 in substPred4 (Pc, add Kt jtail, suc twoN) addEq (oeqrefl4_at (cpf (add Kt jtail) R)) end)
                (* oeq (cpf (add Kt jtail) R)(cpf (Suc 2n) R) *)
    (* tele : oeq (cpf (add Kt jtail) R)(cpf Kt R) ; cpfRw : oeq (cpf (add Kt jtail) R)(cpf (Suc 2n) R)
       want : oeq (cpf (Suc 2n) R)(cpf Kt R) = oeq (cpf (Suc 2n) R)(cpf (Suc(2n/3)) R) *)
    val g = oeq_trans OF [oeq_sym OF [cpfRw], tele]   (* oeq (cpf (Suc 2n) R)(cpf (Suc(2n/3)) R) *)
  in g end;

(* smoke tail_vanish over Frees : gate the marker on the conclusion's shape.
   want : oeq (cpf (Suc 2n) R)(cpf (Suc(2n/3)) R) *)
val tail_vanish_ok =
  let val sF = Free("s_tv2", natT) val nF = Free("n_tv2", natT)
      val twoN = add nF nF val q3 = rdiv twoN three3 val R = binom twoN nF
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val hSsq = Thm.assume (ctermV4 (jT (lt twoN (mult (suc sF)(suc sF)))))
      val hGuard = Thm.assume (ctermV4 (jT (le sF q3)))
      val hH = Thm.assume (ctermV4 (H_prop nF))
      val th = tail_vanish (sF, nF) hn0 hSsq hGuard hH
      val want = jT (oeq (cpf (suc twoN) R)(cpf (suc q3) R))
      val () = out ("tail_vanish smoke : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n")
  in (Thm.prop_of th) aconv want end;

val () = if tail_vanish_ok then out "TAIL_VANISH_OK\n" else out "TAIL_VANISH_FAIL\n";

(* ----------------------------------------------------------------------------
   (UT) UPPER TELESCOPE TO 2n/3.
     cpf (Suc(2n/3)) R <= mult (cpf (Suc s) R)(pow 4 (2n/3))
   Mirror of the cb_prodbound upper-telescope, stopping at Suc(2n/3) instead of
   Suc 2n.  Uses cpf_upper_tele (Hsq) telescoped from Suc s up to Suc(2n/3),
   giving primorial(2n/3); then primorial_bound : primorial(2n/3) <= 4^(2n/3).
   Requires hn0, the floor witness s + hSsq, and the guard le s (2n/3).
   ---------------------------------------------------------------------------- *)
fun upper_tele_23 (sT, nT) hn0 hSsq hGuard =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    val q3   = rdiv twoN three3
    val K    = suc sT
    (* Hsq : !!b. le (Suc s) b ==> prime2 b ==> le (pow b (vp b R)) b *)
    val Hsq  = build_Hsq (sT, nT) hn0 hSsq
    (* le (Suc s)(Suc(2n/3)) [guard, Suc-mono] *)
    val le_K_Sq3 = le_suc_mono4_at (sT, q3) hGuard   (* le (Suc s)(Suc(2n/3)) *)
    (* jVal = sub (Suc(2n/3))(Suc s) ; add (Suc s) jVal = Suc(2n/3) *)
    val jVal = sub (suc q3) K
    val addEq = le_add_sub_4 (K, suc q3) le_K_Sq3   (* oeq (add (Suc s) jVal)(Suc(2n/3)) *)
    val ui = cpf_upper_tele (jVal, sT, nT) Hsq   (* le (cpf (add K jVal) R)(mult (cpf K R)(primorial (add s jVal))) *)
    (* rewrite (add K jVal) -> Suc(2n/3) on LHS via addEq *)
    val cpfRw = (let val zc = Free("zut", natT) val Pc = Term.lambda zc (oeq (cpf (add K jVal) R)(cpf zc R))
                 in substPred4 (Pc, add K jVal, suc q3) addEq (oeqrefl4_at (cpf (add K jVal) R)) end)
                (* oeq (cpf (add K jVal) R)(cpf (Suc(2n/3)) R) *)
    val ui2 = le_cong_l4 (cpf (add K jVal) R, cpf (suc q3) R, mult (cpf K R)(primorial (add sT jVal))) cpfRw ui
              (* le (cpf (Suc(2n/3)) R)(mult (cpf K R)(primorial (add s jVal))) *)
    (* add s jVal = 2n/3 : from addEq (add (Suc s) jVal = Suc(2n/3)) and add_Suc (= Suc(add s jVal)) -> Suc inj *)
    val aSk_j = add_Suc_at4 (sT, jVal)   (* oeq (add (Suc s) jVal)(Suc(add s jVal)) *)
    val sucEq = oeq_trans OF [oeq_sym OF [aSk_j], addEq]   (* oeq (Suc(add s jVal))(Suc(2n/3)) *)
    val addsj_q3 = Suc_inj4 (add sT jVal, q3) sucEq    (* oeq (add s jVal)(2n/3) *)
    val primRw = (let val zp = Free("zputp", natT) val Pp = Term.lambda zp (oeq (primorial (add sT jVal))(primorial zp))
                  in substPred4 (Pp, add sT jVal, q3) addsj_q3 (oeqrefl4_at (primorial (add sT jVal))) end)
                 (* oeq (primorial (add s jVal))(primorial (2n/3)) *)
    val ui3 = le_cong_r4 (cpf (suc q3) R, mult (cpf K R)(primorial (add sT jVal)), mult (cpf K R)(primorial q3))
                (mult_cong_r4 (cpf K R, primorial (add sT jVal), primorial q3) primRw) ui2
              (* le (cpf (Suc(2n/3)) R)(mult (cpf K R)(primorial (2n/3))) *)
    (* cpf K R = cpf (Suc s) R <= (2n)^(Suc s) [LO] *)
    val loK = cpf_pow_bound (K, nT) hn0   (* le (cpf K R)(pow (2n) K) *)
    (* primorial (2n/3) <= 4^(2n/3) [primorial_bound] *)
    val pb = primorial_bound_4 q3   (* le (primorial (2n/3))(pow 4 (2n/3)) *)
    val mlm = mult_le_mono2_4_at (cpf K R, pow twoN K, primorial q3, pow fourC4 q3) loK pb
              (* le (mult (cpf K R)(primorial (2n/3)))(mult (pow 2n K)(pow 4 (2n/3))) *)
    val g = le_trans4_at (cpf (suc q3) R, mult (cpf K R)(primorial q3), mult (pow twoN K)(pow fourC4 q3)) ui3 mlm
            (* le (cpf (Suc(2n/3)) R)(mult (pow 2n (Suc s))(pow 4 (2n/3))) *)
  in g end;

(* smoke upper_tele_23 over Frees : gate the marker on the conclusion's shape.
   want : le (cpf (Suc(2n/3)) R)(mult (pow 2n (Suc s))(pow 4 (2n/3))) *)
val upper_tele_23_ok =
  let val sF = Free("s_ut2", natT) val nF = Free("n_ut2", natT)
      val twoN = add nF nF val q3 = rdiv twoN three3 val R = binom twoN nF
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val hSsq = Thm.assume (ctermV4 (jT (lt twoN (mult (suc sF)(suc sF)))))
      val hGuard = Thm.assume (ctermV4 (jT (le sF q3)))
      val th = upper_tele_23 (sF, nF) hn0 hSsq hGuard
      val want = jT (le (cpf (suc q3) R)(mult (pow twoN (suc sF))(pow fourC4 q3)))
      val () = out ("upper_tele_23 smoke : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n")
  in (Thm.prop_of th) aconv want end;

val () = if upper_tele_23_ok then out "UPPER_TELE_23_OK\n" else out "UPPER_TELE_23_FAIL\n";

(* ----------------------------------------------------------------------------
   (CR) cb_refined.
     lt 0 n ==> lt 0 R ==> H ==>
       Ex s. (le (s*s) 2n /\ lt 2n ((Suc s)^2))
             /\ (le s (rdiv 2n 3) ==> le R (mult (pow 2n (Suc s))(pow 4 (rdiv 2n 3))))
   ---------------------------------------------------------------------------- *)
val () = out "F6_CR_BEGIN\n";

val cb_refined =
  let
    val nF = Free("n_cr", natT)
    val twoN = add nF nF
    val R = binom twoN nF
    val q3 = rdiv twoN three3
    val hn0  = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
    val hcb0 = Thm.assume (ctermV4 (jT (lt ZeroC R)))
    val hH   = Thm.assume (ctermV4 (H_prop nF))
    (* floor_sqrt at 2n *)
    val fs = beta_norm (Drule.infer_instantiate ctxtV4 [(("N_fs",0), ctermV4 twoN)] floor_sqrt)
    val fsBodyAbs = Term.lambda (Free("s",natT))
        (mkConj (le (mult (Free("s",natT))(Free("s",natT))) twoN)
                (lt twoN (mult (suc (Free("s",natT)))(suc (Free("s",natT))))))
    (* refined existential conclusion body *)
    fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                            (mkImp (le sT q3) (le R (mult (pow twoN (suc sT))(pow fourC4 q3))))
    val outAbs = Term.lambda (Free("s_out", natT)) (outBody (Free("s_out", natT)))
    val goalC = mkEx outAbs
    fun body sF (hs : thm) =     (* hs : le (s*s)(2n) /\ lt (2n)((Suc s)^2) *)
      let
        val sq  = mult sF sF
        val sqS = mult (suc sF)(suc sF)
        val hSqle = conjunct1_4 (le sq twoN, lt twoN sqS) hs   (* le (s*s)(2n) *)
        val hSsq  = conjunct2_4 (le sq twoN, lt twoN sqS) hs   (* lt (2n)((Suc s)^2) *)
        (* the conditional bound : assume guard le s (2n/3), produce le R (...) *)
        val condBody =
          let
            val hGuard = Thm.assume (ctermV4 (jT (le sF q3)))   (* le s (2n/3) *)
            (* C = cpf (Suc 2n) R via cpf_binom_2n *)
            val le2ncb = le_2n_cb nF hn0                          (* le 2n R *)
            val leS2ncb = le_suc_mono4_at (twoN, R) le2ncb        (* le (Suc 2n)(Suc R) *)
            val cbEq = cpf_binom_2n_4 nF hn0 hcb0 leS2ncb         (* oeq R (cpf (Suc 2n) R) *)
            (* TAIL : oeq (cpf (Suc 2n) R)(cpf (Suc(2n/3)) R) *)
            val tv = tail_vanish (sF, nF) hn0 hSsq hGuard hH      (* oeq (cpf (Suc 2n) R)(cpf (Suc(2n/3)) R) *)
            (* R = cpf (Suc 2n) R = cpf (Suc(2n/3)) R *)
            val Req = oeq_trans OF [cbEq, tv]                     (* oeq R (cpf (Suc(2n/3)) R) *)
            (* UPPER TELE : le (cpf (Suc(2n/3)) R)(mult (pow 2n (Suc s))(pow 4 (2n/3))) *)
            val ut = upper_tele_23 (sF, nF) hn0 hSsq hGuard       (* le (cpf (Suc(2n/3)) R)(...) *)
            (* le R (...) : rewrite ut's LHS cpf(Suc(2n/3)) R -> R via Req sym *)
            val g = le_cong_l4 (cpf (suc q3) R, R, mult (pow twoN (suc sF))(pow fourC4 q3)) (oeq_sym OF [Req]) ut
                    (* le R (mult (pow 2n (Suc s))(pow 4 (2n/3))) *)
          in Thm.implies_intr (ctermV4 (jT (le sF q3))) g end   (* le s (2n/3) ==> le R (...) *)
        val condImp = impI_4 (le sF q3, le R (mult (pow twoN (suc sF))(pow fourC4 q3))) condBody   (* jT (Imp (le s q3)(le R ...)) *)
        (* package existential body : conj of hs and condImp *)
        val cjInner = conjI_4 (le sq twoN, lt twoN sqS) hSqle hSsq
        val cjFull  = conjI_4 (mkConj (le sq twoN)(lt twoN sqS),
                               mkImp (le sF q3)(le R (mult (pow twoN (suc sF))(pow fourC4 q3))))
                              cjInner condImp
        val ex = exI_4 (outAbs, sF) cjFull
      in ex end
    val concl = exE_elim4 (fsBodyAbs, goalC) fs "s_cr" body
    val d3 = Thm.implies_intr (ctermV4 (H_prop nF)) concl
    val d2 = Thm.implies_intr (ctermV4 (jT (lt ZeroC R))) d3
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) d2
  in varify d1 end;

val () = out ("cb_refined 0hyp=" ^ Bool.toString (zhV4 cb_refined) ^ "\n");
val () = out ("cb_refined : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of cb_refined) ^ "\n");

(* aconv check : the intended interface *)
val i_cb_refined =
  let val nVz = Var(("n_cr",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz val q3 = rdiv twoN three3
      fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                              (mkImp (le sT q3) (le R (mult (pow twoN (suc sT))(pow fourC4 q3))))
  in Logic.mk_implies (jT (lt ZeroC nVz),
       Logic.mk_implies (jT (lt ZeroC R),
         Logic.mk_implies (H_prop nVz,
           jT (mkEx (Term.lambda (Free("s_out",natT)) (outBody (Free("s_out",natT)))))))) end;
val r_cr = (Thm.prop_of cb_refined) aconv i_cb_refined;
val () = out ("cb_refined aconv=" ^ Bool.toString r_cr ^ "\n");
val () = if zhV4 cb_refined andalso r_cr then out "CB_REFINED_OK\n" else out "CB_REFINED_FAIL\n";

(* soundness probe : the exponent on 4 must be 2n/3 (rdiv 2n 3), NOT 2n.
   Replacing q3 by twoN must NOT be aconv. *)
val s_cr_23 =
  let val nVz = Var(("n_cr",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz val q3 = rdiv twoN three3
      fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                              (mkImp (le sT q3) (le R (mult (pow twoN (suc sT))(pow fourC4 twoN))))  (* 4^(2n) — wrong *)
      val bad = Logic.mk_implies (jT (lt ZeroC nVz),
                  Logic.mk_implies (jT (lt ZeroC R),
                    Logic.mk_implies (H_prop nVz,
                      jT (mkEx (Term.lambda (Free("s_out",natT)) (outBody (Free("s_out",natT))))))))
  in not ((Thm.prop_of cb_refined) aconv bad) end;
val () = out ("PROBE cb_refined-exponent-is-2n/3=" ^ Bool.toString s_cr_23 ^ "\n");

(* soundness probe : the refined bound is GUARDED by le s (2n/3) (the N0 condition).
   An UNCONDITIONAL bound (dropping the guard premise) must NOT be aconv. *)
val s_cr_guard =
  let val nVz = Var(("n_cr",0),natT)
      val twoN = add nVz nVz val R = binom twoN nVz val q3 = rdiv twoN three3
      fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                              (le R (mult (pow twoN (suc sT))(pow fourC4 q3)))  (* no guard premise — unsound *)
      val bad = Logic.mk_implies (jT (lt ZeroC nVz),
                  Logic.mk_implies (jT (lt ZeroC R),
                    Logic.mk_implies (H_prop nVz,
                      jT (mkEx (Term.lambda (Free("s_out",natT)) (outBody (Free("s_out",natT))))))))
  in not ((Thm.prop_of cb_refined) aconv bad) end;
val () = out ("PROBE cb_refined-keeps-N0-guard=" ^ Bool.toString s_cr_guard ^ "\n");

