(* exE on ctxtPr *)
fun exE_elimPr (Pabs, goalC) exThm wName bodyFn =
  let
    val wF = Free(wName, natT)
    val hypTerm = jT (Term.betapply (Pabs, wF))
    val hypThm  = Thm.assume (ctermPr hypTerm)
    val body    = bodyFn wF hypThm
    val minor   = Thm.forall_intr (ctermPr wF) (Thm.implies_intr (ctermPr hypTerm) body)
    val inst    = beta_norm (Drule.infer_instantiate ctxtPr
                    [(("P",0), ctermPr Pabs),(("Q",0), ctermPr goalC)] exE_vPr)
  in Thm.implies_elim (Thm.implies_elim inst exThm) minor end;

