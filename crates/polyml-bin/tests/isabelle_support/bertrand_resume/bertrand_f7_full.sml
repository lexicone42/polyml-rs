    val aeq = addSr3_at (nt, ZeroC);
    val a0  = add0r3_at nt;
    val s   = Suc_cong OF [a0];
    val rhs = oeq_trans OF [aeq, s];
    val eqn = oeq_sym OF [rhs];
  in le_intro3 (nt, suc nt, suc ZeroC) eqn end;

