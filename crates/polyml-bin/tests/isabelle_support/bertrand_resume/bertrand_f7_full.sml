(* ============================================================================
   BERTRAND F5 — delta 5 : the UPPER telescope UI2.
     Hsq : !!b. le (Suc s) b ==> prime2 b ==> le (pow b (vp b R)) b
   ==>  le (cpf (add (Suc s) j) R) (mult (cpf (Suc s) R)(primorial (add s j))).
   nat_induct on j.
   ============================================================================ *)
val () = out "F5_D5_BEGIN\n";

(* cpf_upper_tele (jT_, sT, nT) Hsq : returns the bound at top index j. *)
fun cpf_upper_tele (jVal, sT, nT) Hsq =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    val K    = suc sT                (* Suc s *)
    val cpfK = cpf K R
    val zj = Free("z_ut", natT)
    val Pabs = Term.lambda zj (le (cpf (add K zj) R)(mult cpfK (primorial (add sT zj))))
    val ind = nat_induct_4 (Pabs, jVal)
    (* base j=0 : cpf (add K 0) R = cpf K R ; primorial (add s 0) = primorial s ;
       want le (cpf K R)(mult (cpf K R)(primorial s)).  Need le (cpf K R)(mult (cpf K R)(primorial s)).
       primorial s >= 1, so mult (cpf K R)(primorial s) >= cpf K R * 1 = cpf K R.
       le (cpf K R)(mult (cpf K R)(primorial s)) :
         cpf K R = mult (cpf K R) 1 [mult1r sym]; le (mult (cpf K R) 1)(mult (cpf K R)(primorial s))
         by mult_le_mono (le 1 (primorial s)). *)
    val base =
      let
        val a0  = add0r4_at K            (* oeq (add K 0) K *)
        val a0s = add0r4_at sT           (* oeq (add s 0) s *)
        val prpos = primorial_pos_4 sT   (* le 1 (primorial s) *)
        (* le cpfK (mult cpfK (primorial s)) : cpfK = mult cpfK 1 <= mult cpfK (primorial s) *)
        val mlm = mult_le_mono_4 (cpfK, suc ZeroC, primorial sT) prpos  (* le (mult cpfK 1)(mult cpfK (primorial s)) *)
        val m1r = mult1r4_at cpfK        (* oeq (mult cpfK 1) cpfK *)
        val le1 = le_cong_l4 (mult cpfK (suc ZeroC), cpfK, mult cpfK (primorial sT)) m1r mlm  (* le cpfK (mult cpfK (primorial s)) *)
        (* use le_cong_l4 with hpq : oeq cpfK (cpf (add K 0) R).  cpf (add K 0) R = cpfK via a0 (cong first arg). *)
        val cpfA0 = (let val zc = Free("zc0", natT) val Pc = Term.lambda zc (oeq cpfK (cpf zc R))
                     in substPred4 (Pc, K, add K ZeroC) (oeq_sym OF [a0]) (oeqrefl4_at cpfK) end)
                    (* oeq cpfK (cpf (add K 0) R) *)
        val le3 = le_cong_l4 (cpfK, cpf (add K ZeroC) R, mult cpfK (primorial sT)) cpfA0 le1
                  (* le (cpf (add K 0) R)(mult cpfK (primorial s)) *)
        (* rewrite RHS primorial s -> primorial (add s 0) : need oeq (primorial s)(primorial (add s 0)) = a0s sym (cong) *)
        val primEq = (let val zp=Free("zp0",natT) val Pp = Term.lambda zp (oeq (primorial sT)(primorial zp))
                      in substPred4 (Pp, sT, add sT ZeroC)(oeq_sym OF [a0s])(oeqrefl4_at (primorial sT)) end)
                     (* oeq (primorial s)(primorial (add s 0)) *)
        val le4 = le_cong_r4 (cpf (add K ZeroC) R, mult cpfK (primorial sT), mult cpfK (primorial (add sT ZeroC)))
                    (mult_cong_r4 (cpfK, primorial sT, primorial (add sT ZeroC)) primEq) le3
      in le4 end
    val xF = Free("x_ut", natT)
    val ihP = jT (le (cpf (add K xF) R)(mult cpfK (primorial (add sT xF))))
    val IH = Thm.assume (ctermV4 ihP)
    val b   = add K xF             (* the new index : b = add (Suc s) x = Suc(add s x) *)
    val goalStep = le (cpf (add K (suc xF)) R)(mult cpfK (primorial (add sT (suc xF))))
    (* add K (Suc x) = Suc (add K x) = Suc b *)
    val aSr = add_Sr4_at (K, xF)   (* oeq (add K (Suc x))(Suc (add K x)) = oeq (add K (Suc x))(Suc b) *)
    (* add s (Suc x) = Suc (add s x) ; and Suc(add s x) = add (Suc s) x = b  [add_Suc] *)
    val aSs = add_Sr4_at (sT, xF)  (* oeq (add s (Suc x))(Suc (add s x)) *)
    val aSk = add_Suc_at4 (sT, xF) (* oeq (add (Suc s) x)(Suc (add s x)) *) (* = oeq b (Suc(add s x)) *)
    (* so primorial (add s (Suc x)) = primorial (Suc (add s x)) = primorial b' where Suc(add s x)=b *)
    val em = ex_middle_4 (prime2 b)
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 b)))
          (* cpf (Suc b) R = cpf b R * pow b (vp b R) ; but cpf (add K (Suc x)) = cpf (Suc b) via aSr *)
          val L0 = cpf_sp_at (b, R) hpr   (* oeq (cpf (Suc b) R)(mult (cpf b R)(pow b (vp b R))) *)
          (* factor bound : pow b (vp b R) <= b  via Hsq at b *)
          val le_Ks_b = le_add4_at (K, xF)   (* le K b = le (Suc s) b *)
          val hfac = Thm.implies_elim (Thm.implies_elim (Thm.forall_elim (ctermV4 b) Hsq) le_Ks_b) hpr
                     (* le (pow b (vp b R)) b *)
          (* cpf b R = cpf (add K x) R [b = add K x] ; IH : le (cpf (add K x) R)(mult cpfK (primorial (add s x))) *)
          (* product : le (mult (cpf b R)(pow b (vp b R)))(mult (mult cpfK (primorial (add s x))) b) *)
          val mlm = mult_le_mono2_4_at (cpf b R, mult cpfK (primorial (add sT xF)), pow b (vp b R), b) IH hfac
                    (* le (mult (cpf b R)(pow b (vp b R)))(mult (mult cpfK (primorial (add s x))) b) *)
          (* LHS rewrite : mult (cpf b R)(pow b (vp b R)) = cpf (Suc b) R [L0 sym] = cpf (add K (Suc x)) R [aSr sym] *)
          val lhs1 = le_cong_l4 (mult (cpf b R)(pow b (vp b R)), cpf (suc b) R, mult (mult cpfK (primorial (add sT xF))) b) (oeq_sym OF [L0]) mlm
          (* cpf (Suc b) R = cpf (add K (Suc x)) R : cong on first arg, oeq (Suc b)(add K (Suc x)) = aSr sym *)
          val cpfSb_eq = (let val zcs = Free("zcs", natT) val Pcs = Term.lambda zcs (oeq (cpf (suc b) R)(cpf zcs R))
                          in substPred4 (Pcs, suc b, add K (suc xF)) (oeq_sym OF [aSr]) (oeqrefl4_at (cpf (suc b) R)) end)
                         (* oeq (cpf (Suc b) R)(cpf (add K (Suc x)) R) *)
          val lhs2 = le_cong_l4 (cpf (suc b) R, cpf (add K (suc xF)) R, mult (mult cpfK (primorial (add sT xF))) b) cpfSb_eq lhs1
                     (* le (cpf (add K (Suc x)) R)(mult (mult cpfK (primorial (add s x))) b) *)
          (* RHS : mult (mult cpfK (primorial (add s x))) b
                 = mult cpfK (mult (primorial (add s x)) b) [assoc]
                 = mult cpfK (mult b (primorial (add s x))) [comm inner]
                 = mult cpfK (primorial (Suc(add s x))) [primorial_Sp at (add s x) : prime2 (Suc(add s x))=prime2 b]
                 = mult cpfK (primorial (add s (Suc x))) [aSs sym] *)
          val rAssoc = multassoc4_at (cpfK, primorial (add sT xF), b)  (* oeq (mult (mult cpfK (primorial (add s x))) b)(mult cpfK (mult (primorial (add s x)) b)) *)
          val rComm  = mult_cong_r4 (cpfK, mult (primorial (add sT xF)) b, mult b (primorial (add sT xF))) (multcomm4_at (primorial (add sT xF), b))
                       (* oeq (mult cpfK (mult (primorial (add s x)) b))(mult cpfK (mult b (primorial (add s x)))) *)
          (* primorial_Sp at (add s x) needs prime2 (Suc(add s x)). Suc(add s x) = b [aSk sym]. *)
          val hpr_idx = (let val zpr = Free("zpr", natT) val Ppr = Term.lambda zpr (prime2 zpr)
                         in substPred4 (Ppr, b, suc (add sT xF)) aSk hpr end)  (* prime2 (Suc(add s x)) *)
          val pSp = primorial_Sp_4 (add sT xF) hpr_idx   (* oeq (primorial (Suc(add s x)))(mult (Suc(add s x))(primorial (add s x))) *)
          (* mult (Suc(add s x))(primorial (add s x)) ; Suc(add s x) = b. rewrite to mult b (primorial (add s x)) *)
          val pSp_b = (let val zb = Free("zpb", natT) val Pb = Term.lambda zb (oeq (primorial (suc (add sT xF)))(mult zb (primorial (add sT xF))))
                       in substPred4 (Pb, suc (add sT xF), b) (oeq_sym OF [aSk]) pSp end)
                      (* oeq (primorial (Suc(add s x)))(mult b (primorial (add s x))) *)
          (* mult b (primorial(add s x)) =[pSp_b sym] primorial(Suc(add s x)) =[primorial-cong of aSs sym] primorial(add s (Suc x)) *)
          val primorial_cong_aSs = (let val zpc = Free("zpc", natT) val Ppc = Term.lambda zpc (oeq (primorial (suc (add sT xF)))(primorial zpc))
                                    in substPred4 (Ppc, suc (add sT xF), add sT (suc xF)) (oeq_sym OF [aSs]) (oeqrefl4_at (primorial (suc (add sT xF)))) end)
                                   (* oeq (primorial(Suc(add s x)))(primorial(add s (Suc x))) *)
          val rPrim = oeq_trans OF [oeq_sym OF [pSp_b], primorial_cong_aSs]  (* oeq (mult b (primorial (add s x)))(primorial (add s (Suc x))) *)
          (* RHS chain : mult (mult cpfK (primorial (add s x))) b = mult cpfK (mult b (primorial (add s x))) = mult cpfK (primorial (add s (Suc x))) *)
          val rChain = oeq_trans OF [rAssoc, oeq_trans OF [rComm, mult_cong_r4 (cpfK, mult b (primorial (add sT xF)), primorial (add sT (suc xF))) rPrim]]
                       (* oeq (mult (mult cpfK (primorial (add s x))) b)(mult cpfK (primorial (add s (Suc x)))) *)
          val g = le_cong_r4 (cpf (add K (suc xF)) R, mult (mult cpfK (primorial (add sT xF))) b, mult cpfK (primorial (add sT (suc xF)))) rChain lhs2
      in Thm.implies_intr (ctermV4 (jT (prime2 b))) g end
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 b))))
          val L0 = cpf_sn_at (b, R) hnp   (* oeq (cpf (Suc b) R)(cpf b R) *)
          (* cpf (add K (Suc x)) R = cpf (Suc b) R [aSr] = cpf b R [L0] = cpf (add K x) R *)
          val cpfEq = oeq_trans OF [ (let val zc=Free("zcn",natT) val Pc=Term.lambda zc (oeq (cpf (add K (suc xF)) R)(cpf zc R)) in substPred4 (Pc, add K (suc xF), suc b) aSr (oeqrefl4_at (cpf (add K (suc xF)) R)) end), L0 ]
                      (* oeq (cpf (add K (Suc x)) R)(cpf b R) ; b = add K x *)
          (* IH : le (cpf (add K x) R)(mult cpfK (primorial (add s x))) ; b = add K x so cpf b R = cpf (add K x) R *)
          (* primorial (add s (Suc x)) = primorial (Suc(add s x)) = primorial (add s x) [nonprime b => primorial_Sn] *)
          val hnp_idx = (let val znp=Free("znp",natT) val Pnp=Term.lambda znp (neg (prime2 znp))
                         in substPred4 (Pnp, b, suc (add sT xF)) aSk hnp end)  (* neg(prime2 (Suc(add s x))) *)
          val pSn = primorial_Sn_4 (add sT xF) hnp_idx  (* oeq (primorial (Suc(add s x)))(primorial (add s x)) *)
          (* primorial(add s (Suc x)) =[primorial-cong aSs] primorial(Suc(add s x)) =[pSn] primorial(add s x) *)
          val primorial_cong_aSs2 = (let val zpc=Free("zpc2",natT) val Ppc=Term.lambda zpc (oeq (primorial (add sT (suc xF)))(primorial zpc))
                                     in substPred4 (Ppc, add sT (suc xF), suc (add sT xF)) aSs (oeqrefl4_at (primorial (add sT (suc xF)))) end)
                                    (* oeq (primorial(add s (Suc x)))(primorial(Suc(add s x))) *)
          val primEq = oeq_trans OF [primorial_cong_aSs2, pSn]   (* oeq (primorial (add s (Suc x)))(primorial (add s x)) *)
          (* RHS rewrite IH's RHS primorial (add s x) -> primorial (add s (Suc x)) [primEq sym] *)
          val ih2 = le_cong_r4 (cpf (add K xF) R, mult cpfK (primorial (add sT xF)), mult cpfK (primorial (add sT (suc xF)))) (mult_cong_r4 (cpfK, primorial (add sT xF), primorial (add sT (suc xF))) (oeq_sym OF [primEq])) IH
                    (* le (cpf (add K x) R)(mult cpfK (primorial (add s (Suc x)))) *)
          (* LHS : cpf (add K (Suc x)) R = cpf b R = cpf (add K x) R. rewrite ih2's LHS (add K x) -> (add K (Suc x)) via cpfEq sym *)
          val g = le_cong_l4 (cpf (add K xF) R, cpf (add K (suc xF)) R, mult cpfK (primorial (add sT (suc xF)))) (oeq_sym OF [cpfEq]) ih2
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 b)))) g end
    val stepC = disjE_4 (prime2 b, neg (prime2 b), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

