(* ---- ground instantiators on ctxtV (mirroring the ctxtPr patterns) ---- *)
fun oeqreflV_at t      = beta_norm (Drule.infer_instantiate ctxtV [(("a",0), ctermV t)] oeq_refl_vV);
fun substPredV (Pabs, aT, bT) hab hPa =
