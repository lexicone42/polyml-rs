(* at-helpers *)
fun vp_le_4 (pt,nt) hPr hn0 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0),ctermV4 pt),(("n",0),ctermV4 nt)] vp_le_v4)
  in (inst OF [hPr]) OF [hn0] end;
fun sqrt_split_4 (pt,nt) hPr hn0 hsq =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0),ctermV4 pt),(("n",0),ctermV4 nt)] sqrt_split_v4)
  in ((inst OF [hPr]) OF [hn0]) OF [hsq] end;
fun empty_interval_4 (pt,nt) hPr hn0 hle h3p hsq =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0),ctermV4 pt),(("n",0),ctermV4 nt)] empty_interval_v4)
  in ((((inst OF [hPr]) OF [hn0]) OF [hle]) OF [h3p]) OF [hsq] end;
fun cb_upper_4 nt = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 nt)] cb_upper_v4);
fun cb_lower_4 nt = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 nt)] cb_lower_v4);
