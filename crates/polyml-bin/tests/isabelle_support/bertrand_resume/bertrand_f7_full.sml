(* ============================================================================
   BONUS (non-destructive; appended after the bank gate):
   FLOOR-STEP lemma rdiv_step_ndvd : lt 0 p ==> ~(dvd p (Suc n)) ==>
        oeq (rdiv (Suc n) p)(rdiv n p)
   The remainder just increments and stays < p, so the quotient is unchanged.
   Proof by div_mod_unique against the two div-mod representations of Suc n.
   ============================================================================ *)
val () = out "RDIV_STEP_NDVD_BEGIN\n";
val rdiv_step_ndvd =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hpos = Thm.assume (ctermV (jT (lt ZeroC pF)))         (* lt 0 p *)
    val hnd  = Thm.assume (ctermV (jT (neg (dvd pF (suc nF))))) (* ~(dvd p (Suc n)) *)
    val q  = rdiv nF pF;   val r  = rmod nF pF;
    val qS = rdiv (suc nF) pF;  val rS = rmod (suc nF) pF;
    val eqn = div_mod_eq_atV (nF, pF) hpos      (* oeq n (add (mult p q) r) *)
    val rlt = rmod_lt_atV (nF, pF) hpos         (* lt r p = le (Suc r) p *)
    val eqSn = div_mod_eq_atV (suc nF, pF) hpos (* oeq (Suc n)(add (mult p qS) rS) *)
    val rSlt = rmod_lt_atV (suc nF, pF) hpos    (* lt rS p *)
    (* Suc n = p*q + Suc r :  Suc n = Suc(p*q + r) [Suc_cong eqn] = (p*q) + Suc r [add_Suc_right sym] *)
    val sucEqn = Suc_cong OF [eqn]              (* oeq (Suc n)(Suc(add (mult p q) r)) *)
    val asr = addSrV_at (mult pF q, r)         (* oeq (add (mult p q)(Suc r))(Suc(add (mult p q) r)) *)
    val SnRep = oeq_trans OF [sucEqn, oeq_sym OF [asr]]   (* oeq (Suc n)(add (mult p q)(Suc r)) *)
    (* le_cases on le (Suc r) p (= rlt) : Disj (lt (Suc r) p)(oeq (Suc r) p) *)
    val dc = le_cases_atV (suc r, pF) rlt       (* Disj (lt (Suc r) p)(oeq (Suc r) p) *)
    val goalC = oeq qS q
    (* CASE oeq (Suc r) p : Suc n = p*q + Suc r = p*q + p = p*(Suc q) -> dvd p (Suc n) -> contra *)
    val caseEq =
      let val heq = Thm.assume (ctermV (jT (oeq (suc r) pF)))   (* oeq (Suc r) p *)
          (* Suc n = (p*q) + Suc r [SnRep] ; rewrite Suc r -> p [heq] : = (p*q)+p *)
          val step1 = (let val zF = Free("zse",natT)
                           val Pb = Term.lambda zF (oeq (suc nF)(add (mult pF q) zF))
                       in substPredV (Pb, suc r, pF) heq SnRep end);   (* oeq (Suc n)(add (mult p q) p) *)
          (* (p*q)+p = p*(Suc q) [mult_Suc_right sym] *)
          val msr = multSrV_at (pF, q)          (* oeq (mult p (Suc q))(add p (mult p q)) *)
          (* add p (mult p q) = add (mult p q) p [comm] *)
          val msr2 = oeq_trans OF [msr, addcommV_at (pF, mult pF q)]   (* oeq (mult p (Suc q))(add (mult p q) p) *)
          val step2 = oeq_trans OF [step1, oeq_sym OF [msr2]]   (* oeq (Suc n)(mult p (Suc q)) *)
          val ddvd = dvd_introV (pF, suc nF, suc q) step2        (* dvd p (Suc n) *)
          val ff = mp_V (dvd pF (suc nF), oFalseC) hnd ddvd       (* oFalse *)
          val g = Thm.implies_elim (oFalse_elim_V goalC) ff
      in Thm.implies_intr (ctermV (jT (oeq (suc r) pF))) g end;
    (* CASE lt (Suc r) p : div_mod_unique : Suc n = p*q + Suc r (rep1), Suc n = p*qS + rS (rep2) *)
    val caseLt =
      let val hlt = Thm.assume (ctermV (jT (lt (suc r) pF)))   (* lt (Suc r) p *)
          (* EQ : (p*qS)+rS = (p*q)+(Suc r)  : from eqSn (sym) trans SnRep *)
          val EQ = oeq_trans OF [oeq_sym OF [eqSn], SnRep]   (* oeq (add (mult p qS) rS)(add (mult p q)(Suc r)) *)
          (* div_mod_unique_atV (q1,q2,r1,r2,b) hEQ hLT1 hLT2 : Conj (oeq q1 q2)(oeq r1 r2)
             with hEQ : (b*q1+r1)=(b*q2+r2) ; need q1=qS,r1=rS,q2=q,r2=Suc r,b=p *)
          val uniq = div_mod_unique_atV (qS, q, rS, suc r, pF) EQ rSlt hlt;  (* Conj (oeq qS q)(oeq rS (Suc r)) *)
          val g = conjunct1_V (oeq qS q, oeq rS (suc r)) uniq;   (* oeq qS q *)
      in Thm.implies_intr (ctermV (jT (lt (suc r) pF))) g end;
    val body = disjE_elimV (lt (suc r) pF, oeq (suc r) pF, goalC) dc caseLt caseEq;
    val d1 = Thm.implies_intr (ctermV (jT (neg (dvd pF (suc nF))))) body
    val d2 = Thm.implies_intr (ctermV (jT (lt ZeroC pF))) d1
  in varify d2 end;
val () = out ("rdiv_step_ndvd 0hyp=" ^ Bool.toString (zhV rdiv_step_ndvd) ^ "\n");
val i_rdiv_step_ndvd =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (lt ZeroC pVz),
       Logic.mk_implies (jT (neg (dvd pVz (suc nVz))),
         jT (oeq (rdiv (suc nVz) pVz)(rdiv nVz pVz)))) end;
val r_rsn = (Thm.prop_of rdiv_step_ndvd) aconv i_rdiv_step_ndvd;
val () = out ("rdiv_step_ndvd aconv=" ^ Bool.toString r_rsn ^ "\n");
val () = if zhV rdiv_step_ndvd andalso r_rsn then out "RDIV_STEP_NDVD_OK\n" else out "RDIV_STEP_NDVD_FAIL\n";
val () = out "RDIV_STEP_NDVD_DONE\n";

(* ============================================================================
   BONUS (non-destructive): FLOOR-STEP companion
   rdiv_step_dvd : lt 0 p ==> dvd p (Suc n) ==> oeq (rdiv (Suc n) p)(Suc (rdiv n p))
   The quotient increments by one across a multiple boundary.
   ============================================================================ *)
val () = out "RDIV_STEP_DVD_BEGIN\n";
val rdiv_step_dvd =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hpos = Thm.assume (ctermV (jT (lt ZeroC pF)))         (* lt 0 p *)
    val hdvd = Thm.assume (ctermV (jT (dvd pF (suc nF))))     (* dvd p (Suc n) *)
    val q  = rdiv nF pF;   val r  = rmod nF pF;
    val qS = rdiv (suc nF) pF;  val rS = rmod (suc nF) pF;
    val eqn = div_mod_eq_atV (nF, pF) hpos      (* oeq n (add (mult p q) r) *)
    val rlt = rmod_lt_atV (nF, pF) hpos         (* lt r p = le (Suc r) p *)
    val eqSn = div_mod_eq_atV (suc nF, pF) hpos (* oeq (Suc n)(add (mult p qS) rS) *)
    val rSlt = rmod_lt_atV (suc nF, pF) hpos    (* lt rS p *)
    (* Suc n = p*q + Suc r *)
    val sucEqn = Suc_cong OF [eqn]
    val asr = addSrV_at (mult pF q, r)
    val SnRep = oeq_trans OF [sucEqn, oeq_sym OF [asr]]   (* oeq (Suc n)(add (mult p q)(Suc r)) *)
    (* rmod(Suc n,p) = 0 from p|Suc n :  Suc n = p*qS [rdiv_mult_exact] = p*qS + 0 ;
       uniqueness vs Suc n = p*qS + rS gives rS = 0 *)
    val mEx = rdiv_mult_exact_atV (pF, suc nF) hpos hdvd    (* oeq (Suc n)(mult p qS) *)
    val SnRep0 = oeq_trans OF [mEx, oeq_sym OF [add0rV_at (mult pF qS)]]  (* oeq (Suc n)(add (mult p qS) 0) *)
    val EQ0 = oeq_trans OF [oeq_sym OF [eqSn], SnRep0]   (* oeq (add (mult p qS) rS)(add (mult p qS) 0) *)
    val uniq0 = div_mod_unique_atV (qS, qS, rS, ZeroC, pF) EQ0 rSlt hpos;  (* Conj (oeq qS qS)(oeq rS 0) *)
    val rS0 = conjunct2_V (oeq qS qS, oeq rS ZeroC) uniq0;   (* oeq rS 0 *)
    val goalC = oeq qS (suc q)
    val dc = le_cases_atV (suc r, pF) rlt       (* Disj (lt (Suc r) p)(oeq (Suc r) p) *)
    (* CASE lt (Suc r) p : rep (p*q + Suc r) valid ; uniqueness vs (p*qS + rS) -> rS = Suc r ;
       but rS = 0 -> Suc r = 0 -> false *)
    val caseLt =
      let val hlt = Thm.assume (ctermV (jT (lt (suc r) pF)))
          val EQ = oeq_trans OF [oeq_sym OF [eqSn], SnRep]   (* oeq (add (mult p qS) rS)(add (mult p q)(Suc r)) *)
          val uniq = div_mod_unique_atV (qS, q, rS, suc r, pF) EQ rSlt hlt;  (* Conj (oeq qS q)(oeq rS (Suc r)) *)
          val rSeq = conjunct2_V (oeq qS q, oeq rS (suc r)) uniq;   (* oeq rS (Suc r) *)
          (* 0 = rS = Suc r -> Suc r = 0 -> false *)
          val zero_Sr = oeq_trans OF [oeq_sym OF [rS0], rSeq]   (* oeq 0 (Suc r) *)
          val Sr_zero = oeq_sym OF [zero_Sr]                    (* oeq (Suc r) 0 *)
          val ff = (Suc_neq_Zero_atV r) OF [Sr_zero]            (* oFalse *)
          val g = Thm.implies_elim (oFalse_elim_V goalC) ff
      in Thm.implies_intr (ctermV (jT (lt (suc r) pF))) g end;
    (* CASE oeq (Suc r) p : Suc n = p*q + p = p*(Suc q) ; rep (p*(Suc q) + 0) ;
       uniqueness vs (p*qS + rS) -> qS = Suc q *)
    val caseEq =
      let val heq = Thm.assume (ctermV (jT (oeq (suc r) pF)))
          (* Suc n = (p*q)+p [rewrite Suc r -> p in SnRep] *)
          val step1 = (let val zF = Free("zse2",natT)
                           val Pb = Term.lambda zF (oeq (suc nF)(add (mult pF q) zF))
                       in substPredV (Pb, suc r, pF) heq SnRep end);  (* oeq (Suc n)(add (mult p q) p) *)
          (* (p*q)+p = p*(Suc q) *)
          val msr = multSrV_at (pF, q)                 (* oeq (mult p (Suc q))(add p (mult p q)) *)
          val msr2 = oeq_trans OF [msr, addcommV_at (pF, mult pF q)]   (* oeq (mult p (Suc q))(add (mult p q) p) *)
          val SnPq = oeq_trans OF [step1, oeq_sym OF [msr2]]   (* oeq (Suc n)(mult p (Suc q)) *)
          (* rep (p*(Suc q) + 0) *)
          val SnPq0 = oeq_trans OF [SnPq, oeq_sym OF [add0rV_at (mult pF (suc q))]]  (* oeq (Suc n)(add (mult p (Suc q)) 0) *)
          (* uniqueness vs eqSn : (p*qS + rS) = (p*(Suc q) + 0) *)
          val EQq = oeq_trans OF [oeq_sym OF [eqSn], SnPq0]   (* oeq (add (mult p qS) rS)(add (mult p (Suc q)) 0) *)
          val uniqq = div_mod_unique_atV (qS, suc q, rS, ZeroC, pF) EQq rSlt hpos;  (* Conj (oeq qS (Suc q))(oeq rS 0) *)
          val g = conjunct1_V (oeq qS (suc q), oeq rS ZeroC) uniqq;   (* oeq qS (Suc q) *)
      in Thm.implies_intr (ctermV (jT (oeq (suc r) pF))) g end;
    val body = disjE_elimV (lt (suc r) pF, oeq (suc r) pF, goalC) dc caseLt caseEq;
    val d1 = Thm.implies_intr (ctermV (jT (dvd pF (suc nF)))) body
    val d2 = Thm.implies_intr (ctermV (jT (lt ZeroC pF))) d1
  in varify d2 end;
val () = out ("rdiv_step_dvd 0hyp=" ^ Bool.toString (zhV rdiv_step_dvd) ^ "\n");
val i_rdiv_step_dvd =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (lt ZeroC pVz),
       Logic.mk_implies (jT (dvd pVz (suc nVz)),
         jT (oeq (rdiv (suc nVz) pVz)(suc (rdiv nVz pVz))))) end;
val r_rsd = (Thm.prop_of rdiv_step_dvd) aconv i_rdiv_step_dvd;
val () = out ("rdiv_step_dvd aconv=" ^ Bool.toString r_rsd ^ "\n");
val () = if zhV rdiv_step_dvd andalso r_rsd then out "RDIV_STEP_DVD_OK\n" else out "RDIV_STEP_DVD_FAIL\n";
val () = out "RDIV_STEP_DVD_DONE\n";

(* combined floor-step audit *)
val () = if zhV rdiv_step_ndvd andalso r_rsn andalso zhV rdiv_step_dvd andalso r_rsd
         then out "FLOOR_STEP_OK\n" else out "FLOOR_STEP_PARTIAL\n";

(* ============================================================================
   F3b — CONSOLIDATED FINAL AUDIT (all banked pieces, incl. floor-step lemmas).
   Stages delivered (each 0-hyp + aconv on the F3 final context):
     (P)  fact_pos        : lt 0 (fact N)
          mprod_closed    : oeq (mprod p Q)(mult (pow p Q)(fact Q))     [MULT_PROD_OK]
     (toward L) rdiv_step_dvd  / rdiv_step_ndvd  : the FLOOR-STEP lemmas
          coupling rdiv to the per-step divisibility (the foundation of the
          recursive Legendre fact-split)                                [FLOOR_STEP_OK]
     (toward B/LE) vp_pow_self : oeq (vp p (pow p k)) k                 [VP_POW_SELF_OK]
          pow_le_exp     : lt 0 p ==> le i j ==> le (pow p i)(pow p j)  [POW_LE_EXP_OK]
   OPEN (precise blocker for the next fleet):
     legendre_rec needs a new recursive constant pfree p N (product of
     non-multiples of p in 1..N) and the COUPLED induction
        fact (Suc n) = pfree p (Suc n) * mprod p (rdiv (Suc n) p)
     driven by the now-proved floor-step lemmas (rdiv increments iff p|(Suc n)).
     Then: vp p (fact N) = (rdiv N p) + vp p (fact (rdiv N p)) follows from
     vp_additive + mprod_closed + vp_pow_self (all banked).  vp_binom_rec and
     vp_le then compose on legendre_rec + floor01 + pow_le_exp.
   ============================================================================ *)
val () = out "F3B_CONSOLIDATED_BEGIN\n";
val f3b_consolidated =
  zhV fact_pos andalso r_factpos
  andalso zhV2 mprod_closed andalso r_mpc
  andalso zhV pow_le_exp andalso r_ple
  andalso zhV vp_pow_self andalso r_vps
  andalso zhV rdiv_step_ndvd andalso r_rsn
  andalso zhV rdiv_step_dvd andalso r_rsd;
val () =
  let
    val thy = Proof_Context.theory_of ctxtV2
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
  in out ("F3B_FINAL_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM ^ "\n") end;
val () = if f3b_consolidated then out "BERTRAND_F3B_BANK_OK\n" else out "BERTRAND_F3B_BANK_PARTIAL\n";
val () = out "F3B_CONSOLIDATED_DONE\n";

(* ============================================================================
   BERTRAND F3c — CLOSE THE VALUATION WALL.
   NEW final context ctxtV3 extending thyV2 (which already has mprod) with a new
   conservative recursive constant
      pfree : nat => nat => nat       (product of non-multiples of p in 1..N)
        pfree p 0        = 1
        pfree_dvd  : dvd p (Suc n)    ==> pfree p (Suc n) = pfree p n
        pfree_ndvd : ~(dvd p (Suc n)) ==> pfree p (Suc n) = mult (Suc n)(pfree p n)
   Stages : (PF) fact_split ; (CO) pfree_coprime ; (L) legendre_rec ;
            (B) vp_binom_rec ; (LE) vp_le.
   ============================================================================ *)
val () = out "F3C_BEGIN\n";

val thyV3_0 = Sign.add_consts
  [(Binding.name "pfree", natT --> natT --> natT, NoSyn)] thyV2;
val pfreeC = Const (Sign.full_name thyV3_0 (Binding.name "pfree"), natT --> natT --> natT);
fun pfree p n = pfreeC $ p $ n;
val pV3 = Free("p", natT); val nV3 = Free("n", natT);
val ((_,pfree_0_ax),   thyV3_1) = Thm.add_axiom_global (Binding.name "pfree_0",
      jT (oeq (pfree pV3 ZeroC)(suc ZeroC))) thyV3_0;                 (* pfree p 0 = 1 *)
val ((_,pfree_dvd_ax), thyV3_2) = Thm.add_axiom_global (Binding.name "pfree_dvd",
      Logic.mk_implies (jT (dvd pV3 (suc nV3)),
        jT (oeq (pfree pV3 (suc nV3))(pfree pV3 nV3)))) thyV3_1;      (* p|Suc n ==> unchanged *)
val ((_,pfree_ndvd_ax), thyV3) = Thm.add_axiom_global (Binding.name "pfree_ndvd",
      Logic.mk_implies (jT (neg (dvd pV3 (suc nV3))),
        jT (oeq (pfree pV3 (suc nV3))(mult (suc nV3)(pfree pV3 nV3))))) thyV3_2;  (* ~p|Suc n ==> picks up (Suc n) *)

(* ---- THE ONE FINAL CONTEXT ctxtV3 / ctermV3 / thyV3 ---- *)
val ctxtV3  = Proof_Context.init_global thyV3;
val ctermV3 = Thm.cterm_of ctxtV3;
fun zhV3 th = (length (Thm.hyps_of th) = 0) andalso (null (Thm.extra_shyps th));

