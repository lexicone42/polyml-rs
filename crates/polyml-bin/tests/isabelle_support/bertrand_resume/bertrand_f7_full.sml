(* extra mono/cancel instantiators on ctxtV *)
val mult_le_mono_vV       = varify mult_le_mono;        (* le j k ==> le (mult c j)(mult c k) *)
val mult_le_cancel_pos_vV = varify mult_le_cancel_pos;  (* le (mult (Suc k) a)(mult (Suc k) b) ==> le a b *)
val mult_left_cancel_pos_vV = varify mult_left_cancel_pos; (* oeq (mult (Suc k) a)(mult (Suc k) b) ==> oeq a b *)
val add_le_cancel_left_vV = varify add_le_cancel_left;  (* le (add a b)(add a c) ==> le b c *)
val add_left_cancel_vV    = varify add_left_cancel;     (* oeq (add m a)(add m b) ==> oeq a b *)
val sub_add_left_cancel_vV= varify sub_add_left_cancel; (* oeq (sub (add a b)(add a c))(sub b c) *)
fun mult_le_mono_atV (cT,jT_,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("c",0), ctermV cT),(("j",0), ctermV jT_),(("k",0), ctermV kT)] mult_le_mono_vV)) h;
fun mult_le_cancel_pos_atV (kT,aT,bT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("k",0), ctermV kT),(("a",0), ctermV aT),(("b",0), ctermV bT)] mult_le_cancel_pos_vV)) h;
fun mult_left_cancel_pos_atV (kT,aT,bT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("k",0), ctermV kT),(("a",0), ctermV aT),(("b",0), ctermV bT)] mult_left_cancel_pos_vV)) h;
fun add_le_cancel_left_atV (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT)] add_le_cancel_left_vV)) h;
fun add_left_cancel_atV (mT,aT,bT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("m",0), ctermV mT),(("a",0), ctermV aT),(("b",0), ctermV bT)] add_left_cancel_vV)) h;
fun sub_add_left_cancel_atV (aT,bT,cT) = beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT)] sub_add_left_cancel_vV);

(* disj_zero_or_suc on ctxtV *)
fun dzosV_at t = beta_norm (Drule.infer_instantiate ctxtV [(("p",0), ctermV t)] disj_zero_or_suc_vV);

(* le_suc_self on ctxtV : le n (Suc n) *)
fun le_suc_self_atV nt =
  let
    val aeq = addSrV_at (nt, ZeroC);
    val a0  = add0rV_at nt;
    val s   = Suc_cong OF [a0];
    val rhs = oeq_trans OF [aeq, s];
    val eqn = oeq_sym OF [rhs];
  in le_introV (nt, suc nt, suc ZeroC) eqn end;

(* lt_imp_le on ctxtV : lt a b ==> le a b   (lt a b = le (Suc a) b ; le a (Suc a) ; trans) *)
fun lt_imp_le_atV (aT,bT) hlt =
  let val laSa = le_suc_self_atV aT          (* le a (Suc a) *)
  in le_trans_atV (aT, suc aT, bT) laSa hlt end;

(* HELPER sub_zero_l : oeq (sub Zero w) Zero   (cases on w) *)
val sub_zero_l =
  let
    val wF = Free("w", natT)
    val dz = dzosV_at wF                      (* Disj (oeq w 0)(Ex q. oeq w (Suc q)) *)
    val goalC = oeq (sub ZeroC wF) ZeroC
    val caseZ =
      let val hz = Thm.assume (ctermV (jT (oeq wF ZeroC)))   (* oeq w 0 *)
          (* sub 0 w : rewrite w -> 0 ; sub 0 0 = 0 (sub_n_0) *)
          val Pabs = Term.lambda (Free("zsz",natT)) (oeq (sub ZeroC (Free("zsz",natT))) ZeroC)
          val sub00 = subN0V_at ZeroC          (* oeq (sub 0 0) 0 *)
          val g = substPredV (Pabs, ZeroC, wF) (oeq_sym OF [hz]) sub00  (* oeq (sub 0 w) 0 *)
      in Thm.implies_intr (ctermV (jT (oeq wF ZeroC))) g end;
    val PabsQ = Abs("q", natT, oeq wF (suc (Bound 0)))
    val caseS =
      let val hex = Thm.assume (ctermV (jT (mkEx PabsQ)))
          fun body qF (hq : thm) =             (* hq : oeq w (Suc q) *)
            let val s0Sq = sub0SV_at qF         (* oeq (sub 0 (Suc q)) 0 *)
                val Pabs = Term.lambda (Free("zsz2",natT)) (oeq (sub ZeroC (Free("zsz2",natT))) ZeroC)
            in substPredV (Pabs, suc qF, wF) (oeq_sym OF [hq]) s0Sq end;  (* oeq (sub 0 w) 0 *)
          val g = exE_elimV (PabsQ, goalC) hex "q_szl" body
      in Thm.implies_intr (ctermV (jT (mkEx PabsQ))) g end;
    val g = disjE_elimV (oeq wF ZeroC, mkEx PabsQ, goalC) dz caseZ caseS
  in varify g end;
fun sub_zero_l_atV w = beta_norm (Drule.infer_instantiate ctxtV [(("w",0), ctermV w)] sub_zero_l);

val () = out ("sub_zero_l 0hyp=" ^ Bool.toString (zhV sub_zero_l) ^ "\n");

(* HELPER sub_add_self_r : le a b ==> oeq (sub a b) Zero   (truncation when a<=b)
   le a b gives b = a + w ; sub a b = sub a (a+w) = sub (a+0)(a+w) = sub 0 w = 0. *)
fun sub_le_zero_atV (aT,bT) hle =      (* hle : jT (le a b) -> jT (oeq (sub a b) 0) *)
  let
    val PabsLe = Abs("p", natT, oeq bT (add aT (Bound 0)))   (* body of le a b *)
    val goalC = oeq (sub aT bT) ZeroC
    fun body wF (hw : thm) =            (* hw : oeq b (add a w) *)
      let
        (* sub a b = sub a (a+w) : rewrite b -> a+w *)
        val Pb = Term.lambda (Free("zslz",natT)) (oeq (sub aT (Free("zslz",natT))) ZeroC)
        (* compute sub a (a+w) = 0 ; then transport back via hw *)
        (* sub a (a+w) = sub (a+0)(a+w) [rewrite first a as a+0] = sub 0 w = 0 *)
        val a0 = add0rV_at aT             (* oeq (add a 0) a *)
        (* sub_add_left_cancel a 0 w : oeq (sub (a+0)(a+w))(sub 0 w) *)
        val salc = sub_add_left_cancel_atV (aT, ZeroC, wF)   (* oeq (sub (a+0)(a+w))(sub 0 w) *)
        (* rewrite (a+0) -> a in LHS: oeq (sub a (a+w))(sub (a+0)(a+w)) via cong on first arg *)
        val cong1 = (let val zF = Free("zc1",natT)
                         val Pabs = Term.lambda zF (oeq (sub aT (add aT wF))(sub zF (add aT wF)))
                     in substPredV (Pabs, aT, add aT ZeroC) (oeq_sym OF [a0]) (oeqreflV_at (sub aT (add aT wF))) end);
                     (* oeq (sub a (a+w))(sub (a+0)(a+w)) *)
        val s0w = sub_zero_l_atV wF       (* oeq (sub 0 w) 0 *)
        val chain = oeq_trans OF [oeq_trans OF [cong1, salc], s0w]  (* oeq (sub a (a+w)) 0 *)
        (* transport: oeq (sub a b) 0 by rewriting (a+w) -> b via sym hw *)
        val g = substPredV (Pb, add aT wF, bT) (oeq_sym OF [hw]) chain  (* oeq (sub a b) 0 *)
      in g end;
  in exE_elimV (PabsLe, goalC) hle "w_slz" body end;

val () = out "F01_HELPERS_OK\n";

(* ---- floor01 proper ---- *)
fun tflo nT qT = sub (rdiv (add nT nT) qT)(add (rdiv nT qT)(rdiv nT qT));

val floor01 =
  let
    val nF = Free("n", natT); val qF = Free("q", natT);
    val posP = jT (lt ZeroC qF);                 (* lt 0 q *)
    val hPos = Thm.assume (ctermV posP);
    val D2 = rdiv (add nF nF) qF;  val R2 = rmod (add nF nF) qF;
    val D1 = rdiv nF qF;           val R1 = rmod nF qF;
    val DD = add D1 D1;
    val tT = sub D2 DD;
    val goalC = mkDisj (oeq tT ZeroC) (oeq tT (suc ZeroC));

    (* eq2 : 2n = (q*D2) + R2 *)
    val eq2 = div_mod_eq_atV (add nF nF, qF) hPos;   (* oeq (n+n)(add (mult q D2) R2) *)
    (* eq1 : n = (q*D1) + R1 *)
    val eq1 = div_mod_eq_atV (nF, qF) hPos;          (* oeq n (add (mult q D1) R1) *)
    (* R1 < q *)
    val r1lt = rmod_lt_atV (nF, qF) hPos;            (* lt R1 q *)
    val r2lt = rmod_lt_atV (add nF nF, qF) hPos;     (* lt R2 q *)

    (* double eq1 : n+n = (q*D1+R1)+(q*D1+R1) *)
    val dbl = (let val l = add_cong_lV (nF, add (mult qF D1) R1, nF) eq1   (* oeq (n+n)((qD1+R1)+n) *)
                   val r = add_cong_rV (add (mult qF D1) R1, nF, add (mult qF D1) R1) eq1 (* oeq ((qD1+R1)+n)((qD1+R1)+(qD1+R1)) *)
               in oeq_trans OF [l, r] end);          (* oeq (n+n)((qD1+R1)+(qD1+R1)) *)
    (* RHS reshuffle : (qD1+R1)+(qD1+R1) = (qD1+qD1)+(R1+R1) *)
    (* use assoc/comm : ((a+b)+(a+b)) = (a+a)+(b+b) with a=qD1, b=R1 *)
    val a_ = mult qF D1; val b_ = R1;
    (* (a+b)+(a+b) = a+(b+(a+b)) [assoc] *)
    val s1 = addassocV_at (a_, b_, add a_ b_);       (* oeq ((a+b)+(a+b))(a+(b+(a+b))) *)
    (* b+(a+b) = (b+a)+b [assoc sym] ; b+a = a+b [comm] -> = (a+b)+b ; +b assoc: = a+(b+b)?? do step by step *)
    (* compute b+(a+b) = a+(b+b) : b+(a+b) = (b+a)+b = (a+b)+b = a+(b+b) *)
    val t1 = oeq_sym OF [addassocV_at (b_, a_, b_)]; (* oeq (b+(a+b))((b+a)+b) *)
    val t2 = add_cong_lV (add b_ a_, add a_ b_, b_) (addcommV_at (b_, a_));  (* oeq ((b+a)+b)((a+b)+b) *)
    val t3 = addassocV_at (a_, b_, b_);             (* oeq ((a+b)+b)(a+(b+b)) *)
    val bab = oeq_trans OF [t1, oeq_trans OF [t2, t3]];  (* oeq (b+(a+b))(a+(b+b)) *)
    (* a+(b+(a+b)) = a+(a+(b+b)) [cong r] *)
    val s2 = add_cong_rV (a_, add b_ (add a_ b_), add a_ (add b_ b_)) bab;  (* oeq (a+(b+(a+b)))(a+(a+(b+b))) *)
    (* a+(a+(b+b)) = (a+a)+(b+b) [assoc sym] *)
    val s3 = oeq_sym OF [addassocV_at (a_, a_, add b_ b_)];  (* oeq (a+(a+(b+b)))((a+a)+(b+b)) *)
    val rhsEq = oeq_trans OF [s1, oeq_trans OF [s2, s3]];    (* oeq ((a+b)+(a+b))((a+a)+(b+b)) *)
    (* qD1+qD1 = q*(D1+D1) [left_distrib sym] *)
    val ld = ldistV_at (qF, D1, D1);                (* oeq (q*(D1+D1))((q*D1)+(q*D1)) *)
    val aa_qDD = oeq_sym OF [ld];                    (* oeq ((q*D1)+(q*D1))(q*(D1+D1)) *)
    (* (a+a)+(b+b) = (q*(D1+D1))+(R1+R1) [cong l] *)
    val rhsEq2 = oeq_trans OF [rhsEq, add_cong_lV (add a_ a_, mult qF DD, add b_ b_) aa_qDD];
                 (* oeq ((a+b)+(a+b))((q*(D1+D1))+(R1+R1)) *)
    (* combine dbl + rhsEq2 : n+n = (q*(D1+D1))+(R1+R1) *)
    val eqB = oeq_trans OF [dbl, rhsEq2];            (* oeq (n+n)((q*(D1+D1))+(R1+R1)) *)
    (* from eq2 : n+n = (q*D2)+R2 ; so (q*D2)+R2 = (q*(D1+D1))+(R1+R1) *)
    val key = oeq_trans OF [oeq_sym OF [eq2], eqB];  (* oeq ((q*D2)+R2)((q*(D1+D1))+(R1+R1)) *)

    (* total order on DD, D2 *)
    val tot = le_total_atV (DD, D2);                 (* Disj (le DD D2)(le D2 DD) *)
    (* CASE le D2 DD : sub D2 DD = 0 -> left disjunct *)
    val caseLe =
      let val hle = Thm.assume (ctermV (jT (le D2 DD)))
          val sub0 = sub_le_zero_atV (D2, DD) hle    (* oeq (sub D2 DD) 0 *)
          val g = disjI1V_at (oeq tT ZeroC, oeq tT (suc ZeroC)) sub0
      in Thm.implies_intr (ctermV (jT (le D2 DD))) g end;
    (* CASE le DD D2 : exact witness -> tt = sub D2 DD, D2 = DD + tt, derive tt in {0,1} *)
    val caseGe =
      let
        val hge = Thm.assume (ctermV (jT (le DD D2)))
        val PabsLe = Abs("p", natT, oeq D2 (add DD (Bound 0)))   (* body of le DD D2 *)
        fun body ttF (hw : thm) =      (* hw : oeq D2 (add DD tt) *)
          let
            (* sub D2 DD = tt : sub (DD+tt) DD = tt via sub_add_l ; transport D2->DD+tt *)
            val saddl = subaddlV_at (DD, ttF)        (* oeq (sub (add DD tt) DD) tt *)
            (* rewrite (DD+tt) -> D2 (sym hw) on the sub's first arg *)
            val subEq = (let val zF = Free("zse",natT)
                             val Pabs = Term.lambda zF (oeq (sub zF DD) ttF)
                         in substPredV (Pabs, add DD ttF, D2) (oeq_sym OF [hw]) saddl end);  (* oeq (sub D2 DD) tt *)
            (* substitute D2 = DD+tt into key : (q*(DD+tt))+R2 = (q*DD)+(R1+R1) *)
            (* key : (q*D2)+R2 = (q*DD)+(R1+R1).  rewrite D2->DD+tt in q*D2 *)
            val keyTT = (let val zF = Free("zkt",natT)
                             val Pabs = Term.lambda zF (oeq (add (mult qF zF) R2)(add (mult qF DD)(add R1 R1)))
                         in substPredV (Pabs, D2, add DD ttF) hw key end);
                         (* oeq ((q*(DD+tt))+R2)((q*DD)+(R1+R1)) *)
            (* q*(DD+tt) = q*DD + q*tt [left_distrib] *)
            val ldtt = ldistV_at (qF, DD, ttF)        (* oeq (q*(DD+tt))((q*DD)+(q*tt)) *)
            (* LHS becomes ((q*DD)+(q*tt))+R2 ; reassoc = (q*DD)+((q*tt)+R2) *)
            val lhs1 = add_cong_lV (mult qF (add DD ttF), add (mult qF DD)(mult qF ttF), R2) ldtt;
                       (* oeq ((q*(DD+tt))+R2)(((q*DD)+(q*tt))+R2) *)
            val lhs2 = addassocV_at (mult qF DD, mult qF ttF, R2);
                       (* oeq (((q*DD)+(q*tt))+R2)((q*DD)+((q*tt)+R2)) *)
            val lhsChain = oeq_trans OF [oeq_sym OF [lhs2], oeq_sym OF [lhs1]];
                       (* oeq ((q*DD)+((q*tt)+R2))((q*(DD+tt))+R2) *)
            (* so (q*DD)+((q*tt)+R2) = (q*DD)+(R1+R1) [via lhsChain ; keyTT] *)
            val eqQ = oeq_trans OF [lhsChain, keyTT];   (* oeq ((q*DD)+((q*tt)+R2))((q*DD)+(R1+R1)) *)
            (* cancel q*DD on left : (q*tt)+R2 = R1+R1 *)
            val cancel = add_left_cancel_atV (mult qF DD, add (mult qF ttF) R2, add R1 R1) eqQ;
                       (* oeq ((q*tt)+R2)(R1+R1) *)
            (* q*tt <= (q*tt)+R2 = R1+R1 *)
            val le_qtt_sum = le_add_atV (mult qF ttF, R2);   (* le (q*tt)((q*tt)+R2) *)
            (* le (q*tt)(R1+R1) : transport via cancel *)
            val le_qtt_r1r1 = (let val zF = Free("zlq",natT)
                                   val Pabs = Term.lambda zF (le (mult qF ttF) zF)
                               in substPredV (Pabs, add (mult qF ttF) R2, add R1 R1) cancel le_qtt_sum end);
                               (* le (q*tt)(R1+R1) *)
            (* lt (R1+R1)(q+q) : from R1 < q (Suc R1 <= q) and R1 <= q *)
            val r1le = lt_imp_le_atV (R1, qF) r1lt;          (* le R1 q *)
            (* Suc(R1+R1) = (Suc R1)+R1 ; le (Suc R1) q + le R1 q -> le ((Suc R1)+R1)(q+q) (mono2) *)
            (* mult_le_mono2-style add: use le_add_mono twice + le_trans *)
            (* le ((Suc R1)+R1)(q+R1) [le_add_mono on left arg with Suc R1<=q] *)
            (* le_add_mono : le a b ==> le (add a c)(add b c) *)
            val m1 = le_add_mono_atV (suc R1, qF, R1) r1lt;  (* le ((Suc R1)+R1)(q+R1) *)
            (* le (q+R1)(q+q) : le R1 q with add on left -> use add_cong + le_add_mono on the OTHER side *)
            (* le_add_mono adds c on the right ; for (q+R1)<=(q+q) need add on left.  use comm. *)
            val m2pre = le_add_mono_atV (R1, qF, qF) r1le;   (* le (R1+q)(q+q) *)
            (* (q+R1) = (R1+q) [comm] -> le (q+R1)(q+q) *)
            val m2 = (let val zF = Free("zm2",natT)
                          val Pabs = Term.lambda zF (le zF (add qF qF))
                      in substPredV (Pabs, add R1 qF, add qF R1) (addcommV_at (R1, qF)) m2pre end);
                      (* le (q+R1)(q+q) *)
            val leSucChain = le_trans_atV (add (suc R1) R1, add qF R1, add qF qF) m1 m2;
                      (* le ((Suc R1)+R1)(q+q) *)
            (* (Suc R1)+R1 = Suc(R1+R1) [add_Suc] -> le (Suc(R1+R1))(q+q) = lt (R1+R1)(q+q) *)
            val sR1 = addSucV_at (R1, R1);            (* oeq ((Suc R1)+R1)(Suc(R1+R1)) *)
            val ltR1R1 = (let val zF = Free("zlt",natT)
                              val Pabs = Term.lambda zF (le zF (add qF qF))
                          in substPredV (Pabs, add (suc R1) R1, suc (add R1 R1)) sR1 leSucChain end);
                          (* le (Suc(R1+R1))(q+q) = lt (R1+R1)(q+q) *)
            (* now derive tt in {0,1} via dzos twice, contradiction in tt>=2 branch *)
            val dz = dzosV_at ttF                     (* Disj (oeq tt 0)(Ex r. oeq tt (Suc r)) *)
            (* package goal in terms of tT (= sub D2 DD).  We prove Disj over tT using subEq to map tt<->tT *)
            (* It's easier to prove Disj (oeq tt 0)(oeq tt 1) then transport to tT *)
            val gTT = mkDisj (oeq ttF ZeroC)(oeq ttF (suc ZeroC))
            val caseZ =
              let val hz = Thm.assume (ctermV (jT (oeq ttF ZeroC)))
              in Thm.implies_intr (ctermV (jT (oeq ttF ZeroC))) (disjI1V_at (oeq ttF ZeroC, oeq ttF (suc ZeroC)) hz) end;
            val PabsR = Abs("r", natT, oeq ttF (suc (Bound 0)))
            val caseS =
              let val hex = Thm.assume (ctermV (jT (mkEx PabsR)))
                  fun sbody rF (hr : thm) =     (* hr : oeq tt (Suc r) *)
                    let
                      val dz2 = dzosV_at rF       (* Disj (oeq r 0)(Ex s. oeq r (Suc s)) *)
                      val caseRZ =
                        let val hrz = Thm.assume (ctermV (jT (oeq rF ZeroC)))   (* r=0 -> tt=Suc 0 *)
                            val tt1 = (let val zF = Free("ztt1",natT)
                                           val Pabs = Term.lambda zF (oeq ttF (suc zF))
                                       in substPredV (Pabs, rF, ZeroC) hrz hr end);  (* oeq tt (Suc 0) *)
                        in Thm.implies_intr (ctermV (jT (oeq rF ZeroC)))
                             (disjI2V_at (oeq ttF ZeroC, oeq ttF (suc ZeroC)) tt1) end;
                      val PabsS = Abs("s", natT, oeq rF (suc (Bound 0)))
                      val caseRS =
                        let val hex2 = Thm.assume (ctermV (jT (mkEx PabsS)))
                            fun ssbody sF (hs : thm) =     (* hs : oeq r (Suc s) -> tt = Suc(Suc s) >= 2 -> contradiction *)
                              let
                                (* tt = Suc(Suc s) : tt = Suc r = Suc(Suc s) *)
                                val ttSS = (let val zF = Free("ztss",natT)
                                                val Pabs = Term.lambda zF (oeq ttF (suc zF))
                                            in substPredV (Pabs, rF, suc sF) hs hr end);  (* oeq tt (Suc(Suc s)) *)
                                (* le 2 tt : le (Suc(Suc 0)) tt.  tt = Suc(Suc s) ; le (Suc(Suc 0))(Suc(Suc s)) since 0<=s *)
                                (* build: le (Suc(Suc 0))(Suc(Suc s)) via le_suc_mono twice on le 0 s *)
                                val le0s = (* le 0 s : witness s, oeq s (add 0 s) sym of add_0 *)
                                  le_introV (ZeroC, sF, sF) (oeq_sym OF [add0V_at sF]);
                                val le1 = le_suc_mono_atV (ZeroC, sF) le0s;        (* le (Suc 0)(Suc s) *)
                                val le2 = le_suc_mono_atV (suc ZeroC, suc sF) le1; (* le (Suc(Suc 0))(Suc(Suc s)) *)
                                (* transport tt : le 2 tt *)
                                val le2tt = (let val zF = Free("zl2",natT)
                                                 val Pabs = Term.lambda zF (le (suc (suc ZeroC)) zF)
                                             in substPredV (Pabs, suc (suc sF), ttF) (oeq_sym OF [ttSS]) le2 end);  (* le 2 tt *)
                                (* mult_le_mono : le (q*2)(q*tt) *)
                                val mlm = mult_le_mono_atV (qF, suc (suc ZeroC), ttF) le2tt;   (* le (q*2)(q*tt) *)
                                (* q*2 = q+q.  mult_Suc_right: oeq (mult n (Suc m))(add n (mult n m)). *)
                                val q2a = multSrV_at (qF, suc ZeroC);   (* oeq (q*(Suc(Suc 0)))(add q (q*(Suc 0))) *)
                                val q1a = multSrV_at (qF, ZeroC);       (* oeq (q*(Suc 0))(add q (q*0)) *)
                                val q0  = mult0rV_at qF;                (* oeq (q*0) 0 *)
                                (* q*(Suc 0) = q + (q*0) = q + 0 = q *)
                                val q1 = oeq_trans OF [q1a, oeq_trans OF [add_cong_rV (qF, mult qF ZeroC, ZeroC) q0, add0rV_at qF]];
                                        (* oeq (q*(Suc 0)) q *)
                                (* q*2 = q + (q*(Suc 0)) = q + q *)
                                val q2 = oeq_trans OF [q2a, add_cong_rV (qF, mult qF (suc ZeroC), qF) q1];
                                        (* oeq (q*(Suc(Suc 0)))(add q q) *)
                                (* le (q+q)(q*tt) : transport mlm via q2 *)
                                val le_qq_qtt = (let val zF = Free("zqq",natT)
                                                     val Pabs = Term.lambda zF (le zF (mult qF ttF))
                                                 in substPredV (Pabs, mult qF (suc (suc ZeroC)), add qF qF) q2 mlm end);
                                                 (* le (q+q)(q*tt) *)
                                (* le (q+q)(R1+R1) : trans with le_qtt_r1r1 *)
                                val le_qq_r1r1 = le_trans_atV (add qF qF, mult qF ttF, add R1 R1) le_qq_qtt le_qtt_r1r1;
                                                 (* le (q+q)(R1+R1) *)
                                (* but lt (R1+R1)(q+q) = le (Suc(R1+R1))(q+q).  le (q+q)(R1+R1) + le (Suc(R1+R1))(q+q):
                                   le (Suc(R1+R1))(R1+R1) -> contradiction lt_irrefl-ish *)
                                val le_S_r1r1 = le_trans_atV (suc (add R1 R1), add qF qF, add R1 R1) ltR1R1 le_qq_r1r1;
                                                 (* le (Suc(R1+R1))(R1+R1) = lt (R1+R1)(R1+R1) *)
                                val ff = (lt_irrefl_atV (add R1 R1)) OF [le_S_r1r1];   (* oFalse *)
                                val g = Thm.implies_elim (oFalse_elim_V gTT) ff;  (* gTT *)
                              in g end;
                            val g = exE_elimV (PabsS, gTT) hex2 "s_f01" ssbody
                        in Thm.implies_intr (ctermV (jT (mkEx PabsS))) g end;
                      val g = disjE_elimV (oeq rF ZeroC, mkEx PabsS, gTT) dz2 caseRZ caseRS
                    in g end;
                  val g = exE_elimV (PabsR, gTT) hex "r_f01" sbody
              in Thm.implies_intr (ctermV (jT (mkEx PabsR))) g end;
            val gttDisj = disjE_elimV (oeq ttF ZeroC, mkEx PabsR, gTT) dz caseZ caseS;  (* Disj (oeq tt 0)(oeq tt 1) *)
            (* transport tt -> tT (= sub D2 DD) via subEq : oeq (sub D2 DD) tt , i.e. tT = tt *)
            (* subEq : oeq tT tt.  So oeq tt 0 -> oeq tT 0 ; oeq tt 1 -> oeq tT 1.  Map the disjunction. *)
            val ttZ = Thm.assume (ctermV (jT (oeq ttF ZeroC)))
            val cZ = Thm.implies_intr (ctermV (jT (oeq ttF ZeroC)))
                       (disjI1V_at (oeq tT ZeroC, oeq tT (suc ZeroC)) (oeq_trans OF [subEq, ttZ]));
            val ttO = Thm.assume (ctermV (jT (oeq ttF (suc ZeroC))))
            val cO = Thm.implies_intr (ctermV (jT (oeq ttF (suc ZeroC))))
                       (disjI2V_at (oeq tT ZeroC, oeq tT (suc ZeroC)) (oeq_trans OF [subEq, ttO]));
            val gFinal = disjE_elimV (oeq ttF ZeroC, oeq ttF (suc ZeroC), goalC) gttDisj cZ cO;
          in gFinal end;
        val g = exE_elimV (PabsLe, goalC) hge "tt_f01" body
      in Thm.implies_intr (ctermV (jT (le DD D2))) g end;
    val concl = disjE_elimV (le DD D2, le D2 DD, goalC) tot caseGe caseLe;
    val disch = Thm.implies_intr (ctermV posP) concl;
  in varify disch end;

val () = out ("floor01 0hyp=" ^ Bool.toString (zhV floor01) ^ "\n");
val i_floor01 =
  let val nV = Var(("n",0),natT); val qV = Var(("q",0),natT)
  in Logic.mk_implies (jT (lt ZeroC qV),
       jT (mkDisj (oeq (tflo nV qV) ZeroC)(oeq (tflo nV qV) (suc ZeroC)))) end;
val r_floor01 = (Thm.prop_of floor01) aconv i_floor01;
val () = out ("floor01 aconv=" ^ Bool.toString r_floor01 ^ "\n");
val () = if zhV floor01 andalso r_floor01 then out "FLOOR01_OK\n" else out "FLOOR01_FAIL\n";
val floor01_vV = varify floor01;

(* ============================================================================
   (V)  p-adic VALUATION primitive vp + spec lemmas.
        vp : nat=>nat=>nat , conservative WF recursion on m:
          vp_step_dvd  : prime2 p ==> lt 0 m ==> dvd p m ==> oeq (vp p m)(Suc (vp p (rdiv m p)))
          vp_step_ndvd : prime2 p ==> lt 0 m ==> ~(dvd p m) ==> oeq (vp p m) Zero
        (well-founded: rdiv m p < m for p>=2,m>0,p|m).  Then DERIVE:
          vp_pow_dvd : prime2 p ==> lt 0 m ==> dvd (pow p (vp p m)) m
          vp_maximal : prime2 p ==> lt 0 m ==> ~(dvd (pow p (Suc (vp p m))) m)
   ============================================================================ *)
val () = out "V_BEGIN\n";

(* --- more reused lemmas onto ctxtV --- *)
val one_dvd_vV       = varify one_dvd;
val dvd_mult_cong_vV = varify dvd_mult_cong;
val dvd_mult_right_vV= varify dvd_mult_right;
val dvd_trans_vV     = varify dvd_trans;
val dvd_zero_vV      = varify dvd_zero;
val euclid_lemma_vV  = varify euclid_lemma;
val prime_not_dvd_pos_lt_vV = varify prime_not_dvd_pos_lt;
val pow_Zero_vV      = varify pow_Zero_ax;
val pow_Suc_vV       = varify pow_Suc_ax;
val div_mod_unique_vV= varify div_mod_unique;
val strong_induct_vV = varify strong_induct;
val mult_le_mono2_vV = varify mult_le_mono2;

fun one_dvd_atV t = beta_norm (Drule.infer_instantiate ctxtV [(("n",0), ctermV t)] one_dvd_vV);
fun dvd_mult_cong_atV (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT)] dvd_mult_cong_vV)) h;
fun dvd_mult_right_atV (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT)] dvd_mult_right_vV)) h;
fun dvd_trans_atV (aT,bT,cT) h1 h2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT)] dvd_trans_vV)
  in (inst OF [h1]) OF [h2] end;
fun dvd_zero_atV t = beta_norm (Drule.infer_instantiate ctxtV [(("a",0), ctermV t)] dvd_zero_vV);
fun pow0V_at t = beta_norm (Drule.infer_instantiate ctxtV [(("a",0), ctermV t)] pow_Zero_vV);
fun powSucV_at (at,nt) = beta_norm (Drule.infer_instantiate ctxtV [(("a",0), ctermV at),(("n",0), ctermV nt)] pow_Suc_vV);
fun div_mod_unique_atV (q1T,q2T,r1T,r2T,bT) hEQ hLT1 hLT2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV
        [(("q1",0), ctermV q1T),(("q2",0), ctermV q2T),(("r1",0), ctermV r1T),(("r2",0), ctermV r2T),(("b",0), ctermV bT)] div_mod_unique_vV)
  in ((inst OF [hEQ]) OF [hLT1]) OF [hLT2] end;

(* dvd destructor on ctxtV : dvd a b = Ex k. oeq b (mult a k) *)
fun dvd_introV (aT, bT, w) hyp =
  let val Pabs = Abs ("k", natT, oeq bT (mult aT (Bound 0)))
  in (beta_norm (Drule.infer_instantiate ctxtV [(("P",0), ctermV Pabs),(("a",0), ctermV w)] exI_vV)) OF [hyp] end;
fun dvd_cong_rV (pT, xT, yT) hxy hdvd =
  let val zF = Free("z_dc", natT)
      val Pabs = Term.lambda zF (dvd pT zF)
  in (beta_norm (Drule.infer_instantiate ctxtV
        [(("P",0), ctermV Pabs),(("a",0), ctermV xT),(("b",0), ctermV yT)] oeq_subst_vV) OF [hxy]) OF [hdvd] end;
fun dvd_cong_lV (aT, bT, nT) hab hdvd =     (* rewrite the DIVISOR : dvd a n -> dvd b n *)
  let val zF = Free("z_dcl", natT)
      val Pabs = Term.lambda zF (dvd zF nT)
  in (beta_norm (Drule.infer_instantiate ctxtV
        [(("P",0), ctermV Pabs),(("a",0), ctermV aT),(("b",0), ctermV bT)] oeq_subst_vV) OF [hab]) OF [hdvd] end;

(* prime2 helpers on ctxtV *)
fun prime2_gt1_atV p hPrime = conjunct1_V (lt (suc ZeroC) p, mkForall (ppAbs p)) hPrime;  (* lt 1 p *)
(* lt 0 p from lt 1 p :  lt 1 p = le 2 p ; le 1 2 ; trans le 1 p = lt 0 p *)
fun prime2_pos_atV p hPrime =
  let val gt1 = prime2_gt1_atV p hPrime               (* lt 1 p = le (Suc 0) ... no: le (Suc(Suc 0)) p *)
      (* le 1 2 *)
      val le12 = le_suc_self_atV (suc ZeroC)          (* le (Suc 0)(Suc(Suc 0)) *)
  in le_trans_atV (suc ZeroC, suc (suc ZeroC), p) le12 gt1 end;  (* le 1 p = lt 0 p *)
fun euclid_atV (pT,aT,bT) hP hD =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV
        [(("p",0), ctermV pT),(("a",0), ctermV aT),(("b",0), ctermV bT)] euclid_lemma_vV)
  in (inst OF [hP]) OF [hD] end;
fun mult_le_mono2_atV (aT,bT,cT,dT) hab hcd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV aT),(("b",0), ctermV bT),(("c",0), ctermV cT),(("d",0), ctermV dT)] mult_le_mono2_vV)
  in (inst OF [hab]) OF [hcd] end;

val () = out "V_HELPERS_OK\n";

(* ---------------------------------------------------------------------------
   rdiv-divisibility helpers (functional content of div_mod when p | m):
     rdiv_mult_exact : lt 0 p ==> dvd p m ==> oeq m (mult p (rdiv m p))   [m = p*(m/p)]
   from div_mod_eq (m = p*(m/p)+rmod) + uniqueness against (m = p*k + 0).
   --------------------------------------------------------------------------- *)
fun rdiv_mult_exact_atV (pT, mT) hpos hdvd =     (* jT(lt 0 p) -> jT(dvd p m) -> jT(oeq m (mult p (rdiv m p))) *)
  let
    val divEq = div_mod_eq_atV (mT, pT) hpos;    (* oeq m (add (mult p (rdiv m p))(rmod m p)) *)
    val rlt   = rmod_lt_atV (mT, pT) hpos;       (* lt (rmod m p) p *)
    (* dvd p m gives witness k : m = p*k *)
    val PabsK = Abs("k", natT, oeq mT (mult pT (Bound 0)))
    val goalC = oeq mT (mult pT (rdiv mT pT))
    fun body kF (hk : thm) =       (* hk : oeq m (mult p k) *)
      let
        (* m = p*k + 0 : oeq m (add (mult p k) 0) via add0r sym *)
        val mk0 = oeq_trans OF [hk, oeq_sym OF [add0rV_at (mult pT kF)]];   (* oeq m (add (mult p k) 0) *)
        (* EQ : (p*(m/p)) + (rmod m p) = (p*k) + 0 : from divEq (sym) trans mk0 *)
        val eqA = oeq_trans OF [oeq_sym OF [divEq], mk0];   (* oeq (add (mult p (rdiv m p))(rmod m p))(add (mult p k) 0) *)
        (* lt 0 p *)
        val lt0p = hpos
        (* uniqueness: q1=rdiv m p, r1=rmod m p, q2=k, r2=0, b=p ; need EQ as (p*q1+r1)=(p*q2+r2), lt r1 p, lt r2 p *)
        val lt0_p = lt0p  (* lt 0 p = le (Suc 0) p ; this is lt (r2=0) p *)
        val uniq  = div_mod_unique_atV (rdiv mT pT, kF, rmod mT pT, ZeroC, pT) eqA rlt lt0_p;
                    (* Conj (oeq (rdiv m p) k)(oeq (rmod m p) 0) *)
        val eqQ   = conjunct1_V (oeq (rdiv mT pT) kF, oeq (rmod mT pT) ZeroC) uniq;  (* oeq (rdiv m p) k *)
        (* m = p*k = p*(rdiv m p) : from hk, rewrite k -> rdiv m p (sym eqQ) *)
        val g = oeq_trans OF [hk, mult_cong_rV (pT, kF, rdiv mT pT) (oeq_sym OF [eqQ])];  (* oeq m (mult p (rdiv m p)) *)
      in g end;
  in exE_elimV (PabsK, goalC) hdvd "k_rde" body end;

(* rdiv_pos : prime2 p ==> lt 0 m ==> dvd p m ==> lt 0 (rdiv m p)
   if rdiv m p = 0 then m = p*0 = 0 contra m>0. *)
fun rdiv_pos_atV (pT, mT) hPr hm0 hdvd =
  let
    val lt0p  = prime2_pos_atV pT hPr            (* lt 0 p *)
    val mEq   = rdiv_mult_exact_atV (pT, mT) lt0p hdvd;   (* oeq m (mult p (rdiv m p)) *)
    (* ex_middle on lt 0 (rdiv m p) ; if not, rdiv=0 ... use dzos on rdiv m p *)
    val dz = dzosV_at (rdiv mT pT)               (* Disj (oeq (rdiv m p) 0)(Ex q. oeq (rdiv m p)(Suc q)) *)
    val goalC = lt ZeroC (rdiv mT pT)
    val caseZ =
      let val hz = Thm.assume (ctermV (jT (oeq (rdiv mT pT) ZeroC)))  (* rdiv = 0 *)
          (* m = p*(rdiv) = p*0 = 0 -> contra lt 0 m *)
          val mp0 = oeq_trans OF [mEq, oeq_trans OF [mult_cong_rV (pT, rdiv mT pT, ZeroC) hz, mult0rV_at pT]];  (* oeq m 0 *)
          (* lt 0 m = le (Suc 0) m ; rewrite m -> 0 : le (Suc 0) 0 ; impossible *)
          val le10 = (let val zF = Free("zrp",natT)
                          val Pabs = Term.lambda zF (le (suc ZeroC) zF)
                      in substPredV (Pabs, mT, ZeroC) mp0 hm0 end);   (* le (Suc 0) 0 = lt 0 0 *)
          val ff = lt_irrefl_atV ZeroC OF [le10];   (* lt 0 0 -> oFalse *)
          val g = Thm.implies_elim (oFalse_elim_V goalC) ff
      in Thm.implies_intr (ctermV (jT (oeq (rdiv mT pT) ZeroC))) g end;
    val PabsQ = Abs("q", natT, oeq (rdiv mT pT)(suc (Bound 0)))
    val caseS =
      let val hex = Thm.assume (ctermV (jT (mkEx PabsQ)))
          fun body qF (hq : thm) =     (* hq : oeq (rdiv m p)(Suc q) *)
            let (* lt 0 (Suc q) ; rewrite Suc q -> rdiv m p *)
                val lt0Sq = (let val zF = Free("zlt0",natT)
                                 val Pabs = Term.lambda zF (le (suc ZeroC) zF)
                             in le_introV (suc ZeroC, suc qF, qF) (oeq_sym OF [oeq_trans OF [addSucV_at (ZeroC, qF), Suc_cong OF [add0V_at qF]]]) end);
                                 (* le (Suc 0)(Suc q) = lt 0 (Suc q) *)
                val g = (let val zF = Free("zlt1",natT)
                             val Pabs = Term.lambda zF (le (suc ZeroC) zF)
                         in substPredV (Pabs, suc qF, rdiv mT pT) (oeq_sym OF [hq]) lt0Sq end)  (* lt 0 (rdiv m p) *)
            in g end;
          val g = exE_elimV (PabsQ, goalC) hex "q_rp" body
      in Thm.implies_intr (ctermV (jT (mkEx PabsQ))) g end;
  in disjE_elimV (oeq (rdiv mT pT) ZeroC, mkEx PabsQ, goalC) dz caseZ caseS end;

(* rdiv_lt : prime2 p ==> lt 0 m ==> dvd p m ==> lt (rdiv m p) m
   m = p*(m/p) >= 2*(m/p) = (m/p)+(m/p) > (m/p) since m/p>0. *)
fun rdiv_lt_atV (pT, mT) hPr hm0 hdvd =
  let
    val lt0p   = prime2_pos_atV pT hPr
    val gt1p   = prime2_gt1_atV pT hPr            (* lt 1 p = le 2 p *)
    val mEq    = rdiv_mult_exact_atV (pT, mT) lt0p hdvd;   (* oeq m (mult p (rdiv m p)) *)
    val rpos   = rdiv_pos_atV (pT, mT) hPr hm0 hdvd;       (* lt 0 (rdiv m p) = le 1 (rdiv m p) *)
    val dP = rdiv mT pT
    (* le 2 p, le (rdiv) (rdiv) -> mult_le_mono2 : le (2*rdiv)(p*rdiv) *)
    val mlm = mult_le_mono2_atV (suc (suc ZeroC), pT, dP, dP) gt1p (le_refl_atV dP);  (* le (2*rdiv)(p*rdiv) *)
    (* 2*rdiv = rdiv+rdiv : mult_Suc twice. 2*x = (Suc(Suc 0))*x = x + (Suc 0)*x = x + (x + 0*x) = x + x *)
    val ms2 = multSucV_at (suc ZeroC, dP)         (* oeq ((Suc(Suc 0))*rdiv)(add rdiv ((Suc 0)*rdiv)) *)
    val ms1 = multSucV_at (ZeroC, dP)             (* oeq ((Suc 0)*rdiv)(add rdiv (0*rdiv)) *)
    val m0r = mult0V_at dP                        (* oeq (0*rdiv) 0 *)
    val s1  = oeq_trans OF [ms1, oeq_trans OF [add_cong_rV (dP, mult ZeroC dP, ZeroC) m0r, add0rV_at dP]];  (* (Suc 0)*rdiv = rdiv *)
    val two_rdiv = oeq_trans OF [ms2, add_cong_rV (dP, mult (suc ZeroC) dP, dP) s1];   (* oeq (2*rdiv)(add rdiv rdiv) *)
    (* le (rdiv+rdiv)(p*rdiv) : transport mlm via two_rdiv *)
    val le_dd_prd = (let val zF = Free("zld",natT)
                         val Pabs = Term.lambda zF (le zF (mult pT dP))
                     in substPredV (Pabs, mult (suc (suc ZeroC)) dP, add dP dP) two_rdiv mlm end);  (* le (rdiv+rdiv)(p*rdiv) *)
    (* p*rdiv = m (sym mEq) -> le (rdiv+rdiv) m *)
    val le_dd_m = (let val zF = Free("zlm",natT)
                       val Pabs = Term.lambda zF (le (add dP dP) zF)
                   in substPredV (Pabs, mult pT dP, mT) (oeq_sym OF [mEq]) le_dd_prd end);  (* le (rdiv+rdiv) m *)
    (* lt rdiv (rdiv+rdiv) : Suc rdiv <= rdiv + rdiv.  rpos : le 1 rdiv.  le (Suc rdiv)(rdiv+rdiv)?
       Suc rdiv = rdiv + 1 (add comm/Suc) <= rdiv + rdiv (le_add_mono on right with 1<=rdiv) *)
    (* le (Suc 0) rdiv (=rpos).  le (rdiv + Suc 0)(rdiv + rdiv) via add on left ; convert to Suc rdiv. *)
    (* le_add_mono adds c on the right: le a b -> le (a+c)(b+c).  want le (1+rdiv)(rdiv+rdiv) : a=1,b=rdiv,c=rdiv *)
    val lam = le_add_mono_atV (suc ZeroC, dP, dP) rpos;   (* le ((Suc 0)+rdiv)(rdiv+rdiv) *)
    (* (Suc 0)+rdiv = Suc rdiv (add_Suc + add_0) *)
    val s0r = oeq_trans OF [addSucV_at (ZeroC, dP), Suc_cong OF [add0V_at dP]];  (* oeq ((Suc 0)+rdiv)(Suc rdiv) *)
    val lt_d_dd = (let val zF = Free("zsd",natT)
                       val Pabs = Term.lambda zF (le zF (add dP dP))
                   in substPredV (Pabs, add (suc ZeroC) dP, suc dP) s0r lam end);  (* le (Suc rdiv)(rdiv+rdiv) = lt rdiv (rdiv+rdiv) *)
    (* lt rdiv m : le (Suc rdiv)(rdiv+rdiv) <= m -> le (Suc rdiv) m *)
    val g = le_trans_atV (suc dP, add dP dP, mT) lt_d_dd le_dd_m;   (* le (Suc rdiv) m = lt rdiv m *)
  in g end;

val () = out "V_RDIV_HELPERS_OK\n";

(* ---------------------------------------------------------------------------
   vp_pow_dvd : prime2 p ==> lt 0 m ==> dvd (pow p (vp p m)) m
   STRONG INDUCTION on m.  Pat m := Imp (lt 0 m)(dvd (pow p (vp p m)) m).
     ~dvd p m : vp=0, pow p 0 = 1, one_dvd : dvd 1 m.
     dvd p m  : vp = Suc(vp p (m/p)) ; pow p (Suc k) = p * pow p k ;
                IH at m/p (< m, >0): dvd (pow p (vp(m/p)))(m/p) ;
                dvd_mult_cong : dvd (p*pow..)(p*(m/p)) ; p*(m/p)=m.
   --------------------------------------------------------------------------- *)
fun mk_vp_pow_dvd pF =     (* pF : a Free p ; assumes hPr : prime2 p in scope *)
  let
    val hPr = Thm.assume (ctermV (jT (prime2 pF)))
    fun Pat t = mkImp (lt ZeroC t)(dvd (pow pF (vp pF t)) t)
    val Ppred = Term.lambda (Free("m_vpd", natT)) (Pat (Free("m_vpd", natT)))
    val nH = Free("n_h", natT)
    fun GpropOf nt = let val jB = Free("j_g", natT)
                     in Logic.all jB (Logic.mk_implies (jT (lt jB nt), jT (Pat jB))) end
    val Hthm = Thm.assume (ctermV (GpropOf nH))
    fun ihAt jt hlt = Thm.implies_elim (Thm.forall_elim (ctermV jt) Hthm) hlt   (* lt j n_h -> jT (Pat j) *)
    val stepConcl =     (* prove jT (Pat n_h) = Imp (lt 0 n_h)(dvd (pow p (vp p n_h)) n_h) *)
      let
        val mF = nH
        val goalImp = Pat mF
        val hpos = Thm.assume (ctermV (jT (lt ZeroC mF)))   (* lt 0 m *)
        (* ex_middle dvd p m *)
        val em = ex_middle_V (dvd pF mF)                    (* Disj (dvd p m)(neg (dvd p m)) *)
        val concl = dvd (pow pF (vp pF mF)) mF
        (* CASE dvd p m *)
        val caseD =
          let
            val hd = Thm.assume (ctermV (jT (dvd pF mF)))
            (* vp p m = Suc(vp p (m/p)) *)
            val vstep = vp_step_dvd_atV (pF, mF) hPr hpos hd   (* oeq (vp p m)(Suc(vp p (m/p))) *)
            val mP = rdiv mF pF
            (* m/p < m, m/p > 0 *)
            val rlt = rdiv_lt_atV (pF, mF) hPr hpos hd     (* lt (m/p) m *)
            val rpos= rdiv_pos_atV (pF, mF) hPr hpos hd    (* lt 0 (m/p) *)
            (* IH at m/p *)
            val ihImp = ihAt mP rlt                        (* jT (Pat (m/p)) = Imp (lt 0 (m/p))(dvd (pow p (vp p (m/p)))(m/p)) *)
            val ihD = mp_V (lt ZeroC mP, dvd (pow pF (vp pF mP)) mP) ihImp rpos;  (* dvd (pow p (vp p (m/p)))(m/p) *)
            (* dvd_mult_cong : dvd (pow.. * p)((m/p) * p) ... we need p on LEFT.  use dvd_mult_cong with c=p :
               dvd a b -> dvd (a*c)(b*c) ; a=pow(vp(m/p)), b=m/p, c=p -> dvd (pow*p)((m/p)*p) *)
            val dmc = dvd_mult_cong_atV (pow pF (vp pF mP), mP, pF) ihD;  (* dvd (mult (pow p (vp p (m/p))) p)(mult (m/p) p) *)
            (* want dvd (mult p (pow p (vp p (m/p)))) m.  commute both products. *)
            (* (pow * p) = (p * pow) [comm] ; ((m/p)*p) = (p*(m/p)) = m *)
            val comm1 = multcommV_at (pow pF (vp pF mP), pF)   (* oeq ((pow)*p)(p*(pow)) *)
            val dmc1 = dvd_cong_lV (mult (pow pF (vp pF mP)) pF, mult pF (pow pF (vp pF mP)), mult mP pF) comm1 dmc;
                       (* dvd (mult p (pow p (vp p (m/p))))(mult (m/p) p) *)
            (* (m/p)*p = m : (m/p)*p = p*(m/p) [comm] = m [sym mEq] *)
            val mEq = rdiv_mult_exact_atV (pF, mF) (prime2_pos_atV pF hPr) hd;  (* oeq m (mult p (m/p)) *)
            val mp_pm = multcommV_at (mP, pF)              (* oeq ((m/p)*p)(p*(m/p)) *)
            val mp_m = oeq_trans OF [mp_pm, oeq_sym OF [mEq]];   (* oeq ((m/p)*p) m *)
            val dmc2 = dvd_cong_rV (mult pF (pow pF (vp pF mP)), mult mP pF, mF) mp_m dmc1;
                       (* dvd (mult p (pow p (vp p (m/p)))) m *)
            (* pow p (Suc(vp p (m/p))) = p * pow p (vp p (m/p)) [pow_Suc] *)
            val psuc = powSucV_at (pF, vp pF mP)           (* oeq (pow p (Suc(vp(m/p))))(mult p (pow p (vp(m/p)))) *)
            (* dvd (pow p (Suc(vp(m/p)))) m : rewrite divisor mult p pow -> pow p (Suc..) via sym psuc *)
            val dPS = dvd_cong_lV (mult pF (pow pF (vp pF mP)), pow pF (suc (vp pF mP)), mF) (oeq_sym OF [psuc]) dmc2;
                       (* dvd (pow p (Suc(vp p (m/p)))) m *)
            (* rewrite vp p m = Suc(vp p (m/p)) (sym vstep) into pow's exponent *)
            val g = (let val zF = Free("zvp",natT)
                         val Pabs = Term.lambda zF (dvd (pow pF zF) mF)
                     in substPredV (Pabs, suc (vp pF mP), vp pF mF) (oeq_sym OF [vstep]) dPS end);
                     (* dvd (pow p (vp p m)) m *)
          in Thm.implies_intr (ctermV (jT (dvd pF mF))) g end;
        (* CASE ~dvd p m *)
        val caseN =
          let
            val hn = Thm.assume (ctermV (jT (neg (dvd pF mF))))
            val vstep = vp_step_ndvd_atV (pF, mF) hPr hpos hn   (* oeq (vp p m) Zero *)
            (* pow p (vp p m) = pow p 0 = 1 *)
            (* dvd 1 m -> rewrite 1 -> pow p (vp p m) *)
            val one_m = one_dvd_atV mF                     (* dvd (Suc 0) m *)
            val p0 = pow0V_at pF                           (* oeq (pow p 0)(Suc 0) *)
            (* dvd (pow p 0) m : rewrite divisor (Suc 0) -> (pow p 0) via sym p0 *)
            val dP0 = dvd_cong_lV (suc ZeroC, pow pF ZeroC, mF) (oeq_sym OF [p0]) one_m;  (* dvd (pow p 0) m *)
            (* rewrite 0 -> vp p m (sym vstep) in exponent *)
            val g = (let val zF = Free("zvn",natT)
                         val Pabs = Term.lambda zF (dvd (pow pF zF) mF)
                     in substPredV (Pabs, ZeroC, vp pF mF) (oeq_sym OF [vstep]) dP0 end);
                     (* dvd (pow p (vp p m)) m *)
          in Thm.implies_intr (ctermV (jT (neg (dvd pF mF)))) g end;
        val body = disjE_elimV (dvd pF mF, neg (dvd pF mF), concl) em caseD caseN;
        (* body : jT (dvd (pow p (vp p m)) m) under meta-hyp jT(lt 0 m).  wrap to object Imp. *)
        val metaImp = Thm.implies_intr (ctermV (jT (lt ZeroC mF))) body;  (* jT(lt 0 m) ==> jT(dvd..) *)
      in impI_V (lt ZeroC mF, dvd (pow pF (vp pF mF)) mF) metaImp end;   (* jT (Pat n_h) = jT (Imp (lt 0 m)(dvd..)) *)
    val stepThm = Thm.forall_intr (ctermV nH) (Thm.implies_intr (ctermV (GpropOf nH)) stepConcl)
    val kF = Free("m", natT)
    val siInst = beta_norm (Drule.infer_instantiate ctxtV
                   [(("P",0), ctermV Ppred),(("k",0), ctermV kF)] strong_induct_vV)
    val Pk = Thm.implies_elim siInst stepThm   (* jT (Pat m) = jT (Imp (lt 0 m)(dvd (pow p (vp p m)) m)) *)
    (* convert object Imp -> meta : assume lt 0 m, mp, re-discharge meta *)
    val hpos2 = Thm.assume (ctermV (jT (lt ZeroC kF)))
    val dvdM  = mp_V (lt ZeroC kF, dvd (pow pF (vp pF kF)) kF) Pk hpos2;  (* jT (dvd (pow p (vp p m)) m) *)
    val metaForm = Thm.implies_intr (ctermV (jT (lt ZeroC kF))) dvdM;    (* jT(lt 0 m) ==> jT(dvd..) *)
    (* discharge prime2 p *)
  in Thm.implies_intr (ctermV (jT (prime2 pF))) metaForm end;

val vp_pow_dvd =
  let val pF = Free("p", natT)
  in varify (mk_vp_pow_dvd pF) end;

val () = out ("vp_pow_dvd 0hyp=" ^ Bool.toString (zhV vp_pow_dvd) ^ "\n");
val i_vp_pow_dvd =
  let val pVz = Var(("p",0),natT); val mVz = Var(("m",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC mVz),
         jT (dvd (pow pVz (vp pVz mVz)) mVz))) end;
val r_vpd = (Thm.prop_of vp_pow_dvd) aconv i_vp_pow_dvd;
val () = out ("vp_pow_dvd aconv=" ^ Bool.toString r_vpd ^ "\n");
val () = if zhV vp_pow_dvd andalso r_vpd then out "VP_POW_DVD_OK\n" else out "VP_POW_DVD_FAIL\n";
val vp_pow_dvd_vV = varify vp_pow_dvd;

(* ---------------------------------------------------------------------------
   HELPER dvd_mult_cancel_l : lt 0 p ==> dvd (mult p a)(mult p b) ==> dvd a b
     dvd (p*a)(p*b) gives p*b = (p*a)*c = p*(a*c) [assoc]; p=Suc k; mult_left_cancel_pos
     => b = a*c => dvd a b.
   --------------------------------------------------------------------------- *)
fun dvd_mult_cancel_l_atV (pT,aT,bT) hpos hdvd =
  let
    (* p = Suc k : dzos p ; p<>0 since lt 0 p *)
    val dzp = dzosV_at pT          (* Disj (oeq p 0)(Ex k. oeq p (Suc k)) *)
    val goalC = dvd aT bT
    val caseZ =
      let val hz = Thm.assume (ctermV (jT (oeq pT ZeroC)))
          (* lt 0 p with p=0 -> le (Suc 0) 0 -> false *)
          val le10 = (let val zF = Free("zdz",natT)
                          val Pabs = Term.lambda zF (le (suc ZeroC) zF)
                      in substPredV (Pabs, pT, ZeroC) hz hpos end)
          val ff = lt_irrefl_atV ZeroC OF [le10]
          val g = Thm.implies_elim (oFalse_elim_V goalC) ff
      in Thm.implies_intr (ctermV (jT (oeq pT ZeroC))) g end;
    val PabsK = Abs("k", natT, oeq pT (suc (Bound 0)))
    val caseS =
      let val hex = Thm.assume (ctermV (jT (mkEx PabsK)))
          fun kbody kF (hk : thm) =    (* hk : oeq p (Suc k) *)
            let
              (* dvd (p*a)(p*b) = Ex c. oeq (p*b)(mult (p*a) c) *)
              val PabsC = Abs("c", natT, oeq (mult pT bT)(mult (mult pT aT) (Bound 0)))
              fun cbody cF (hc : thm) =    (* hc : oeq (p*b)((p*a)*c) *)
                let
                  (* (p*a)*c = p*(a*c) [assoc] *)
                  val assoc = multassocV_at (pT, aT, cF)   (* oeq ((p*a)*c)(p*(a*c)) *)
                  val pbEq = oeq_trans OF [hc, assoc]       (* oeq (p*b)(p*(a*c)) *)
                  (* rewrite p -> Suc k on both sides : oeq ((Suc k)*b)((Suc k)*(a*c)) *)
                  val lhsK = (let val zF = Free("zlk",natT)
                                  val Pabs = Term.lambda zF (oeq (mult zF bT)(mult zF (mult aT cF)))
                              in substPredV (Pabs, pT, suc kF) hk pbEq end)
                              (* oeq ((Suc k)*b)((Suc k)*(a*c)) *)
                  val beq = mult_left_cancel_pos_atV (kF, bT, mult aT cF) lhsK   (* oeq b (a*c) *)
                  val g = dvd_introV (aT, bT, cF) beq      (* dvd a b *)
                in g end;
              val g = exE_elimV (PabsC, goalC) hdvd "c_dmc" cbody
            in g end;
          val g = exE_elimV (PabsK, goalC) hex "k_dmc" kbody
      in Thm.implies_intr (ctermV (jT (mkEx PabsK))) g end;
  in disjE_elimV (oeq pT ZeroC, mkEx PabsK, goalC) dzp caseZ caseS end;

(* ---------------------------------------------------------------------------
   vp_maximal : prime2 p ==> lt 0 m ==> ~(dvd (pow p (Suc (vp p m))) m)
   STRONG INDUCTION on m.  Pat m := Imp (lt 0 m)(neg (dvd (pow p (Suc (vp p m))) m)).
     ~dvd p m : vp=0 ; pow p (Suc 0) = p*1 = p ; ~(dvd p m) -> ~(dvd (pow p (Suc 0)) m).
     dvd p m  : vp=Suc(vp(m/p)) ; assume dvd (pow p (Suc(Suc(vp(m/p)))) ) m for contra ;
                pow p (Suc(Suc k)) = p * pow p (Suc k) ; m = p*(m/p) ;
                dvd (p * pow p (Suc k))(p*(m/p)) ; cancel p : dvd (pow p (Suc k))(m/p) ;
                contradict IH at m/p : ~(dvd (pow p (Suc(vp(m/p))))(m/p)).
   --------------------------------------------------------------------------- *)
fun mk_vp_maximal pF =
  let
    val hPr = Thm.assume (ctermV (jT (prime2 pF)))
    fun Pat t = mkImp (lt ZeroC t)(neg (dvd (pow pF (suc (vp pF t))) t))
    val Ppred = Term.lambda (Free("m_vpm", natT)) (Pat (Free("m_vpm", natT)))
    val nH = Free("n_h", natT)
    fun GpropOf nt = let val jB = Free("j_g", natT)
                     in Logic.all jB (Logic.mk_implies (jT (lt jB nt), jT (Pat jB))) end
    val Hthm = Thm.assume (ctermV (GpropOf nH))
    fun ihAt jt hlt = Thm.implies_elim (Thm.forall_elim (ctermV jt) Hthm) hlt
    val stepConcl =
      let
        val mF = nH
        val hpos = Thm.assume (ctermV (jT (lt ZeroC mF)))
        val em = ex_middle_V (dvd pF mF)
        val concl = neg (dvd (pow pF (suc (vp pF mF))) mF)   (* object neg = Imp .. oFalse *)
        (* CASE dvd p m *)
        val caseD =
          let
            val hd = Thm.assume (ctermV (jT (dvd pF mF)))
            val vstep = vp_step_dvd_atV (pF, mF) hPr hpos hd   (* oeq (vp p m)(Suc(vp p (m/p))) *)
            val mP = rdiv mF pF
            val kk = vp pF mP                                  (* k = vp p (m/p) *)
            val rlt = rdiv_lt_atV (pF, mF) hPr hpos hd
            val rpos= rdiv_pos_atV (pF, mF) hPr hpos hd
            val ihImp = ihAt mP rlt
            val ihNeg = mp_V (lt ZeroC mP, neg (dvd (pow pF (suc kk)) mP)) ihImp rpos;
                        (* ~(dvd (pow p (Suc k))(m/p)) *)
            val mEq = rdiv_mult_exact_atV (pF, mF) (prime2_pos_atV pF hPr) hd;  (* oeq m (mult p (m/p)) *)
            (* assume dvd (pow p (Suc(vp p m))) m -> derive oFalse *)
            val hAssume = Thm.assume (ctermV (jT (dvd (pow pF (suc (vp pF mF))) mF)))
            (* Suc(vp p m) = Suc(Suc k) : rewrite vp p m -> Suc k via vstep *)
            val expEq = Suc_cong OF [vstep]     (* oeq (Suc(vp p m))(Suc(Suc k)) *)
            (* dvd (pow p (Suc(Suc k))) m : rewrite exponent Suc(vp p m) -> Suc(Suc k) *)
            val dSS = (let val zF = Free("zss",natT)
                           val Pabs = Term.lambda zF (dvd (pow pF zF) mF)
                       in substPredV (Pabs, suc (vp pF mF), suc (suc kk)) expEq hAssume end);
                       (* dvd (pow p (Suc(Suc k))) m *)
            (* pow p (Suc(Suc k)) = p * pow p (Suc k) [pow_Suc] *)
            val pSS = powSucV_at (pF, suc kk)   (* oeq (pow p (Suc(Suc k)))(mult p (pow p (Suc k))) *)
            val dProd = dvd_cong_lV (pow pF (suc (suc kk)), mult pF (pow pF (suc kk)), mF) pSS dSS;
                        (* dvd (mult p (pow p (Suc k))) m *)
            (* m = p*(m/p) : rewrite m -> p*(m/p) in dividend *)
            val dProdM = dvd_cong_rV (mult pF (pow pF (suc kk)), mF, mult pF mP) mEq dProd;
                        (* dvd (mult p (pow p (Suc k)))(mult p (m/p)) *)
            (* cancel p : dvd (pow p (Suc k))(m/p) *)
            val lt0p = prime2_pos_atV pF hPr
            val dCancel = dvd_mult_cancel_l_atV (pF, pow pF (suc kk), mP) lt0p dProdM;
                        (* dvd (pow p (Suc k))(m/p) *)
            (* contradiction with ihNeg *)
            val ff = mp_V (dvd (pow pF (suc kk)) mP, oFalseC) ihNeg dCancel;  (* oFalse *)
            val negThm = Thm.implies_intr (ctermV (jT (dvd (pow pF (suc (vp pF mF))) mF))) ff;
                        (* jT(dvd..) ==> jT oFalse *)
            (* wrap to object neg via impI *)
            val g = impI_V (dvd (pow pF (suc (vp pF mF))) mF, oFalseC) negThm;   (* neg(dvd..) *)
          in Thm.implies_intr (ctermV (jT (dvd pF mF))) g end;
        (* CASE ~dvd p m *)
        val caseN =
          let
            val hn = Thm.assume (ctermV (jT (neg (dvd pF mF))))
            val vstep = vp_step_ndvd_atV (pF, mF) hPr hpos hn   (* oeq (vp p m) Zero *)
            (* Suc(vp p m) = Suc 0 : Suc_cong vstep *)
            val expEq = Suc_cong OF [vstep]    (* oeq (Suc(vp p m))(Suc 0) *)
            (* pow p (Suc 0) = p * pow p 0 = p * 1 = p *)
            val pS0 = powSucV_at (pF, ZeroC)   (* oeq (pow p (Suc 0))(mult p (pow p 0)) *)
            val p0  = pow0V_at pF              (* oeq (pow p 0)(Suc 0) *)
            val pp1 = oeq_trans OF [pS0, oeq_trans OF [mult_cong_rV (pF, pow pF ZeroC, suc ZeroC) p0, mult1rV_at pF]];
                      (* oeq (pow p (Suc 0)) p *)
            (* pow p (Suc(vp p m)) = pow p (Suc 0) = p : chain via expEq then pp1 *)
            val expVal = oeq_trans OF [(let val zF = Free("zev",natT)
                                            val Pabs = Term.lambda zF (oeq (pow pF (suc (vp pF mF)))(pow pF zF))
                                        in substPredV (Pabs, suc (vp pF mF), suc ZeroC) expEq (oeqreflV_at (pow pF (suc (vp pF mF)))) end),
                                       pp1];
                         (* oeq (pow p (Suc(vp p m))) p *)
            (* ~(dvd p m) -> ~(dvd (pow p (Suc(vp p m))) m) : rewrite divisor p -> pow.. via sym expVal *)
            (* hn : neg (dvd p m) = Imp (dvd p m) oFalse.  We want neg (dvd (pow..) m).
               assume dvd (pow..) m ; rewrite divisor (pow..) -> p via expVal ; dvd p m ; mp hn -> oFalse. *)
            val hAssume = Thm.assume (ctermV (jT (dvd (pow pF (suc (vp pF mF))) mF)))
            val dpm = dvd_cong_lV (pow pF (suc (vp pF mF)), pF, mF) expVal hAssume;  (* dvd p m *)
            val ff  = mp_V (dvd pF mF, oFalseC) hn dpm;   (* oFalse *)
            val negThm = Thm.implies_intr (ctermV (jT (dvd (pow pF (suc (vp pF mF))) mF))) ff;
            val g = impI_V (dvd (pow pF (suc (vp pF mF))) mF, oFalseC) negThm;
          in Thm.implies_intr (ctermV (jT (neg (dvd pF mF)))) g end;
        val body = disjE_elimV (dvd pF mF, neg (dvd pF mF), concl) em caseD caseN;
        val metaImp = Thm.implies_intr (ctermV (jT (lt ZeroC mF))) body;
      in impI_V (lt ZeroC mF, neg (dvd (pow pF (suc (vp pF mF))) mF)) metaImp end;
    val stepThm = Thm.forall_intr (ctermV nH) (Thm.implies_intr (ctermV (GpropOf nH)) stepConcl)
    val kF = Free("m", natT)
    val siInst = beta_norm (Drule.infer_instantiate ctxtV
                   [(("P",0), ctermV Ppred),(("k",0), ctermV kF)] strong_induct_vV)
    val Pk = Thm.implies_elim siInst stepThm
    val hpos2 = Thm.assume (ctermV (jT (lt ZeroC kF)))
    val negM  = mp_V (lt ZeroC kF, neg (dvd (pow pF (suc (vp pF kF))) kF)) Pk hpos2;
    val metaForm = Thm.implies_intr (ctermV (jT (lt ZeroC kF))) negM;
  in Thm.implies_intr (ctermV (jT (prime2 pF))) metaForm end;

val vp_maximal =
  let val pF = Free("p", natT)
  in varify (mk_vp_maximal pF) end;

val () = out ("vp_maximal 0hyp=" ^ Bool.toString (zhV vp_maximal) ^ "\n");
val i_vp_maximal =
  let val pVz = Var(("p",0),natT); val mVz = Var(("m",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC mVz),
         jT (neg (dvd (pow pVz (suc (vp pVz mVz))) mVz)))) end;
val r_vpm = (Thm.prop_of vp_maximal) aconv i_vp_maximal;
val () = out ("vp_maximal aconv=" ^ Bool.toString r_vpm ^ "\n");
val () = if zhV vp_maximal andalso r_vpm then out "VP_MAXIMAL_OK\n" else out "VP_MAXIMAL_FAIL\n";
val vp_maximal_vV = varify vp_maximal;

val () = if zhV vp_pow_dvd andalso r_vpd andalso zhV vp_maximal andalso r_vpm
         then out "VP_CORE_HALF_OK\n" else out "VP_CORE_HALF_PARTIAL\n";  (* vp_additive completes VP_CORE; see VA stage *)

(* ============================================================================
   vp_additive : prime2 p ==> lt 0 a ==> lt 0 b ==> oeq (vp p (mult a b))(add (vp p a)(vp p b))
   via UNIQUENESS (vp_pow_dvd + vp_maximal determine vp).
   ============================================================================ *)
val () = out "VA_BEGIN\n";

val pow_add_vV  = varify pow_add;
val dvd_refl_vV = varify dvd_refl;
fun pow_add_atV (at,mt,nt) = beta_norm (Drule.infer_instantiate ctxtV
        [(("a",0), ctermV at),(("m",0), ctermV mt),(("n",0), ctermV nt)] pow_add_vV);
fun dvd_refl_atV t = beta_norm (Drule.infer_instantiate ctxtV [(("a",0), ctermV t)] dvd_refl_vV);

(* pow congruence in exponent: oeq i j -> oeq (pow p i)(pow p j) *)
fun pow_cong_expV (pT, iT, jT_) hij =
  let val zF = Free("zpc", natT)
      val Pabs = Term.lambda zF (oeq (pow pT iT)(pow pT zF))
  in substPredV (Pabs, iT, jT_) hij (oeqreflV_at (pow pT iT)) end;

(* pow_dvd_mono : le i j ==> dvd (pow p i)(pow p j) *)
fun pow_dvd_mono_atV (pT,iT,jT_) hle =
  let
    val PabsLe = Abs("d", natT, oeq jT_ (add iT (Bound 0)))
    val goalC = dvd (pow pT iT)(pow pT jT_)
    fun body dF (hd : thm) =     (* hd : oeq j (add i d) *)
      let
        val padd = pow_add_atV (pT, iT, dF)         (* oeq (pow p (i+d))(mult (pow p i)(pow p d)) *)
        val drefl = dvd_refl_atV (pow pT iT)        (* dvd (pow p i)(pow p i) *)
        val dprod = dvd_mult_right_atV (pow pT iT, pow pT iT, pow pT dF) drefl;  (* dvd (pow p i)(mult (pow p i)(pow p d)) *)
        val dij1 = dvd_cong_rV (pow pT iT, mult (pow pT iT)(pow pT dF), pow pT (add iT dF)) (oeq_sym OF [padd]) dprod;
                   (* dvd (pow p i)(pow p (i+d)) *)
        val idj = pow_cong_expV (pT, add iT dF, jT_) (oeq_sym OF [hd]);   (* oeq (pow p (i+d))(pow p j) *)
        val g = dvd_cong_rV (pow pT iT, pow pT (add iT dF), pow pT jT_) idj dij1;  (* dvd (pow p i)(pow p j) *)
      in g end;
  in exE_elimV (PabsLe, goalC) hle "d_pdm" body end;
val () = out "VA_POWDVDMONO_OK\n";

(* dvd_mult_both : dvd a c ==> dvd b d ==> dvd (mult a b)(mult c d) *)
fun dvd_mult_both_atV (aT,bT,cT,dT) hac hbd =
  let
    val d1 = dvd_mult_cong_atV (aT, cT, bT) hac;     (* dvd (a*b)(c*b) *)
    val d2raw = dvd_mult_cong_atV (bT, dT, cT) hbd;  (* dvd (b*c)(d*c) *)
    val d2a = dvd_cong_lV (mult bT cT, mult cT bT, mult dT cT) (multcommV_at (bT,cT)) d2raw;  (* dvd (c*b)(d*c) *)
    val d2  = dvd_cong_rV (mult cT bT, mult dT cT, mult cT dT) (multcommV_at (dT,cT)) d2a;    (* dvd (c*b)(c*d) *)
    val g = dvd_trans_atV (mult aT bT, mult cT bT, mult cT dT) d1 d2;   (* dvd (a*b)(c*d) *)
  in g end;
val () = out "VA_DVDMULTBOTH_OK\n";

(* le m n => Disj (lt m n)(oeq m n) *)
fun le_cases_atV (mT, nT) hle =
  let
    val PabsP = Abs("p", natT, oeq nT (add mT (Bound 0)))
    val goalC = mkDisj (lt mT nT)(oeq mT nT)
    fun body wF (hw : thm) =     (* hw : oeq n (add m w) *)
      let val dzw = dzosV_at wF
          val caseW0 =
            let val hw0 = Thm.assume (ctermV (jT (oeq wF ZeroC)))
                val nm = oeq_trans OF [hw, oeq_trans OF [add_cong_rV (mT, wF, ZeroC) hw0, add0rV_at mT]];  (* oeq n m *)
                val mn = oeq_sym OF [nm]
            in Thm.implies_intr (ctermV (jT (oeq wF ZeroC))) (disjI2V_at (lt mT nT, oeq mT nT) mn) end;
          val PabsQ = Abs("q", natT, oeq wF (suc (Bound 0)))
          val caseWS =
            let val hexq = Thm.assume (ctermV (jT (mkEx PabsQ)))
                fun qb qF (hq : thm) =
                  let val nmSq = oeq_trans OF [hw, add_cong_rV (mT, wF, suc qF) hq];  (* oeq n (add m (Suc q)) *)
                      val mSq = addSrV_at (mT, qF)
                      val Smq = oeq_sym OF [addSucV_at (mT, qF)]
                      val nSmq = oeq_trans OF [nmSq, oeq_trans OF [mSq, Smq]];   (* oeq n ((Suc m)+q) *)
                      val leSmn = le_introV (suc mT, nT, qF) nSmq;  (* le (Suc m) n = lt m n *)
                  in disjI1V_at (lt mT nT, oeq mT nT) leSmn end;
                val g = exE_elimV (PabsQ, goalC) hexq "q_lc" qb
            in Thm.implies_intr (ctermV (jT (mkEx PabsQ))) g end;
      in disjE_elimV (oeq wF ZeroC, mkEx PabsQ, goalC) dzw caseW0 caseWS end;
  in exE_elimV (PabsP, goalC) hle "w_lc" body end;

(* vp_unique : prime2 p ==> lt 0 m ==> dvd (pow p k) m ==> ~(dvd (pow p (Suc k)) m) ==> oeq (vp p m) k *)
fun vp_unique_atV (pT,mT,kT) hPr hpos hdvdk hndvdSk =
  let
    val vv = vp pT mT
    val vpd = (let val inst = beta_norm (Drule.infer_instantiate ctxtV [(("p",0), ctermV pT),(("m",0), ctermV mT)] vp_pow_dvd_vV)
               in (inst OF [hPr]) OF [hpos] end);           (* dvd (pow p v) m *)
    val vmx = (let val inst = beta_norm (Drule.infer_instantiate ctxtV [(("p",0), ctermV pT),(("m",0), ctermV mT)] vp_maximal_vV)
               in (inst OF [hPr]) OF [hpos] end);           (* ~(dvd (pow p (Suc v)) m) *)
    val goalC = oeq vv kT
    val tot = le_total_atV (vv, kT)        (* Disj (le v k)(le k v) *)
    val caseVK =
      let val hle = Thm.assume (ctermV (jT (le vv kT)))
          val dc = le_cases_atV (vv, kT) hle      (* Disj (lt v k)(oeq v k) *)
          val cLt =
            let val hlt = Thm.assume (ctermV (jT (lt vv kT)))
                val dmono = pow_dvd_mono_atV (pT, suc vv, kT) hlt;
                val dSvm = dvd_trans_atV (pow pT (suc vv), pow pT kT, mT) dmono hdvdk;
                val ff = mp_V (dvd (pow pT (suc vv)) mT, oFalseC) vmx dSvm;
                val g = Thm.implies_elim (oFalse_elim_V goalC) ff
            in Thm.implies_intr (ctermV (jT (lt vv kT))) g end;
          val cEq =
            let val heq = Thm.assume (ctermV (jT (oeq vv kT)))
            in Thm.implies_intr (ctermV (jT (oeq vv kT))) heq end;
          val g = disjE_elimV (lt vv kT, oeq vv kT, goalC) dc cLt cEq
      in Thm.implies_intr (ctermV (jT (le vv kT))) g end;
    val caseKV =
      let val hle = Thm.assume (ctermV (jT (le kT vv)))
          val dc = le_cases_atV (kT, vv) hle      (* Disj (lt k v)(oeq k v) *)
          val cLt =
            let val hlt = Thm.assume (ctermV (jT (lt kT vv)))
                val dmono = pow_dvd_mono_atV (pT, suc kT, vv) hlt;
                val dSkm = dvd_trans_atV (pow pT (suc kT), pow pT vv, mT) dmono vpd;
                val ff = mp_V (dvd (pow pT (suc kT)) mT, oFalseC) hndvdSk dSkm;
                val g = Thm.implies_elim (oFalse_elim_V goalC) ff
            in Thm.implies_intr (ctermV (jT (lt kT vv))) g end;
          val cEq =
            let val heq = Thm.assume (ctermV (jT (oeq kT vv)))
            in Thm.implies_intr (ctermV (jT (oeq kT vv))) (oeq_sym OF [heq]) end;
          val g = disjE_elimV (lt kT vv, oeq kT vv, goalC) dc cLt cEq
      in Thm.implies_intr (ctermV (jT (le kT vv))) g end;
  in disjE_elimV (le vv kT, le kT vv, goalC) tot caseVK caseKV end;
val () = out "VA_VPUNIQUE_OK\n";

(* vp_factor : prime2 p ==> lt 0 m ==> Ex m'. oeq m (mult (pow p (vp p m)) m') /\ ~(dvd p m') *)
fun vp_factorBodyAbs (pT, mT) =
  let val mpF = Free("z_vf", natT)
  in Term.lambda mpF (mkConj (oeq mT (mult (pow pT (vp pT mT)) mpF)) (neg (dvd pT mpF))) end;
fun vp_factor_atV (pT,mT) hPr hpos =
  let
    val vv = vp pT mT
    val vpd = (let val inst = beta_norm (Drule.infer_instantiate ctxtV [(("p",0), ctermV pT),(("m",0), ctermV mT)] vp_pow_dvd_vV)
               in (inst OF [hPr]) OF [hpos] end);
    val vmx = (let val inst = beta_norm (Drule.infer_instantiate ctxtV [(("p",0), ctermV pT),(("m",0), ctermV mT)] vp_maximal_vV)
               in (inst OF [hPr]) OF [hpos] end);
    val goalEx = mkEx (vp_factorBodyAbs (pT, mT))
    val PabsK = Abs("k", natT, oeq mT (mult (pow pT vv) (Bound 0)))
    fun body mpF (hmp : thm) =     (* hmp : oeq m (mult (pow p v) m') *)
      let
        val hdp = Thm.assume (ctermV (jT (dvd pT mpF)))   (* dvd p m' *)
        val dmc = dvd_mult_cong_atV (pT, mpF, pow pT vv) hdp;   (* dvd (mult p (pow p v))(mult m' (pow p v)) *)
        val dmc1 = dvd_cong_lV (mult pT (pow pT vv), mult (pow pT vv) pT, mult mpF (pow pT vv)) (multcommV_at (pT, pow pT vv)) dmc;
        val dmc2 = dvd_cong_rV (mult (pow pT vv) pT, mult mpF (pow pT vv), mult (pow pT vv) mpF) (multcommV_at (mpF, pow pT vv)) dmc1;
                   (* dvd (mult (pow p v) p)(mult (pow p v) m') *)
        val psuc = powSucV_at (pT, vv)     (* oeq (pow p (Suc v))(mult p (pow p v)) *)
        val psuc2 = oeq_trans OF [psuc, multcommV_at (pT, pow pT vv)];  (* oeq (pow p (Suc v))(mult (pow p v) p) *)
        val dSv1 = dvd_cong_lV (mult (pow pT vv) pT, pow pT (suc vv), mult (pow pT vv) mpF) (oeq_sym OF [psuc2]) dmc2;
                   (* dvd (pow p (Suc v))(mult (pow p v) m') *)
        val dSvm = dvd_cong_rV (pow pT (suc vv), mult (pow pT vv) mpF, mT) (oeq_sym OF [hmp]) dSv1;
                   (* dvd (pow p (Suc v)) m *)
        val ff = mp_V (dvd (pow pT (suc vv)) mT, oFalseC) vmx dSvm;
        val ndp = impI_V (dvd pT mpF, oFalseC) (Thm.implies_intr (ctermV (jT (dvd pT mpF))) ff);  (* ~(dvd p m') *)
        val conj = conjI_V (oeq mT (mult (pow pT vv) mpF), neg (dvd pT mpF)) hmp ndp;
        val exG = (beta_norm (Drule.infer_instantiate ctxtV
                     [(("P",0), ctermV (vp_factorBodyAbs (pT,mT))),(("a",0), ctermV mpF)] exI_vV)) OF [conj];
      in exG end;
  in exE_elimV (PabsK, goalEx) vpd "mp_vf" body end;
val () = out "VA_VPFACTOR_OK\n";

(* ---------------------------------------------------------------------------
   vp_additive proper.  Let va=vp p a, vb=vp p b.
   vp_factor a : a = p^va * a', ~p|a'.   vp_factor b : b = p^vb * b', ~p|b'.
   ab = p^va*a' * p^vb*b' = p^(va+vb) * (a'*b')  [comm/assoc/pow_add].
   dvd (pow p (va+vb)) (ab)  [witness a'*b'].
   ~(dvd (pow p (Suc(va+vb)))(ab)) : else pow p (Suc(va+vb))=p^(va+vb)*p | p^(va+vb)*(a'b')
     -> cancel p^(va+vb) -> p | a'b' -> euclid -> p|a' or p|b' -> contra.
   vp_unique : oeq (vp p (ab)) (va+vb).
   --------------------------------------------------------------------------- *)
fun pow_pos_atV (pT, kT) hPos =     (* lt 0 p ==> lt 0 (pow p k) : induction on k.  p>0 -> p^k>0. *)
  let
    (* prove by nat_induct on k : Pat k = lt 0 (pow p k).
       NOTE: lt introduces a binder, so abstract over a FRESH Free (not raw Bound 0). *)
    val zPF = Free("z_pp", natT)
    val Pabs = Term.lambda zPF (lt ZeroC (pow pT zPF))
    val ind = beta_norm (Drule.infer_instantiate ctxtV [(("P",0), ctermV Pabs),(("k",0), ctermV kT)] nat_induct_vV)
    (* base : lt 0 (pow p 0) = lt 0 1 ; pow p 0 = 1 ; lt 0 1 = le 1 1 = le_refl *)
    val p0 = pow0V_at pT       (* oeq (pow p 0)(Suc 0) *)
    val le11 = le_refl_atV (suc ZeroC)   (* le (Suc 0)(Suc 0) = lt 0 1 *)
    val base = (let val zF = Free("zpb",natT)
                    val Pb = Term.lambda zF (le (suc ZeroC) zF)
                in substPredV (Pb, suc ZeroC, pow pT ZeroC) (oeq_sym OF [p0]) le11 end);  (* lt 0 (pow p 0) *)
    val xF = Free("x", natT)
    val ihP = jT (lt ZeroC (pow pT xF))
    val IH = Thm.assume (ctermV ihP)
    (* step : lt 0 (pow p (Suc x)) ; pow p (Suc x) = p * pow p x ; lt 0 p, lt 0 (pow p x) -> lt 0 (p*pow) *)
    val pS = powSucV_at (pT, xF)      (* oeq (pow p (Suc x))(mult p (pow p x)) *)
    (* lt 0 (mult p (pow p x)) : le 1 p, le 1 (pow p x) -> le (1*1)(p*pow) = le 1 (p*pow) via mult_le_mono2 *)
    val mlm = mult_le_mono2_atV (suc ZeroC, pT, suc ZeroC, pow pT xF) hPos IH;  (* le (1*1)(p*pow) *)
    val m11 = mult1lV_at (suc ZeroC)   (* oeq (mult (Suc 0)(Suc 0))(Suc 0) *)
    val lt0prod = (let val zF = Free("zps",natT)
                       val Pb = Term.lambda zF (le zF (mult pT (pow pT xF)))
                   in substPredV (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end);  (* le 1 (p*pow) *)
    val stepC = (let val zF = Free("zss2",natT)
                     val Pb = Term.lambda zF (le (suc ZeroC) zF)
                 in substPredV (Pb, mult pT (pow pT xF), pow pT (suc xF)) (oeq_sym OF [pS]) lt0prod end);  (* lt 0 (pow p (Suc x)) *)
    val step = Thm.forall_intr (ctermV xF) (Thm.implies_intr (ctermV ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

val vp_additive =
  let
    val pF = Free("p", natT); val aF = Free("a", natT); val bF = Free("b", natT);
    val hPr  = Thm.assume (ctermV (jT (prime2 pF)))
    val hap  = Thm.assume (ctermV (jT (lt ZeroC aF)))
    val hbp  = Thm.assume (ctermV (jT (lt ZeroC bF)))
    val lt0p = prime2_pos_atV pF hPr
    val va = vp pF aF; val vb = vp pF bF
    val abT = mult aF bF
    (* ab > 0 : a>0,b>0 -> a*b>0 via mult_le_mono2 on le 1 a, le 1 b then 1*1=1 *)
    val abpos =
      let val mlm = mult_le_mono2_atV (suc ZeroC, aF, suc ZeroC, bF) hap hbp   (* le (1*1)(a*b) *)
          val m11 = mult1lV_at (suc ZeroC)
      in (let val zF = Free("zab",natT) val Pb = Term.lambda zF (le zF abT)
          in substPredV (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end) end;   (* lt 0 (a*b) *)
    val goalC = oeq (vp pF abT)(add va vb)
    (* factor a, factor b *)
    val facA = vp_factor_atV (pF, aF) hPr hap   (* Ex a'. a = p^va*a' /\ ~p|a' *)
    val facB = vp_factor_atV (pF, bF) hPr hbp
    fun bodyA apF (haC : thm) =    (* haC : Conj (oeq a (mult (pow p va) a'))(neg (dvd p a')) *)
      let
        val aEq = conjunct1_V (oeq aF (mult (pow pF va) apF), neg (dvd pF apF)) haC;  (* oeq a (p^va*a') *)
        val napA = conjunct2_V (oeq aF (mult (pow pF va) apF), neg (dvd pF apF)) haC;  (* ~p|a' *)
        fun bodyB bpF (hbC : thm) =
          let
            val bEq = conjunct1_V (oeq bF (mult (pow pF vb) bpF), neg (dvd pF bpF)) hbC;
            val nbpB = conjunct2_V (oeq bF (mult (pow pF vb) bpF), neg (dvd pF bpF)) hbC;
            (* ab = (p^va*a')*(p^vb*b') = p^(va+vb)*(a'*b') *)
            (* step: ab = (p^va*a')*(p^vb*b') via cong both *)
            val abFac = oeq_trans OF [mult_cong_lV (aF, mult (pow pF va) apF, bF) aEq,
                                      mult_cong_rV (mult (pow pF va) apF, bF, mult (pow pF vb) bpF) bEq];
                        (* oeq (a*b)((p^va*a')*(p^vb*b')) *)
            (* rearrange (X*a')*(Y*b') = (X*Y)*(a'*b') where X=p^va, Y=p^vb.
               (X*a')*(Y*b') = X*(a'*(Y*b')) [assoc] = X*((a'*Y)*b') [assoc sym] = X*((Y*a')*b') [comm]
                             = X*(Y*(a'*b')) [assoc] = (X*Y)*(a'*b') [assoc sym] *)
            val X = pow pF va; val Y = pow pF vb; val A = apF; val B = bpF
            val r1 = multassocV_at (X, A, mult Y B)            (* (X*A)*(Y*B) = X*(A*(Y*B)) *)
            val r2 = oeq_sym OF [multassocV_at (A, Y, B)]      (* A*(Y*B) = (A*Y)*B  -> sym: (A*Y)*B ... wait *)
            (* multassoc A Y B : (A*Y)*B = A*(Y*B) ; sym: A*(Y*B) = (A*Y)*B *)
            val r2b = oeq_sym OF [multassocV_at (A, Y, B)]     (* oeq (A*(Y*B))((A*Y)*B) *)
            val r3 = mult_cong_lV (mult A Y, mult Y A, B) (multcommV_at (A, Y))   (* (A*Y)*B = (Y*A)*B *)
            val r4 = multassocV_at (Y, A, B)                   (* (Y*A)*B = Y*(A*B) *)
            (* X*(A*(Y*B)) = X*((A*Y)*B) = X*((Y*A)*B) = X*(Y*(A*B)) *)
            val inner = oeq_trans OF [r2b, oeq_trans OF [r3, r4]]   (* oeq (A*(Y*B))(Y*(A*B)) *)
            val r5 = mult_cong_rV (X, mult A (mult Y B), mult Y (mult A B)) inner   (* X*(A*(Y*B)) = X*(Y*(A*B)) *)
            val r6 = oeq_sym OF [multassocV_at (X, Y, mult A B)]    (* X*(Y*(A*B)) = (X*Y)*(A*B) *)
            val rearr = oeq_trans OF [r1, oeq_trans OF [r5, r6]]   (* oeq ((X*A)*(Y*B))((X*Y)*(A*B)) *)
            (* X*Y = p^(va+vb) [pow_add sym] *)
            val padd = pow_add_atV (pF, va, vb)    (* oeq (pow p (va+vb))(mult X Y) *)
            val rearr2 = oeq_trans OF [rearr, mult_cong_lV (mult X Y, pow pF (add va vb), mult A B) (oeq_sym OF [padd])];
                         (* oeq ((X*A)*(Y*B))((p^(va+vb))*(A*B)) *)
            val abPow = oeq_trans OF [abFac, rearr2];   (* oeq (a*b)((p^(va+vb))*(A*B)) *)
            (* dvd (pow p (va+vb))(a*b) : witness A*B, a*b = p^(va+vb)*(A*B) *)
            val ddvd = dvd_introV (pow pF (add va vb), abT, mult A B) abPow;  (* dvd (pow p (va+vb))(a*b) *)
            (* ~(dvd (pow p (Suc(va+vb)))(a*b)) *)
            val hAssume = Thm.assume (ctermV (jT (dvd (pow pF (suc (add va vb))) abT)))
            (* pow p (Suc(va+vb)) = p^(va+vb) * p [pow_Suc + comm] ; a*b = p^(va+vb)*(A*B) ;
               dvd (p^(va+vb)*p)(p^(va+vb)*(A*B)) ; cancel? need cancel by p^(va+vb) (pos). *)
            (* rewrite dividend a*b -> p^(va+vb)*(A*B) *)
            val dAB = dvd_cong_rV (pow pF (suc (add va vb)), abT, mult (pow pF (add va vb))(mult A B)) abPow hAssume;
                      (* dvd (pow p (Suc(va+vb)))(p^(va+vb)*(A*B)) *)
            (* pow p (Suc(va+vb)) = mult (pow p (va+vb)) p *)
            val pS = powSucV_at (pF, add va vb)   (* oeq (pow p (Suc(va+vb)))(mult p (pow p (va+vb))) *)
            val pS2 = oeq_trans OF [pS, multcommV_at (pF, pow pF (add va vb))];  (* oeq .. (mult (pow p (va+vb)) p) *)
            val dAB2 = dvd_cong_lV (pow pF (suc (add va vb)), mult (pow pF (add va vb)) pF, mult (pow pF (add va vb))(mult A B)) pS2 dAB;
                       (* dvd (mult (pow p (va+vb)) p)(mult (pow p (va+vb))(A*B)) *)
            (* cancel pow p (va+vb) (pos) -> dvd p (A*B) *)
            val powpos = pow_pos_atV (pF, add va vb) lt0p   (* lt 0 (pow p (va+vb)) *)
            val dpAB = dvd_mult_cancel_l_atV (pow pF (add va vb), pF, mult A B) powpos dAB2;  (* dvd p (A*B) *)
            (* euclid : dvd p A \/ dvd p B *)
            val disjAB = euclid_atV (pF, A, B) hPr dpAB   (* Disj (dvd p A)(dvd p B) *)
            val cA = let val hda = Thm.assume (ctermV (jT (dvd pF A)))
                         val ff = mp_V (dvd pF A, oFalseC) napA hda
                     in Thm.implies_intr (ctermV (jT (dvd pF A))) ff end;
            val cB = let val hdb = Thm.assume (ctermV (jT (dvd pF B)))
                         val ff = mp_V (dvd pF B, oFalseC) nbpB hdb
                     in Thm.implies_intr (ctermV (jT (dvd pF B))) ff end;
            val ff = disjE_elimV (dvd pF A, dvd pF B, oFalseC) disjAB cA cB;  (* oFalse *)
            val nSk = impI_V (dvd (pow pF (suc (add va vb))) abT, oFalseC)
                        (Thm.implies_intr (ctermV (jT (dvd (pow pF (suc (add va vb))) abT))) ff);
                      (* ~(dvd (pow p (Suc(va+vb)))(a*b)) *)
            (* vp_unique : oeq (vp p (a*b))(va+vb) *)
            val g = vp_unique_atV (pF, abT, add va vb) hPr abpos ddvd nSk;
          in g end;
        val g = exE_elimV (vp_factorBodyAbs (pF, bF), goalC) facB "bp_va" bodyB
      in g end;
    val concl = exE_elimV (vp_factorBodyAbs (pF, aF), goalC) facA "ap_va" bodyA
    val d1 = Thm.implies_intr (ctermV (jT (lt ZeroC bF))) concl
    val d2 = Thm.implies_intr (ctermV (jT (lt ZeroC aF))) d1
    val d3 = Thm.implies_intr (ctermV (jT (prime2 pF))) d2
  in varify d3 end;

val () = out ("vp_additive 0hyp=" ^ Bool.toString (zhV vp_additive) ^ "\n");
val i_vp_additive =
  let val pVz = Var(("p",0),natT); val aVz = Var(("a",0),natT); val bVz = Var(("b",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC aVz),
         Logic.mk_implies (jT (lt ZeroC bVz),
           jT (oeq (vp pVz (mult aVz bVz))(add (vp pVz aVz)(vp pVz bVz)))))) end;
val r_vpa = (Thm.prop_of vp_additive) aconv i_vp_additive;
val () = out ("vp_additive aconv=" ^ Bool.toString r_vpa ^ "\n");
val () = if zhV vp_additive andalso r_vpa then out "VP_ADDITIVE_OK\n" else out "VP_ADDITIVE_FAIL\n";
val vp_additive_vV = varify vp_additive;

(* VP_CORE complete : vp primitive + vp_pow_dvd + vp_maximal + vp_additive all 0-hyp + aconv *)
val () = if zhV vp_pow_dvd andalso r_vpd andalso zhV vp_maximal andalso r_vpm
            andalso zhV vp_additive andalso r_vpa
         then out "VP_CORE_OK\n" else out "VP_CORE_PARTIAL\n";

(* ============================================================================
   F3 banked-stage soundness audit (R + F01 + VP_CORE + VP_ADDITIVE).
   ============================================================================ *)
val () = out "F3_AUDIT_BEGIN\n";
(* soundness probes : kernel must REJECT false variants *)
val s_floor01_cond =     (* floor01 must keep the lt 0 q premise (not unconditional) *)
  let val nV = Var(("n",0),natT); val qV = Var(("q",0),natT)
  in not ((Thm.prop_of floor01) aconv
       (jT (mkDisj (oeq (tflo nV qV) ZeroC)(oeq (tflo nV qV) (suc ZeroC))))) end;
val s_vpa_cond =         (* vp_additive must keep lt 0 a / lt 0 b (drop a-positivity changes it) *)
  let val pVz = Var(("p",0),natT); val aVz = Var(("a",0),natT); val bVz = Var(("b",0),natT)
  in not ((Thm.prop_of vp_additive) aconv
       (Logic.mk_implies (jT (prime2 pVz),
          Logic.mk_implies (jT (lt ZeroC bVz),
            jT (oeq (vp pVz (mult aVz bVz))(add (vp pVz aVz)(vp pVz bVz))))))) end;
val s_vpmax_cond =       (* vp_maximal must be the Suc(vp)+1 nondivisibility, not vp itself dividing-failure *)
  let val pVz = Var(("p",0),natT); val mVz = Var(("m",0),natT)
  in not ((Thm.prop_of vp_maximal) aconv
       (Logic.mk_implies (jT (prime2 pVz),
          Logic.mk_implies (jT (lt ZeroC mVz),
            jT (neg (dvd (pow pVz (vp pVz mVz)) mVz)))))) end;   (* would contradict vp_pow_dvd if provable *)
val () = out ("PROBE floor01-conditional=" ^ Bool.toString s_floor01_cond
            ^ " vp_additive-conditional=" ^ Bool.toString s_vpa_cond
            ^ " vp_maximal-shape=" ^ Bool.toString s_vpmax_cond ^ "\n");

val () =
  let
    val thy = Proof_Context.theory_of ctxtV
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nRdiv = length (List.filter (fn s => String.isSubstring "div_mod_eq" s
                                          orelse String.isSubstring "rmod_lt" s) names)
    val nVp   = length (List.filter (fn s => String.isSubstring "vp_step" s) names)
  in out ("F3_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " rdiv_axioms=" ^ Int.toString nRdiv
          ^ " vp_recursion_axioms=" ^ Int.toString nVp ^ "\n") end;

val f3_all =
  zhV div_mod_eq_vV andalso zhV rmod_lt_vV
  andalso zhV floor01 andalso r_floor01 andalso s_floor01_cond
  andalso zhV vp_pow_dvd andalso r_vpd
  andalso zhV vp_maximal andalso r_vpm andalso s_vpmax_cond
  andalso zhV vp_additive andalso r_vpa andalso s_vpa_cond;
val () = if f3_all then out "BERTRAND_F3_BANK_OK\n" else out "BERTRAND_F3_BANK_PARTIAL\n";
val () = out "F3_AUDIT_DONE\n";

(* ============================================================================
   BERTRAND F3b — finish the valuation WALL toward Bertrand's postulate.
   Stages:  (P) fact_pos + MULTIPLES PRODUCT ;  (L) legendre_rec ;
            (B) vp_binom_rec ;  (LE) vp_le.
   All on the F3 final context ctxtV / ctermV / thyV.
   ============================================================================ *)
val () = out "F3B_BEGIN\n";

(* re-varify fact axioms onto ctxtV *)
val fact_0_vV   = varify fact_0_ax;
val fact_Suc_vV = varify fact_Suc_ax;
fun fact0V_at ()  = fact_0_vV;
fun factSucV_at t = beta_norm (Drule.infer_instantiate ctxtV [(("n",0), ctermV t)] fact_Suc_vV);

(* ---------------------------------------------------------------------------
   (P)  fact_pos : lt 0 (fact N)     by nat_induct on N.
        base : fact 0 = 1, lt 0 1.
        step : fact (Suc x) = (Suc x)*(fact x) ; le 1 (Suc x), le 1 (fact x) ->
               le (1*1)((Suc x)*(fact x)) = le 1 (...) via mult_le_mono2.
   --------------------------------------------------------------------------- *)
val () = out "FACTPOS_BEGIN\n";
val fact_pos =
  let
    val NF = Free("N", natT)
    val zPF = Free("z_fp", natT)
    val Pabs = Term.lambda zPF (lt ZeroC (fact zPF))     (* lt 0 (fact .) *)
    val ind = beta_norm (Drule.infer_instantiate ctxtV [(("P",0), ctermV Pabs),(("k",0), ctermV NF)] nat_induct_vV)
    (* base : lt 0 (fact 0) ; fact 0 = 1 (fact_0) ; lt 0 1 = le 1 1 = le_refl *)
    val f0 = fact0V_at ()                 (* oeq (fact 0)(Suc 0) *)
    val le11 = le_refl_atV (suc ZeroC)    (* le (Suc 0)(Suc 0) = lt 0 1 *)
    val base = (let val zF = Free("zfpb",natT)
                    val Pb = Term.lambda zF (le (suc ZeroC) zF)
                in substPredV (Pb, suc ZeroC, fact ZeroC) (oeq_sym OF [f0]) le11 end);  (* lt 0 (fact 0) *)
    val xF = Free("x", natT)
    val ihP = jT (lt ZeroC (fact xF))
    val IH = Thm.assume (ctermV ihP)      (* lt 0 (fact x) = le 1 (fact x) *)
    (* step : lt 0 (fact (Suc x)).  fact (Suc x) = (Suc x)*(fact x). *)
    val fS = factSucV_at xF               (* oeq (fact (Suc x))(mult (Suc x)(fact x)) *)
    (* le 1 (Suc x) : 1 = Suc 0 <= Suc x via le_suc_mono on le 0 x (le_add/le_total?) -- use le 1 (Suc x) directly:
       le (Suc 0)(Suc x) from le 0 x via le_suc_mono.  le 0 x = le_add? Actually le 0 x always.  *)
    (* le 0 x : le_add at (0,x) gives le 0 (0+x); 0+x=x ; OR simpler: le 0 anything.  Use le_add_atV (ZeroC, xF): le 0 (add 0 x). *)
    val le0x = (let val la = le_add_atV (ZeroC, xF)         (* le 0 (add 0 x) *)
                    val a0 = add0V_at xF                     (* oeq (add 0 x) x *)
                in (let val zF = Free("zl0x",natT)
                        val Pb = Term.lambda zF (le ZeroC zF)
                    in substPredV (Pb, add ZeroC xF, xF) a0 la end) end);   (* le 0 x *)
    val le1Sx = le_suc_mono_atV (ZeroC, xF) le0x;            (* le (Suc 0)(Suc x) = le 1 (Suc x) *)
    (* mult_le_mono2 : le 1 (Suc x) -> le 1 (fact x) -> le (1*1)((Suc x)*(fact x)) *)
    val mlm = mult_le_mono2_atV (suc ZeroC, suc xF, suc ZeroC, fact xF) le1Sx IH;  (* le (1*1)((Suc x)*(fact x)) *)
    val m11 = mult1lV_at (suc ZeroC)      (* oeq (mult (Suc 0)(Suc 0))(Suc 0) *)
    val lt0prod = (let val zF = Free("zfps",natT)
                       val Pb = Term.lambda zF (le zF (mult (suc xF)(fact xF)))
                   in substPredV (Pb, mult (suc ZeroC)(suc ZeroC), suc ZeroC) m11 mlm end);  (* le 1 ((Suc x)*(fact x)) *)
    val stepC = (let val zF = Free("zfps2",natT)
                     val Pb = Term.lambda zF (le (suc ZeroC) zF)
                 in substPredV (Pb, mult (suc xF)(fact xF), fact (suc xF)) (oeq_sym OF [fS]) lt0prod end);  (* lt 0 (fact (Suc x)) *)
    val step = Thm.forall_intr (ctermV xF) (Thm.implies_intr (ctermV ihP) stepC)
  in varify (Thm.implies_elim (Thm.implies_elim ind base) step) end;

val () = out ("fact_pos 0hyp=" ^ Bool.toString (zhV fact_pos) ^ "\n");
val i_fact_pos =
  let val nVz = Var(("N",0),natT)
  in jT (lt ZeroC (fact nVz)) end;
val r_factpos = (Thm.prop_of fact_pos) aconv i_fact_pos;
val () = out ("fact_pos aconv=" ^ Bool.toString r_factpos ^ "\n");
val () = if zhV fact_pos andalso r_factpos then out "FACT_POS_OK\n" else out "FACT_POS_FAIL\n";
val fact_pos_vV = varify fact_pos;
fun fact_pos_atV t = beta_norm (Drule.infer_instantiate ctxtV [(("N",0), ctermV t)] fact_pos_vV);

val () = out "F3B_FACTPOS_DONE\n";

(* ============================================================================
   (P)  MULTIPLES PRODUCT.  Define mprod p Q := product of p*1,..,p*Q :
          mprod p 0       = 1
          mprod p (Suc q) = (p * Suc q) * mprod p q
        Then prove the closed form
          mprod_closed : oeq (mprod p Q)(mult (pow p Q)(fact Q))        [= p^Q * Q!]
        by nat_induct on Q.  This is the "product of the multiples of p in 1..N
        equals p^(N/p) * (N/p)!" with Q := N/p.
        Defining a constant EXTENDS the theory -> new context ctxtV2.
   ============================================================================ *)
val () = out "MPROD_BEGIN\n";

(* --- new theory thyV2 with mprod ; new final context ctxtV2 --- *)
val thyV2_0 = Sign.add_consts
  [(Binding.name "mprod", natT --> natT --> natT, NoSyn)] thyV;
val mprodC = Const (Sign.full_name thyV2_0 (Binding.name "mprod"), natT --> natT --> natT);
fun mprod p q = mprodC $ p $ q;
val pV2 = Free("p", natT); val qV2 = Free("q", natT);
val ((_,mprod_0_ax),  thyV2_1) = Thm.add_axiom_global (Binding.name "mprod_0",
      jT (oeq (mprod pV2 ZeroC)(suc ZeroC))) thyV2_0;                 (* mprod p 0 = 1 *)
val ((_,mprod_Suc_ax), thyV2) = Thm.add_axiom_global (Binding.name "mprod_Suc",
      jT (oeq (mprod pV2 (suc qV2))(mult (mult pV2 (suc qV2))(mprod pV2 qV2)))) thyV2_1;
      (* mprod p (Suc q) = (p*(Suc q)) * mprod p q *)

val ctxtV2  = Proof_Context.init_global thyV2;
val ctermV2 = Thm.cterm_of ctxtV2;
fun zhV2 th = (length (Thm.hyps_of th) = 0) andalso (null (Thm.extra_shyps th));

(* re-varify the lemmas/axioms we need onto ctxtV2 (thyV2 extends thyV) *)
val oeq_refl_v2     = varify oeq_refl;
val oeq_subst_v2    = varify oeq_subst;
val nat_induct_v2   = varify nat_induct;
val add_0_v2        = varify add_0;
val mult_0_v2       = varify mult_0;
val mult_Suc_v2     = varify mult_Suc;
val mult_0_right_v2 = varify mult_0_right;
val mult_Suc_right_v2 = varify mult_Suc_right;
val mult_comm_v2    = varify mult_comm;
val mult_assoc_v2   = varify mult_assoc;
val mult_1_left_v2  = varify mult_1_left;
val mult_1_right_v2 = varify mult_1_right;
val pow_Zero_v2     = varify pow_Zero_ax;
val pow_Suc_v2      = varify pow_Suc_ax;
val fact_0_v2       = varify fact_0_ax;
val fact_Suc_v2     = varify fact_Suc_ax;
val mprod_0_v2      = varify mprod_0_ax;
val mprod_Suc_v2    = varify mprod_Suc_ax;

(* instantiators on ctxtV2 *)
fun oeqrefl2_at t      = beta_norm (Drule.infer_instantiate ctxtV2 [(("a",0), ctermV2 t)] oeq_refl_v2);
fun substPred2 (Pabs, aT, bT) hab hPa =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV2
        [(("P",0), ctermV2 Pabs), (("a",0), ctermV2 aT), (("b",0), ctermV2 bT)] oeq_subst_v2)
  in inst OF [hab, hPa] end;
fun mult0_2_at t       = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 t)] mult_0_v2);
fun multSuc2_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtV2 [(("m",0), ctermV2 mt),(("n",0), ctermV2 nt)] mult_Suc_v2);
fun mult0r2_at t       = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 t)] mult_0_right_v2);
fun multSr2_at (nt,mt) = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 nt),(("m",0), ctermV2 mt)] mult_Suc_right_v2);
fun multcomm2_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtV2 [(("m",0), ctermV2 mt),(("n",0), ctermV2 nt)] mult_comm_v2);
fun multassoc2_at (mt,nt,kt)= beta_norm (Drule.infer_instantiate ctxtV2 [(("m",0), ctermV2 mt),(("n",0), ctermV2 nt),(("k",0), ctermV2 kt)] mult_assoc_v2);
fun mult1l2_at t       = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 t)] mult_1_left_v2);
fun mult1r2_at t       = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 t)] mult_1_right_v2);
fun pow0_2_at t        = beta_norm (Drule.infer_instantiate ctxtV2 [(("a",0), ctermV2 t)] pow_Zero_v2);
fun powSuc2_at (at,nt) = beta_norm (Drule.infer_instantiate ctxtV2 [(("a",0), ctermV2 at),(("n",0), ctermV2 nt)] pow_Suc_v2);
fun fact0_2_at ()      = fact_0_v2;
fun factSuc2_at t      = beta_norm (Drule.infer_instantiate ctxtV2 [(("n",0), ctermV2 t)] fact_Suc_v2);
fun mprod0_at t        = beta_norm (Drule.infer_instantiate ctxtV2 [(("p",0), ctermV2 t)] mprod_0_v2);
fun mprodSuc_at (pt,qt)= beta_norm (Drule.infer_instantiate ctxtV2 [(("p",0), ctermV2 pt),(("q",0), ctermV2 qt)] mprod_Suc_v2);

(* mult congruences on ctxtV2 *)
fun mult_cong_l2 (pT, qT, kT) hpq =
  let val Pabs = Abs("z", natT, oeq (mult pT kT) (mult (Bound 0) kT))
  in substPred2 (Pabs, pT, qT) hpq (oeqrefl2_at (mult pT kT)) end;
fun mult_cong_r2 (hT, pT, qT) hpq =
  let val Pabs = Abs("z", natT, oeq (mult hT pT) (mult hT (Bound 0)))
  in substPred2 (Pabs, pT, qT) hpq (oeqrefl2_at (mult hT pT)) end;

val () = out "MPROD_HELPERS_OK\n";

(* mprod_closed : oeq (mprod p Q)(mult (pow p Q)(fact Q))  by nat_induct on Q *)
val mprod_closed =
  let
    val pF = Free("p", natT); val QF = Free("Q", natT)
    val zPF = Free("z_mc", natT)
    val Pabs = Term.lambda zPF (oeq (mprod pF zPF)(mult (pow pF zPF)(fact zPF)))
    val ind = beta_norm (Drule.infer_instantiate ctxtV2 [(("P",0), ctermV2 Pabs),(("k",0), ctermV2 QF)] nat_induct_v2)
    (* BASE Q=0 : mprod p 0 = 1 ; pow p 0 * fact 0 = 1*1 = 1.  show oeq (mprod p 0)(pow p 0 * fact 0). *)
    val mp0 = mprod0_at pF            (* oeq (mprod p 0)(Suc 0) *)
    val p0  = pow0_2_at pF            (* oeq (pow p 0)(Suc 0) *)
    val f0  = fact0_2_at ()           (* oeq (fact 0)(Suc 0) *)
    (* pow p 0 * fact 0 = 1 * 1 = 1 *)
    val rhs1 = oeq_trans OF [mult_cong_l2 (pow pF ZeroC, suc ZeroC, fact ZeroC) p0,
                             mult_cong_r2 (suc ZeroC, fact ZeroC, suc ZeroC) f0];   (* oeq (pow p0*fact0)(1*1) *)
    val r11 = mult1l2_at (suc ZeroC)  (* oeq (mult (Suc 0)(Suc 0))(Suc 0) *)
    val rhsAll = oeq_trans OF [rhs1, r11]    (* oeq (pow p 0 * fact 0)(Suc 0) *)
    val base = oeq_trans OF [mp0, oeq_sym OF [rhsAll]]   (* oeq (mprod p 0)(pow p 0 * fact 0) *)
    (* STEP : assume IH oeq (mprod p q)(pow p q * fact q) ; show for Suc q. *)
    val qF = Free("q", natT)
    val ihP = jT (oeq (mprod pF qF)(mult (pow pF qF)(fact qF)))
    val IH = Thm.assume (ctermV2 ihP)
    (* mprod p (Suc q) = (p*(Suc q)) * mprod p q  [mprod_Suc] *)
    val mpS = mprodSuc_at (pF, qF)    (* oeq (mprod p (Suc q))((p*(Suc q)) * mprod p q) *)
    (* rewrite mprod p q -> (pow p q * fact q) via IH *)
    val mpS2 = oeq_trans OF [mpS, mult_cong_r2 (mult pF (suc qF), mprod pF qF, mult (pow pF qF)(fact qF)) IH];
               (* oeq (mprod p (Suc q))((p*(Suc q)) * (pow p q * fact q)) *)
    (* TARGET RHS : pow p (Suc q) * fact (Suc q) = (p * pow p q) * ((Suc q) * fact q) *)
    val pS  = powSuc2_at (pF, qF)     (* oeq (pow p (Suc q))(p * pow p q) *)
    val fS  = factSuc2_at qF          (* oeq (fact (Suc q))((Suc q) * fact q) *)
    val rhsExp = oeq_trans OF [mult_cong_l2 (pow pF (suc qF), mult pF (pow pF qF), fact (suc qF)) pS,
                               mult_cong_r2 (mult pF (pow pF qF), fact (suc qF), mult (suc qF)(fact qF)) fS];
                 (* oeq (pow p (Suc q) * fact (Suc q))((p * pow p q) * ((Suc q) * fact q)) *)
    (* Now show LHS' = (p*(Suc q))*(pow p q * fact q)  equals  (p*pow p q)*((Suc q)*fact q)
       by CA rearrangement.  Let A=p, B=Suc q, C=pow p q, D=fact q.
       (A*B)*(C*D) = (A*C)*(B*D).
       proof: (A*B)*(C*D) = A*(B*(C*D)) [assoc]
                          = A*((B*C)*D) [assoc sym]
                          = A*((C*B)*D) [comm B C]
                          = A*(C*(B*D)) [assoc]
                          = (A*C)*(B*D) [assoc sym] *)
    val A = pF; val B = suc qF; val C = pow pF qF; val D = fact qF
    val e1 = multassoc2_at (A, B, mult C D)              (* (A*B)*(C*D) = A*(B*(C*D)) *)
    val e2 = oeq_sym OF [multassoc2_at (B, C, D)]        (* B*(C*D) = (B*C)*D  -> sym: B*(C*D) = (B*C)*D ; careful *)
    (* multassoc2_at (B,C,D) : oeq ((B*C)*D)(B*(C*D)).  sym -> oeq (B*(C*D))((B*C)*D). good. *)
    val e2b = oeq_sym OF [multassoc2_at (B, C, D)]       (* oeq (B*(C*D))((B*C)*D) *)
    val e3 = mult_cong_l2 (mult B C, mult C B, D) (multcomm2_at (B, C))  (* (B*C)*D = (C*B)*D *)
    val e4 = multassoc2_at (C, B, D)                     (* (C*B)*D = C*(B*D) *)
    (* inner : B*(C*D) = C*(B*D) *)
    val inner = oeq_trans OF [e2b, oeq_trans OF [e3, e4]]   (* oeq (B*(C*D))(C*(B*D)) *)
    val e5 = mult_cong_r2 (A, mult B (mult C D), mult C (mult B D)) inner   (* A*(B*(C*D)) = A*(C*(B*D)) *)
    val e6 = oeq_sym OF [multassoc2_at (A, C, mult B D)]    (* A*(C*(B*D)) = (A*C)*(B*D) *)
    val rearr = oeq_trans OF [e1, oeq_trans OF [e5, e6]]    (* oeq ((A*B)*(C*D))((A*C)*(B*D)) *)
    (* chain : mprod p (Suc q) = (A*B)*(C*D) [mpS2] = (A*C)*(B*D) [rearr] = pow(Sq)*fact(Sq) [sym rhsExp] *)
    val stepC = oeq_trans OF [mpS2, oeq_trans OF [rearr, oeq_sym OF [rhsExp]]];
                (* oeq (mprod p (Suc q))(pow p (Suc q) * fact (Suc q)) *)
    val step = Thm.forall_intr (ctermV2 qF) (Thm.implies_intr (ctermV2 ihP) stepC)
  in varify (Thm.implies_elim (Thm.implies_elim ind base) step) end;

val () = out ("mprod_closed 0hyp=" ^ Bool.toString (zhV2 mprod_closed) ^ "\n");
val i_mprod_closed =
  let val pVz = Var(("p",0),natT); val QVz = Var(("Q",0),natT)
  in jT (oeq (mprod pVz QVz)(mult (pow pVz QVz)(fact QVz))) end;
val r_mpc = (Thm.prop_of mprod_closed) aconv i_mprod_closed;
val () = out ("mprod_closed aconv=" ^ Bool.toString r_mpc ^ "\n");
val () = if zhV2 mprod_closed andalso r_mpc then out "MPROD_CLOSED_OK\n" else out "MPROD_CLOSED_FAIL\n";

val () = if zhV fact_pos andalso r_factpos andalso zhV2 mprod_closed andalso r_mpc
         then out "MULT_PROD_OK\n" else out "MULT_PROD_PARTIAL\n";
val () = out "F3B_MPROD_DONE\n";

(* ============================================================================
   (LE-helper)  pow_le_exp : lt 0 p ==> le i j ==> le (pow p i)(pow p j)
     le i j gives j = i+d.  pow p j = pow p (i+d) = pow p i * pow p d [pow_add].
     pow p d >= 1 (pow_pos).  pow p i = pow p i * 1 <= pow p i * pow p d [mult_le_mono].
   This is the EXPONENT-monotone (<=) companion to the banked dvd-monotone pow_dvd_mono,
   and is the bound used by VP_LE (pow_le_mono).
   ============================================================================ *)
val () = out "POWLEEXP_BEGIN\n";
fun pow_le_exp_atV (pT, iT, jT_) hPos hle =
  let
    val PabsLe = Abs("d", natT, oeq jT_ (add iT (Bound 0)))
    val goalC = le (pow pT iT)(pow pT jT_)
    fun body dF (hd : thm) =     (* hd : oeq j (add i d) *)
      let
        val ppd_pos = pow_pos_atV (pT, dF) hPos      (* lt 0 (pow p d) = le (Suc 0)(pow p d) *)
        (* le (pow p i * 1)(pow p i * pow p d) via mult_le_mono with c = pow p i, j=1, k=pow p d *)
        val mlm = mult_le_mono_atV (pow pT iT, suc ZeroC, pow pT dF) ppd_pos;  (* le ((pow p i)*1)((pow p i)*(pow p d)) *)
        (* (pow p i)*1 = pow p i *)
        val m1r = mult1rV_at (pow pT iT)             (* oeq ((pow p i)*1)(pow p i) *)
        val lhsRw = (let val zF = Free("zple1",natT)
                         val Pb = Term.lambda zF (le zF (mult (pow pT iT)(pow pT dF)))
                     in substPredV (Pb, mult (pow pT iT)(suc ZeroC), pow pT iT) m1r mlm end);
                     (* le (pow p i)((pow p i)*(pow p d)) *)
        (* (pow p i)*(pow p d) = pow p (i+d) [pow_add sym] = pow p j *)
        val padd = pow_add_atV (pT, iT, dF)          (* oeq (pow p (i+d))((pow p i)*(pow p d)) *)
        val rhsRw = (let val zF = Free("zple2",natT)
                         val Pb = Term.lambda zF (le (pow pT iT) zF)
                     in substPredV (Pb, mult (pow pT iT)(pow pT dF), pow pT (add iT dF)) (oeq_sym OF [padd]) lhsRw end);
                     (* le (pow p i)(pow p (i+d)) *)
        val g = (let val zF = Free("zple3",natT)
                     val Pb = Term.lambda zF (le (pow pT iT)(pow pT zF))
                 in substPredV (Pb, add iT dF, jT_) (oeq_sym OF [hd]) rhsRw end);  (* le (pow p i)(pow p j) *)
      in g end;
  in exE_elimV (PabsLe, goalC) hle "d_ple" body end;

(* package as a closed schematic lemma for the audit *)
val pow_le_exp =
  let
    val pF = Free("p", natT); val iF = Free("i", natT); val jF = Free("j", natT)
    val hPos = Thm.assume (ctermV (jT (lt ZeroC pF)))
    val hle  = Thm.assume (ctermV (jT (le iF jF)))
    val g    = pow_le_exp_atV (pF, iF, jF) hPos hle
    val d1   = Thm.implies_intr (ctermV (jT (le iF jF))) g
    val d2   = Thm.implies_intr (ctermV (jT (lt ZeroC pF))) d1
  in varify d2 end;
val () = out ("pow_le_exp 0hyp=" ^ Bool.toString (zhV pow_le_exp) ^ "\n");
val i_pow_le_exp =
  let val pVz = Var(("p",0),natT); val iVz = Var(("i",0),natT); val jVz = Var(("j",0),natT)
  in Logic.mk_implies (jT (lt ZeroC pVz),
       Logic.mk_implies (jT (le iVz jVz),
         jT (le (pow pVz iVz)(pow pVz jVz)))) end;
val r_ple = (Thm.prop_of pow_le_exp) aconv i_pow_le_exp;
val () = out ("pow_le_exp aconv=" ^ Bool.toString r_ple ^ "\n");
val () = if zhV pow_le_exp andalso r_ple then out "POW_LE_EXP_OK\n" else out "POW_LE_EXP_FAIL\n";
val () = out "F3B_POWLEEXP_DONE\n";

(* ============================================================================
   (B-helper)  vp_pow_self : prime2 p ==> oeq (vp p (pow p k)) k     [vp(p^k)=k]
     via vp_unique at m = pow p k :
        lt 0 (pow p k)              [pow_pos]
        dvd (pow p k)(pow p k)      [dvd_refl]
        ~(dvd (pow p (Suc k))(pow p k))  : else dvd_le gives le (p^(Suc k))(p^k),
            but p^(Suc k) = p*p^k > p^k (lt_x_px), contra.
   This is the "vp(p^k)=k" fact the Legendre/VP_LE route names explicitly.
   ============================================================================ *)
val () = out "VPPOWSELF_BEGIN\n";

(* dvd_le on ctxtV *)
val dvd_le_vV = varify dvd_le;
fun dvd_le_atV (dT, nT) hdvd hnzMeta =     (* hdvd : dvd d n ; hnzMeta : jT(oeq n 0) ==> jT oFalse *)
  let val inst = beta_norm (Drule.infer_instantiate ctxtV [(("d",0), ctermV dT),(("n",0), ctermV nT)] dvd_le_vV)
  in Thm.implies_elim (Thm.implies_elim inst hdvd) hnzMeta end;

(* lt_x_px : prime2 p ==> lt 0 x ==> lt x (mult p x)
   x = Suc 0 * x ... use 2*x = x+x > x ; p*x >= 2*x.  (mirrors rdiv_lt). *)
fun lt_x_px_atV (pT, xT) hPr hxpos =
  let
    val gt1p = prime2_gt1_atV pT hPr            (* lt 1 p = le 2 p *)
    (* le (2*x)(p*x) via mult_le_mono2 (le 2 p)(le x x) *)
    val mlm = mult_le_mono2_atV (suc (suc ZeroC), pT, xT, xT) gt1p (le_refl_atV xT);  (* le (2*x)(p*x) *)
    (* 2*x = x+x *)
    val ms2 = multSucV_at (suc ZeroC, xT)       (* oeq ((Suc(Suc 0))*x)(add x ((Suc 0)*x)) *)
    val ms1 = multSucV_at (ZeroC, xT)           (* oeq ((Suc 0)*x)(add x (0*x)) *)
    val m0r = mult0V_at xT                       (* oeq (0*x) 0 *)
    val s1  = oeq_trans OF [ms1, oeq_trans OF [add_cong_rV (xT, mult ZeroC xT, ZeroC) m0r, add0rV_at xT]];  (* (Suc0)*x = x *)
    val two_x = oeq_trans OF [ms2, add_cong_rV (xT, mult (suc ZeroC) xT, xT) s1];   (* oeq (2*x)(add x x) *)
    val le_xx_px = (let val zF = Free("zlx",natT) val Pb = Term.lambda zF (le zF (mult pT xT))
                    in substPredV (Pb, mult (suc (suc ZeroC)) xT, add xT xT) two_x mlm end);  (* le (x+x)(p*x) *)
    (* lt x (x+x) : le (Suc x)(x+x).  le (1+x)(x+x) via le_add_mono on (le 1 x); 1+x = Suc x. *)
    val lam = le_add_mono_atV (suc ZeroC, xT, xT) hxpos;   (* le ((Suc 0)+x)(x+x) *)
    val s0r = oeq_trans OF [addSucV_at (ZeroC, xT), Suc_cong OF [add0V_at xT]];  (* oeq ((Suc 0)+x)(Suc x) *)
    val lt_x_xx = (let val zF = Free("zsx",natT) val Pb = Term.lambda zF (le zF (add xT xT))
                   in substPredV (Pb, add (suc ZeroC) xT, suc xT) s0r lam end);  (* le (Suc x)(x+x) = lt x (x+x) *)
    val g = le_trans_atV (suc xT, add xT xT, mult pT xT) lt_x_xx le_xx_px;  (* le (Suc x)(p*x) = lt x (p*x) *)
  in g end;

fun vp_pow_self_atV (pT, kT) hPr =       (* -> oeq (vp p (pow p k)) k *)
  let
    val lt0p = prime2_pos_atV pT hPr
    val pk   = pow pT kT
    val ppos = pow_pos_atV (pT, kT) lt0p     (* lt 0 (pow p k) = le 1 (pow p k) *)
    val drefl= dvd_refl_atV pk               (* dvd (pow p k)(pow p k) *)
    (* ~(dvd (pow p (Suc k))(pow p k)) *)
    val hAssume = Thm.assume (ctermV (jT (dvd (pow pT (suc kT)) pk)))
    (* pow p (Suc k) = p * pow p k *)
    val psuc = powSucV_at (pT, kT)           (* oeq (pow p (Suc k))(mult p (pow p k)) *)
    (* dvd (pow p (Suc k))(pow p k) , pow p k != 0 -> le (pow p (Suc k))(pow p k) [dvd_le] *)
    val nzMeta = (let val hz = Thm.assume (ctermV (jT (oeq pk ZeroC)))  (* oeq (pow p k) 0 *)
                      val le10 = (let val zF = Free("znz",natT) val Pb = Term.lambda zF (le (suc ZeroC) zF)
                                  in substPredV (Pb, pk, ZeroC) hz ppos end)   (* le 1 0 *)
                      val ff = lt_irrefl_atV ZeroC OF [le10]
                  in Thm.implies_intr (ctermV (jT (oeq pk ZeroC))) ff end);   (* oeq (pow p k) 0 ==> oFalse *)
    val leSkk = dvd_le_atV (pow pT (suc kT), pk) hAssume nzMeta;   (* le (pow p (Suc k))(pow p k) *)
    (* lt (pow p k)(pow p (Suc k)) : lt (pow p k)(p * pow p k) [lt_x_px], rewrite p*pow -> pow p (Suc k) *)
    val ltpk = lt_x_px_atV (pT, pk) hPr ppos;     (* lt (pow p k)(mult p (pow p k)) = le (Suc(pow p k))(mult p (pow p k)) *)
    val ltpk2 = (let val zF = Free("zlp",natT) val Pb = Term.lambda zF (le (suc pk) zF)
                 in substPredV (Pb, mult pT pk, pow pT (suc kT)) (oeq_sym OF [psuc]) ltpk end);  (* le (Suc(pow p k))(pow p (Suc k)) *)
    (* contradiction : le (Suc(pow p k))(pow p (Suc k)) and le (pow p (Suc k))(pow p k) -> le (Suc(pow p k))(pow p k) -> lt (pow p k)(pow p k) -> false *)
    val leChain = le_trans_atV (suc pk, pow pT (suc kT), pk) ltpk2 leSkk;  (* le (Suc(pow p k))(pow p k) = lt (pow p k)(pow p k) *)
    val ff = lt_irrefl_atV pk OF [leChain];        (* oFalse *)
    val ndvd = impI_V (dvd (pow pT (suc kT)) pk, oFalseC)
                 (Thm.implies_intr (ctermV (jT (dvd (pow pT (suc kT)) pk))) ff);  (* ~(dvd (pow p (Suc k))(pow p k)) *)
    val g = vp_unique_atV (pT, pk, kT) hPr ppos drefl ndvd;   (* oeq (vp p (pow p k)) k *)
  in g end;

val vp_pow_self =
  let
    val pF = Free("p", natT); val kF = Free("k", natT)
    val hPr = Thm.assume (ctermV (jT (prime2 pF)))
    val g = vp_pow_self_atV (pF, kF) hPr
    val d1 = Thm.implies_intr (ctermV (jT (prime2 pF))) g
  in varify d1 end;
val () = out ("vp_pow_self 0hyp=" ^ Bool.toString (zhV vp_pow_self) ^ "\n");
val i_vp_pow_self =
  let val pVz = Var(("p",0),natT); val kVz = Var(("k",0),natT)
  in Logic.mk_implies (jT (prime2 pVz), jT (oeq (vp pVz (pow pVz kVz)) kVz)) end;
val r_vps = (Thm.prop_of vp_pow_self) aconv i_vp_pow_self;
val () = out ("vp_pow_self aconv=" ^ Bool.toString r_vps ^ "\n");
val () = if zhV vp_pow_self andalso r_vps then out "VP_POW_SELF_OK\n" else out "VP_POW_SELF_FAIL\n";
val vp_pow_self_vV = varify vp_pow_self;
val () = out "F3B_VPPOWSELF_DONE\n";

(* ============================================================================
   F3b — what is NOT yet closed (precise blocker, for the report):
   The recursive legendre_rec : prime2 p ==> oeq (vp p (fact N))(add (rdiv N p)(vp p (fact (rdiv N p))))
   needs the MULTIPLICATIVE fact-split
       fact N = (product of non-multiples of p in 1..N) * (mprod p (rdiv N p))
   with the non-multiples product COPRIME to p (vp = 0).  Building it requires
   (a) a new recursive constant pfree p N (product of non-multiples), and
   (b) the FLOOR-STEP lemmas coupling the recursion to rdiv:
         rdiv_step_dvd  : lt 0 p ==> dvd p (Suc n)      ==> oeq (rdiv (Suc n) p)(Suc (rdiv n p))
         rdiv_step_ndvd : lt 0 p ==> ~(dvd p (Suc n))   ==> oeq (rdiv (Suc n) p)(rdiv n p)
       (so N/p increments exactly when p|(Suc n)), then a COUPLED induction on N.
   With the split in hand the chain is short:
     vp p (fact N) = vp(pfree) + vp(mprod p (N/p))           [vp_additive, both >0]
                   = 0 + vp(pow p (N/p) * fact(N/p))          [vp on coprime = 0; mprod_closed]
                   = (N/p) + vp(fact (N/p))                    [vp_additive + vp_pow_self]
   The banked F3b pieces (mprod_closed, vp_pow_self, fact_pos, pow_le_exp) are
   exactly the algebraic content the chain consumes once the split exists.
   ============================================================================ *)
val () = out "F3B_FINALE_BEGIN\n";

(* soundness probes : kernel must REJECT shape-weakened variants *)
val s_mpc_shape =     (* mprod_closed must be p^Q*Q!, not p^Q (drop the fact factor) *)
  let val pVz = Var(("p",0),natT); val QVz = Var(("Q",0),natT)
  in not ((Thm.prop_of mprod_closed) aconv (jT (oeq (mprod pVz QVz)(pow pVz QVz)))) end;
val s_vps_cond =      (* vp_pow_self must keep prime2 p (drop it -> different) *)
  let val pVz = Var(("p",0),natT); val kVz = Var(("k",0),natT)
  in not ((Thm.prop_of vp_pow_self) aconv (jT (oeq (vp pVz (pow pVz kVz)) kVz))) end;
val () = out ("PROBE mprod_closed-shape=" ^ Bool.toString s_mpc_shape
            ^ " vp_pow_self-conditional=" ^ Bool.toString s_vps_cond ^ "\n");

(* axiom audit : only ex_middle classical ; mprod recursion conservative (2 step axioms) *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtV2
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nMprod = length (List.filter (fn s => String.isSubstring "mprod" s) names)
    val nVp    = length (List.filter (fn s => String.isSubstring "vp_step" s) names)
    val nRdiv  = length (List.filter (fn s => String.isSubstring "div_mod_eq" s
                                          orelse String.isSubstring "rmod_lt" s) names)
  in out ("F3B_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " mprod_recursion_axioms=" ^ Int.toString nMprod
          ^ " vp_recursion_axioms=" ^ Int.toString nVp
          ^ " rdiv_axioms=" ^ Int.toString nRdiv ^ "\n") end;

val f3b_all =
