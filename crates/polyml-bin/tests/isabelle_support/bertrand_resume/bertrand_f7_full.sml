(* exE on ctxtV *)
fun exE_elimV (Pabs, goalC) exThm wName bodyFn =
  let
    val wF = Free(wName, natT)
    val hypTerm = jT (Term.betapply (Pabs, wF))
    val hypThm  = Thm.assume (ctermV hypTerm)
    val body    = bodyFn wF hypThm
    val minor   = Thm.forall_intr (ctermV wF) (Thm.implies_intr (ctermV hypTerm) body)
    val inst    = beta_norm (Drule.infer_instantiate ctxtV
                    [(("P",0), ctermV Pabs),(("Q",0), ctermV goalC)] exE_vV)
  in Thm.implies_elim (Thm.implies_elim inst exThm) minor end;

