(* ============================================================================
   BERTRAND F2b — (G1) PRIME-PRODUCT-DIVIDES
     prime_prod_dvd : prime2 p ==> dvd p N ==> ~(dvd p U) ==> dvd U N
                        ==> dvd (mult p U) N
   PROOF.  dvd U N gives N = U*k.  dvd p N + that gives dvd p (U*k); euclid:
   dvd p U \/ dvd p k.  dvd p U contradicts ~(dvd p U).  dvd p k gives k = p*j,
   so N = U*(p*j) = (U*p)*j = (p*U)*j, hence dvd (p*U) N (witness j).
   ============================================================================ *)
val () = out "G1_BEGIN\n";

fun euclid_atPr (pT,aT,bT) hP hD =     (* prime2 p -> dvd p (a*b) -> Disj (dvd p a)(dvd p b) *)
  let val inst = beta_norm (Drule.infer_instantiate ctxtPr
        [(("p",0), ctermPr pT),(("a",0), ctermPr aT),(("b",0), ctermPr bT)] euclid_lemma_vPr)
  in (inst OF [hP]) OF [hD] end;

val prime_prod_dvd =
  let
    val pF = Free("p", natT); val NF = Free("N", natT); val UF = Free("U", natT);
    val prP   = jT (prime2 pF);             val hPr   = Thm.assume (ctermPr prP);
    val dpN   = jT (dvd pF NF);             val hDpN  = Thm.assume (ctermPr dpN);
    val npU   = jT (neg (dvd pF UF));       val hNpU  = Thm.assume (ctermPr npU);  (* Imp (dvd p U) oFalse *)
    val dUN   = jT (dvd UF NF);             val hDUN  = Thm.assume (ctermPr dUN);
    val goalC = dvd (mult pF UF) NF;

    (* exE on dvd U N : witness k with oeq N (mult U k) *)
    val PabsK = Abs("k", natT, oeq NF (mult UF (Bound 0)));   (* dvd U N = Ex (%k. oeq N (mult U k)) *)
    fun bodyK kF (hk : thm) =      (* hk : oeq N (mult U k) *)
      let
        (* dvd p (mult U k) : rewrite dvd p N's argument N -> mult U k *)
        val dp_Uk = dvd_cong_rPr (pF, NF, mult UF kF) hk hDpN;   (* dvd p (mult U k) *)
        val disjUK = euclid_atPr (pF, UF, kF) hPr dp_Uk;          (* Disj (dvd p U)(dvd p k) *)
        (* CASE dvd p U : contradicts ~(dvd p U) *)
        val caseU =
          let
            val hdu = Thm.assume (ctermPr (jT (dvd pF UF)));
            val ff  = mp_Pr (dvd pF UF, oFalseC) hNpU hdu;        (* oFalse *)
            val g   = Thm.implies_elim (oFalse_elim_Pr goalC) ff; (* dvd (p*U) N *)
          in Thm.implies_intr (ctermPr (jT (dvd pF UF))) g end;
        (* CASE dvd p k : witness j with k = p*j -> N = (p*U)*j *)
        val caseK =
          let
            val hdk = Thm.assume (ctermPr (jT (dvd pF kF)));
            val PabsJ = Abs("j", natT, oeq kF (mult pF (Bound 0)));   (* dvd p k = Ex (%j. oeq k (mult p j)) *)
            fun bodyJ jF (hj : thm) =     (* hj : oeq k (mult p j) *)
              let
                (* N = U*k ; rewrite k -> p*j : oeq N (mult U (mult p j)) *)
                val Nk_Upj = oeq_trans OF [hk, mult_cong_rPr (UF, kF, mult pF jF) hj];  (* oeq N (mult U (mult p j)) *)
                (* (U*p)*j = U*(p*j)  [mult_assoc m=U,n=p,k=j] -> sym -> U*(p*j) = (U*p)*j *)
                val assoc = multassocPr_at (UF, pF, jF);              (* oeq (mult (mult U p) j)(mult U (mult p j)) *)
                val assocSym = oeq_sym OF [assoc];                    (* oeq (mult U (mult p j))(mult (mult U p) j) *)
                (* U*p = p*U [mult_comm] -> (U*p)*j = (p*U)*j  [cong on left] *)
                val comm = multcommPr_at (UF, pF);                    (* oeq (mult U p)(mult p U) *)
                val congJ = mult_cong_lPr (mult UF pF, mult pF UF, jF) comm;  (* oeq (mult (mult U p) j)(mult (mult p U) j) *)
                (* chain : N = U*(p*j) = (U*p)*j = (p*U)*j *)
                val Neq = oeq_trans OF [oeq_trans OF [Nk_Upj, assocSym], congJ];  (* oeq N (mult (mult p U) j) *)
                val g = dvd_introPr (mult pF UF, NF, jF) Neq;        (* dvd (mult p U) N *)
              in g end;
            val g = exE_elimPr (PabsJ, goalC) hdk "j_ppd" bodyJ;     (* dvd (p*U) N *)
          in Thm.implies_intr (ctermPr (jT (dvd pF kF))) g end;
        val g = disjE_elimPr (dvd pF UF, dvd pF kF, goalC) disjUK caseU caseK;
      in g end;
    val concl = exE_elimPr (PabsK, goalC) hDUN "k_ppd" bodyK;        (* dvd (mult p U) N *)
    val d1 = Thm.implies_intr (ctermPr dUN) concl;
    val d2 = Thm.implies_intr (ctermPr npU) d1;
    val d3 = Thm.implies_intr (ctermPr dpN) d2;
    val d4 = Thm.implies_intr (ctermPr prP) d3;
  in varify d4 end;

val () = out ("prime_prod_dvd 0hyp=" ^ Bool.toString (zhPr prime_prod_dvd) ^ "\n");
val i_prime_prod_dvd =
  let val pV = Var(("p",0),natT); val NV = Var(("N",0),natT); val UV = Var(("U",0),natT)
  in Logic.mk_implies (jT (prime2 pV),
       Logic.mk_implies (jT (dvd pV NV),
         Logic.mk_implies (jT (neg (dvd pV UV)),
           Logic.mk_implies (jT (dvd UV NV),
             jT (dvd (mult pV UV) NV))))) end;
val r_ppd = (Thm.prop_of prime_prod_dvd) aconv i_prime_prod_dvd;
val () = out ("prime_prod_dvd aconv=" ^ Bool.toString r_ppd ^ "\n");
(* soundness probe : must NOT drop the ~(dvd p U) premise *)
val s_ppd =
  let val pV = Var(("p",0),natT); val NV = Var(("N",0),natT); val UV = Var(("U",0),natT)
  in not ((Thm.prop_of prime_prod_dvd) aconv
       (Logic.mk_implies (jT (prime2 pV),
          Logic.mk_implies (jT (dvd pV NV),
            Logic.mk_implies (jT (dvd UV NV),
              jT (dvd (mult pV UV) NV)))))) end;
val () = if zhPr prime_prod_dvd andalso r_ppd andalso s_ppd
         then out "COPRIME_DVD_OK\n" else out "COPRIME_DVD_FAIL\n";

val prime_prod_dvd_vPr = varify prime_prod_dvd;
fun prime_prod_dvd_atPr (pT,NT,UT) hPr hDpN hNpU hDUN =
  let val inst = beta_norm (Drule.infer_instantiate ctxtPr
        [(("p",0), ctermPr pT),(("N",0), ctermPr NT),(("U",0), ctermPr UT)] prime_prod_dvd_vPr)
  in (((inst OF [hPr]) OF [hDpN]) OF [hNpU]) OF [hDUN] end;

(* ============================================================================
   BERTRAND F2b — G2 prep : not_dvd_one + base-case helper checks
     not_dvd_one : lt (Suc 0) q ==> dvd q (Suc 0) ==> oFalse
       dvd q 1 + 1!=0 -> le q 1 (dvd_le).  lt 1 q = le 2 q.  le_trans(le 2 q)(le q 1)
       = le 2 1 = lt 1 1 -> lt_irrefl.
   ============================================================================ *)
val () = out "G2PREP_BEGIN\n";

val not_dvd_one =
  let
    val qF = Free("q", natT);
    val hgt1 = Thm.assume (ctermPr (jT (lt (suc ZeroC) qF)));   (* le 2 q *)
    val hdvd = Thm.assume (ctermPr (jT (dvd qF (suc ZeroC))));  (* dvd q 1 *)
    (* META : oeq 1 0 ==> oFalse  (Suc_neq_Zero at 0) *)
    val nzMeta =
      let val h10 = Thm.assume (ctermPr (jT (oeq (suc ZeroC) ZeroC)))   (* oeq (Suc 0) 0 *)
      in Thm.implies_intr (ctermPr (jT (oeq (suc ZeroC) ZeroC))) (Suc_neq_Zero_atPr ZeroC OF [h10]) end;
    val le_q_1 = dvd_le_atPr (qF, suc ZeroC) hdvd nzMeta;       (* le q 1 *)
    (* le 2 q (= hgt1) and le q 1 -> le 2 1 = lt 1 1 *)
    val le_2_1 = le_trans_atPr (suc (suc ZeroC), qF, suc ZeroC) hgt1 le_q_1;  (* le 2 1 = lt 1 1 *)
    val ff = lt_irrefl_atPr (suc ZeroC) OF [le_2_1];           (* oFalse  (lt 1 1) *)
    val d1 = Thm.implies_intr (ctermPr (jT (dvd qF (suc ZeroC)))) ff;
    val d2 = Thm.implies_intr (ctermPr (jT (lt (suc ZeroC) qF))) d1;
  in varify d2 end;

val () = out ("not_dvd_one 0hyp=" ^ Bool.toString (zhPr not_dvd_one) ^ "\n");
val i_ndo =
  let val qV = Var(("q",0),natT)
  in Logic.mk_implies (jT (lt (suc ZeroC) qV), Logic.mk_implies (jT (dvd qV (suc ZeroC)), jT oFalseC)) end;
val () = out ("not_dvd_one aconv=" ^ Bool.toString ((Thm.prop_of not_dvd_one) aconv i_ndo) ^ "\n");
val not_dvd_one_vPr = varify not_dvd_one;
fun not_dvd_one_atPr qT hgt1 hdvd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtPr [(("q",0), ctermPr qT)] not_dvd_one_vPr)
  in (inst OF [hgt1]) OF [hdvd] end;

val () = if zhPr not_dvd_one andalso ((Thm.prop_of not_dvd_one) aconv i_ndo)
         then out "G2PREP_OK\n" else out "G2PREP_FAIL\n";
(* ============================================================================
   BERTRAND F2b — binom_pos : le k n ==> lt 0 (binom n k)
   ============================================================================ *)
val () = out "BINOMPOS_BEGIN\n";
val binom_pos =
  let
    fun obody nt = let val kF = Free("k_bp", natT)
                   in Term.lambda kF (mkImp (le kF nt) (lt ZeroC (binom nt kF))) end;
    val nV = Free("n", natT);
    val Qpred = Term.lambda nV (mkForall (obody nV));    (* %n. Forall (obody n) *)
    val ind = beta_norm (Drule.infer_instantiate ctxtPr
                [(("P",0), ctermPr Qpred),(("k",0), ctermPr nV)] nat_induct_vPr);

    (* BASE n=0 : !k. le k 0 ==> lt 0 (binom 0 k) *)
    val base =
      let
        val kF = Free("k", natT);
        val hLe = Thm.assume (ctermPr (jT (le kF ZeroC)));     (* le k 0 *)
        val k0  = le_zero_imp_eqPr kF hLe;                      (* oeq k 0 *)
        (* binom 0 k -> binom 0 0 (cong on 2nd arg) ; binom 0 0 = 1 *)
        val bcong = oeq_rewrite_in (fn z => binom ZeroC z, kF, ZeroC) k0;  (* oeq (binom 0 k)(binom 0 0) *)
        val b00 = binomN0Pr_at ZeroC;                          (* oeq (binom 0 0)(Suc 0) *)
        val beq = oeq_trans OF [bcong, b00];                   (* oeq (binom 0 k)(Suc 0) *)
        (* lt 0 (Suc 0) = le 1 1 = le_refl 1 ; rewrite to lt 0 (binom 0 k) via sym beq *)
        val lt01 = le_refl_atPr (suc ZeroC);                   (* le 1 1 = lt 0 1 *)
        val lt0bk = (let val zF = Free("zb", natT)
                         val Pabs = Term.lambda zF (lt ZeroC zF)
                     in substPredPr (Pabs, suc ZeroC, binom ZeroC kF) (oeq_sym OF [beq]) lt01 end);  (* lt 0 (binom 0 k) *)
        val imp = impI_Pr (le kF ZeroC, lt ZeroC (binom ZeroC kF))
                    (Thm.implies_intr (ctermPr (jT (le kF ZeroC))) lt0bk);
        val allm = Thm.forall_intr (ctermPr kF) imp;           (* !!k. jT(obody 0 k) *)
      in allI_Pr (obody ZeroC) allm end;

    (* STEP n=Suc x ; IH : Forall (obody x) *)
    val xF  = Free("x", natT);
    val ihP = jT (mkForall (obody xF));
    val IH  = Thm.assume (ctermPr ihP);
    val step =
      let
        val Sx = suc xF;
        val kF = Free("k", natT);
        val hLe = Thm.assume (ctermPr (jT (le kF Sx)));        (* le k (Suc x) *)
        (* cases on k via disj_zero_or_suc *)
        val dz = dzosPr_at kF;                                 (* Disj (oeq k 0)(Ex q. oeq k (Suc q)) *)
        val goalC = lt ZeroC (binom Sx kF);
        (* case k=0 *)
        val caseZ =
          let
            val hk0 = Thm.assume (ctermPr (jT (oeq kF ZeroC)))     (* oeq k 0 *)
            (* binom (Suc x) k -> binom (Suc x) 0 -> 1 *)
            val bcong = oeq_rewrite_in (fn z => binom Sx z, kF, ZeroC) hk0;  (* oeq (binom Sx k)(binom Sx 0) *)
            val bSx0 = binomN0Pr_at Sx;                          (* oeq (binom Sx 0)(Suc 0) *)
            val beq  = oeq_trans OF [bcong, bSx0];               (* oeq (binom Sx k)(Suc 0) *)
            val lt01 = le_refl_atPr (suc ZeroC);                 (* lt 0 1 *)
            val g = (let val zF = Free("zb2", natT)
                         val Pabs = Term.lambda zF (lt ZeroC zF)
                     in substPredPr (Pabs, suc ZeroC, binom Sx kF) (oeq_sym OF [beq]) lt01 end);
          in Thm.implies_intr (ctermPr (jT (oeq kF ZeroC))) g end;
        (* case k=Suc q *)
        val caseS =
          let
            val PabsQ = Abs("q", natT, oeq kF (suc (Bound 0)))    (* %q. oeq k (Suc q) *)
            fun bodyQ qF (hq : thm) =     (* hq : oeq k (Suc q) *)
              let
                (* le k (Suc x) with k = Suc q -> le (Suc q)(Suc x) -> le q x *)
                val hLeSqSx = (let val zF = Free("zk", natT)
                                   val Pabs = Term.lambda zF (le zF Sx)
                               in substPredPr (Pabs, kF, suc qF) hq hLe end);   (* le (Suc q)(Suc x) *)
                val le_q_x = le_Suc_Suc_rev_atPr (qF, xF) hLeSqSx;              (* le q x *)
                (* IH at q : Imp (le q x)(lt 0 (binom x q)) -> apply *)
                val ihAtq = allE_Pr (obody xF) qF IH;             (* Imp (le q x)(lt 0 (binom x q)) *)
                val lt0xq = mp_Pr (le qF xF, lt ZeroC (binom xF qF)) ihAtq le_q_x;  (* lt 0 (binom x q) *)
                (* binom (Suc x)(Suc q) = binom x q + binom x (Suc q) ; lt 0 (a) -> lt 0 (a+b) *)
                val bSS = binomSSPr_at (xF, qF);                  (* oeq (binom (Suc x)(Suc q))(add (binom x q)(binom x (Suc q))) *)
                val lt0sum = lt_0_add_lPr (binom xF qF, binom xF (suc qF)) lt0xq;  (* lt 0 (add (binom x q)(binom x (Suc q))) *)
                (* rewrite add(..)(..) -> binom(Suc x)(Suc q) via sym bSS *)
                val lt0bSS = (let val zF = Free("zs", natT)
                                  val Pabs = Term.lambda zF (lt ZeroC zF)
                              in substPredPr (Pabs, add (binom xF qF)(binom xF (suc qF)), binom Sx (suc qF))
                                   (oeq_sym OF [bSS]) lt0sum end);  (* lt 0 (binom (Suc x)(Suc q)) *)
                (* rewrite binom (Suc x)(Suc q) -> binom (Suc x) k via sym hq (k = Suc q) on 2nd arg *)
                val g = (let val zF = Free("zk2", natT)
                             val Pabs = Term.lambda zF (lt ZeroC (binom Sx zF))
                         in substPredPr (Pabs, suc qF, kF) (oeq_sym OF [hq]) lt0bSS end);  (* lt 0 (binom (Suc x) k) *)
              in g end;
            val g = exE_elimPr (PabsQ, goalC) (Thm.assume (ctermPr (jT (mkEx PabsQ)))) "q_bp" bodyQ;
          in Thm.implies_intr (ctermPr (jT (mkEx PabsQ))) g end;
        val g = disjE_elimPr (oeq kF ZeroC, mkEx (Abs("q", natT, oeq kF (suc (Bound 0)))), goalC) dz caseZ caseS;
        val imp = impI_Pr (le kF Sx, lt ZeroC (binom Sx kF))
                    (Thm.implies_intr (ctermPr (jT (le kF Sx))) g);
        val allm = Thm.forall_intr (ctermPr kF) imp;
      in allI_Pr (obody Sx) allm end;

    val step1 = Thm.forall_intr (ctermPr xF) (Thm.implies_intr (ctermPr ihP) step);
    val r1 = Thm.implies_elim ind base;
    val r2 = Thm.implies_elim r1 step1;        (* jT (Forall (obody n)) for the Free n *)
    (* specialise the outer Forall to a fresh k, then discharge to get the meta rule. *)
    val kF2 = Free("k", natT);
    val impAt = allE_Pr (obody nV) kF2 r2;     (* Imp (le k n)(lt 0 (binom n k)) *)
    val hLe = Thm.assume (ctermPr (jT (le kF2 nV)));
    val concl = mp_Pr (le kF2 nV, lt ZeroC (binom nV kF2)) impAt hLe;
    val disch = Thm.implies_intr (ctermPr (jT (le kF2 nV))) concl;   (* le k n ==> lt 0 (binom n k) *)
  in varify disch end;

val () = out ("binom_pos 0hyp=" ^ Bool.toString (zhPr binom_pos) ^ "\n");
val i_binom_pos =
  let val nVp = Var(("n",0),natT); val kVp = Var(("k",0),natT)
  in Logic.mk_implies (jT (le kVp nVp), jT (lt ZeroC (binom nVp kVp))) end;
val () = out ("binom_pos aconv=" ^ Bool.toString ((Thm.prop_of binom_pos) aconv i_binom_pos) ^ "\n");
val binom_pos_vPr = varify binom_pos;
fun binom_pos_atPr (nT,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtPr
        [(("n",0), ctermPr nT),(("k",0), ctermPr kT)] binom_pos_vPr)) h;
val () = if zhPr binom_pos andalso ((Thm.prop_of binom_pos) aconv i_binom_pos)
         then out "BINOM_POS_OK\n" else out "BINOM_POS_FAIL\n";

(* ============================================================================
   BERTRAND F2b — (G2) UPPER-RANGE PRODUCT  (gap induction)
   m a fixed Free.  C = binom (2m+1) m  with 2m+1 = add (add m m)(Suc 0).
   idx d = add (Suc m) d.  Induction predicate (object-Imp form):
     Rbody d = Imp (le d m)
                (Ex U. Conj (oeq (primorial (idx d)) (mult (primorial (Suc m)) U))
                            (Conj (dvd U C)
                                  (Forall (%q. Imp (prime2 q)
                                              (Imp (lt (idx d) q) (neg (dvd q U)))))))
   Prove  !d. Rbody d  by nat_induct, then specialise d := m to get primorial_split.
   ============================================================================ *)
val () = out "G2_BEGIN\n";

val mG  = Free("m", natT);
val twoMp1 = add (add mG mG) (suc ZeroC);          (* 2m+1 *)
val CG  = binom twoMp1 mG;                          (* C(2m+1,m) *)
fun idx d = add (suc mG) d;
val SmG = suc mG;

(* coprimality predicate : %q. Imp (prime2 q)(Imp (lt I q)(neg (dvd q U)))
   built with Term.lambda over a FRESH Free (prime2/lt/dvd carry inner binders -> manual
   Bound 0 would be CAPTURED).  *)
fun coP_of (I, U) =
  let val qF = Free("q_co", natT)
  in Term.lambda qF (mkImp (prime2 qF) (mkImp (lt I qF) (neg (dvd qF U)))) end;
(* the conjunction body for a concrete U Free : Conj (oeq..)(Conj (dvd U C)(Forall (coP_of (I,U)))) *)
fun bodyConj (I, U) =
  mkConj (oeq (primorial I) (mult (primorial SmG) U))
    (mkConj (dvd U CG) (mkForall (coP_of (I, U))));
(* the existential body : %U. bodyConj (I, U)   (Term.lambda over FRESH Free) *)
fun exBody I =
  let val uF = Free("U_eb", natT)
  in Term.lambda uF (bodyConj (I, uF)) end;
fun RbodyTerm d = mkImp (le d mG) (mkEx (exBody (idx d)));

(* ---- arithmetic facts reused below ---- *)
(* 2m+1 = Suc(m+m) : add (add m m)(Suc 0) = Suc(add m m) *)
val twoMp1_eq =
  let val aS = addSrPr_at (add mG mG, ZeroC)      (* (m+m) + Suc 0 = Suc((m+m)+0) *)
      val a0 = add0rPr_at (add mG mG)             (* (m+m)+0 = m+m *)
      val s  = Suc_cong OF [a0]                    (* Suc((m+m)+0) = Suc(m+m) *)
  in oeq_trans OF [aS, s] end;                     (* oeq (2m+1)(Suc(m+m)) *)

(* idx (Suc d) = Suc (idx d) : add (Suc m)(Suc d) = Suc(add (Suc m) d) *)
fun idxSuc_eq d = addSrPr_at (SmG, d);             (* oeq (idx (Suc d))(Suc(idx d)) *)

val () = out "G2_ARITH_OK\n";

(* ============================================================================
   THE INDUCTION
   ============================================================================ *)
val upper_prod_all =     (* |- !d. Rbody d   (as jT (P d) with P = %d. RbodyTerm d) *)
  let
    val dV    = Free("d", natT);
    val Pind  = Term.lambda dV (RbodyTerm dV);           (* %d. RbodyTerm d  (correct de Bruijn) *)
    val ind   = beta_norm (Drule.infer_instantiate ctxtPr
                  [(("P",0), ctermPr Pind), (("k",0), ctermPr dV)] nat_induct_vPr);

    (* ---------- BASE  d = 0 ---------- *)
    val base =
      let
        val hLe0 = Thm.assume (ctermPr (jT (le ZeroC mG)));   (* le 0 m (unused but discharged) *)
        val U0   = suc ZeroC;                                 (* U = 1 *)
        (* conjunct1 : oeq (primorial (idx 0)) (mult (primorial (Suc m)) 1) *)
        val idx0_eq = add0rPr_at SmG;                          (* oeq (add (Suc m) 0)(Suc m) *)
        val prim_cong = oeq_rewrite_in (fn z => primorial z, idx ZeroC, SmG) idx0_eq;
                                                               (* oeq (primorial (idx 0))(primorial (Suc m)) *)
        val m1r = mult1rPr_at (primorial SmG);                 (* oeq (mult (primorial (Suc m)) 1)(primorial (Suc m)) *)
        val c1  = oeq_trans OF [prim_cong, oeq_sym OF [m1r]];  (* oeq (primorial (idx 0))(mult (primorial (Suc m)) 1) *)
        (* conjunct2 : dvd 1 C *)
        val c2  = one_dvd_atPr CG;                             (* dvd (Suc 0) C *)
        (* conjunct3 : Forall (%q. Imp (prime2 q)(Imp (lt (idx 0) q)(neg (dvd q 1)))) *)
        val coP = coP_of (idx ZeroC, U0);
        val qF  = Free("q", natT);
        val perq =
          let
            val hPrq = Thm.assume (ctermPr (jT (prime2 qF)));            (* prime2 q *)
            val hLtq = Thm.assume (ctermPr (jT (lt (idx ZeroC) qF)));    (* lt (idx 0) q *)
            (* neg (dvd q 1) : assume dvd q 1 -> oFalse via not_dvd_one (need lt 1 q from prime2 q) *)
            val negDvd =
              let
                val hdvd = Thm.assume (ctermPr (jT (dvd qF U0)))         (* dvd q 1 *)
                val gt1  = prime2_gt1_atPr qF hPrq                       (* lt 1 q *)
                val ff   = not_dvd_one_atPr qF gt1 hdvd                  (* oFalse *)
                val meta = Thm.implies_intr (ctermPr (jT (dvd qF U0))) ff
              in impI_Pr (dvd qF U0, oFalseC) meta end;                  (* jT (Imp (dvd q 1) oFalse) = jT(neg (dvd q 1)) *)
            val s2 = impI_Pr (lt (idx ZeroC) qF, neg (dvd qF U0))
                       (Thm.implies_intr (ctermPr (jT (lt (idx ZeroC) qF))) negDvd);
            val s1 = impI_Pr (prime2 qF, mkImp (lt (idx ZeroC) qF) (neg (dvd qF U0)))
                       (Thm.implies_intr (ctermPr (jT (prime2 qF))) s2);
          in s1 end;
        val allq = allI_Pr coP (Thm.forall_intr (ctermPr qF) perq);     (* Forall (coP) *)
        (* assemble the conjunction, then exI at U=1 *)
        val conj = conjI_Pr (oeq (primorial (idx ZeroC)) (mult (primorial SmG) U0),
                             mkConj (dvd U0 CG) (mkForall coP)) c1
                     (conjI_Pr (dvd U0 CG, mkForall coP) c2 allq);
        val exU  = (beta_norm (Drule.infer_instantiate ctxtPr
                      [(("P",0), ctermPr (exBody (idx ZeroC))),(("a",0), ctermPr U0)] exI_vPr)) OF [conj];
        (* discharge le 0 m as an OBJECT Imp : Imp (le 0 m)(Ex ...) = Rbody 0 *)
        val metaImp = Thm.implies_intr (ctermPr (jT (le ZeroC mG))) exU;   (* jT(le 0 m) ==> jT(Ex) *)
      in impI_Pr (le ZeroC mG, mkEx (exBody (idx ZeroC))) metaImp end;     (* jT (Imp (le 0 m)(Ex)) *)

    (* ---------- STEP  d -> Suc d ---------- *)
    val xF    = Free("x", natT);                  (* the induction variable d *)
    val ihP   = jT (RbodyTerm xF);                (* IH : Rbody x = Imp (le x m)(Ex ...) *)
    val IH    = Thm.assume (ctermPr ihP);
    val step  =
      let
        val hLeSx = Thm.assume (ctermPr (jT (le (suc xF) mG)));   (* le (Suc x) m *)
        (* le x m from le (Suc x) m : le x (Suc x) trans le (Suc x) m *)
        val le_x_Sx = le_suc_self_atPr xF;                        (* le x (Suc x) *)
        val le_x_m  = le_trans_atPr (xF, suc xF, mG) le_x_Sx hLeSx;  (* le x m *)
        (* apply IH : Ex U. exBody (idx x) U *)
        val exThm = mp_Pr (le xF mG, mkEx (exBody (idx xF))) IH le_x_m;  (* Ex U. ... *)
        val kT    = idx xF;                          (* k = idx x = Suc m + x *)
        val Sk    = suc kT;                          (* Suc k *)
        (* idx (Suc x) = Suc k *)
        val idxS_eq = idxSuc_eq xF;                  (* oeq (idx (Suc x))(Suc k) *)
        val goalSuc = mkEx (exBody (idx (suc xF)));  (* the Ex for Suc x *)

        fun bodyU UF (hU : thm) =     (* hU : Conj (oeq (primorial (idx x))(mult (primorial(Sm)) U))(Conj (dvd U C)(Forall coP_of(k,U))) *)
          let
            val coAbs = coP_of (kT, UF);    (* %q. Imp (prime2 q)(Imp (lt k q)(neg (dvd q U))) *)
            val eqA = conjunct1_Pr (oeq (primorial kT) (mult (primorial SmG) UF),
                          mkConj (dvd UF CG) (mkForall coAbs)) hU;
                      (* oeq (primorial k)(mult (primorial(Sm)) U) *)
            val restA = conjunct2_Pr (oeq (primorial kT) (mult (primorial SmG) UF),
                          mkConj (dvd UF CG) (mkForall coAbs)) hU;
            val dvdUC = conjunct1_Pr (dvd UF CG, mkForall coAbs) restA;
                        (* dvd U C *)
            val coAll = conjunct2_Pr (dvd UF CG, mkForall coAbs) restA;
                        (* Forall (%q. Imp (prime2 q)(Imp (lt k q)(neg (dvd q U)))) *)
            (* coAt q : prime2 q -> lt k q -> neg (dvd q U) *)
            fun coAt qT hPrq hLtkq =
              let val impAt = allE_Pr coAbs qT coAll       (* Imp (prime2 q)(Imp (lt k q)(neg (dvd q U))) *)
                  val i2 = mp_Pr (prime2 qT, mkImp (lt kT qT)(neg (dvd qT UF))) impAt hPrq
              in mp_Pr (lt kT qT, neg (dvd qT UF)) i2 hLtkq end;

            (* ---- common : lt k q from lt (Suc k) q  (for use in both cases) ---- *)
            fun ltk_of_ltSk qT hLtSkq =     (* hLtSkq : lt (Suc k) q = le (Suc(Suc k)) q ; want lt k q = le (Suc k) q *)
              let val le_Sk_SSk = le_suc_self_atPr Sk        (* le (Suc k)(Suc(Suc k)) *)
              in le_trans_atPr (Sk, suc Sk, qT) le_Sk_SSk hLtSkq end;   (* le (Suc k) q = lt k q *)

            (* split on prime2 (Suc k) *)
            val emThm = ex_middle_Pr (prime2 Sk);    (* Disj (prime2 (Suc k))(neg (prime2 (Suc k))) *)

            (* ===== PRIME CASE : prime2 (Suc k), U' = (Suc k)*U ===== *)
            val casePrime =
              let
                val hPrSk = Thm.assume (ctermPr (jT (prime2 Sk)));   (* prime2 (Suc k) *)
                val Up = mult Sk UF;                                 (* U' = (Suc k)*U *)
                (* --- conjunct1 : oeq (primorial (idx (Suc x))) (mult (primorial(Sm)) U') --- *)
                (* primorial (Suc k) = (Suc k)*primorial k   [psp] *)
                val prSk = primorial_Suc_prime_atPr kT hPrSk;        (* oeq (primorial(Suc k))(mult (Suc k)(primorial k)) *)
                (* (Suc k)*primorial k = (Suc k)*(primorial(Sm)*U)  [cong on 2nd arg with eqA] *)
                val congPk = mult_cong_rPr (Sk, primorial kT, mult (primorial SmG) UF) eqA;
                                                                     (* oeq (mult (Suc k)(primorial k))(mult (Suc k)(mult (primorial(Sm)) U)) *)
                (* (Suc k)*(pm*U) = ((Suc k)*pm)*U  [assoc sym] *)
                val assoc1 = multassocPr_at (Sk, primorial SmG, UF); (* oeq (((Suc k)*pm)*U)((Suc k)*(pm*U)) *)
                val assoc1s = oeq_sym OF [assoc1];                   (* oeq ((Suc k)*(pm*U))(((Suc k)*pm)*U) *)
                (* (Suc k)*pm = pm*(Suc k)  [comm] -> ((Suc k)*pm)*U = (pm*(Suc k))*U  [cong l] *)
                val commPk = multcommPr_at (Sk, primorial SmG);      (* oeq ((Suc k)*pm)(pm*(Suc k)) *)
                val congL  = mult_cong_lPr (mult Sk (primorial SmG), mult (primorial SmG) Sk, UF) commPk;
                                                                     (* oeq (((Suc k)*pm)*U)((pm*(Suc k))*U) *)
                (* (pm*(Suc k))*U = pm*((Suc k)*U) = pm*U'  [assoc] *)
                val assoc2 = multassocPr_at (primorial SmG, Sk, UF); (* oeq ((pm*(Suc k))*U)(pm*((Suc k)*U)) *)
                (* chain : primorial(Suc k) = ... = pm*U' *)
                val ch1 = oeq_trans OF [prSk, congPk];               (* primorial(Suc k) = (Suc k)*(pm*U) *)
                val ch2 = oeq_trans OF [ch1, assoc1s];               (* = ((Suc k)*pm)*U *)
                val ch3 = oeq_trans OF [ch2, congL];                 (* = (pm*(Suc k))*U *)
                val ch4 = oeq_trans OF [ch3, assoc2];                (* = pm*((Suc k)*U) = mult pm U' *)
                (* rewrite LHS primorial(Suc k) -> primorial(idx(Suc x)) via sym idxS_eq *)
                val congIdx = oeq_rewrite_in (fn z => primorial z, idx (suc xF), Sk) idxS_eq;
                                                                     (* oeq (primorial(idx(Suc x)))(primorial(Suc k)) *)
                val c1p = oeq_trans OF [congIdx, ch4];               (* oeq (primorial(idx(Suc x)))(mult pm U') *)

                (* --- conjunct2 : dvd U' C  via prime_prod_dvd --- *)
                (* dvd (Suc k) C via mid_dvd : need lt (Suc m)(Suc k) and le (Suc k)(2m+1) *)
                (* le (Suc k)(2m+1) : Suc k = idx(Suc x)? we keep Sk = Suc(idx x).
                   le (Suc k)(Suc(m+m)) iff le k (m+m).  k = Suc m + x = Suc(m+x).
                   so need le (Suc(m+x))(m+m).  From le (Suc x) m : le ((Suc x)+m)(m+m) [le_add_mono c:=m];
                   (Suc x)+m = Suc(x+m) = Suc(m+x) [comm]. *)
                val le_addm = le_add_mono_atPr (suc xF, mG, mG) hLeSx;   (* le ((Suc x)+m)(m+m) *)
                (* (Suc x)+m = Suc(x+m) [add_Suc] ; x+m = m+x [comm] -> Suc(m+x) *)
                val sxm  = addSucPr_at (xF, mG);                    (* oeq ((Suc x)+m)(Suc(x+m)) *)
                val xm_mx= addcommPr_at (xF, mG);                  (* oeq (x+m)(m+x) *)
                val sxm2 = oeq_trans OF [sxm, Suc_cong OF [xm_mx]];(* oeq ((Suc x)+m)(Suc(m+x)) *)
                (* rewrite le ((Suc x)+m)(m+m) -> le (Suc(m+x))(m+m) on the LEFT arg *)
                val le_Smx_mm = (let val zF = Free("zle", natT)
                                     val Pabs = Term.lambda zF (le zF (add mG mG))
                                 in substPredPr (Pabs, add (suc xF) mG, suc (add mG xF)) sxm2 le_addm end);
                                  (* le (Suc(m+x))(m+m) *)
                (* k = Suc(m+x) : k = idx x = Suc m + x = Suc(m+x) [add_Suc] *)
                val k_eq = addSucPr_at (mG, xF);                   (* oeq (idx x)(Suc(m+x))  i.e. oeq k (Suc(m+x)) *)
                (* le k (m+m) : rewrite le (Suc(m+x))(m+m) -> le k (m+m) via sym k_eq on left *)
                val le_k_mm = (let val zF = Free("zlk", natT)
                                   val Pabs = Term.lambda zF (le zF (add mG mG))
                               in substPredPr (Pabs, suc (add mG xF), kT) (oeq_sym OF [k_eq]) le_Smx_mm end);
                                (* le k (m+m) *)
                (* le (Suc k)(Suc(m+m)) [le_suc_mono] ; rewrite Suc(m+m) -> 2m+1 via sym twoMp1_eq *)
                val le_Sk_Smm = le_suc_mono_atPr (kT, add mG mG) le_k_mm;  (* le (Suc k)(Suc(m+m)) *)
                val le_Sk_2mp1 = (let val zF = Free("zr", natT)
                                      val Pabs = Term.lambda zF (le Sk zF)
                                  in substPredPr (Pabs, suc (add mG mG), twoMp1) (oeq_sym OF [twoMp1_eq]) le_Sk_Smm end);
                                   (* le (Suc k)(2m+1) *)
                (* lt (Suc m)(Suc k) = le (Suc(Suc m))(Suc k).
                   le (Suc m) k : k = Suc m + x ; le (Suc m)(Suc m + x) [le_add]. then le_suc_mono. *)
                val le_Sm_k = le_add_atPr (SmG, xF);              (* le (Suc m)(Suc m + x) = le (Suc m) k *)
                val lt_Sm_Sk = le_suc_mono_atPr (SmG, kT) le_Sm_k;  (* le (Suc(Suc m))(Suc k) = lt (Suc m)(Suc k) *)
                val dvd_Sk_C = mid_dvd_atPr (Sk, mG) hPrSk lt_Sm_Sk le_Sk_2mp1;   (* dvd (Suc k) C *)
                (* ~(dvd (Suc k) U) : from coAt at q = Suc k (need prime2 (Suc k) and lt k (Suc k)) *)
                val lt_k_Sk = le_refl_atPr Sk;                    (* le (Suc k)(Suc k) = lt k (Suc k) *)
                val negSkU  = coAt Sk hPrSk lt_k_Sk;              (* neg (dvd (Suc k) U) *)
                val dvdUpC  = prime_prod_dvd_atPr (Sk, CG, UF) hPrSk dvd_Sk_C negSkU dvdUC;
                            (* dvd ((Suc k)*U) C = dvd U' C *)

                (* --- conjunct3 : Forall (%q. Imp (prime2 q)(Imp (lt (idx(Suc x)) q)(neg (dvd q U')))) --- *)
                val coP' = coP_of (idx (suc xF), Up);
                val qF2 = Free("q", natT);
                val perq' =
                  let
                    val hPrq = Thm.assume (ctermPr (jT (prime2 qF2)))
                    val hLtq = Thm.assume (ctermPr (jT (lt (idx (suc xF)) qF2)))   (* lt (idx(Suc x)) q *)
                    (* rewrite lt (idx(Suc x)) q -> lt (Suc k) q via idxS_eq on the FIRST arg of lt.
                       lt a q = le (Suc a) q ; rewrite a -> Suc k : need oeq (idx(Suc x))(Suc k) = idxS_eq.
                       lt (idx(Suc x)) q = le (Suc(idx(Suc x))) q ; we rewrite the Suc(idx(Suc x)) inner.
                       Simplify: define rewrite on lt's left operand via Pabs %z. lt z q (= le (Suc z) q). *)
                    val hLtSkq = (let val zF = Free("zlt", natT)
                                      val Pabs = Term.lambda zF (lt zF qF2)
                                  in substPredPr (Pabs, idx (suc xF), Sk) idxS_eq hLtq end);
                                   (* lt (Suc k) q *)
                    val negDvd =
                      let
                        val hdvd = Thm.assume (ctermPr (jT (dvd qF2 Up)))   (* dvd q ((Suc k)*U) *)
                        val disj = euclid_atPr (qF2, Sk, UF) hPrq hdvd      (* Disj (dvd q (Suc k))(dvd q U) *)
                        (* case dvd q (Suc k) : q>1, Suc k>1 (prime), q>Suc k -> prime_not_dvd_pos_lt *)
                        val caseSk =
                          let
                            val hd = Thm.assume (ctermPr (jT (dvd qF2 Sk)))
                            (* lt 0 (Suc k) *)
                            val pos = lt_zero_suc_atPr kT                    (* lt 0 (Suc k) *)
                            val ff  = prime_not_dvd_pos_lt_atPr (qF2, Sk) hd pos hLtSkq  (* oFalse *)
                          in Thm.implies_intr (ctermPr (jT (dvd qF2 Sk))) ff end;
                        (* case dvd q U : IH coAt at q (need lt k q from lt (Suc k) q) *)
                        val caseU =
                          let
                            val hd = Thm.assume (ctermPr (jT (dvd qF2 UF)))
                            val lt_k_q = ltk_of_ltSk qF2 hLtSkq              (* lt k q *)
                            val negqU  = coAt qF2 hPrq lt_k_q                (* neg (dvd q U) *)
                            val ff = mp_Pr (dvd qF2 UF, oFalseC) negqU hd    (* oFalse *)
                          in Thm.implies_intr (ctermPr (jT (dvd qF2 UF))) ff end;
                        val ff = disjE_elimPr (dvd qF2 Sk, dvd qF2 UF, oFalseC) disj caseSk caseU;
                      in impI_Pr (dvd qF2 Up, oFalseC)
                           (Thm.implies_intr (ctermPr (jT (dvd qF2 Up))) ff) end;   (* jT(neg (dvd q U')) *)
                    val s2 = impI_Pr (lt (idx (suc xF)) qF2, neg (dvd qF2 Up))
                               (Thm.implies_intr (ctermPr (jT (lt (idx (suc xF)) qF2))) negDvd);
                    val s1 = impI_Pr (prime2 qF2, mkImp (lt (idx (suc xF)) qF2) (neg (dvd qF2 Up)))
                               (Thm.implies_intr (ctermPr (jT (prime2 qF2))) s2);
                  in s1 end;
                val allq' = allI_Pr coP' (Thm.forall_intr (ctermPr qF2) perq');

                (* assemble + exI at U' *)
                val conj = conjI_Pr (oeq (primorial (idx (suc xF))) (mult (primorial SmG) Up),
                             mkConj (dvd Up CG) (mkForall coP')) c1p
                             (conjI_Pr (dvd Up CG, mkForall coP') dvdUpC allq');
                val exU' = (beta_norm (Drule.infer_instantiate ctxtPr
                              [(("P",0), ctermPr (exBody (idx (suc xF)))),(("a",0), ctermPr Up)] exI_vPr)) OF [conj];
              in Thm.implies_intr (ctermPr (jT (prime2 Sk))) exU' end;

            (* ===== NONPRIME CASE : neg (prime2 (Suc k)), U' = U ===== *)
            val caseNonprime =
              let
                val hNpSk = Thm.assume (ctermPr (jT (neg (prime2 Sk))));   (* Imp (prime2 (Suc k)) oFalse *)
                (* primorial (Suc k) = primorial k  [psp_nonprime] *)
                val prSkn = primorial_Suc_nonprime_atPr kT hNpSk;          (* oeq (primorial(Suc k))(primorial k) *)
                (* conjunct1 : oeq (primorial(idx(Suc x)))(mult pm U) *)
                val congIdx = oeq_rewrite_in (fn z => primorial z, idx (suc xF), Sk) idxS_eq;
                                                                           (* oeq (primorial(idx(Suc x)))(primorial(Suc k)) *)
                val c1n = oeq_trans OF [oeq_trans OF [congIdx, prSkn], eqA];  (* oeq (primorial(idx(Suc x)))(mult pm U) *)
                (* conjunct3 : Forall (%q. ... neg (dvd q U)) at idx(Suc x) *)
                val coP'' = coP_of (idx (suc xF), UF);
                val qF3 = Free("q", natT);
                val perq'' =
                  let
                    val hPrq = Thm.assume (ctermPr (jT (prime2 qF3)))
                    val hLtq = Thm.assume (ctermPr (jT (lt (idx (suc xF)) qF3)))
                    val hLtSkq = (let val zF = Free("zlt2", natT)
                                      val Pabs = Term.lambda zF (lt zF qF3)
                                  in substPredPr (Pabs, idx (suc xF), Sk) idxS_eq hLtq end);  (* lt (Suc k) q *)
                    val lt_k_q = ltk_of_ltSk qF3 hLtSkq                    (* lt k q *)
                    val negqU  = coAt qF3 hPrq lt_k_q                      (* neg (dvd q U) : jT(Imp (dvd q U) oFalse) *)
                    val s2 = impI_Pr (lt (idx (suc xF)) qF3, neg (dvd qF3 UF))
                               (Thm.implies_intr (ctermPr (jT (lt (idx (suc xF)) qF3))) negqU);
                    val s1 = impI_Pr (prime2 qF3, mkImp (lt (idx (suc xF)) qF3) (neg (dvd qF3 UF)))
                               (Thm.implies_intr (ctermPr (jT (prime2 qF3))) s2);
                  in s1 end;
                val allq'' = allI_Pr coP'' (Thm.forall_intr (ctermPr qF3) perq'');
                val conj = conjI_Pr (oeq (primorial (idx (suc xF))) (mult (primorial SmG) UF),
                             mkConj (dvd UF CG) (mkForall coP'')) c1n
                             (conjI_Pr (dvd UF CG, mkForall coP'') dvdUC allq'');
                val exU'' = (beta_norm (Drule.infer_instantiate ctxtPr
                              [(("P",0), ctermPr (exBody (idx (suc xF)))),(("a",0), ctermPr UF)] exI_vPr)) OF [conj];
              in Thm.implies_intr (ctermPr (jT (neg (prime2 Sk)))) exU'' end;

            val gEx = disjE_elimPr (prime2 Sk, neg (prime2 Sk), goalSuc) emThm casePrime caseNonprime;
          in gEx end;

        val exGoal = exE_elimPr (exBody (idx xF), goalSuc) exThm "U_up" bodyU;   (* Ex U'. ... for Suc x *)
        val metaImpS = Thm.implies_intr (ctermPr (jT (le (suc xF) mG))) exGoal; (* jT(le (Suc x) m)==>jT(Ex) *)
      in impI_Pr (le (suc xF) mG, goalSuc) metaImpS end;                        (* jT (Rbody (Suc x)) *)

    val step1 = Thm.forall_intr (ctermPr xF) (Thm.implies_intr (ctermPr ihP) step);
    val r1 = Thm.implies_elim ind base;
    val r2 = Thm.implies_elim r1 step1;   (* jT (P d) = jT (RbodyTerm d) *)
  in r2 end;

val () = out ("upper_prod_all (open d) 0hyp=" ^ Bool.toString (zhPr upper_prod_all) ^ "\n");
val () = out "G2_INDUCT_OK\n";

(* ============================================================================
   primorial_split : specialise d := m, mp with (le m m), then extract.
     primorial (idx m) = primorial(Suc m) * U,  dvd U C,  le U (pow 4 m).
   idx m = Suc m + m = Suc(m+m) = 2m+1.
   ============================================================================ *)
(* jT (RbodyTerm m) = jT (Imp (le m m)(Ex U. bodyConj (idx m, U))) *)
val dFreeM = Free("d", natT);    (* same Free that upper_prod_all is open over *)
val rb_at_m = Thm.forall_elim (ctermPr mG) (Thm.forall_intr (ctermPr dFreeM) upper_prod_all);
val () = out ("rb_at_m 0hyp=" ^ Bool.toString (zhPr rb_at_m) ^ "\n");
val exU_at_m = mp_Pr (le mG mG, mkEx (exBody (idx mG))) rb_at_m (le_refl_atPr mG);  (* Ex U. bodyConj (idx m, U) *)

(* idx m = 2m+1 : add (Suc m) m = Suc(m+m) [add_Suc] ; 2m+1 = Suc(m+m) [twoMp1_eq] *)
val idxm_eq_2mp1 =
  let val s = addSucPr_at (mG, mG)        (* oeq (add (Suc m) m)(Suc(m+m)) *)
  in oeq_trans OF [s, oeq_sym OF [twoMp1_eq]] end;   (* oeq (idx m)(2m+1) *)

(* primorial_split : produce, via exE, the three facts wrapped so we can use them.
   We package: Ex U. Conj (oeq (primorial (2m+1))(mult (primorial(Suc m)) U))(Conj (dvd U C)(le U (pow 4 m))).
   Then the strong-induction odd step will exE this. *)
val four = suc (suc (suc (suc ZeroC)));   (* re-bind locally for clarity (matches base `four`) *)
val splitBodyAbs =
  let val uF = Free("U_sp", natT)
  in Term.lambda uF (mkConj (oeq (primorial twoMp1) (mult (primorial SmG) uF))
                       (mkConj (dvd uF CG) (le uF (pow four mG)))) end;
val primorial_split_ex =     (* jT (Ex U. Conj (oeq prim(2m+1) = prim(Sm)*U)(Conj (dvd U C)(le U (4^m)))) *)
  let
    fun bodyU UF (hU : thm) =    (* hU : bodyConj (idx m, U) = Conj (oeq (prim(idx m))(prim(Sm)*U))(Conj (dvd U C)(Forall coP)) *)
      let
        val coAbs = coP_of (idx mG, UF);
        val eqA = conjunct1_Pr (oeq (primorial (idx mG)) (mult (primorial SmG) UF),
                      mkConj (dvd UF CG) (mkForall coAbs)) hU;     (* oeq (prim (idx m))(prim(Sm)*U) *)
        val restA = conjunct2_Pr (oeq (primorial (idx mG)) (mult (primorial SmG) UF),
                      mkConj (dvd UF CG) (mkForall coAbs)) hU;
        val dvdUC = conjunct1_Pr (dvd UF CG, mkForall coAbs) restA;  (* dvd U C *)
        (* rewrite prim(idx m) -> prim(2m+1) via idxm_eq_2mp1 on LHS of eqA *)
        val eqA2 = (let val zF = Free("zpm", natT)
                        val Pabs = Term.lambda zF (oeq (primorial zF)(mult (primorial SmG) UF))
                    in substPredPr (Pabs, idx mG, twoMp1) idxm_eq_2mp1 eqA end);  (* oeq (prim(2m+1))(prim(Sm)*U) *)
        (* le U (pow 4 m) : dvd U C -> le U C (dvd_le, C != 0 via binom_pos) ; le C (4^m) [odd_mid_bound] ; trans *)
        (* C != 0 : binom_pos (2m+1, m) needs le m (2m+1). le m (Suc m + m) = le m (idx m)? we use le m (2m+1).
           le m (2m+1): 2m+1 = Suc(m+m) ; le m (m+m) [le_add] ; le (m+m)(Suc(m+m)) [le_suc_self] trans ;
           then rewrite Suc(m+m) -> 2m+1. *)
        val le_m_mm   = le_add_atPr (mG, mG);                      (* le m (m+m) *)
        val le_mm_Smm = le_suc_self_atPr (add mG mG);             (* le (m+m)(Suc(m+m)) *)
        val le_m_Smm  = le_trans_atPr (mG, add mG mG, suc (add mG mG)) le_m_mm le_mm_Smm;  (* le m (Suc(m+m)) *)
        val le_m_2mp1 = (let val zF = Free("zlm", natT)
                             val Pabs = Term.lambda zF (le mG zF)
                         in substPredPr (Pabs, suc (add mG mG), twoMp1) (oeq_sym OF [twoMp1_eq]) le_m_Smm end);  (* le m (2m+1) *)
        val lt0C = binom_pos_atPr (twoMp1, mG) le_m_2mp1;          (* lt 0 C = le 1 C *)
        (* nzMeta : oeq C 0 ==> oFalse.  from lt 0 C (= le 1 C) assume oeq C 0 -> le 1 0 -> impossible.
           le 1 C and oeq C 0 -> le 1 0 (rewrite C->0) ; le 1 0 = le (Suc 0) 0 = lt 0 0 -> lt_irrefl 0. *)
        val nzMeta =
          let
            val hC0 = Thm.assume (ctermPr (jT (oeq CG ZeroC)))     (* oeq C 0 *)
            val le10 = (let val zF = Free("zc", natT)
                            val Pabs = Term.lambda zF (le (suc ZeroC) zF)
                        in substPredPr (Pabs, CG, ZeroC) hC0 lt0C end)  (* le 1 0 = lt 0 0 *)
            val ff = lt_irrefl_atPr ZeroC OF [le10]                 (* oFalse *)
          in Thm.implies_intr (ctermPr (jT (oeq CG ZeroC))) ff end;
        val le_U_C = dvd_le_atPr (UF, CG) dvdUC nzMeta;            (* le U C *)
        val le_C_4m = odd_mid_bound_atPr mG;                       (* le C (pow 4 m) *)
        val le_U_4m = le_trans_atPr (UF, CG, pow four mG) le_U_C le_C_4m;  (* le U (pow 4 m) *)
        (* assemble Conj (eqA2)(Conj (dvdUC)(le_U_4m)) and exI at U *)
        val conj = conjI_Pr (oeq (primorial twoMp1)(mult (primorial SmG) UF),
                     mkConj (dvd UF CG)(le UF (pow four mG))) eqA2
                     (conjI_Pr (dvd UF CG, le UF (pow four mG)) dvdUC le_U_4m);
        val exU' = (beta_norm (Drule.infer_instantiate ctxtPr
                      [(("P",0), ctermPr splitBodyAbs),(("a",0), ctermPr UF)] exI_vPr)) OF [conj];
      in exU' end;
    val goalEx = mkEx splitBodyAbs;
  in exE_elimPr (exBody (idx mG), goalEx) exU_at_m "U_sp0" bodyU end;

val () = out ("primorial_split_ex 0hyp=" ^ Bool.toString (zhPr primorial_split_ex) ^ "\n");
val () = out "PRIMORIAL_SPLIT_OK\n";
(* generalise m : a meta-rule  !!m. jT (Ex U. ...)  so the strong-induct step can specialise *)
val primorial_split_gen = Thm.forall_intr (ctermPr mG) primorial_split_ex;   (* !!m. jT(Ex U. split body) *)
val () = out ("primorial_split_gen 0hyp=" ^ Bool.toString (zhPr primorial_split_gen) ^ "\n");
val () = out "UPPER_PROD_OK\n";

(* ============================================================================
   BERTRAND F2b — STAGE (H) : parity + STRONG INDUCTION  primorial n <= 4^n
   ============================================================================ *)
val () = out "H_BEGIN\n";

(* ---------------------------------------------------------------------------
   parity : Disj (Ex m. oeq n (add m m)) (Ex m. oeq n (Suc (add m m)))
   by induction on n.
   --------------------------------------------------------------------------- *)
val evenAbs = fn nt => Abs("m", natT, oeq nt (add (Bound 0)(Bound 0)));          (* %m. n = m+m *)
val oddAbs  = fn nt => Abs("m", natT, oeq nt (suc (add (Bound 0)(Bound 0))));    (* %m. n = Suc(m+m) *)
fun evenEx nt = mkEx (evenAbs nt);
fun oddEx  nt = mkEx (oddAbs nt);

val parity =
  let
    fun pbody nt = mkDisj (evenEx nt) (oddEx nt);
    val nV = Free("n", natT);
    val Qpred = Term.lambda nV (pbody nV);
    val ind = beta_norm (Drule.infer_instantiate ctxtPr
                [(("P",0), ctermPr Qpred),(("k",0), ctermPr nV)] nat_induct_vPr);
    (* BASE n=0 : even, m=0 : oeq 0 (add 0 0) ; add 0 0 = 0 *)
    val base =
      let
        val a00 = add0Pr_at ZeroC;                  (* oeq (add 0 0) 0 *)
        val eq0 = oeq_sym OF [a00];                 (* oeq 0 (add 0 0) *)
        val exE = (beta_norm (Drule.infer_instantiate ctxtPr
                    [(("P",0), ctermPr (evenAbs ZeroC)),(("a",0), ctermPr ZeroC)] exI_vPr)) OF [eq0];  (* evenEx 0 *)
      in disjI1Pr_at (evenEx ZeroC, oddEx ZeroC) exE end;
    (* STEP n=Suc x ; IH : Disj (evenEx x)(oddEx x) *)
    val xF = Free("x", natT);
    val Sx = suc xF;
    val ihP = jT (pbody xF);
    val IH  = Thm.assume (ctermPr ihP);
    val step =
      let
        val goalC = pbody Sx;
        (* case even x : x = m+m -> Suc x = Suc(m+m) -> odd, same m *)
        val caseE =
          let
            fun bodyM mF (hm : thm) =     (* hm : oeq x (add m m) *)
              let
                val sc = Suc_cong OF [hm];                (* oeq (Suc x)(Suc(add m m)) *)
                val exO = (beta_norm (Drule.infer_instantiate ctxtPr
                            [(("P",0), ctermPr (oddAbs Sx)),(("a",0), ctermPr mF)] exI_vPr)) OF [sc];  (* oddEx (Suc x) *)
              in disjI2Pr_at (evenEx Sx, oddEx Sx) exO end;
            val g = exE_elimPr (evenAbs xF, goalC) (Thm.assume (ctermPr (jT (evenEx xF)))) "m_pe" bodyM;
          in Thm.implies_intr (ctermPr (jT (evenEx xF))) g end;
        (* case odd x : x = Suc(m+m) -> Suc x = Suc(Suc(m+m)) = (Suc m)+(Suc m) -> even, m'=Suc m *)
        val caseO =
          let
            fun bodyM mF (hm : thm) =     (* hm : oeq x (Suc(add m m)) *)
              let
                val sc = Suc_cong OF [hm];                (* oeq (Suc x)(Suc(Suc(add m m))) *)
                (* (Suc m)+(Suc m) = Suc(m + Suc m) [add_Suc] = Suc(Suc(m+m)) [add_Suc_right inside] *)
                val aS  = addSucPr_at (mF, suc mF);       (* oeq ((Suc m)+(Suc m))(Suc(m + Suc m)) *)
                val aSr = addSrPr_at (mF, mF);            (* oeq (m + Suc m)(Suc(m+m)) *)
                val inner = Suc_cong OF [aSr];            (* oeq (Suc(m + Suc m))(Suc(Suc(m+m))) *)
                val smsm = oeq_trans OF [aS, inner];      (* oeq ((Suc m)+(Suc m))(Suc(Suc(m+m))) *)
                val eqEven = oeq_trans OF [sc, oeq_sym OF [smsm]];  (* oeq (Suc x)((Suc m)+(Suc m)) *)
                val exE = (beta_norm (Drule.infer_instantiate ctxtPr
                            [(("P",0), ctermPr (evenAbs Sx)),(("a",0), ctermPr (suc mF))] exI_vPr)) OF [eqEven];  (* evenEx (Suc x) *)
              in disjI1Pr_at (evenEx Sx, oddEx Sx) exE end;
            val g = exE_elimPr (oddAbs xF, goalC) (Thm.assume (ctermPr (jT (oddEx xF)))) "m_po" bodyM;
          in Thm.implies_intr (ctermPr (jT (oddEx xF))) g end;
        val g = disjE_elimPr (evenEx xF, oddEx xF, goalC) IH caseE caseO;
      in g end;
    val step1 = Thm.forall_intr (ctermPr xF) (Thm.implies_intr (ctermPr ihP) step);
    val r1 = Thm.implies_elim ind base;
    val r2 = Thm.implies_elim r1 step1;     (* jT (pbody n) for Free n *)
  in r2 end;   (* open in n (Free) *)

val () = out ("parity (open n) 0hyp=" ^ Bool.toString (zhPr parity) ^ "\n");
val () = out "PARITY_OK\n";

(* parity applicator : for a Free/term nt, gives jT (Disj (evenEx nt)(oddEx nt)). *)
val parity_gen = Thm.forall_intr (ctermPr (Free("n",natT))) parity;   (* !!n. jT (pbody n) *)
fun parity_at nt = Thm.forall_elim (ctermPr nt) parity_gen;

(* ---------------------------------------------------------------------------
   small numeric facts.
   --------------------------------------------------------------------------- *)
val twoC  = suc (suc ZeroC);
val fourC = suc (suc (suc (suc ZeroC)));
(* add_compute : oeq (add (Suc^i 0) w) (Suc^i w) chain — we just need concretes; build via le_intro. *)
(* le_self_mult4 : le a (mult 4 a)   [mult_le_mono2 (le 1 4)(le_refl a) ; mult_1_left] *)
fun le1_4 () =     (* le 1 4 : witness 3 ; oeq 4 (add 1 3) *)
  let
    val w  = suc (suc (suc ZeroC));    (* 3 *)
    val aS = addSucPr_at (ZeroC, w);   (* oeq (add 1 3)(Suc(0+3)) *)
    val a0 = add0Pr_at w;              (* oeq (0+3) 3 *)
    val sc = Suc_cong OF [a0];         (* oeq (Suc(0+3)) 4 *)
    val chain = oeq_trans OF [aS, sc]; (* oeq (add 1 3) 4 *)
    val eqn = oeq_sym OF [chain];      (* oeq 4 (add 1 3) *)
  in le_introPr (suc ZeroC, fourC, w) eqn end;
fun le_self_mult4 aT =     (* le a (mult 4 a) *)
  let
    val mm = mult_le_mono2_atPr (suc ZeroC, fourC, aT, aT) (le1_4 ()) (le_refl_atPr aT);  (* le (mult 1 a)(mult 4 a) *)
    val m1l = mult1lPr_at aT;          (* oeq (mult 1 a) a *)
    (* rewrite le (mult 1 a)(mult 4 a) -> le a (mult 4 a) on LEFT *)
  in (let val zF = Free("zlm4", natT)
          val Pabs = Term.lambda zF (le zF (mult fourC aT))
      in substPredPr (Pabs, mult (suc ZeroC) aT, aT) m1l mm end) end;

(* ---------------------------------------------------------------------------
   STRONG INDUCTION : primorial_bound : le (primorial n)(pow 4 n)
   --------------------------------------------------------------------------- *)
val primorial_bound =
  let
    val Ppred = Term.lambda (Free("n_pb", natT)) (le (primorial (Free("n_pb", natT))) (pow fourC (Free("n_pb", natT))));
    fun Pat t = le (primorial t)(pow fourC t);     (* the body Ppred t *)

    (* strong-IH structure : Gprop nt = !!j. lt j nt ==> jT (Pat j) *)
    val nH = Free("n_h", natT);
    fun GpropOf nt = let val jB = Free("j_g", natT)
                     in Logic.all jB (Logic.mk_implies (jT (lt jB nt), jT (Pat jB))) end;
    val Hthm = Thm.assume (ctermPr (GpropOf nH));   (* the strong IH at the bound n_h *)
    fun ihAt jt hlt = Thm.implies_elim (Thm.forall_elim (ctermPr jt) Hthm) hlt;  (* lt j n_h -> jT(Pat j) *)

    (* the step body : prove jT (Pat n_h) from Hthm *)
    val stepConcl =
      let
        val nF = nH;
        val goalC = Pat nF;
        (* cases : n=0 | n=Suc n' *)
        val dz = dzosPr_at nF;     (* Disj (oeq n 0)(Ex q. oeq n (Suc q)) *)
        (* CASE n=0 *)
        val case0 =
          let
            val hn0 = Thm.assume (ctermPr (jT (oeq nF ZeroC)))   (* oeq n 0 *)
            (* primorial 0 = 1, pow 4 0 = 1, le 1 1 ; rewrite to Pat n via n=0 *)
            val p0  = primorial_0_vPr;                            (* oeq (primorial 0)(Suc 0) *)
            val pw0 = pow0Pr_at fourC;                            (* oeq (pow 4 0)(Suc 0) *)
            val le11 = le_refl_atPr (suc ZeroC);                 (* le 1 1 *)
            (* le (primorial 0)(pow 4 0) : rewrite both *)
            val l1 = (let val zF = Free("zp0a", natT)
                          val Pabs = Term.lambda zF (le zF (suc ZeroC))
                      in substPredPr (Pabs, suc ZeroC, primorial ZeroC) (oeq_sym OF [p0]) le11 end);  (* le (primorial 0) 1 *)
            val l2 = (let val zF = Free("zp0b", natT)
                          val Pabs = Term.lambda zF (le (primorial ZeroC) zF)
                      in substPredPr (Pabs, suc ZeroC, pow fourC ZeroC) (oeq_sym OF [pw0]) l1 end);  (* le (primorial 0)(pow 4 0) *)
            (* rewrite 0 -> n via sym hn0 in both primorial and pow positions *)
            val g = (let val zF = Free("zp0c", natT)
                         val Pabs = Term.lambda zF (le (primorial zF)(pow fourC zF))
                     in substPredPr (Pabs, ZeroC, nF) (oeq_sym OF [hn0]) l2 end);  (* Pat n *)
          in Thm.implies_intr (ctermPr (jT (oeq nF ZeroC))) g end;
        (* CASE n=Suc n' *)
        val PabsSuc = Abs("q", natT, oeq nF (suc (Bound 0)));
        val caseSuc =
          let
            fun bodyNp npF (hnp : thm) =     (* hnp : oeq n (Suc n') *)
              let
                val Snp = suc npF;
                (* ex_middle prime2 n *)
                val emP = ex_middle_Pr (prime2 nF);   (* Disj (prime2 n)(neg (prime2 n)) *)
                (* ===== ~prime2 n : primorial n = primorial n' ; IH at n' ===== *)
                val caseNotPrime =
                  let
                    val hNp = Thm.assume (ctermPr (jT (neg (prime2 nF))));  (* Imp (prime2 n) oFalse *)
                    (* primorial n = primorial (Suc n') = primorial n'  [psp_nonprime needs ~prime2(Suc n')] *)
                    (* rewrite neg (prime2 n) -> neg (prime2 (Suc n')) via hnp (n = Suc n') on the prime2 arg *)
                    val hNpS = (let val zF = Free("znp", natT)
                                    val Pabs = Term.lambda zF (neg (prime2 zF))
                                in substPredPr (Pabs, nF, Snp) hnp hNp end);  (* neg (prime2 (Suc n')) *)
                    val prn = primorial_Suc_nonprime_atPr npF hNpS;  (* oeq (primorial (Suc n'))(primorial n') *)
                    (* rewrite LHS primorial (Suc n') -> primorial n via sym hnp *)
                    val prn2 = (let val zF = Free("zpr", natT)
                                    val Pabs = Term.lambda zF (oeq (primorial zF)(primorial npF))
                                in substPredPr (Pabs, Snp, nF) (oeq_sym OF [hnp]) prn end);  (* oeq (primorial n)(primorial n') *)
                    (* lt n' n : n = Suc n' ; lt n' (Suc n') = le (Suc n')(Suc n') = le_refl ; rewrite Suc n' -> n *)
                    val lt_np_Sn = le_refl_atPr Snp;     (* le (Suc n')(Suc n') = lt n' (Suc n') *)
                    val lt_np_n  = (let val zF = Free("zlt", natT)
                                        val Pabs = Term.lambda zF (lt npF zF)
                                    in substPredPr (Pabs, Snp, nF) (oeq_sym OF [hnp]) lt_np_Sn end);  (* lt n' n *)
                    val ihNp = ihAt npF lt_np_n;         (* le (primorial n')(pow 4 n') *)
                    (* le (pow 4 n')(pow 4 n) : pow 4 n = pow 4 (Suc n') = mult 4 (pow 4 n') ; le (pow 4 n')(mult 4 (pow 4 n')) *)
                    val le_self = le_self_mult4 (pow fourC npF);  (* le (pow 4 n')(mult 4 (pow 4 n')) *)
                    val pwSuc = powSucPr_at (fourC, npF);         (* oeq (pow 4 (Suc n'))(mult 4 (pow 4 n')) *)
                    (* rewrite mult 4 (pow 4 n') -> pow 4 (Suc n') (sym pwSuc), then Suc n' -> n (sym hnp) *)
                    val le_pwnp_pwSn = (let val zF = Free("zpw", natT)
                                            val Pabs = Term.lambda zF (le (pow fourC npF) zF)
                                        in substPredPr (Pabs, mult fourC (pow fourC npF), pow fourC Snp) (oeq_sym OF [pwSuc]) le_self end);
                                        (* le (pow 4 n')(pow 4 (Suc n')) *)
                    val le_pwnp_pwn = (let val zF = Free("zpw2", natT)
                                           val Pabs = Term.lambda zF (le (pow fourC npF)(pow fourC zF))
                                       in substPredPr (Pabs, Snp, nF) (oeq_sym OF [hnp]) le_pwnp_pwSn end);  (* le (pow 4 n')(pow 4 n) *)
                    (* le (primorial n)(pow 4 n) : primorial n = primorial n' [prn2] ; le (primorial n')(pow 4 n') [ihNp]
                       -> le (primorial n')(pow 4 n) [trans with le_pwnp_pwn] ; rewrite primorial n' -> primorial n (sym prn2) *)
                    val le_npr_pwn = le_trans_atPr (primorial npF, pow fourC npF, pow fourC nF) ihNp le_pwnp_pwn;  (* le (primorial n')(pow 4 n) *)
                    val g = (let val zF = Free("zfin", natT)
                                 val Pabs = Term.lambda zF (le zF (pow fourC nF))
                             in substPredPr (Pabs, primorial npF, primorial nF) (oeq_sym OF [prn2]) le_npr_pwn end);  (* Pat n *)
                  in Thm.implies_intr (ctermPr (jT (neg (prime2 nF)))) g end;
                (* ===== prime2 n : cases on 2|n ===== *)
                val casePrime =
                  let
                    val hPr = Thm.assume (ctermPr (jT (prime2 nF)));  (* prime2 n *)
                    val em2 = ex_middle_Pr (dvd twoC nF);             (* Disj (dvd 2 n)(neg (dvd 2 n)) *)
                    (* --- 2|n : n=2 (concrete) --- *)
                    val case2dvd =
                      let
                        val h2dvd = Thm.assume (ctermPr (jT (dvd twoC nF)));  (* dvd 2 n *)
                        val disj21 = prime2_div_atPr (nF, twoC) hPr h2dvd;    (* Disj (oeq 2 1)(oeq 2 n) *)
                        (* oeq 2 1 -> oFalse (Suc_inj + Suc_neq_Zero) *)
                        val c21 =
                          let
                            val h = Thm.assume (ctermPr (jT (oeq twoC (suc ZeroC))))  (* oeq (Suc(Suc 0))(Suc 0) *)
                            val inj = Suc_inj_atPr (suc ZeroC, ZeroC) OF [h]            (* oeq (Suc 0) 0 *)
                            val ff  = Suc_neq_Zero_atPr ZeroC OF [inj]                  (* oFalse *)
                            val g   = Thm.implies_elim (oFalse_elim_Pr (Pat nF)) ff     (* Pat n *)
                          in Thm.implies_intr (ctermPr (jT (oeq twoC (suc ZeroC)))) g end;
                        (* oeq 2 n -> n=2 ; compute primorial 2 = 2 ; le 2 16 = pow 4 2 *)
                        val c2n =
                          let
                            val h2n = Thm.assume (ctermPr (jT (oeq twoC nF)))   (* oeq 2 n *)
                            val hn2 = oeq_sym OF [h2n]                          (* oeq n 2 *)
                            (* primorial 2 = 2 : primorial(Suc 1) = 2*primorial 1 [psp, needs prime2 2].
                               prime2 2 from prime2 n + n=2 (rewrite). *)
                            val pr2 = (let val zF = Free("zp2", natT)
                                           val Pabs = Term.lambda zF (prime2 zF)
                                       in substPredPr (Pabs, nF, twoC) hn2 hPr end);  (* prime2 2 (rewrite n->2 via hn2: oeq n 2) *)
                            val psp2 = primorial_Suc_prime_atPr (suc ZeroC) pr2;       (* oeq (primorial 2)(mult 2 (primorial 1)) *)
                            (* primorial 1 = 1 : primorial(Suc 0) = primorial 0 [nonprime, ~prime2 1] = 1 *)
                            (* ~prime2 1 : prime2 1 = Conj (lt 1 1)(...) ; conjunct1 -> lt 1 1 -> lt_irrefl. *)
                            val notpr1 =
                              let
                                val hp1 = Thm.assume (ctermPr (jT (prime2 (suc ZeroC))))   (* prime2 1 *)
                                val gt1 = prime2_gt1_atPr (suc ZeroC) hp1                   (* lt 1 1 *)
                                val ff  = lt_irrefl_atPr (suc ZeroC) OF [gt1]               (* oFalse *)
                                val meta = Thm.implies_intr (ctermPr (jT (prime2 (suc ZeroC)))) ff
                              in impI_Pr (prime2 (suc ZeroC), oFalseC) meta end;            (* neg (prime2 1) *)
                            val pnp1 = primorial_Suc_nonprime_atPr ZeroC notpr1;            (* oeq (primorial 1)(primorial 0) *)
                            val pr1eq1 = oeq_trans OF [pnp1, primorial_0_vPr];              (* oeq (primorial 1)(Suc 0) *)
                            (* primorial 2 = mult 2 (primorial 1) = mult 2 1 = 2 *)
                            val congP1 = mult_cong_rPr (twoC, primorial (suc ZeroC), suc ZeroC) pr1eq1;  (* oeq (mult 2 (primorial 1))(mult 2 1) *)
                            val m21 = mult1rPr_at twoC;                                     (* oeq (mult 2 1) 2 *)
                            val pr2eq2 = oeq_trans OF [oeq_trans OF [psp2, congP1], m21];   (* oeq (primorial 2) 2 *)
                            (* pow 4 2 = 16 ; le 2 16 *)
                            (* le 2 (pow 4 2) : we bound primorial 2 = 2 <= pow 4 2.  pow 4 2 = mult 4 (pow 4 1) = mult 4 (mult 4 1).
                               le 2 (pow 4 2): build numerically.  Easier: le (primorial 2)(pow 4 2) via 2 <= 4^2.
                               2 <= 4 <= 4^2.  le 2 4 (witness 2) ; le 4 (pow 4 2). *)
                            val pw2_a = powSucPr_at (fourC, suc ZeroC);    (* oeq (pow 4 2)(mult 4 (pow 4 1)) *)
                            val pw1_a = powSucPr_at (fourC, ZeroC);        (* oeq (pow 4 1)(mult 4 (pow 4 0)) *)
                            val pw0_a = pow0Pr_at fourC;                   (* oeq (pow 4 0)(Suc 0) *)
                            (* pow 4 1 = mult 4 1 = 4 *)
                            val congpw1 = mult_cong_rPr (fourC, pow fourC ZeroC, suc ZeroC) pw0_a;  (* oeq (mult 4 (pow 4 0))(mult 4 1) *)
                            val m41 = mult1rPr_at fourC;                   (* oeq (mult 4 1) 4 *)
                            val pw1eq4 = oeq_trans OF [oeq_trans OF [pw1_a, congpw1], m41];  (* oeq (pow 4 1) 4 *)
                            (* le 4 (pow 4 2) : pow 4 2 = mult 4 (pow 4 1) ; le (pow 4 1)(mult 4 (pow 4 1)) [le_self_mult4]
                               rewrite pow 4 1 -> 4 ... actually want le 4 (pow 4 2).
                               le (pow 4 1)(mult 4 (pow 4 1)) ; mult 4 (pow 4 1) = pow 4 2 (sym pw2_a) ; pow 4 1 = 4 (pw1eq4). *)
                            val le_pw1_m = le_self_mult4 (pow fourC (suc ZeroC));  (* le (pow 4 1)(mult 4 (pow 4 1)) *)
                            val le_pw1_pw2 = (let val zF = Free("zpw3", natT)
                                                  val Pabs = Term.lambda zF (le (pow fourC (suc ZeroC)) zF)
                                              in substPredPr (Pabs, mult fourC (pow fourC (suc ZeroC)), pow fourC twoC) (oeq_sym OF [pw2_a]) le_pw1_m end);
                                              (* le (pow 4 1)(pow 4 2) *)
                            val le_4_pw2 = (let val zF = Free("zpw4", natT)
                                                val Pabs = Term.lambda zF (le zF (pow fourC twoC))
                                            in substPredPr (Pabs, pow fourC (suc ZeroC), fourC) pw1eq4 le_pw1_pw2 end);  (* le 4 (pow 4 2) *)
                            (* le 2 4 : witness 2 ; oeq 4 (add 2 2) *)
                            val le_2_4 =
                              let
                                val w = twoC;  (* 2 *)
                                val aS1 = addSucPr_at (suc ZeroC, w);   (* oeq (add 2 2)(Suc(add 1 2)) *)
                                val aS2 = addSucPr_at (ZeroC, w);       (* oeq (add 1 2)(Suc(add 0 2)) *)
                                val a0  = add0Pr_at w;                  (* oeq (add 0 2) 2 *)
                                val s0  = Suc_cong OF [a0];             (* oeq (Suc(add 0 2)) 3 *)
                                val s1  = Suc_cong OF [oeq_trans OF [aS2, s0]];   (* oeq (Suc(add 1 2)) 4 *)
                                val chain = oeq_trans OF [aS1, s1];     (* oeq (add 2 2) 4 *)
                                val eqn = oeq_sym OF [chain];           (* oeq 4 (add 2 2) *)
                              in le_introPr (twoC, fourC, w) eqn end;   (* le 2 4 *)
                            val le_2_pw2 = le_trans_atPr (twoC, fourC, pow fourC twoC) le_2_4 le_4_pw2;  (* le 2 (pow 4 2) *)
                            (* le (primorial 2)(pow 4 2) : rewrite primorial 2 -> 2 (sym pr2eq2) on left *)
                            val le_pr2_pw2 = (let val zF = Free("zpr2", natT)
                                                  val Pabs = Term.lambda zF (le zF (pow fourC twoC))
                                              in substPredPr (Pabs, twoC, primorial twoC) (oeq_sym OF [pr2eq2]) le_2_pw2 end);  (* le (primorial 2)(pow 4 2) *)
                            (* rewrite 2 -> n via sym hn2 (oeq n 2 -> use hn2 : oeq n 2 ; rewrite 2->n means use sym? we have n=2.
                               le (primorial 2)(pow 4 2) ; rewrite 2 -> n with oeq 2 n = h2n *)
                            val g = (let val zF = Free("zn2", natT)
                                         val Pabs = Term.lambda zF (le (primorial zF)(pow fourC zF))
                                     in substPredPr (Pabs, twoC, nF) h2n le_pr2_pw2 end);  (* Pat n *)
                          in Thm.implies_intr (ctermPr (jT (oeq twoC nF))) g end;
                        val g = disjE_elimPr (oeq twoC (suc ZeroC), oeq twoC nF, Pat nF) disj21 c21 c2n;
                      in Thm.implies_intr (ctermPr (jT (dvd twoC nF))) g end;
                    (* --- ~(2|n) : n odd, n=2m+1, m>=1, split + IH at Suc m --- *)
                    val caseNot2 =
                      let
                        val hNot2 = Thm.assume (ctermPr (jT (neg (dvd twoC nF))));  (* Imp (dvd 2 n) oFalse *)
                        (* parity n : even or odd *)
                        val par = parity_at nF;   (* Disj (evenEx n)(oddEx n) *)
                        (* even n -> 2|n -> contradiction with hNot2 *)
                        val caseEv =
                          let
                            fun bodyM mF (hm : thm) =   (* hm : oeq n (add m m) *)
                              let
                                (* dvd 2 n : n = m+m = 2*m ; oeq n (mult 2 m) ? m+m = mult 2 m.
                                   mult 2 m = mult (Suc(Suc 0)) m = add m (mult (Suc 0) m) [mult_Suc]
                                            = add m (add m (mult 0 m)) ... let's do: mult 2 m = m + (m + 0*m).
                                   Simpler: oeq (add m m)(mult 2 m).  mult_Suc: mult (Suc k) m = add m (mult k m).
                                     mult 2 m = mult (Suc 1) m = add m (mult 1 m) = add m m (mult_1_left). *)
                                val ms = multSucPr_at (suc ZeroC, mF);    (* oeq (mult 2 m)(add m (mult 1 m)) *)
                                val m1 = mult1lPr_at mF;                  (* oeq (mult 1 m) m *)
                                val congm = add_cong_rPr (mF, mult (suc ZeroC) mF, mF) m1;  (* oeq (add m (mult 1 m))(add m m) *)
                                val mult2m_eq = oeq_trans OF [ms, congm];  (* oeq (mult 2 m)(add m m) *)
                                (* oeq n (mult 2 m) : n = m+m [hm] ; add m m = mult 2 m [sym] *)
                                val n_eq_2m = oeq_trans OF [hm, oeq_sym OF [mult2m_eq]];  (* oeq n (mult 2 m) *)
                                val dvd2n = dvd_introPr (twoC, nF, mF) n_eq_2m;  (* dvd 2 n *)
                                val ff = mp_Pr (dvd twoC nF, oFalseC) hNot2 dvd2n;  (* oFalse *)
                                val g = Thm.implies_elim (oFalse_elim_Pr (Pat nF)) ff;  (* Pat n *)
                              in g end;
                            val g = exE_elimPr (evenAbs nF, Pat nF) (Thm.assume (ctermPr (jT (evenEx nF)))) "m_ev" bodyM;
                          in Thm.implies_intr (ctermPr (jT (evenEx nF))) g end;
                        (* odd n = Suc(m+m) = 2m+1 *)
                        val caseOdd =
                          let
                            fun bodyM mF (hm : thm) =   (* hm : oeq n (Suc(add m m)) *)
                              let
                                (* n = 2m+1 = add (add m m)(Suc 0).  Suc(m+m) = (m+m) + Suc 0 [add_Suc_right: x + Suc 0 = Suc(x+0)=Suc x] *)
                                val aSr = addSrPr_at (add mF mF, ZeroC);   (* oeq ((m+m) + Suc 0)(Suc((m+m)+0)) *)
                                val a0  = add0rPr_at (add mF mF);          (* oeq ((m+m)+0)(m+m) *)
                                val s0  = Suc_cong OF [a0];                (* oeq (Suc((m+m)+0))(Suc(m+m)) *)
                                val twoMp1_compute = oeq_trans OF [aSr, s0];  (* oeq ((m+m) + Suc 0)(Suc(m+m)) *)
                                (* oeq n (2m+1) : n = Suc(m+m) [hm] ; Suc(m+m) = (m+m)+Suc 0 [sym] *)
                                val n_eq = oeq_trans OF [hm, oeq_sym OF [twoMp1_compute]];  (* oeq n (add (add m m)(Suc 0)) *)
                                (* m >= 1 : m = Suc m'.  if m = 0 : n = 1, but prime2 n -> lt 1 n -> n>1 -> contra.
                                   cases on m via dzosPr. *)
                                val dzm = dzosPr_at mF;   (* Disj (oeq m 0)(Ex q. oeq m (Suc q)) *)
                                val goalP = Pat nF;
                                (* m=0 : n = Suc 0 = 1.  prime2 n -> lt 1 n.  n=1 -> lt 1 1 -> false. *)
                                val cm0 =
                                  let
                                    val hm0 = Thm.assume (ctermPr (jT (oeq mF ZeroC)))   (* oeq m 0 *)
                                    (* n = Suc(m+m) [hm] ; m+m = 0+0 = 0 with m=0 ; so n = Suc 0 = 1 *)
                                    val congmm = (let val zF = Free("zm0", natT)
                                                      val Pabs = Term.lambda zF (oeq (add mF mF)(add zF zF))
                                                  in substPredPr (Pabs, mF, ZeroC) hm0 (oeqreflPr_at (add mF mF)) end);  (* oeq (m+m)(0+0) *)
                                    val a00 = add0Pr_at ZeroC;          (* oeq (0+0) 0 *)
                                    val mm0 = oeq_trans OF [congmm, a00];  (* oeq (m+m) 0 *)
                                    val n_eq_1 = oeq_trans OF [hm, Suc_cong OF [mm0]];  (* oeq n (Suc 0) *)
                                    (* prime2 n -> lt 1 n ; rewrite n -> 1 -> lt 1 1 -> false *)
                                    val gt1n = prime2_gt1_atPr nF hPr;   (* lt 1 n *)
                                    val gt11 = (let val zF = Free("zg", natT)
                                                    val Pabs = Term.lambda zF (lt (suc ZeroC) zF)
                                                in substPredPr (Pabs, nF, suc ZeroC) n_eq_1 gt1n end);  (* lt 1 1 *)
                                    val ff = lt_irrefl_atPr (suc ZeroC) OF [gt11];  (* oFalse *)
                                    val g = Thm.implies_elim (oFalse_elim_Pr goalP) ff;
                                  in Thm.implies_intr (ctermPr (jT (oeq mF ZeroC))) g end;
                                (* m=Suc m' : use split at m + IH at Suc m *)
                                val PabsMq = Abs("q", natT, oeq mF (suc (Bound 0)));
                                val cmS =
                                  let
                                    fun bodyMq mpF (hmq : thm) =   (* hmq : oeq m (Suc m') ; m' = mpF *)
                                      let
                                        (* primorial_split at m : Ex U. primorial(2m+1)=primorial(Suc m)*U, dvd U C, le U (4^m) *)
                                        val splitM = Thm.forall_elim (ctermPr mF) primorial_split_gen;  (* jT (Ex U. split body @ m) *)
                                        (* split body specialised to the half mF (mG -> mF) *)
                                        val twoMp1F = add (add mF mF)(suc ZeroC);    (* 2*mF + 1 *)
                                        val SmF = suc mF;
                                        val CF  = binom twoMp1F mF;
                                        val splitBodyAbsF =
                                          let val uF = Free("U_sp", natT)
                                          in Term.lambda uF (mkConj (oeq (primorial twoMp1F) (mult (primorial SmF) uF))
                                                               (mkConj (dvd uF CF) (le uF (pow four mF)))) end;
                                        (* lt (Suc m) n : n = 2m+1 = Suc(2m).  Suc m < Suc(2m) iff m < 2m.
                                           m = Suc m' >= 1 ; m < 2m = m + m ; lt m (m+m) = le (Suc m)(m+m).
                                           le (Suc m)(add m m): Suc m = Suc m, m+m = m + m ; m = Suc m' so m+m = (Suc m')+m = Suc(m'+m).
                                           le (Suc m)(Suc(m'+m)) iff le m (m'+m).  m = Suc m' ; le (Suc m')(m'+m)?
                                           Hmm. Use: le (Suc m) (m+m) via witness: m+m = (Suc m) + (m-1) ... messy.
                                           Cleaner: lt (Suc m) (Suc(2m)) <- lt m (2m) = le (Suc m)(m+m).
                                           m = Suc m'. le (Suc m)(m+m) = le (Suc m)(add m m).
                                           add m m = add (Suc m') m = Suc(add m' m) = Suc(m'+m).
                                           So le (Suc m)(Suc(m'+m)) ; by le_suc_mono need le m (m'+m).
                                           m = Suc m' ; le (Suc m')(m'+m).  le (Suc m')((Suc m')+ (m - 1))?
                                           Note m'+m = m' + Suc m' = Suc(m'+m') ; le (Suc m')(Suc(m'+m')) iff le m' (m'+m') [le_add]. YES. *)
                                        (* Build step by step. *)
                                        (* le m' (m'+m') [le_add] *)
                                        val le_mp_mpmp = le_add_atPr (mpF, mpF);   (* le m' (m'+m') *)
                                        val le_Smp_Smpmp = le_suc_mono_atPr (mpF, add mpF mpF) le_mp_mpmp;  (* le (Suc m')(Suc(m'+m')) *)
                                        (* m'+m = m' + Suc m' = Suc(m'+m') [add_Suc_right] *)
                                        val mpm_eq = addSrPr_at (mpF, mpF);     (* oeq (m' + Suc m')(Suc(m'+m')) *)
                                        (* m = Suc m' so m' + m = m' + Suc m' : rewrite via hmq *)
                                        (* we want le (Suc m')(m'+m).  have le (Suc m')(Suc(m'+m')).  rewrite Suc(m'+m') -> (m'+ Suc m') [sym mpm_eq] -> (m'+m) [rewrite Suc m' -> m via sym hmq] *)
                                        val le_Smp_a = (let val zF = Free("za", natT)
                                                            val Pabs = Term.lambda zF (le (suc mpF) zF)
                                                        in substPredPr (Pabs, suc (add mpF mpF), add mpF (suc mpF)) (oeq_sym OF [mpm_eq]) le_Smp_Smpmp end);
                                                        (* le (Suc m')(m' + Suc m') *)
                                        val le_Smp_mpm = (let val zF = Free("zb", natT)
                                                              val Pabs = Term.lambda zF (le (suc mpF)(add mpF zF))
                                                          in substPredPr (Pabs, suc mpF, mF) (oeq_sym OF [hmq]) le_Smp_a end);
                                                          (* le (Suc m')(m' + m) *)
                                        (* le (Suc m')(m'+m) ; rewrite Suc m' -> m : le m (m'+m) *)
                                        val le_m_mpm = (let val zF = Free("zc2", natT)
                                                            val Pabs = Term.lambda zF (le zF (add mpF mF))
                                                        in substPredPr (Pabs, suc mpF, mF) (oeq_sym OF [hmq]) le_Smp_mpm end);
                                                        (* le m (m' + m) *)
                                        (* m' + m = m + m ?  no.  We need le (Suc m)(m+m).
                                           add m m = add (Suc m') m = Suc(add m' m) = Suc(m'+m) [add_Suc].
                                           le (Suc m)(Suc(m'+m)) by le_suc_mono on le m (m'+m). *)
                                        val le_Sm_Smpm = le_suc_mono_atPr (mF, add mpF mF) le_m_mpm;  (* le (Suc m)(Suc(m'+m)) *)
                                        (* add m m = Suc(m'+m) : m = Suc m' ; add m m = add (Suc m') m [rewrite m->Suc m' on FIRST arg] = Suc(m'+m) [add_Suc] *)
                                        val mm_via = (let val zF = Free("zmm", natT)
                                                          val Pabs = Term.lambda zF (oeq (add mF mF)(add zF mF))
                                                      in substPredPr (Pabs, mF, suc mpF) hmq (oeqreflPr_at (add mF mF)) end);  (* oeq (add m m)(add (Suc m') m) *)
                                        val addSucmm = addSucPr_at (mpF, mF);   (* oeq (add (Suc m') m)(Suc(add m' m)) *)
                                        val mm_eq_S = oeq_trans OF [mm_via, addSucmm];  (* oeq (add m m)(Suc(m'+m)) *)
                                        (* le (Suc m)(add m m) : rewrite Suc(m'+m) -> add m m (sym mm_eq_S) in le_Sm_Smpm *)
                                        val le_Sm_mm = (let val zF = Free("zd", natT)
                                                            val Pabs = Term.lambda zF (le (suc mF) zF)
                                                        in substPredPr (Pabs, suc (add mpF mF), add mF mF) (oeq_sym OF [mm_eq_S]) le_Sm_Smpm end);
                                                        (* le (Suc m)(add m m) = lt m (m+m) *)
                                        (* lt (Suc m) n : n = 2m+1 = Suc(m+m) ; lt (Suc m)(Suc(m+m)) = le (Suc(Suc m))(Suc(m+m))
                                           by le_suc_mono on le (Suc m)(m+m). then rewrite Suc(m+m) -> n. *)
                                        val lt_Sm_Smm = le_suc_mono_atPr (suc mF, add mF mF) le_Sm_mm;  (* le (Suc(Suc m))(Suc(m+m)) = lt (Suc m)(Suc(m+m)) *)
                                        (* n = Suc(m+m) : from hm (n = Suc(m+m)).  rewrite Suc(m+m) -> n via sym hm *)
                                        val lt_Sm_n = (let val zF = Free("zn", natT)
                                                           val Pabs = Term.lambda zF (lt (suc mF) zF)
                                                       in substPredPr (Pabs, suc (add mF mF), nF) (oeq_sym OF [hm]) lt_Sm_Smm end);  (* lt (Suc m) n *)
                                        val ihSm = ihAt (suc mF) lt_Sm_n;   (* le (primorial (Suc m))(pow 4 (Suc m)) *)
                                        (* now exE split *)
                                        fun bodyU UF (hU : thm) =   (* hU : Conj (oeq (primorial(2m+1))(primorial(Suc m)*U))(Conj (dvd U C)(le U (pow 4 m))) *)
                                          let
                                            val eqSplit = conjunct1_Pr (oeq (primorial twoMp1F)(mult (primorial SmF) UF),
                                                              mkConj (dvd UF CF)(le UF (pow fourC mF))) hU;  (* oeq (primorial(2m+1))(primorial(Suc m)*U) *)
                                            val restU = conjunct2_Pr (oeq (primorial twoMp1F)(mult (primorial SmF) UF),
                                                              mkConj (dvd UF CF)(le UF (pow fourC mF))) hU;
                                            val leU4m = conjunct2_Pr (dvd UF CF, le UF (pow fourC mF)) restU;  (* le U (pow 4 m) *)
                                            (* le (primorial(Suc m)*U)(pow 4 (Suc m) * pow 4 m) [mult_le_mono2 ihSm leU4m] *)
                                            val le_prod = mult_le_mono2_atPr (primorial SmF, pow fourC SmF, UF, pow fourC mF) ihSm leU4m;
                                                          (* le (mult (primorial(Suc m)) U)(mult (pow 4 (Suc m))(pow 4 m)) *)
                                            (* pow 4 (Suc m) * pow 4 m = pow 4 ((Suc m)+m) [pow_add] ; (Suc m)+m = Suc(m+m) = 2m+1 *)
                                            val padd = pow_add_atPr (fourC, SmF, mF);  (* oeq (pow 4 ((Suc m)+m))(mult (pow 4 (Suc m))(pow 4 m)) *)
                                            (* (Suc m)+m = Suc(m+m) [add_Suc] ; Suc(m+m) = 2m+1 [sym twoMp1_compute] *)
                                            val sm_m = addSucPr_at (mF, mF);   (* oeq ((Suc m)+m)(Suc(m+m)) *)
                                            val sm_m_2 = oeq_trans OF [sm_m, oeq_sym OF [twoMp1_compute]];  (* oeq ((Suc m)+m)(2m+1) *)
                                            (* pow 4 (2m+1) = pow 4 ((Suc m)+m) [cong sym sm_m_2] = mult (pow 4 (Suc m))(pow 4 m) [padd] *)
                                            val pcong = (let val zF = Free("zpc", natT)
                                                             val Pabs = Term.lambda zF (oeq (pow fourC zF)(mult (pow fourC SmF)(pow fourC mF)))
                                                         in substPredPr (Pabs, add SmF mF, twoMp1F) sm_m_2 padd end);
                                                         (* oeq (pow 4 (2m+1))(mult (pow 4 (Suc m))(pow 4 m)) *)
                                            (* le (primorial(Suc m)*U)(pow 4 (2m+1)) : rewrite RHS of le_prod (mult..) -> pow 4 (2m+1) via sym pcong *)
                                            val le_prod2 = (let val zF = Free("zlp", natT)
                                                                val Pabs = Term.lambda zF (le (mult (primorial SmF) UF) zF)
                                                            in substPredPr (Pabs, mult (pow fourC SmF)(pow fourC mF), pow fourC twoMp1F) (oeq_sym OF [pcong]) le_prod end);
                                                            (* le (primorial(Suc m)*U)(pow 4 (2m+1)) *)
                                            (* le (primorial(2m+1))(pow 4 (2m+1)) : rewrite LHS primorial(Suc m)*U -> primorial(2m+1) via sym eqSplit *)
                                            val le_pr_pw = (let val zF = Free("zls", natT)
                                                                val Pabs = Term.lambda zF (le zF (pow fourC twoMp1F))
                                                            in substPredPr (Pabs, mult (primorial SmF) UF, primorial twoMp1F) (oeq_sym OF [eqSplit]) le_prod2 end);
                                                            (* le (primorial(2m+1))(pow 4 (2m+1)) *)
                                            (* rewrite 2m+1 -> n via sym n_eq2 (n = 2m+1) in both primorial and pow positions *)
                                            val g = (let val zF = Free("zng", natT)
                                                         val Pabs = Term.lambda zF (le (primorial zF)(pow fourC zF))
                                                     in substPredPr (Pabs, twoMp1F, nF) (oeq_sym OF [n_eq]) le_pr_pw end);  (* Pat n *)
                                          in g end;
                                        val g = exE_elimPr (splitBodyAbsF, Pat nF) splitM "U_pb" bodyU;
                                      in g end;
                                    val g = exE_elimPr (PabsMq, goalP) (Thm.assume (ctermPr (jT (mkEx PabsMq)))) "mp_pb" bodyMq;
                                  in Thm.implies_intr (ctermPr (jT (mkEx PabsMq))) g end;
                                val g = disjE_elimPr (oeq mF ZeroC, mkEx PabsMq, goalP) dzm cm0 cmS;
                              in g end;
                            val g = exE_elimPr (oddAbs nF, Pat nF) (Thm.assume (ctermPr (jT (oddEx nF)))) "m_od" bodyM;
                          in Thm.implies_intr (ctermPr (jT (oddEx nF))) g end;
                        val g = disjE_elimPr (evenEx nF, oddEx nF, Pat nF) par caseEv caseOdd;
                      in Thm.implies_intr (ctermPr (jT (neg (dvd twoC nF)))) g end;
                    val g = disjE_elimPr (dvd twoC nF, neg (dvd twoC nF), Pat nF) em2 case2dvd caseNot2;
                  in Thm.implies_intr (ctermPr (jT (prime2 nF))) g end;
                val g = disjE_elimPr (prime2 nF, neg (prime2 nF), Pat nF) emP casePrime caseNotPrime;
              in g end;
            val g = exE_elimPr (PabsSuc, Pat nF) (Thm.assume (ctermPr (jT (mkEx PabsSuc)))) "np_pb" bodyNp;
          in Thm.implies_intr (ctermPr (jT (mkEx PabsSuc))) g end;
        val g = disjE_elimPr (oeq nF ZeroC, mkEx PabsSuc, Pat nF) dz case0 caseSuc;
      in g end;   (* jT (Pat n_h) under hyp Hthm (the strong IH) *)

    (* discharge Hthm -> forall_intr n_h -> the strong_induct step form *)
    val stepThm = Thm.forall_intr (ctermPr nH) (Thm.implies_intr (ctermPr (GpropOf nH)) stepConcl);
    val kF = Free("n", natT);
    val siInst = beta_norm (Drule.infer_instantiate ctxtPr
                   [(("P",0), ctermPr Ppred),(("k",0), ctermPr kF)] strong_induct_vPr);
    val Pk = Thm.implies_elim siInst stepThm;   (* jT (Pat k) = le (primorial k)(pow 4 k) *)
  in varify Pk end;

val () = out ("primorial_bound 0hyp=" ^ Bool.toString (zhPr primorial_bound) ^ "\n");
val i_primorial_bound =
  let val nVb = Var(("n",0),natT)
  in jT (le (primorial nVb)(pow fourC nVb)) end;
val r_pb = (Thm.prop_of primorial_bound) aconv i_primorial_bound;
val () = out ("primorial_bound aconv=" ^ Bool.toString r_pb ^ "\n");
val () = if zhPr primorial_bound andalso r_pb then out "PRIMORIAL_BOUND_OK\n" else out "PRIMORIAL_BOUND_FAIL\n";


(* ============================================================================
   BERTRAND F2b — FINALE : the closed primorial bound + soundness audit.
   ============================================================================ *)
val () = out "F2B_FINALE_BEGIN\n";

(* soundness probes : the kernel must REJECT false variants *)
(* (a) prime_prod_dvd must keep the ~(dvd p U) premise (proved s_ppd as COPRIME_DVD_OK). *)
(* (b) primorial_bound must NOT be aconv the bogus "le (primorial n)(pow 3 n)" (3^n). *)
val s_pb_reject =
  let val nVb = Var(("n",0),natT)
  in not ((Thm.prop_of primorial_bound) aconv
       (jT (le (primorial nVb)(pow (suc (suc (suc ZeroC))) nVb)))) end;   (* 3^n *)
(* (c) binom_pos must keep the le-premise (not unconditional lt 0 (binom n k)). *)
val s_bp_cond =
  let val nVp = Var(("n",0),natT); val kVp = Var(("k",0),natT)
  in not ((Thm.prop_of binom_pos) aconv (jT (lt ZeroC (binom nVp kVp)))) end;
val () = out ("PROBE primorial-bound-rejects-3^n=" ^ Bool.toString s_pb_reject
            ^ " binom_pos-conditional=" ^ Bool.toString s_bp_cond ^ "\n");

val allF2b =
  zhPr prime_prod_dvd andalso r_ppd andalso s_ppd
  andalso zhPr binom_pos andalso ((Thm.prop_of binom_pos) aconv i_binom_pos) andalso s_bp_cond
  andalso zhPr parity
  andalso zhPr primorial_split_ex
  andalso zhPr primorial_bound andalso r_pb andalso s_pb_reject;

(* axiom audit : only ex_middle classical ; the conservative const defs (fact/primorial) *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtPr
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nFact = length (List.filter (fn s => String.isSubstring "fact" s) names)
    val nPrim = length (List.filter (fn s => String.isSubstring "primorial" s) names)
  in out ("AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " fact_axioms=" ^ Int.toString nFact
          ^ " primorial_axioms=" ^ Int.toString nPrim ^ "\n") end;

val () = if allF2b then out "BERTRAND_F2B_ALL_OK\n" else out "BERTRAND_F2B_PARTIAL\n";
val () = out "F2B_FINALE_DONE\n";

(* ============================================================================
   BERTRAND F3 — p-adic VALUATION machinery toward VP_LE.
   APPENDIX to bertrand_f2b_full.sml.  Final base context: ctxtPr/ctermPr/thyPr.

   (R)   port rdiv/rmod onto a NEW final context ctxtV (extending thyPr).
   (F01) floor01 : lt 0 q ==> Disj (oeq (t n q) 0)(oeq (t n q) (Suc 0))
         where t n q := sub (rdiv (add n n) q)(add (rdiv n q)(rdiv n q)).
   ============================================================================ *)
val () = out "F3_DELTA_BEGIN\n";

(* ---------------------------------------------------------------------------
   (R)  rdiv / rmod consts + the two functional axioms, extending thyPr.
        div_mod_eq : lt 0 p ==> oeq a (add (mult p (rdiv a p)) (rmod a p))
        rmod_lt    : lt 0 p ==> lt (rmod a p) p
   --------------------------------------------------------------------------- *)
val thyV0 = Sign.add_consts
  [(Binding.name "rmod", natT --> natT --> natT, NoSyn),
   (Binding.name "rdiv", natT --> natT --> natT, NoSyn),
   (Binding.name "vp",   natT --> natT --> natT, NoSyn)] thyPr;
val rmodC = Const (Sign.full_name thyV0 (Binding.name "rmod"), natT --> natT --> natT);
val rdivC = Const (Sign.full_name thyV0 (Binding.name "rdiv"), natT --> natT --> natT);
val vpC   = Const (Sign.full_name thyV0 (Binding.name "vp"),   natT --> natT --> natT);
fun rmod a p = rmodC $ a $ p;
fun rdiv a p = rdivC $ a $ p;
fun vp p m = vpC $ p $ m;

val aV = Free("a", natT); val pV = Free("p", natT); val mVv = Free("m", natT);
val ((_,div_mod_eq_ax), thyV1) = Thm.add_axiom_global (Binding.name "div_mod_eq",
      Logic.mk_implies (jT (lt ZeroC pV),
        jT (oeq aV (add (mult pV (rdiv aV pV)) (rmod aV pV))))) thyV0;
val ((_,rmod_lt_ax), thyV2) = Thm.add_axiom_global (Binding.name "rmod_lt",
      Logic.mk_implies (jT (lt ZeroC pV), jT (lt (rmod aV pV) pV))) thyV1;
(* vp conservative WF recursion on m (decreases via rdiv m p < m, p>=2,m>0,p|m) *)
val ((_,vp_step_dvd_ax), thyV3) = Thm.add_axiom_global (Binding.name "vp_step_dvd",
      Logic.mk_implies (jT (prime2 pV),
        Logic.mk_implies (jT (lt ZeroC mVv),
          Logic.mk_implies (jT (dvd pV mVv),
            jT (oeq (vp pV mVv) (suc (vp pV (rdiv mVv pV)))))))) thyV2;
val ((_,vp_step_ndvd_ax), thyV) = Thm.add_axiom_global (Binding.name "vp_step_ndvd",
      Logic.mk_implies (jT (prime2 pV),
        Logic.mk_implies (jT (lt ZeroC mVv),
          Logic.mk_implies (jT (neg (dvd pV mVv)),
            jT (oeq (vp pV mVv) ZeroC))))) thyV3;

(* ---- THE ONE FINAL CONTEXT ctxtV / ctermV / thyV ---- *)
val ctxtV  = Proof_Context.init_global thyV;
val ctermV = Thm.cterm_of ctxtV;
fun zhV th = (length (Thm.hyps_of th) = 0) andalso (null (Thm.extra_shyps th));

(* ---- re-varify every reused axiom/lemma onto ctxtV (schematic; thyV extends all) ---- *)
val oeq_refl_vV      = varify oeq_refl;
val oeq_subst_vV     = varify oeq_subst;
