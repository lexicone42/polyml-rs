  let val sF = Free("s_hsq_sm", natT) val nF = Free("n_hsq_sm", natT)
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val hSsq = Thm.assume (ctermV4 (jT (lt (add nF nF)(mult (suc sF)(suc sF)))))
      val th = build_Hsq (sF, nF) hn0 hSsq
  in out ("build_Hsq smoke : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n") end;

