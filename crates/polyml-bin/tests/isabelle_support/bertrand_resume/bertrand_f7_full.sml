(* re-varify extra base lemmas onto ctxtV4 *)
val le_total_v4          = varify le_total;
val lt_trans_v4          = varify lt_trans;
val le_eq_or_succ_le_v4  = varify le_eq_or_succ_le;
val le_neq_lt_v4         = varify le_neq_lt;
val pow_le_exp_v4        = varify pow_le_exp;
val pow_le_mono_base_v4  = varify pow_le_mono_base;
