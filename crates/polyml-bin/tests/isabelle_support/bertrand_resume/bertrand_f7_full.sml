(* binom_row_le_central onto V4 *)
val binom_row_le_central_v4 = varify binom_row_le_central;
fun binom_row_le_central_4 (nt,kt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("n",0),ctermV4 nt),(("k",0),ctermV4 kt)] binom_row_le_central_v4)) h;

(* le_2n_cb : lt 0 n ==> le (add n n)(binom (add n n) n)   [2n <= C(2n,n)] via C(2n,1)=2n <= C(2n,n). *)
fun le_2n_cb nT hn0 =
  let
    val twoN = add nT nT
    (* le 1 (2n) : lt 0 (2n) ; from hn0 (lt 0 n) and le n (2n) *)
    val h2N0 = le_trans4_at (suc ZeroC, nT, twoN) hn0 (le_add4_at (nT, nT))  (* le 1 (2n) *)
    (* unimodality at k=1 : le 1 (2n) ==> le (binom (2n) 1)(binom (2n) n) *)
    val uni = binom_row_le_central_4 (nT, suc ZeroC) h2N0   (* le (binom (2n)(Suc 0))(binom (2n) n) *)
    (* C(2n,1) = 2n *)
    val c2n1 = binom_n_1 twoN   (* oeq (binom (2n)(Suc 0)) (2n) *)
    val g = le_cong_l4 (binom twoN (suc ZeroC), twoN, binom twoN nT) c2n1 uni  (* le (2n)(binom (2n) n) *)
  in g end;

