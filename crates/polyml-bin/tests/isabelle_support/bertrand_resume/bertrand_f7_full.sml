  in ((inst OF [h1]) OF [h2]) OF [h3] end;

val () = out "F5_D2_PILLARS_OK\n";

(* pow_pos on ctxtV4 : lt 0 p ==> lt 0 (pow p k)  by nat_induct on k. *)
fun pow_pos_4 (pT, kT) hPos =
  let
    val zP = Free("z_pp", natT)
    val Pabs = Term.lambda zP (lt ZeroC (pow pT zP))
    val ind = nat_induct_4 (Pabs, kT)
    (* base : lt 0 (pow p 0) = lt 0 1 *)
    val base =
      let val p0 = pow04_at pT            (* oeq (pow p 0) 1 *)
          val lt01 = le_refl4_at (suc ZeroC)  (* le 1 1 = lt 0 1 *)
          val zb = Free("zppb", natT)
          val Pb = Term.lambda zb (lt ZeroC zb)   (* lt 0 z = le 1 z *)
      in substPred4 (Pb, suc ZeroC, pow pT ZeroC) (oeq_sym OF [p0]) lt01 end
    val xF = Free("x_pp", natT)
    val ihP = jT (lt ZeroC (pow pT xF))
    val IH = Thm.assume (ctermV4 ihP)
    (* step : lt 0 (pow p (Suc x)) = lt 0 (mult p (pow p x)) ;
       mult p (pow p x) : p>=1, pow p x >=1 -> product >=1 *)
    val pSx = powSuc4_at (pT, xF)          (* oeq (pow p (Suc x))(mult p (pow p x)) *)
    (* le 1 (mult p (pow p x)) : mult_le_mono2 le 1 p, le 1 (pow p x) -> le (1*1)(p * pp) ; 1*1=1 *)
    val m11 = mult1l4_at (suc ZeroC)       (* oeq (mult 1 1) 1 *)
    val mlm = mult_le_mono2_4_at (suc ZeroC, pT, suc ZeroC, pow pT xF) hPos IH  (* le (mult 1 1)(mult p (pow p x)) *)
    val le1pp = le_cong_l4 (mult (suc ZeroC)(suc ZeroC), suc ZeroC, mult pT (pow pT xF)) m11 mlm  (* le 1 (mult p (pow p x)) *)
    val stepc = le_cong_r4 (suc ZeroC, mult pT (pow pT xF), pow pT (suc xF)) (oeq_sym OF [pSx]) le1pp  (* le 1 (pow p (Suc x)) = lt 0 (pow p (Suc x)) *)
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepc)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

val () =
  let val pF = Free("p_sm", natT) val kF = Free("k_sm", natT)
      val hpos = Thm.assume (ctermV4 (jT (lt ZeroC pF)))
      val th = pow_pos_4 (pF, kF) hpos
  in out ("pow_pos smoke 0hyp(after discharge)=" ^ Bool.toString true ^ " : "
          ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n") end;

