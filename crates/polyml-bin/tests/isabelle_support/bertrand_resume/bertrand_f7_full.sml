(* ---- ground instantiators on ctxtV3 ---- *)
fun oeqrefl3_at t      = beta_norm (Drule.infer_instantiate ctxtV3 [(("a",0), ctermV3 t)] oeq_refl_v3);
fun substPred3 (Pabs, aT, bT) hab hPa =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
