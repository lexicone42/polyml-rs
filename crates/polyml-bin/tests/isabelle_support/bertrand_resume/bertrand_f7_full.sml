(* ============================================================================
   BERTRAND F7 — THRESHOLD ASSEMBLY (the analytic-wall combination).
   Combine cb_lower + cb_refined under H to assemble the explicit inequality
       4^n <= (2n+1) * (2n)^(Suc s) * 4^(2n/3)
   with s = floor_sqrt(2n) and under the guard le s (2n/3).

   We package this as a single 0-hyp schematic lemma:
     threshold_assembled :
        lt 0 n ==> lt 0 (binom 2n n) ==> H n ==>
          Ex s. (le (s*s) 2n /\ lt 2n ((Suc s)^2))
                /\ (le s (2n/3) ==>
                      le (pow 4 n)
                         (mult (Suc 2n) (mult (pow 2n (Suc s)) (pow 4 (2n/3)))))
   This is the precise resume point named in the task: the assembled product/lower
   combination under H.  It is the genuine mathematical content of the threshold;
   the remaining step (showing it is impossible for n >= N0) is the growth wall.
   ============================================================================ *)
val () = out "F7_THRESHOLD_BEGIN\n";

val threshold_assembled =
  let
    val nF   = Free("n_th", natT)
    val twoN = add nF nF
    val R    = binom twoN nF
    val q3   = rdiv twoN three3
    val hn0  = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
    val hR0  = Thm.assume (ctermV4 (jT (lt ZeroC R)))
    val hH   = Thm.assume (ctermV4 (H_prop nF))
    (* cb_lower at n : le (pow 4 n)(mult (Suc 2n) R) *)
    val cbl  = cb_lower_4 nF                          (* le (pow 4 n)(mult (Suc 2n) R) *)
    (* cb_refined at n applied to hn0, hR0, hH : Ex s. (sq facts) /\ (guard -> le R (..)) *)
    val crIn = ((cb_refined OF [hn0]) OF [hR0]) OF [hH]  (* jT (Ex s_out. ...) *)
    (* output body builder (must match cb_refined's outBody exactly) *)
    fun crBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                           (mkImp (le sT q3) (le R (mult (pow twoN (suc sT))(pow fourC4 q3))))
    val crAbs = Term.lambda (Free("s_out", natT)) (crBody (Free("s_out", natT)))
    (* target output body : (sq facts) /\ (guard -> le (4^n)((2n+1)*(2n)^(Suc s)*(4^(2n/3)))) *)
    fun outBody sT = mkConj (mkConj (le (mult sT sT) twoN)(lt twoN (mult (suc sT)(suc sT))))
                            (mkImp (le sT q3)
                              (le (pow fourC4 nF)
                                  (mult (suc twoN)
                                        (mult (pow twoN (suc sT))(pow fourC4 q3)))))
    val outAbs = Term.lambda (Free("s_out", natT)) (outBody (Free("s_out", natT)))
    val goalC = mkEx outAbs
    fun body sF (hs : thm) =     (* hs : crBody sF *)
      let
        val sq  = mult sF sF
        val sqS = mult (suc sF)(suc sF)
        (* split the two conjuncts of cb_refined's output *)
        val hSqFacts = conjunct1_4 (mkConj (le sq twoN)(lt twoN sqS),
                                    mkImp (le sF q3)(le R (mult (pow twoN (suc sF))(pow fourC4 q3)))) hs
                       (* le (s*s) 2n /\ lt 2n ((Suc s)^2) *)
        val hCond    = conjunct2_4 (mkConj (le sq twoN)(lt twoN sqS),
                                    mkImp (le sF q3)(le R (mult (pow twoN (suc sF))(pow fourC4 q3)))) hs
                       (* le s q3 -> le R (mult (pow 2n (Suc s))(pow 4 q3)) *)
        (* build the conditional bound under the guard *)
        val condBound =
          let
            val hGuard = Thm.assume (ctermV4 (jT (le sF q3)))   (* le s q3 *)
            (* le R ((2n)^(Suc s) * 4^q3) *)
            val leR = mp_4 (le sF q3, le R (mult (pow twoN (suc sF))(pow fourC4 q3))) hCond hGuard
            (* mult_le_mono : le R (..) -> le (mult (Suc 2n) R)(mult (Suc 2n)(..)) *)
            val mlm = mult_le_mono_4 (suc twoN, R, mult (pow twoN (suc sF))(pow fourC4 q3)) leR
                      (* le (mult (Suc 2n) R)(mult (Suc 2n)(mult (pow 2n (Suc s))(pow 4 q3))) *)
            (* chain : le (4^n)(mult (Suc 2n) R) [cbl] ; le (mult (Suc 2n) R)(...) [mlm] -> trans *)
            val g = le_trans4_at (pow fourC4 nF, mult (suc twoN) R,
                                  mult (suc twoN)(mult (pow twoN (suc sF))(pow fourC4 q3))) cbl mlm
                    (* le (4^n)(mult (Suc 2n)(mult (pow 2n (Suc s))(pow 4 q3))) *)
          in Thm.implies_intr (ctermV4 (jT (le sF q3))) g end
        val condImp = impI_4 (le sF q3,
                              le (pow fourC4 nF)
                                 (mult (suc twoN)(mult (pow twoN (suc sF))(pow fourC4 q3))))
                             condBound
        val cjFull = conjI_4 (mkConj (le sq twoN)(lt twoN sqS),
                              mkImp (le sF q3)
                                (le (pow fourC4 nF)
                                    (mult (suc twoN)(mult (pow twoN (suc sF))(pow fourC4 q3)))))
                             hSqFacts condImp
        val ex = exI_4 (outAbs, sF) cjFull
      in ex end
    val concl = exE_elim4 (crAbs, goalC) crIn "s_th" body
    val d3 = Thm.implies_intr (ctermV4 (H_prop nF)) concl
    val d2 = Thm.implies_intr (ctermV4 (jT (lt ZeroC R))) d3
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) d2
  in varify d1 end;

