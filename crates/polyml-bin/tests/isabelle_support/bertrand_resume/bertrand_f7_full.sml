val pow_one_v4 = varify pow_one;
fun pow_one_4 t = beta_norm (Drule.infer_instantiate ctxtV4 [(("a",0), ctermV4 t)] pow_one_v4);  (* oeq (pow t 1) t *)

(* HSQ DISCHARGE.
   Given : hn0 : lt 0 n ;  hSsq : lt (add n n) (mult (Suc s)(Suc s))   [from floor_sqrt conj2] ;
   build  Hsq : !!b. le (Suc s) b ==> prime2 b ==> le (pow b (vp b R)) b. *)
fun build_Hsq (sT, nT) hn0 hSsq =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    val K    = suc sT
    val bF   = Free("b_hsq", natT)
    val concl = jT (le (pow bF (vp bF R)) bF)
    (* body : assume le K b, prime2 b ; prove le (pow b (vp b R)) b *)
    val hKb  = Thm.assume (ctermV4 (jT (le K bF)))      (* le (Suc s) b *)
    val hpr  = Thm.assume (ctermV4 (jT (prime2 bF)))    (* prime2 b *)
    (* b^2 > 2n :  (Suc s)^2 <= b^2  [mult_le_mono2 le K b, le K b] ; 2n < (Suc s)^2 [hSsq] ; lt_le_trans *)
    val leKsq = mult_le_mono2_4_at (K, bF, K, bF) hKb hKb   (* le (mult K K)(mult b b) *)
    (* lt (2n)(mult b b) : 2n < (Suc s)^2 = mult K K <= mult b b *)
    (* lt a c from lt a b' and le b' c :  lt a b' = le (Suc a) b' ; le_trans (Suc a) b' c *)
    val hbsq = le_trans4_at (suc twoN, mult K K, mult bF bF) hSsq leKsq   (* le (Suc 2n)(mult b b) = lt 2n (mult b b) *)
    (* sqrt_split : prime2 b -> lt 0 n -> lt 2n (b*b) -> le (vp b R)(Suc 0) *)
    val hvp1 = sqrt_split_4 (bF, nT) hpr hn0 hbsq   (* le (vp b R) 1 *)
    (* pow b (vp b R) <= pow b 1 = b :  pow_le_exp (b>0, vp<=1) ; pow_one *)
    val hbpos = prime2_pos_4 bF hpr   (* le 1 b = lt 0 b *)
    val pexp = pow_le_exp_4 (bF, vp bF R, suc ZeroC) hbpos hvp1   (* le (pow b (vp b R))(pow b 1) *)
    val p1   = pow_one_4 bF           (* oeq (pow b 1) b *)
    val g    = le_cong_r4 (pow bF (vp bF R), pow bF (suc ZeroC), bF) p1 pexp   (* le (pow b (vp b R)) b *)
    val body = Thm.implies_intr (ctermV4 (jT (prime2 bF))) (Thm.implies_intr (ctermV4 (jT (le K bF))) g)
    (* hmm : need order le K b first then prime2 b in the meta-impl (Hsq expects le first) *)
    val body2 = Thm.implies_intr (ctermV4 (jT (le K bF))) (Thm.implies_intr (ctermV4 (jT (prime2 bF))) g)
  in Thm.forall_intr (ctermV4 bF) body2 end;

