fun lt_zero_suc_atPr t =     (* lt 0 (Suc t) = le (Suc 0)(Suc t) ; witness t : oeq (Suc t)(add (Suc 0) t) *)
  let
    val aS  = addSucPr_at (ZeroC, t);          (* (Suc 0 + t) = Suc(0 + t) *)
    val s0  = Suc_cong OF [add0Pr_at t];        (* Suc(0 + t) = Suc t *)
    val sumv= oeq_trans OF [aS, s0];            (* (Suc 0 + t) = Suc t *)
    val eqn = oeq_sym OF [sumv];                (* Suc t = (Suc 0 + t) *)
  in le_introPr (suc ZeroC, suc t, t) eqn end;

