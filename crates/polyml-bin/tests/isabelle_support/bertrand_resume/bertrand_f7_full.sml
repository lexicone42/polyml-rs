fun left_distrib_4 (dt,pt,qt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("x",0),ctermV4 dt),(("m",0),ctermV4 pt),(("n",0),ctermV4 qt)] left_distrib_v4);

