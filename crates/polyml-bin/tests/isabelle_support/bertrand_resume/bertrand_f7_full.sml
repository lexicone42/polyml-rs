fun substPredF (Pabs, aT, bT) hab hPa =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("P",0), ctermF Pabs), (("a",0), ctermF aT), (("b",0), ctermF bT)] oeq_subst_vF)
  in inst OF [hab, hPa] end;
