(* ============================================================================
   ============================  FLEET F3d  ===================================
   CLOSE THE VALUATION WALL :
     vp_le : prime2 p ==> lt 0 n ==> le (pow p (vp p (binom (add n n) n)))(add n n).
   Route (all deep algebra banked above) :
     (M)  maxpow         : prime2 p ==> lt 0 N ==> Ex M. le (pow p M) N /\ lt N (pow p (Suc M))
          rdiv_zero_of_lt: lt N q ==> oeq (rdiv N q) 0
          floor_double_ge: lt 0 q ==> le (n/q + n/q)(2n/q)   [2*floor x <= floor 2x]
     (LF) legendre_full  : remainder vanishes at L=M ; vp(fact N)=sumf (%i.N/p^(Suc i)) M for N<p^(Suc M)
     (BE) vp_binom_eq    : vp(binom(2n,n)) = sumf (%i. tflo n (p^(Suc i))) M
     (LE) vp_le          : the sum has each term in {0,1} and i=M term 0 -> sum<=M -> pow p (vp)<=pow p M<=2n
   ============================================================================ *)
val () = out "F3D_BEGIN\n";

(* ---- extra reused lemmas re-varified onto ctxtV3 ---- *)
val le_total_v3        = varify le_total;       (* Disj (le m n)(le n m)  (m,n) *)
val nlt_le_v3          = varify nlt_le;          (* neg (lt d c) ==> le c d  (d,c) *)
val add_left_cancel_v3 = varify add_left_cancel; (* oeq (add m a)(add m b) ==> oeq a b  (m,a,b) *)
val le_add_v3b         = le_add_v3;              (* le m (add m p)  (m,p) -- already varified above *)
val floor01_v3         = varify floor01;         (* lt 0 q ==> Disj (oeq (tflo n q)0)(oeq (tflo n q)1)  (n,q) *)
val pow_le_exp_v3      = varify pow_le_exp;       (* lt 0 p ==> le i j ==> le (pow p i)(pow p j)  (p,i,j) *)
val sumf_le_v3         = varify sumf_le;          (* (!!k. le k n ==> le (f k)(g k)) ==> le (sumf f n)(sumf g n)  (f,g,n) *)
val sum_const_v3       = varify sum_const;        (* oeq (sumf (%k.c) n)(mult (Suc n) c)  (c,n) *)
val sum_add_v3         = varify sum_add;          (* oeq (add (sumf f n)(sumf g n))(sumf (%k. add (f k)(g k)) n)  (f,g,n) *)
val sum_cong_v3        = varify sum_cong;         (* (!!k. le k n ==> oeq (f k)(g k)) ==> oeq (sumf f n)(sumf g n)  (f,g,n) *)
val legendre_sum_rem_v3 = varify legendre_sum_rem; (* prime2 p ==> vp(fact N)=sumf(%i.N/p^(Suc i)) L + vp(fact(N/p^(Suc L)))  (p,N,L) *)
val fact_0_v3b         = fact_0_v3;               (* oeq (fact 0)(Suc 0) *)
val disj_zero_or_suc_v3b = disj_zero_or_suc_v3;   (* Disj (oeq p 0)(Ex q. oeq p (Suc q)) *)

(* ---- V3 instantiators for the new helpers ---- *)
fun le_total_3 (mT,nT) = beta_norm (Drule.infer_instantiate ctxtV3
        [(("m",0), ctermV3 mT),(("n",0), ctermV3 nT)] le_total_v3);
fun nlt_le_3 (dT,cT) hneg = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("d",0), ctermV3 dT),(("c",0), ctermV3 cT)] nlt_le_v3)) hneg;
fun add_left_cancel_3 (mT,aT,bT) h = (beta_norm (Drule.infer_instantiate ctxtV3
        [(("m",0), ctermV3 mT),(("a",0), ctermV3 aT),(("b",0), ctermV3 bT)] add_left_cancel_v3)) OF [h];
fun floor01_3 (nT,qT) hpos = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("n",0), ctermV3 nT),(("q",0), ctermV3 qT)] floor01_v3)) hpos;
fun pow_le_exp_3 (pT,iT,jT_) hpos hle =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("i",0), ctermV3 iT),(("j",0), ctermV3 jT_)] pow_le_exp_v3)
  in (inst OF [hpos]) OF [hle] end;
fun sumf_le_3 (fAbs,gAbs,nT) metaProof =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("f",0), ctermV3 fAbs),(("g",0), ctermV3 gAbs),(("n",0), ctermV3 nT)] sumf_le_v3)
  in Thm.implies_elim inst metaProof end;
fun sum_const_3 (cT,nT) = beta_norm (Drule.infer_instantiate ctxtV3
        [(("c",0), ctermV3 cT),(("n",0), ctermV3 nT)] sum_const_v3);
fun sum_add_3 (fAbs,gAbs,nT) = beta_norm (Drule.infer_instantiate ctxtV3
        [(("f",0), ctermV3 fAbs),(("g",0), ctermV3 gAbs),(("n",0), ctermV3 nT)] sum_add_v3);
fun sum_cong_3 (fAbs,gAbs,nT) metaProof =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("f",0), ctermV3 fAbs),(("g",0), ctermV3 gAbs),(("n",0), ctermV3 nT)] sum_cong_v3)
  in Thm.implies_elim inst metaProof end;
fun legendre_sum_rem_3 (pT,NT,LT) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("N",0), ctermV3 NT),(("L",0), ctermV3 LT)] legendre_sum_rem_v3)
  in inst OF [hPr] end;
fun strong_induct_3 (Pabs, kT) hStep =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("P",0), ctermV3 Pabs),(("k",0), ctermV3 kT)] (varify strong_induct))
  in Thm.implies_elim inst hStep end;

(* le congruences on ctxtV3 (oeq p q ==> le p b ==> le q b , etc.) *)
fun le_cong_l3 (pT,qT,bT) hpq hle =
  let val zF = Free("zlc3", natT)
      val Pabs = Term.lambda zF (le zF bT)
  in substPred3 (Pabs, pT, qT) hpq hle end;
fun le_cong_r3 (aT,pT,qT) hpq hle =
  let val zF = Free("zrc3", natT)
      val Pabs = Term.lambda zF (le aT zF)
  in substPred3 (Pabs, pT, qT) hpq hle end;

(* le_add_sub on ctxtV3 : le k n ==> oeq (add k (sub n k)) n   (k,n) *)
val le_add_sub_v3 = varify le_add_sub;
fun le_add_sub_3 (kT,nT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("k",0), ctermV3 kT),(("n",0), ctermV3 nT)] le_add_sub_v3)) h;

(* sub_self on ctxtV3 : oeq (sub n n) 0   (n) ; sub congruence on both args *)
val sub_self_v3 = varify sub_self;
fun sub_self_3 t = beta_norm (Drule.infer_instantiate ctxtV3 [(("n",0), ctermV3 t)] sub_self_v3);
fun sub_cong_l3 (pT, qT, kT) hpq =
  let val Pabs = Abs("z", natT, oeq (sub pT kT) (sub (Bound 0) kT))
  in substPred3 (Pabs, pT, qT) hpq (oeqrefl3_at (sub pT kT)) end;
fun sub_cong_r3 (hT, pT, qT) hpq =
  let val Pabs = Abs("z", natT, oeq (sub hT pT) (sub hT (Bound 0)))
  in substPred3 (Pabs, pT, qT) hpq (oeqrefl3_at (sub hT pT)) end;

(* mult_Suc_right on ctxtV3 already = multSr3_at : oeq (mult n (Suc m))(add n (mult n m))  (n,m) *)

(* le 0 t for any t : witness t, oeq t (add 0 t) sym of add_0 *)
fun le_zero3_at t = le_intro3 (ZeroC, t, t) (oeq_sym OF [add03_at t]);

(* vp_binom_split applicator on ctxtV3 *)
fun vp_binom_split_3 (pT, nT) hPr =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("n",0), ctermV3 nT)] vp_binom_split_v3)
  in inst OF [hPr] end;

val () = out "F3D_HELPERS_OK\n";

(* ============================================================================
   (M-1)  rdiv_zero_of_lt : lt N q ==> oeq (rdiv N q) 0
   ============================================================================ *)
val () = out "F3D_M_BEGIN\n";

(* lt N q ==> lt 0 q  (q >= Suc N >= 1) *)
fun lt_pos_of_lt3 (NT, qT) hlt =     (* hlt : lt N q = le (Suc N) q -> lt 0 q = le (Suc 0) q *)
  let
    val le0N = le_zero3_at NT                          (* le 0 N *)
    val le1SN = le_suc_mono3_at (ZeroC, NT) le0N       (* le (Suc 0)(Suc N) *)
    val g = le_trans3_at (suc ZeroC, suc NT, qT) le1SN hlt  (* le (Suc 0) q *)
  in g end;

fun rdiv_zero_of_lt3 (NT, qT) hlt =     (* hlt : lt N q -> oeq (rdiv N q) 0 *)
  let
    val hpos = lt_pos_of_lt3 (NT, qT) hlt             (* lt 0 q *)
    val divEq = div_mod_eq_3 (NT, qT) hpos            (* oeq N (add (mult q (rdiv N q))(rmod N q)) *)
    val rlt   = rmod_lt_3 (NT, qT) hpos               (* lt (rmod N q) q *)
    (* Rep2 : N = q*0 + N.  add (mult q 0) N = 0 + N = N *)
    val q0   = mult0r3_at qT                          (* oeq (mult q 0) 0 *)
    val rep2 = oeq_trans OF [add_cong_l3 (mult qT ZeroC, ZeroC, NT) q0, add03_at NT]; (* oeq (add (mult q 0) N) N *)
    val rep2s= oeq_sym OF [rep2]                      (* oeq N (add (mult q 0) N) *)
    (* hEQ : add (mult q (rdiv N q))(rmod N q) = add (mult q 0) N  (both = N) *)
    val hEQ = oeq_trans OF [oeq_sym OF [divEq], rep2s]
    val uniq = div_mod_unique_3 (rdiv NT qT, ZeroC, rmod NT qT, NT, qT) hEQ rlt hlt
    val g = conjunct1_3 (oeq (rdiv NT qT) ZeroC, oeq (rmod NT qT) NT) uniq  (* oeq (rdiv N q) 0 *)
  in g end;

val () = out "F3D_RDIVZERO_OK\n";

(* ============================================================================
   (M-2)  floor_double_ge : lt 0 q ==> le (add (rdiv n q)(rdiv n q))(rdiv (add n n) q)
          i.e.  2*floor(n/q) <= floor(2n/q).
   Proof : key  (q*D2)+R2 = (q*DD)+(R1+R1)  [same algebra as floor01], then
           assume lt D2 DD -> R2 >= q contradiction -> neg(lt D2 DD) -> nlt_le -> le DD D2.
   ============================================================================ *)
val () = out "F3D_FDG_BEGIN\n";

fun floor_double_ge3 (nT, qT) hpos =    (* hpos : lt 0 q -> le (add (n/q)(n/q))(2n/q) *)
  let
    val D2 = rdiv (add nT nT) qT;  val R2 = rmod (add nT nT) qT;
    val D1 = rdiv nT qT;           val R1 = rmod nT qT;
    val DD = add D1 D1;
    (* eq2 : 2n = q*D2 + R2 ; eq1 : n = q*D1 + R1 *)
    val eq2 = div_mod_eq_3 (add nT nT, qT) hpos
    val eq1 = div_mod_eq_3 (nT, qT) hpos
    val r1lt = rmod_lt_3 (nT, qT) hpos
    val r2lt = rmod_lt_3 (add nT nT, qT) hpos
    (* double eq1 : n+n = (qD1+R1)+(qD1+R1) *)
    val dbl = (let val l = add_cong_l3 (nT, add (mult qT D1) R1, nT) eq1
                   val r = add_cong_r3 (add (mult qT D1) R1, nT, add (mult qT D1) R1) eq1
               in oeq_trans OF [l, r] end)            (* oeq (n+n)((qD1+R1)+(qD1+R1)) *)
    (* reshuffle (a+b)+(a+b) = (a+a)+(b+b) with a=qD1, b=R1 *)
    val a_ = mult qT D1; val b_ = R1;
    val s1 = addassoc3_at (a_, b_, add a_ b_)         (* ((a+b)+(a+b))(a+(b+(a+b))) *)
    val t1 = oeq_sym OF [addassoc3_at (b_, a_, b_)]   (* (b+(a+b))((b+a)+b) *)
    val t2 = add_cong_l3 (add b_ a_, add a_ b_, b_) (addcomm3_at (b_, a_))  (* ((b+a)+b)((a+b)+b) *)
    val t3 = addassoc3_at (a_, b_, b_)               (* ((a+b)+b)(a+(b+b)) *)
    val bab = oeq_trans OF [t1, oeq_trans OF [t2, t3]] (* (b+(a+b))(a+(b+b)) *)
    val s2 = add_cong_r3 (a_, add b_ (add a_ b_), add a_ (add b_ b_)) bab
    val s3 = oeq_sym OF [addassoc3_at (a_, a_, add b_ b_)]
    val rhsEq = oeq_trans OF [s1, oeq_trans OF [s2, s3]]  (* ((a+b)+(a+b))((a+a)+(b+b)) *)
    val ld = ldist_3 (qT, D1, D1)                    (* (q*(D1+D1))((q*D1)+(q*D1)) *)
    val aa_qDD = oeq_sym OF [ld]                     (* ((q*D1)+(q*D1))(q*(D1+D1)) *)
    val rhsEq2 = oeq_trans OF [rhsEq, add_cong_l3 (add a_ a_, mult qT DD, add b_ b_) aa_qDD]
    val eqB = oeq_trans OF [dbl, rhsEq2]             (* oeq (n+n)((q*DD)+(R1+R1)) *)
    val key = oeq_trans OF [oeq_sym OF [eq2], eqB]   (* oeq ((q*D2)+R2)((q*DD)+(R1+R1)) *)
    (* contradiction : assume lt D2 DD *)
    val hlt = Thm.assume (ctermV3 (jT (lt D2 DD)))   (* le (Suc D2) DD *)
    val mlm = mult_le_mono_3 (qT, suc D2, DD) hlt    (* le (q*(Suc D2))(q*DD) *)
    val qSD2 = multSr3_at (qT, D2)                   (* oeq (q*(Suc D2))(add q (q*D2)) *)
    val qSD2c = oeq_trans OF [qSD2, addcomm3_at (qT, mult qT D2)]  (* oeq (q*(Suc D2))(add (q*D2) q) *)
    val le_qD2q_qDD = le_cong_l3 (mult qT (suc D2), add (mult qT D2) qT, mult qT DD) qSD2c mlm
                                                     (* le (add (q*D2) q)(q*DD) *)
    val le_add = le_add_mono_3 (add (mult qT D2) qT, mult qT DD, add R1 R1) le_qD2q_qDD
                                                     (* le ((q*D2+q)+(R1+R1))((q*DD)+(R1+R1)) *)
    (* (q*DD)+(R1+R1) = (q*D2)+R2  [sym key] *)
    val le_to_qD2R2 = le_cong_r3 (add (add (mult qT D2) qT)(add R1 R1), add (mult qT DD)(add R1 R1), add (mult qT D2) R2)
                        (oeq_sym OF [key]) le_add     (* le ((q*D2+q)+(R1+R1))((q*D2)+R2) *)
    (* le (q*D2+q)((q*D2+q)+(R1+R1)) ; trans *)
    val le_self = le_add3_at (add (mult qT D2) qT, add R1 R1)  (* le (q*D2+q)((q*D2+q)+(R1+R1)) *)
    val le_qD2q_qD2R2 = le_trans3_at (add (mult qT D2) qT, add (add (mult qT D2) qT)(add R1 R1), add (mult qT D2) R2)
                          le_self le_to_qD2R2          (* le (q*D2+q)((q*D2)+R2) *)
    (* lt ((q*D2)+R2)((q*D2)+q) : from lt R2 q via add-left-mono *)
    val m1 = le_add_mono_3 (suc R2, qT, mult qT D2) r2lt    (* le ((Suc R2)+(q*D2))(q+(q*D2)) *)
    (* comm both sides : le ((q*D2)+(Suc R2))((q*D2)+q) *)
    val m1l = le_cong_l3 (add (suc R2)(mult qT D2), add (mult qT D2)(suc R2), add qT (mult qT D2))
                (addcomm3_at (suc R2, mult qT D2)) m1
    val m1lr = le_cong_r3 (add (mult qT D2)(suc R2), add qT (mult qT D2), add (mult qT D2) qT)
                 (addcomm3_at (qT, mult qT D2)) m1l    (* le ((q*D2)+(Suc R2))((q*D2)+q) *)
    (* (q*D2)+(Suc R2) = Suc((q*D2)+R2)  [add_Suc_right] *)
    val asr = addSr3_at (mult qT D2, R2)              (* oeq ((q*D2)+(Suc R2))(Suc((q*D2)+R2)) *)
    val lt_qD2R2_qD2q = le_cong_l3 (add (mult qT D2)(suc R2), suc (add (mult qT D2) R2), add (mult qT D2) qT)
                          asr m1lr                     (* le (Suc((q*D2)+R2))((q*D2)+q) = lt ((q*D2)+R2)((q*D2)+q) *)
    (* combine : le (q*D2+q)((q*D2)+R2) and le (Suc((q*D2)+R2))((q*D2)+q) -> le (Suc((q*D2)+R2))((q*D2)+R2) -> false *)
    val leChain = le_trans3_at (suc (add (mult qT D2) R2), add (mult qT D2) qT, add (mult qT D2) R2)
                    lt_qD2R2_qD2q le_qD2q_qD2R2        (* le (Suc((q*D2)+R2))((q*D2)+R2) = lt x x *)
    val ff = (lt_irrefl3_at (add (mult qT D2) R2)) OF [leChain]   (* oFalse *)
    val negLtMeta = Thm.implies_intr (ctermV3 (jT (lt D2 DD))) ff  (* meta : jT(lt D2 DD) ==> jT oFalse *)
    val negLt = impI_3 (lt D2 DD, oFalseC) negLtMeta  (* jT (Imp (lt D2 DD) oFalse) = jT (neg (lt D2 DD)) *)
    val g = nlt_le_3 (D2, DD) negLt                  (* le DD D2 = le (add (n/q)(n/q))(2n/q) *)
  in g end;

val () = out "F3D_FDG_OK\n";

(* ============================================================================
   (M-3)  general (non-dvd) floor facts for maxpow's recursion :
     pmNp_le_N   : lt 0 p ==> le (mult p (rdiv N p)) N           [p*(N/p) <= N]
     N_lt_pmNp_p : lt 0 p ==> lt N (add (mult p (rdiv N p)) p)    [N < p*(N/p)+p]
     Np_pos_gen  : prime2 p ==> le p N ==> lt 0 (rdiv N p)
     Np_lt_gen   : prime2 p ==> le p N ==> lt (rdiv N p) N
   ============================================================================ *)
val () = out "F3D_GENFLOOR_BEGIN\n";

fun pmNp_le_N3 (pT, NT) hpos =      (* le (mult p (rdiv N p)) N *)
  let
    val divEq = div_mod_eq_3 (NT, pT) hpos   (* oeq N (add (mult p (rdiv N p))(rmod N p)) *)
    (* le (p*(N/p))((p*(N/p))+(rmod N p)) [le_add] ; rewrite rhs -> N (sym divEq) *)
    val le0 = le_add3_at (mult pT (rdiv NT pT), rmod NT pT)  (* le (p*(N/p))((p*(N/p))+rmod) *)
    val g = le_cong_r3 (mult pT (rdiv NT pT), add (mult pT (rdiv NT pT))(rmod NT pT), NT) (oeq_sym OF [divEq]) le0
  in g end;

fun N_lt_pmNp_p3 (pT, NT) hpos =    (* lt N (add (mult p (rdiv N p)) p) *)
  let
    val divEq = div_mod_eq_3 (NT, pT) hpos   (* oeq N (add (mult p (rdiv N p))(rmod N p)) *)
    val rlt   = rmod_lt_3 (NT, pT) hpos      (* lt (rmod N p) p = le (Suc(rmod N p)) p *)
    val Q = mult pT (rdiv NT pT)
    (* lt ((Q)+(rmod N p))((Q)+p) : from lt (rmod) p via add-left-mono ; then rewrite lhs -> Suc N *)
    val m1 = le_add_mono_3 (suc (rmod NT pT), pT, Q) rlt   (* le ((Suc rmod)+Q)(p+Q) *)
    val m1l = le_cong_l3 (add (suc (rmod NT pT)) Q, add Q (suc (rmod NT pT)), add pT Q)
                (addcomm3_at (suc (rmod NT pT), Q)) m1
    val m1lr = le_cong_r3 (add Q (suc (rmod NT pT)), add pT Q, add Q pT)
                 (addcomm3_at (pT, Q)) m1l   (* le (Q+(Suc rmod))(Q+p) *)
    (* Q+(Suc rmod) = Suc(Q+rmod) [add_Suc_right] ; Q+rmod = N (sym divEq) ; so Q+(Suc rmod) = Suc N *)
    val asr = addSr3_at (Q, rmod NT pT)        (* oeq (Q+(Suc rmod))(Suc(Q+rmod)) *)
    val sN  = oeq_trans OF [asr, Suc_cong OF [oeq_sym OF [divEq]]]  (* oeq (Q+(Suc rmod))(Suc N) *)
    val g = le_cong_l3 (add Q (suc (rmod NT pT)), suc NT, add Q pT) sN m1lr  (* le (Suc N)(Q+p) = lt N (Q+p) *)
  in g end;

fun Np_pos_gen3 (pT, NT) hPr hleP =     (* prime2 p, le p N -> lt 0 (rdiv N p) *)
  let
    val hpos = prime2_pos_3 pT hPr        (* lt 0 p *)
    val dz = dzos3_at (rdiv NT pT)        (* Disj (oeq (N/p) 0)(Ex q. oeq (N/p)(Suc q)) *)
    val goalC = lt ZeroC (rdiv NT pT)
    val caseZ =
      let val hz = Thm.assume (ctermV3 (jT (oeq (rdiv NT pT) ZeroC)))
          (* N/p = 0 -> p*(N/p)=p*0=0 -> N < 0+p = p contradicts le p N *)
          val ple = pmNp_le_N3 (pT, NT) hpos        (* le (p*(N/p)) N *)
          val Nlt = N_lt_pmNp_p3 (pT, NT) hpos      (* lt N (p*(N/p)+p) *)
          (* p*(N/p) = p*0 = 0 [cong hz + mult0r] *)
          val pNp0 = oeq_trans OF [mult_cong_r3 (pT, rdiv NT pT, ZeroC) hz, mult0r3_at pT]  (* oeq (p*(N/p)) 0 *)
          (* p*(N/p)+p = 0+p = p *)
          val rhsP = oeq_trans OF [add_cong_l3 (mult pT (rdiv NT pT), ZeroC, pT) pNp0, add03_at pT]  (* oeq (p*(N/p)+p) p *)
          val NltP = le_cong_r3 (suc NT, add (mult pT (rdiv NT pT)) pT, pT) rhsP Nlt   (* lt N p = le (Suc N) p *)
          (* le p N and lt N p -> le (Suc N) p <= N -> le (Suc N) N -> lt N N -> false *)
          val chain = le_trans3_at (suc NT, pT, NT) NltP hleP   (* le (Suc N) N *)
          val ff = (lt_irrefl3_at NT) OF [chain]
          val g = Thm.implies_elim (oFalse_elim_3 goalC) ff
      in Thm.implies_intr (ctermV3 (jT (oeq (rdiv NT pT) ZeroC))) g end;
    val PabsQ = Abs("q", natT, oeq (rdiv NT pT)(suc (Bound 0)))
    val caseS =
      let val hex = Thm.assume (ctermV3 (jT (mkEx PabsQ)))
          fun body qF (hq : thm) =     (* hq : oeq (N/p)(Suc q) *)
            let val lt0Sq = le_intro3 (suc ZeroC, suc qF, qF)
                              (oeq_sym OF [oeq_trans OF [addSuc3_at (ZeroC, qF), Suc_cong OF [add03_at qF]]])
                              (* le (Suc 0)(Suc q) = lt 0 (Suc q) *)
                val g = (let val zF = Free("zlt1g",natT)
                             val Pb = Term.lambda zF (le (suc ZeroC) zF)
                         in substPred3 (Pb, suc qF, rdiv NT pT) (oeq_sym OF [hq]) lt0Sq end)
            in g end
          val g = exE_elim3 (PabsQ, goalC) hex "q_npg" body
      in Thm.implies_intr (ctermV3 (jT (mkEx PabsQ))) g end;
  in disjE_3 (oeq (rdiv NT pT) ZeroC, mkEx PabsQ, goalC) dz caseZ caseS end;

fun Np_lt_gen3 (pT, NT) hPr hleP =     (* prime2 p, le p N -> lt (rdiv N p) N *)
  let
    val hpos = prime2_pos_3 pT hPr
    val gt1  = prime2_gt1_3 pT hPr       (* le 2 p *)
    val rpos = Np_pos_gen3 (pT, NT) hPr hleP  (* lt 0 (N/p) = le 1 (N/p) *)
    val dP = rdiv NT pT
    val ple = pmNp_le_N3 (pT, NT) hpos   (* le (p*(N/p)) N *)
    (* le 2 p, le dP dP -> mult_le_mono2 : le (2*dP)(p*dP) *)
    val mlm = mult_le_mono2_3_at (suc (suc ZeroC), pT, dP, dP) gt1 (le_refl3_at dP)  (* le (2*dP)(p*dP) *)
    (* 2*dP = dP+dP *)
    val ms2 = multSuc3_at (suc ZeroC, dP)   (* oeq ((Suc(Suc 0))*dP)(add dP ((Suc 0)*dP)) *)
    val ms1 = multSuc3_at (ZeroC, dP)       (* oeq ((Suc 0)*dP)(add dP (0*dP)) *)
    val m0r = mult03_at dP                   (* oeq (0*dP) 0 *)
    val s1  = oeq_trans OF [ms1, oeq_trans OF [add_cong_r3 (dP, mult ZeroC dP, ZeroC) m0r, add0r3_at dP]]  (* (Suc0)*dP = dP *)
    val two_dP = oeq_trans OF [ms2, add_cong_r3 (dP, mult (suc ZeroC) dP, dP) s1]   (* oeq (2*dP)(add dP dP) *)
    val le_dd_pdP = le_cong_l3 (mult (suc (suc ZeroC)) dP, add dP dP, mult pT dP) two_dP mlm  (* le (dP+dP)(p*dP) *)
    val le_dd_N = le_trans3_at (add dP dP, mult pT dP, NT) le_dd_pdP ple   (* le (dP+dP) N *)
    (* lt dP (dP+dP) : le (Suc dP)(dP+dP).  le_add_mono on rpos (le 1 dP) : le (1+dP)(dP+dP) ; 1+dP=Suc dP *)
    val lam = le_add_mono_3 (suc ZeroC, dP, dP) rpos   (* le ((Suc 0)+dP)(dP+dP) *)
    val s0r = oeq_trans OF [addSuc3_at (ZeroC, dP), Suc_cong OF [add03_at dP]]  (* oeq ((Suc 0)+dP)(Suc dP) *)
    val lt_d_dd = le_cong_l3 (add (suc ZeroC) dP, suc dP, add dP dP) s0r lam   (* le (Suc dP)(dP+dP) *)
    val g = le_trans3_at (suc dP, add dP dP, NT) lt_d_dd le_dd_N   (* le (Suc dP) N = lt dP N *)
  in g end;

val () = out "F3D_GENFLOOR_OK\n";

(* ============================================================================
   (M)  maxpow : prime2 p ==> lt 0 N ==> Ex M. Conj (le (pow p M) N)(lt N (pow p (Suc M)))
        by strong induction on N (P N := lt 0 N ==> Ex M. ...).
   ============================================================================ *)
val () = out "F3D_MAXPOW_BEGIN\n";

val maxpow =
  let
    val pF = Free("p", natT); val NF = Free("N", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val lt0p = prime2_pos_3 pF hPr
    (* ExBody M : Conj (le (pow p M) X)(lt X (pow p (Suc M))).
       CAPTURE-SAFE : build the body over a FRESH Free M then Term.lambda — never pass
       a term containing a dangling Bound to le/lt (they wrap arg 1 under a fresh Abs). *)
    val Mfv = Free("M_mp", natT)
    fun exAbs XT = Term.lambda Mfv (mkConj (le (pow pF Mfv) XT)(lt XT (pow pF (suc Mfv))))
    fun exGoal XT = mkEx (exAbs XT)
    (* P n = Imp (lt 0 n)(Ex M. ...)  — object Imp so the strong-induct predicate is nat->o *)
    val zMP = Free("z_mp", natT)
    val Ppred = Term.lambda zMP (mkImp (lt ZeroC zMP)(exGoal zMP))
    (* strong-induct STEP : !!n. (!!m. lt m n ==> P m) ==> P n *)
    val nSI = Free("n_mp", natT)
    val mSI = Free("m_mp", natT)
    val Hstep =     (* the inner hypothesis (!!m. lt m n ==> P m) *)
      Logic.all mSI (Logic.mk_implies (jT (lt mSI nSI), jT (Term.betapply (Ppred, mSI))))
    val Hassume = Thm.assume (ctermV3 Hstep)
    (* prove P n = Imp (lt 0 n)(exGoal n) : assume lt 0 n *)
    val hN0 = Thm.assume (ctermV3 (jT (lt ZeroC nSI)))
    (* case split : lt n p  (M=0)  vs  neg(lt n p) -> le p n (recurse) *)
    val em = ex_middle_3 (lt nSI pF)     (* Disj (lt n p)(neg (lt n p)) *)
    (* CASE lt n p : witness M=0 : le (pow p 0) n  and  lt n (pow p (Suc 0)) *)
    val caseLt =
      let
        val hlt = Thm.assume (ctermV3 (jT (lt nSI pF)))
        (* le (pow p 0) n : pow p 0 = 1 ; le 1 n = lt 0 n = hN0 *)
        val p0 = pow03_at pF                 (* oeq (pow p 0)(Suc 0) *)
        val le1n = hN0                        (* le (Suc 0) n = lt 0 n *)
        val lePow0 = le_cong_l3 (suc ZeroC, pow pF ZeroC, nSI) (oeq_sym OF [p0]) le1n  (* le (pow p 0) n *)
        (* lt n (pow p (Suc 0)) : pow p (Suc 0) = p*(pow p 0) = p*1 = p ; lt n p = hlt *)
        val pS0 = powSuc3_at (pF, ZeroC)     (* oeq (pow p (Suc 0))(mult p (pow p 0)) *)
        val pS0b = oeq_trans OF [pS0, oeq_trans OF [mult_cong_r3 (pF, pow pF ZeroC, suc ZeroC) p0, mult1r3_at pF]]
                   (* oeq (pow p (Suc 0)) p *)
        val ltnP = le_cong_r3 (suc nSI, pF, pow pF (suc ZeroC)) (oeq_sym OF [pS0b]) hlt   (* lt n (pow p (Suc 0)) *)
        val conj = conjI_3 (le (pow pF ZeroC) nSI, lt nSI (pow pF (suc ZeroC))) lePow0 ltnP
        val ex = (beta_norm (Drule.infer_instantiate ctxtV3
                   [(("P",0), ctermV3 (exAbs nSI)),(("a",0), ctermV3 ZeroC)] exI_v3)) OF [conj]
                 (* Ex M. Conj ... *)
      in Thm.implies_intr (ctermV3 (jT (lt nSI pF))) ex end;
    (* CASE neg (lt n p) -> le p n : recurse on K = n/p *)
    val caseGe =
      let
        val hng = Thm.assume (ctermV3 (jT (neg (lt nSI pF))))
        val hlePn = nlt_le_3 (nSI, pF) hng    (* le p n *)
        val K = rdiv nSI pF
        val Kpos = Np_pos_gen3 (pF, nSI) hPr hlePn   (* lt 0 K *)
        val KltN = Np_lt_gen3 (pF, nSI) hPr hlePn    (* lt K n *)
        (* IH at K : P K = Imp (lt 0 K)(exGoal K) ; via Hassume *)
        val Hm_K = Thm.implies_elim (Thm.forall_elim (ctermV3 K) Hassume) KltN  (* jT (P K) = jT (Imp (lt 0 K)(exGoal K)) *)
        val PK = beta_norm Hm_K
        val exK = mp_3 (lt ZeroC K, exGoal K) PK Kpos   (* Ex M'. Conj (le (pow p M') K)(lt K (pow p (Suc M'))) *)
        (* eliminate the witness M' ; build witness Suc M' for n *)
        fun ebody mpF (hmp : thm) =   (* hmp : Conj (le (pow p M') K)(lt K (pow p (Suc M'))) *)
          let
            val hle = conjunct1_3 (le (pow pF mpF) K, lt K (pow pF (suc mpF))) hmp   (* le (pow p M') K *)
            val hlt = conjunct2_3 (le (pow pF mpF) K, lt K (pow pF (suc mpF))) hmp   (* lt K (pow p (Suc M')) *)
            (* (1) le (pow p (Suc M')) n :
                   pow p (Suc M') = p*(pow p M') ; le (pow p M') K -> le (p*pow)(p*K) [mult_le_mono]
                   p*K = p*(n/p) <= n [pmNp_le_N] *)
            val pSm = powSuc3_at (pF, mpF)        (* oeq (pow p (Suc M'))(mult p (pow p M')) *)
            val lepK = mult_le_mono_3 (pF, pow pF mpF, K) hle   (* le (p*(pow p M'))(p*K) *)
            val pKleN = pmNp_le_N3 (pF, nSI) lt0p  (* le (p*K) n *)
            val le_ppow_n = le_trans3_at (mult pF (pow pF mpF), mult pF K, nSI) lepK pKleN  (* le (p*(pow p M')) n *)
            val leSm_n = le_cong_l3 (mult pF (pow pF mpF), pow pF (suc mpF), nSI) (oeq_sym OF [pSm]) le_ppow_n
                         (* le (pow p (Suc M')) n *)
            (* (2) lt n (pow p (Suc(Suc M'))) :
                   lt K (pow p (Suc M')) = le (Suc K) (pow p (Suc M')) ; p*(Suc K) <= p*(pow p (Suc M')) [mono]
                   p*(Suc K) = p*K + p ; n < p*K + p [N_lt_pmNp_p] ; pow p (Suc(Suc M')) = p*(pow p (Suc M')) *)
            val lepSK = mult_le_mono_3 (pF, suc K, pow pF (suc mpF)) hlt  (* le (p*(Suc K))(p*(pow p (Suc M'))) *)
            (* p*(Suc K) = p + p*K = p*K + p *)
            val pSK = multSr3_at (pF, K)          (* oeq (p*(Suc K))(add p (p*K)) *)
            val pSKc = oeq_trans OF [pSK, addcomm3_at (pF, mult pF K)]  (* oeq (p*(Suc K))(add (p*K) p) *)
            val le_pKp_ppow = le_cong_l3 (mult pF (suc K), add (mult pF K) pF, mult pF (pow pF (suc mpF)))
                                pSKc lepSK         (* le ((p*K)+p)(p*(pow p (Suc M'))) *)
            val Nlt = N_lt_pmNp_p3 (pF, nSI) lt0p  (* lt n ((p*K)+p) = le (Suc n)((p*K)+p) *)
            val le_SN_ppow = le_trans3_at (suc nSI, add (mult pF K) pF, mult pF (pow pF (suc mpF))) Nlt le_pKp_ppow
                             (* le (Suc n)(p*(pow p (Suc M'))) = lt n (p*(pow p (Suc M'))) *)
            (* pow p (Suc(Suc M')) = p*(pow p (Suc M')) *)
            val pSS = powSuc3_at (pF, suc mpF)    (* oeq (pow p (Suc(Suc M')))(mult p (pow p (Suc M'))) *)
            val ltn_SS = le_cong_r3 (suc nSI, mult pF (pow pF (suc mpF)), pow pF (suc (suc mpF)))
                           (oeq_sym OF [pSS]) le_SN_ppow   (* lt n (pow p (Suc(Suc M'))) *)
            (* witness M = Suc M' *)
            val conj = conjI_3 (le (pow pF (suc mpF)) nSI, lt nSI (pow pF (suc (suc mpF)))) leSm_n ltn_SS
            val ex = (beta_norm (Drule.infer_instantiate ctxtV3
                       [(("P",0), ctermV3 (exAbs nSI)),(("a",0), ctermV3 (suc mpF))] exI_v3)) OF [conj]
          in ex end;
        val gEx = exE_elim3 (exAbs K, exGoal nSI) exK "Mp_mp" ebody
      in Thm.implies_intr (ctermV3 (jT (neg (lt nSI pF)))) gEx end;
    val exN = disjE_3 (lt nSI pF, neg (lt nSI pF), exGoal nSI) em caseLt caseGe
    val PnMeta = Thm.implies_intr (ctermV3 (jT (lt ZeroC nSI))) exN  (* meta : jT(lt 0 n) ==> jT(exGoal n) *)
    val Pn = impI_3 (lt ZeroC nSI, exGoal nSI) PnMeta   (* jT (Imp (lt 0 n)(exGoal n)) = jT (P n) *)
    (* discharge Hstep -> the strong-induct step !!n. Hstep ==> P n *)
    val stepThm = Thm.forall_intr (ctermV3 nSI) (Thm.implies_intr (ctermV3 Hstep) Pn)
    val atN = strong_induct_3 (Ppred, NF) stepThm    (* jT (P N) = jT (Imp (lt 0 N)(exGoal N)) *)
    (* turn into : prime2 p ==> lt 0 N ==> exGoal N *)
    val h0N = Thm.assume (ctermV3 (jT (lt ZeroC NF)))
    val exFinal = mp_3 (lt ZeroC NF, exGoal NF) atN h0N
    val d1 = Thm.implies_intr (ctermV3 (jT (lt ZeroC NF))) exFinal
    val d2 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d1
  in varify d2 end;
val () = out ("maxpow 0hyp=" ^ Bool.toString (zhV3 maxpow) ^ "\n");
val i_maxpow =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT)
      val Mfv = Free("M_mp", natT)
      val MB = Term.lambda Mfv (mkConj (le (pow pVz Mfv) NVz)(lt NVz (pow pVz (suc Mfv))))
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC NVz),
         jT (mkEx MB))) end;
val r_maxpow = (Thm.prop_of maxpow) aconv i_maxpow;
val () = out ("maxpow aconv=" ^ Bool.toString r_maxpow ^ "\n");
val () = if zhV3 maxpow andalso r_maxpow then out "MAXPOW_OK\n" else out "MAXPOW_FAIL\n";
val () = out "F3D_MAXPOW_DONE\n";

(* ============================================================================
   (LF)  legendre_full (conditional) :
     prime2 p ==> lt N (pow p (Suc M)) ==>
       oeq (vp p (fact N))(sumf (%i. rdiv N (pow p (Suc i))) M)
   = legendre_sum_rem at L=M with the remainder vp(fact (N/p^(Suc M))) vanishing
     (N < p^(Suc M) -> N/p^(Suc M) = 0 -> vp(fact 0) = vp 1 = 0).
   ============================================================================ *)
val () = out "F3D_LF_BEGIN\n";

(* vp(fact 0) = 0 : fact 0 = 1 ; vp p 1 ... need vp p (Suc 0) = 0.  Use vp_step_ndvd : ~(p | 1).
   Simpler : pfree/vp route?  We have vp_pow_self (vp(p^k)=k) at k=0 : vp(p^0)=vp 1=0. *)
fun vp_fact_zero3 pT hPr =       (* oeq (vp p (fact 0)) 0 *)
  let
    val f0 = fact03_at ()                 (* oeq (fact 0)(Suc 0) *)
    (* vp p (fact 0) = vp p (Suc 0) [cong f0] ; vp p (Suc 0) = vp p (pow p 0) [pow p 0 = 1] = 0 [vp_pow_self k=0] *)
    val p0 = pow03_at pT                   (* oeq (pow p 0)(Suc 0) *)
    val vps0 = vp_pow_self_3 (pT, ZeroC) hPr  (* oeq (vp p (pow p 0)) 0 *)
    (* vp p (Suc 0) = vp p (pow p 0) [cong sym p0] *)
    val vSuc0_eq = vp_cong_3 (pT, suc ZeroC, pow pT ZeroC) (oeq_sym OF [p0])  (* oeq (vp p (Suc 0))(vp p (pow p 0)) *)
    val vSuc0_0 = oeq_trans OF [vSuc0_eq, vps0]   (* oeq (vp p (Suc 0)) 0 *)
    val vf0_eq = vp_cong_3 (pT, fact ZeroC, suc ZeroC) f0   (* oeq (vp p (fact 0))(vp p (Suc 0)) *)
    val g = oeq_trans OF [vf0_eq, vSuc0_0]    (* oeq (vp p (fact 0)) 0 *)
  in g end;

val legendre_full =
  let
    val pF = Free("p", natT); val NF = Free("N", natT); val MF = Free("M_lf", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hlt  = Thm.assume (ctermV3 (jT (lt NF (pow pF (suc MF)))))   (* N < p^(Suc M) *)
    (* f i = rdiv N (pow p (Suc i)) ; capture-safe abstraction over Free *)
    val iLF = Free("i_lf", natT)
    val fAbs = Term.lambda iLF (rdiv NF (pow pF (suc iLF)))
    (* legendre_sum_rem at L = M : vp(fact N) = sumf f M + vp(fact (N/p^(Suc M))) *)
    val lsr = legendre_sum_rem_3 (pF, NF, MF) hPr   (* oeq (vp p (fact N))(add (sumf f M)(vp p (fact (rdiv N (pow p (Suc M)))))) *)
    (* remainder : N/p^(Suc M) = 0 [rdiv_zero_of_lt with N < p^(Suc M)] *)
    val rz = rdiv_zero_of_lt3 (NF, pow pF (suc MF)) hlt   (* oeq (rdiv N (pow p (Suc M))) 0 *)
    (* vp(fact (N/p^(Suc M))) = vp(fact 0) [cong rz] = 0 *)
    val vfRem_eq = vp_cong_3 (pF, fact (rdiv NF (pow pF (suc MF))), fact ZeroC)
                     (let val zF = Free("zfr",natT)
                          val Pb = Term.lambda zF (oeq (fact (rdiv NF (pow pF (suc MF))))(fact zF))
                      in substPred3 (Pb, rdiv NF (pow pF (suc MF)), ZeroC) rz (oeqrefl3_at (fact (rdiv NF (pow pF (suc MF))))) end)
                     (* oeq (vp p (fact (N/p^(Suc M))))(vp p (fact 0)) *)
    val vfRem0 = oeq_trans OF [vfRem_eq, vp_fact_zero3 pF hPr]   (* oeq (vp p (fact (N/p^(Suc M)))) 0 *)
    (* RHS = add (sumf f M)(vp(fact rem)) -> add (sumf f M) 0 -> sumf f M *)
    val rhs1 = add_cong_r3 (sumf fAbs MF, vp pF (fact (rdiv NF (pow pF (suc MF)))), ZeroC) vfRem0
               (* oeq (add (sumf f M)(vp(fact rem)))(add (sumf f M) 0) *)
    val rhs2 = oeq_trans OF [rhs1, add0r3_at (sumf fAbs MF)]   (* oeq (add (sumf f M)(vp(fact rem)))(sumf f M) *)
    val g = oeq_trans OF [lsr, rhs2]   (* oeq (vp p (fact N))(sumf f M) *)
    val d2 = Thm.implies_intr (ctermV3 (jT (lt NF (pow pF (suc MF))))) g
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("legendre_full 0hyp=" ^ Bool.toString (zhV3 legendre_full) ^ "\n");
val i_legendre_full =
  let val pVz = Var(("p",0),natT); val NVz = Var(("N",0),natT); val MVz = Var(("M_lf",0),natT)
      val iLF = Free("i_lf", natT)
      val fAbs = Term.lambda iLF (rdiv NVz (pow pVz (suc iLF)))
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt NVz (pow pVz (suc MVz))),
         jT (oeq (vp pVz (fact NVz))(sumf fAbs MVz)))) end;
val r_lf = (Thm.prop_of legendre_full) aconv i_legendre_full;
val () = out ("legendre_full aconv=" ^ Bool.toString r_lf ^ "\n");
val () = if zhV3 legendre_full andalso r_lf then out "LEGENDRE_FULL_OK\n" else out "LEGENDRE_FULL_FAIL\n";
fun legendre_full_3 (pT,NT,MT) hPr hlt =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("N",0), ctermV3 NT),(("M_lf",0), ctermV3 MT)] (varify legendre_full))
  in (inst OF [hPr]) OF [hlt] end;
val () = out "F3D_LF_DONE\n";

(* ============================================================================
   (BE)  vp_binom_eq (conditional) :
     prime2 p ==> lt 0 n ==> lt (add n n)(pow p (Suc M)) ==>
       oeq (vp p (binom (add n n) n))(sumf (%i. tflo n (pow p (Suc i))) M)
   ============================================================================ *)
val () = out "F3D_BE_BEGIN\n";

(* le n (2n) = le n (add n n) via le_add3 *)
(* lt n (pow p (Suc M))  from  lt (2n)(pow p (Suc M))  and  le n (2n) *)
fun lt_n_of_lt2n3 (nT, XT) hlt2n =     (* hlt2n : lt (add n n) X -> lt n X *)
  let
    val le_n_2n = le_add3_at (nT, nT)               (* le n (add n n) *)
    val le_Sn_S2n = le_suc_mono3_at (nT, add nT nT) le_n_2n  (* le (Suc n)(Suc (2n)) *)
    val g = le_trans3_at (suc nT, suc (add nT nT), XT) le_Sn_S2n hlt2n  (* le (Suc n) X = lt n X *)
  in g end;

val vp_binom_eq =
  let
    val pF = Free("p", natT); val nF = Free("n", natT); val MF = Free("M_be", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hn0  = Thm.assume (ctermV3 (jT (lt ZeroC nF)))
    val hlt2 = Thm.assume (ctermV3 (jT (lt (add nF nF)(pow pF (suc MF)))))   (* 2n < p^(Suc M) *)
    val lt0p = prime2_pos_3 pF hPr
    val twoN = add nF nF
    (* capture-safe abstractions over Free i *)
    val iBE = Free("i_be", natT)
    val f2Abs   = Term.lambda iBE (rdiv twoN (pow pF (suc iBE)))            (* %i. (2n)/p^(Suc i) *)
    val f1Abs   = Term.lambda iBE (rdiv nF (pow pF (suc iBE)))             (* %i. n/p^(Suc i) *)
    val f1pAbs  = Term.lambda iBE (add (rdiv nF (pow pF (suc iBE)))(rdiv nF (pow pF (suc iBE))))  (* %i. (n/p^(Suc i))+(n/p^(Suc i)) *)
    val tfloAbs = Term.lambda iBE (sub (rdiv twoN (pow pF (suc iBE)))(add (rdiv nF (pow pF (suc iBE)))(rdiv nF (pow pF (suc iBE)))))
                                                                          (* %i. tflo n (pow p (Suc i)) *)
    val ltn = lt_n_of_lt2n3 (nF, pow pF (suc MF)) hlt2       (* lt n (p^(Suc M)) *)
    (* S2 = sumf f2 M ; S1 = sumf f1 M *)
    val lfN2 = legendre_full_3 (pF, twoN, MF) hPr hlt2       (* oeq (vp p (fact 2n))(sumf f2 M) *)
    val lfN1 = legendre_full_3 (pF, nF, MF) hPr ltn          (* oeq (vp p (fact n))(sumf f1 M) *)
    val vbs  = vp_binom_split_3 (pF, nF) hPr                 (* oeq (vp p (fact 2n))(add (vp p (binom 2n n))(add (vp p (fact n))(vp p (fact n)))) *)
    (* rewrite vbs RHS : vp(fact n) -> sumf f1 M  (both occurrences) *)
    val S1 = sumf f1Abs MF
    val vbs1 = oeq_trans OF [vbs,
                  add_cong_r3 (vp pF (binom twoN nF), add (vp pF (fact nF))(vp pF (fact nF)), add S1 S1)
                    (oeq_trans OF [add_cong_l3 (vp pF (fact nF), S1, vp pF (fact nF)) lfN1,
                                   add_cong_r3 (S1, vp pF (fact nF), S1) lfN1])]
               (* oeq (vp p (fact 2n))(add (vp p (binom 2n n))(add S1 S1)) *)
    (* and vp(fact 2n) -> sumf f2 M : sumf f2 M = add (vp binom)(S1+S1) *)
    val S2 = sumf f2Abs MF
    val key2 = oeq_trans OF [oeq_sym OF [lfN2], vbs1]    (* oeq (sumf f2 M)(add (vp binom)(add S1 S1)) *)
    (* ---- per-term identity (for sum_cong) : !!k. le k M ==> oeq (add (tflo k)(f1p k))(f2 k) ---- *)
    val gAddAbs = Term.lambda iBE (add (Term.betapply (tfloAbs, iBE))(Term.betapply (f1pAbs, iBE)))
                  (* %i. add (tflo i)(f1p i) *)
    val kBE = Free("k_be", natT)
    fun perTerm kT =     (* oeq (add (tflo k)(f1p k))(f2 k) *)
      let
        val q = pow pF (suc kT)
        val qpos = pow_pos_3 (pF, suc kT) lt0p          (* lt 0 q *)
        val fdg = floor_double_ge3 (nF, q) qpos         (* le (add (n/q)(n/q))((2n)/q) = le (f1p k)(f2 k) *)
        (* le_add_sub : le (f1p k)(f2 k) -> oeq (add (f1p k)(sub (f2 k)(f1p k)))(f2 k) = (f1p k)+(tflo k) = f2 k *)
        val recov = le_add_sub_3 (add (rdiv nF q)(rdiv nF q), rdiv twoN q) fdg
                    (* oeq (add (f1p k)(sub (f2 k)(f1p k)))(f2 k) *)
        (* comm : (f1p k)+(tflo k) -> (tflo k)+(f1p k) *)
        val f1pk = add (rdiv nF q)(rdiv nF q)
        val tflok = sub (rdiv twoN q)(add (rdiv nF q)(rdiv nF q))
        val recovC = oeq_trans OF [addcomm3_at (tflok, f1pk), recov]
                     (* oeq (add (tflo k)(f1p k))(f2 k) *)
      in recovC end;
    val perTermProof =
      Thm.forall_intr (ctermV3 kBE)
        (Thm.implies_intr (ctermV3 (jT (le kBE MF))) (perTerm kBE))
        (* !!k. jT (le k M) ==> jT (oeq (add (tflo k)(f1p k))(f2 k)) *)
    val sc = sum_cong_3 (gAddAbs, f2Abs, MF) perTermProof   (* oeq (sumf gAdd M)(sumf f2 M) *)
    (* sum_add : add (sumf tflo M)(sumf f1p M) = sumf gAdd M *)
    val saddT = sum_add_3 (tfloAbs, f1pAbs, MF)   (* oeq (add (sumf tflo M)(sumf f1p M))(sumf gAdd M) *)
    (* so add (sumf tflo M)(sumf f1p M) = sumf f2 M *)
    val Ttflo = sumf tfloAbs MF; val Sf1p = sumf f1pAbs MF
    val eqA = oeq_trans OF [saddT, sc]   (* oeq (add (sumf tflo M)(sumf f1p M))(sumf f2 M) *)
    (* sum_add : add (sumf f1 M)(sumf f1 M) = sumf f1p M  (f1p i = add (f1 i)(f1 i)) *)
    val saddF1 = sum_add_3 (f1Abs, f1Abs, MF)   (* oeq (add S1 S1)(sumf f1p M) *)
    (* key2 : S2 = add (vp binom)(add S1 S1) ; rewrite (add S1 S1) -> Sf1p [saddF1] *)
    val key3 = oeq_trans OF [key2,
                 add_cong_r3 (vp pF (binom twoN nF), add S1 S1, Sf1p) saddF1]
               (* oeq (sumf f2 M)(add (vp binom) Sf1p) *)
    (* eqA : add T Sf1p = sumf f2 M = add (vp binom) Sf1p [key3] *)
    val eqB = oeq_trans OF [eqA, key3]   (* oeq (add T Sf1p)(add (vp binom) Sf1p) *)
    (* comm both -> add Sf1p T = add Sf1p (vp binom) ; left-cancel Sf1p *)
    (* comm_L : add Sf1p T = add T Sf1p ; eqB : add T Sf1p = add (vp binom) Sf1p ;
       comm_R : add (vp binom) Sf1p = add Sf1p (vp binom) *)
    val eqC = oeq_trans OF [addcomm3_at (Sf1p, Ttflo),
                oeq_trans OF [eqB, addcomm3_at (vp pF (binom twoN nF), Sf1p)]]
              (* oeq (add Sf1p T)(add Sf1p (vp binom)) *)
    val canc = add_left_cancel_3 (Sf1p, Ttflo, vp pF (binom twoN nF)) eqC  (* oeq T (vp binom) *)
    val g = oeq_sym OF [canc]   (* oeq (vp binom)(sumf tflo M) *)
    val d3 = Thm.implies_intr (ctermV3 (jT (lt (add nF nF)(pow pF (suc MF))))) g
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC nF))) d3
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("vp_binom_eq 0hyp=" ^ Bool.toString (zhV3 vp_binom_eq) ^ "\n");
val i_vp_binom_eq =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT); val MVz = Var(("M_be",0),natT)
      val iBE = Free("i_be", natT)
      val twoN = add nVz nVz
      val tfloAbs = Term.lambda iBE (sub (rdiv twoN (pow pVz (suc iBE)))(add (rdiv nVz (pow pVz (suc iBE)))(rdiv nVz (pow pVz (suc iBE)))))
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC nVz),
         Logic.mk_implies (jT (lt twoN (pow pVz (suc MVz))),
           jT (oeq (vp pVz (binom twoN nVz))(sumf tfloAbs MVz))))) end;
val r_be = (Thm.prop_of vp_binom_eq) aconv i_vp_binom_eq;
val () = out ("vp_binom_eq aconv=" ^ Bool.toString r_be ^ "\n");
val () = if zhV3 vp_binom_eq andalso r_be then out "VP_BINOM_EQ_OK\n" else out "VP_BINOM_EQ_FAIL\n";
fun vp_binom_eq_3 (pT,nT,MT) hPr hn0 hlt2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("n",0), ctermV3 nT),(("M_be",0), ctermV3 MT)] (varify vp_binom_eq))
  in ((inst OF [hPr]) OF [hn0]) OF [hlt2] end;
val () = out "F3D_BE_DONE\n";

(* ============================================================================
   (LE)  vp_le : prime2 p ==> lt 0 n ==> le (pow p (vp p (binom (add n n) n)))(add n n).
   ============================================================================ *)
val () = out "F3D_LE_BEGIN\n";

(* tflo_le1 : lt 0 q ==> le (tflo n q)(Suc 0)  [from floor01 disjunction] *)
fun tflo_le1_3 (nT, qT) hpos =
  let
    val tT = tflo nT qT     (* sub (rdiv (add n n) q)(add (rdiv n q)(rdiv n q)) *)
    val dj = floor01_3 (nT, qT) hpos    (* Disj (oeq tT 0)(oeq tT 1) *)
    val goalC = le tT (suc ZeroC)
    val caseZ =
      let val hz = Thm.assume (ctermV3 (jT (oeq tT ZeroC)))   (* tT = 0 ; le 0 1 then rewrite *)
          val le01 = le_zero3_at (suc ZeroC)                  (* le 0 (Suc 0) *)
          val g = le_cong_l3 (ZeroC, tT, suc ZeroC) (oeq_sym OF [hz]) le01  (* le tT (Suc 0) *)
      in Thm.implies_intr (ctermV3 (jT (oeq tT ZeroC))) g end;
    val caseO =
      let val ho = Thm.assume (ctermV3 (jT (oeq tT (suc ZeroC))))  (* tT = 1 ; le 1 1 then rewrite *)
          val le11 = le_refl3_at (suc ZeroC)                  (* le (Suc 0)(Suc 0) *)
          val g = le_cong_l3 (suc ZeroC, tT, suc ZeroC) (oeq_sym OF [ho]) le11  (* le tT (Suc 0) *)
      in Thm.implies_intr (ctermV3 (jT (oeq tT (suc ZeroC)))) g end;
  in disjE_3 (oeq tT ZeroC, oeq tT (suc ZeroC), goalC) dj caseZ caseO end;

val vp_le =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hn0  = Thm.assume (ctermV3 (jT (lt ZeroC nF)))
    val lt0p = prime2_pos_3 pF hPr
    val twoN = add nF nF
    (* lt 0 (2n) : le 1 n and le n (2n) -> le 1 (2n) *)
    val le_n_2n = le_add3_at (nF, nF)                  (* le n (2n) *)
    val lt0_2n  = le_trans3_at (suc ZeroC, nF, twoN) hn0 le_n_2n   (* le (Suc 0)(2n) = lt 0 (2n) *)
    (* maxpow at 2n *)
    val mpThm = (let val inst = beta_norm (Drule.infer_instantiate ctxtV3
                       [(("p",0), ctermV3 pF),(("N",0), ctermV3 twoN)] (varify maxpow))
                 in (inst OF [hPr]) OF [lt0_2n] end)   (* Ex M. Conj (le (pow p M)(2n))(lt (2n)(pow p (Suc M))) *)
    (* exGoal predicate for maxpow at 2n *)
    val Mfv = Free("M_le", natT)
    val mpAbs = Term.lambda Mfv (mkConj (le (pow pF Mfv) twoN)(lt twoN (pow pF (suc Mfv))))
    val goalC = le (pow pF (vp pF (binom twoN nF))) twoN
    (* abstraction for the tflo sum *)
    val iLE = Free("i_le", natT)
    val tfloAbs = Term.lambda iLE (sub (rdiv twoN (pow pF (suc iLE)))(add (rdiv nF (pow pF (suc iLE)))(rdiv nF (pow pF (suc iLE)))))
    val oneAbs  = Term.lambda iLE (suc ZeroC)    (* %i. Suc 0 (constant 1) *)
    fun mbody MT (hConj : thm) =     (* hConj : Conj (le (pow p M)(2n))(lt (2n)(pow p (Suc M))) *)
      let
        val hleM = conjunct1_3 (le (pow pF MT) twoN, lt twoN (pow pF (suc MT))) hConj  (* le (pow p M)(2n) *)
        val hltM = conjunct2_3 (le (pow pF MT) twoN, lt twoN (pow pF (suc MT))) hConj  (* lt (2n)(pow p (Suc M)) *)
        (* vp_binom_eq : vp(binom 2n n) = sumf tflo M *)
        val vbe = vp_binom_eq_3 (pF, nF, MT) hPr hn0 hltM   (* oeq (vp p (binom 2n n))(sumf tfloAbs M) *)
        (* ---- bound : le (sumf tfloAbs M) M ---- *)
        (* tflo top zero : tflo n (p^(Suc M)) = 0 *)
        val qM = pow pF (suc MT)
        val ltn_qM = lt_n_of_lt2n3 (nF, qM) hltM           (* lt n (p^(Suc M)) *)
        val rz2 = rdiv_zero_of_lt3 (twoN, qM) hltM          (* oeq ((2n)/p^(Suc M)) 0 *)
        val rz1 = rdiv_zero_of_lt3 (nF, qM) ltn_qM          (* oeq (n/p^(Suc M)) 0 *)
        (* tflo n qM = sub ((2n)/qM)(add (n/qM)(n/qM)) -> sub 0 (add 0 0) -> sub 0 0 -> 0 *)
        val D2M = rdiv twoN qM; val D1M = rdiv nF qM
        val st1 = sub_cong_l3 (D2M, ZeroC, add D1M D1M) rz2     (* oeq (sub D2M (D1M+D1M))(sub 0 (D1M+D1M)) *)
        val ddz = oeq_trans OF [add_cong_l3 (D1M, ZeroC, D1M) rz1,
                                oeq_trans OF [add_cong_r3 (ZeroC, D1M, ZeroC) rz1, add03_at ZeroC]]
                  (* oeq (add D1M D1M)(add 0 0) -> 0 : (D1M+D1M)=(0+D1M)=(0+0)=0 *)
        val st2 = sub_cong_r3 (ZeroC, add D1M D1M, ZeroC) ddz   (* oeq (sub 0 (D1M+D1M))(sub 0 0) *)
        val st3 = sub_self_3 ZeroC                             (* oeq (sub 0 0) 0 *)
        val tfloM0 = oeq_trans OF [st1, oeq_trans OF [st2, st3]]  (* oeq (tflo n qM) 0 *)
        (* dzos on M : M=0 or M=Suc k *)
        val dzM = dzos3_at MT          (* Disj (oeq M 0)(Ex k. oeq M (Suc k)) *)
        val boundGoal = le (sumf tfloAbs MT) MT
        val caseM0 =
          let val hM0 = Thm.assume (ctermV3 (jT (oeq MT ZeroC)))   (* M = 0 *)
              (* sumf tflo M = sumf tflo 0 [cong hM0] = tflo 0 [sumf0] ; tflo 0 = tflo M [cong sym hM0] = 0 ; le 0 0 *)
              val sfMcong = (let val zF = Free("zsfm",natT)
                                 val Pb = Term.lambda zF (oeq (sumf tfloAbs MT)(sumf tfloAbs zF))
                             in substPred3 (Pb, MT, ZeroC) hM0 (oeqrefl3_at (sumf tfloAbs MT)) end)
                            (* oeq (sumf tflo M)(sumf tflo 0) *)
              val sf0 = beta_norm (sumf0_3 tfloAbs)    (* oeq (sumf tflo 0)(tflo n (pow p (Suc 0))) *)
              (* tflo n (pow p (Suc 0)) = tflo n (pow p (Suc M)) [cong sym hM0 on M] = 0 [tfloM0] *)
              val t0_eq_tM = (let val zF = Free("ztfm",natT)
                                  val Pb = Term.lambda zF (oeq (Term.betapply (tfloAbs, ZeroC))(Term.betapply (tfloAbs, zF)))
                              in substPred3 (Pb, ZeroC, MT) (oeq_sym OF [hM0]) (oeqrefl3_at (Term.betapply (tfloAbs, ZeroC))) end)
                             (* oeq (tflo @ 0)(tflo @ M) *)
              val sfM0 = oeq_trans OF [sfMcong, oeq_trans OF [sf0, oeq_trans OF [t0_eq_tM, tfloM0]]]
                         (* oeq (sumf tflo M) 0 *)
              (* le (sumf tflo M) M : rewrite both 0 ; le 0 M ... but need le (sumf) M = le 0 0 via hM0 ; just: sumf=0, M=0 -> le 0 0 *)
              val le00 = le_zero3_at ZeroC    (* le 0 0 *)
              val gle = le_cong_l3 (ZeroC, sumf tfloAbs MT, ZeroC) (oeq_sym OF [sfM0]) le00  (* le (sumf tflo M) 0 *)
              val g = le_cong_r3 (sumf tfloAbs MT, ZeroC, MT) (oeq_sym OF [hM0]) gle   (* le (sumf tflo M) M *)
          in Thm.implies_intr (ctermV3 (jT (oeq MT ZeroC))) g end;
        val PabsK = Abs("k", natT, oeq MT (suc (Bound 0)))
        val caseMS =
          let val hex = Thm.assume (ctermV3 (jT (mkEx PabsK)))
              fun kbody kF (hk : thm) =     (* hk : oeq M (Suc k) *)
                let
                  (* sumf tflo M = sumf tflo (Suc k) [cong hk] = sumf tflo k + tflo(Suc k) [sumfSuc] *)
                  val sfMc = (let val zF = Free("zsk",natT)
                                  val Pb = Term.lambda zF (oeq (sumf tfloAbs MT)(sumf tfloAbs zF))
                              in substPred3 (Pb, MT, suc kF) hk (oeqrefl3_at (sumf tfloAbs MT)) end)
                             (* oeq (sumf tflo M)(sumf tflo (Suc k)) *)
                  val sfS = beta_norm (sumfSuc_3 (tfloAbs, kF))   (* oeq (sumf tflo (Suc k))(add (sumf tflo k)(tflo @ (Suc k))) *)
                  (* tflo @ (Suc k) = tflo @ M [cong sym hk] = 0 [tfloM0] *)
                  val tSk_M = (let val zF = Free("ztk",natT)
                                   val Pb = Term.lambda zF (oeq (Term.betapply (tfloAbs, suc kF))(Term.betapply (tfloAbs, zF)))
                               in substPred3 (Pb, suc kF, MT) (oeq_sym OF [hk]) (oeqrefl3_at (Term.betapply (tfloAbs, suc kF))) end)
                              (* oeq (tflo @ Suc k)(tflo @ M) *)
                  val tSk0 = oeq_trans OF [tSk_M, tfloM0]    (* oeq (tflo @ Suc k) 0 *)
                  (* sumf tflo (Suc k) = add (sumf tflo k)(tflo @ Suc k) = add (sumf tflo k) 0 = sumf tflo k *)
                  val sfSk = oeq_trans OF [sfS,
                               oeq_trans OF [add_cong_r3 (sumf tfloAbs kF, Term.betapply (tfloAbs, suc kF), ZeroC) tSk0,
                                             add0r3_at (sumf tfloAbs kF)]]
                             (* oeq (sumf tflo (Suc k))(sumf tflo k) *)
                  (* sumf tflo k <= sumf (%i.1) k  [sumf_le, pointwise tflo i <= 1 for i<=k] *)
                  val kk2 = Free("kk_le", natT)
                  fun ptproof kT =     (* le (tflo @ k')(Suc 0) *)
                    let val q = pow pF (suc kT)
                        val qpos = pow_pos_3 (pF, suc kT) lt0p
                    in tflo_le1_3 (nF, q) qpos end    (* le (tflo n q)(Suc 0) = le (tflo @ k')(Suc 0) *)
                  val sumfLeMeta = Thm.forall_intr (ctermV3 kk2)
                       (Thm.implies_intr (ctermV3 (jT (le kk2 kF))) (ptproof kk2))
                       (* !!k'. le k' k ==> le (tflo @ k')(1) *)
                  val sle = sumf_le_3 (tfloAbs, oneAbs, kF) sumfLeMeta   (* le (sumf tflo k)(sumf (%i.1) k) *)
                  (* sumf (%i.1) k = (Suc k)*1 = Suc k [sum_const + mult_1_right] *)
                  val sc = sum_const_3 (suc ZeroC, kF)   (* oeq (sumf (%i.1) k)(mult (Suc k)(Suc 0)) *)
                  val sc1 = oeq_trans OF [sc, mult1r3_at (suc kF)]   (* oeq (sumf (%i.1) k)(Suc k) *)
                  val le_sfk_Sk = le_cong_r3 (sumf tfloAbs kF, sumf oneAbs kF, suc kF) sc1 sle  (* le (sumf tflo k)(Suc k) *)
                  (* sumf tflo M = sumf tflo k [sfMc;sfSk] ; le (sumf tflo k)(Suc k) ; Suc k = M [sym hk] *)
                  val sfM_sfk = oeq_trans OF [sfMc, sfSk]   (* oeq (sumf tflo M)(sumf tflo k) *)
                  val le_sfM_Sk = le_cong_l3 (sumf tfloAbs kF, sumf tfloAbs MT, suc kF) (oeq_sym OF [sfM_sfk]) le_sfk_Sk
                                  (* le (sumf tflo M)(Suc k) *)
                  val g = le_cong_r3 (sumf tfloAbs MT, suc kF, MT) (oeq_sym OF [hk]) le_sfM_Sk  (* le (sumf tflo M) M *)
                in g end
              val g = exE_elim3 (PabsK, boundGoal) hex "k_le" kbody
          in Thm.implies_intr (ctermV3 (jT (mkEx PabsK))) g end;
        val boundThm = disjE_3 (oeq MT ZeroC, mkEx PabsK, boundGoal) dzM caseM0 caseMS  (* le (sumf tflo M) M *)
        (* le (vp binom) M : vbe (vp binom = sumf tflo M) + boundThm *)
        val le_vp_M = le_cong_l3 (sumf tfloAbs MT, vp pF (binom twoN nF), MT) (oeq_sym OF [vbe]) boundThm
                      (* le (vp p (binom 2n n)) M *)
        (* le (pow p (vp binom))(pow p M) [pow_le_exp] *)
        val le_pow = pow_le_exp_3 (pF, vp pF (binom twoN nF), MT) lt0p le_vp_M  (* le (pow p (vp binom))(pow p M) *)
        (* le (pow p M)(2n) = hleM ; le_trans *)
        val g = le_trans3_at (pow pF (vp pF (binom twoN nF)), pow pF MT, twoN) le_pow hleM
                (* le (pow p (vp binom))(2n) = goalC *)
      in g end;
    val concl = exE_elim3 (mpAbs, goalC) mpThm "M_le" mbody   (* le (pow p (vp binom))(2n) *)
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC nF))) concl
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("vp_le 0hyp=" ^ Bool.toString (zhV3 vp_le) ^ "\n");
val i_vp_le =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC nVz),
         jT (le (pow pVz (vp pVz (binom (add nVz nVz) nVz)))(add nVz nVz)))) end;
val r_vple = (Thm.prop_of vp_le) aconv i_vp_le;
val () = out ("vp_le aconv=" ^ Bool.toString r_vple ^ "\n");
val () = if zhV3 vp_le andalso r_vple then out "VP_LE_OK\n" else out "VP_LE_FAIL\n";
val () = out "F3D_LE_DONE\n";

(* soundness probe : vp_le must keep BOTH hypotheses (prime2 p AND lt 0 n) *)
val s_vple_cond =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in not ((Thm.prop_of vp_le) aconv
            (jT (le (pow pVz (vp pVz (binom (add nVz nVz) nVz)))(add nVz nVz)))) end;
val () = out ("PROBE vp_le-conditional=" ^ Bool.toString s_vple_cond ^ "\n");

(* axiom audit *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtV3
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
  in out ("F3D_AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM ^ "\n") end;

val f3d_bank =
  zhV3 maxpow andalso r_maxpow
  andalso zhV3 legendre_full andalso r_lf
  andalso zhV3 vp_binom_eq andalso r_be
  andalso zhV3 vp_le andalso r_vple andalso s_vple_cond;
val () = if f3d_bank then out "BERTRAND_F3D_ALL_OK\n" else out "BERTRAND_F3D_BANK_PARTIAL\n";
val () = out "F3D_FINALE_DONE\n";

(* ============================================================================
   BERTRAND F4 — the two RANGE lemmas + the prime-power FACTORIZATION of C(2n,n).
   Appended to the F3d base (final context ctxtV3 / ctermV3 / thyV3).
   ============================================================================ *)
val () = out "F4_BEGIN\n";

(* an instantiator for vp_le (banked above, schematic after varify) *)
val vp_le_v4 = varify vp_le;
fun vp_le_3 (pT, nT) hPr hn0 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("p",0), ctermV3 pT),(("n",0), ctermV3 nT)] vp_le_v4)
  in (inst OF [hPr]) OF [hn0] end;

(* numerals *)
val twoNum   = suc (suc ZeroC);
val threeNum = suc (suc (suc ZeroC));

(* ----------------------------------------------------------------------------
   (S) sqrt_split :
     prime2 p ==> lt 0 n ==> lt (add n n)(mult p p)
       ==> le (vp p (binom (add n n) n))(Suc Zero).
   p^2 > 2n  ==>  v_p(C(2n,n)) <= 1.
   ---------------------------------------------------------------------------- *)
val () = out "F4_S_BEGIN\n";

val sqrt_split =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hn0  = Thm.assume (ctermV3 (jT (lt ZeroC nF)))
    val hpp  = Thm.assume (ctermV3 (jT (lt (add nF nF)(mult pF pF))))   (* 2n < p*p *)
    val lt0p = prime2_pos_3 pF hPr
    val twoN = add nF nF
    val V    = vp pF (binom twoN nF)
    (* le (pow p V)(2n) *)
    val vple = vp_le_3 (pF, nF) hPr hn0       (* le (pow p (vp p (binom 2n n)))(2n) *)
    (* pow p 2 = mult p p :  pow p (Suc(Suc 0)) = p*(p*(pow p 0)) = p*(p*1) = p*p *)
    val pS0  = pow03_at pF                     (* oeq (pow p 0)(Suc 0) *)
    val pS1  = powSuc3_at (pF, ZeroC)          (* oeq (pow p (Suc 0))(mult p (pow p 0)) *)
    val pS1b = oeq_trans OF [pS1, oeq_trans OF [mult_cong_r3 (pF, pow pF ZeroC, suc ZeroC) pS0, mult1r3_at pF]]
               (* oeq (pow p (Suc 0)) p *)
    val pS2  = powSuc3_at (pF, suc ZeroC)      (* oeq (pow p (Suc(Suc 0)))(mult p (pow p (Suc 0))) *)
    val pow2_pp = oeq_trans OF [pS2, mult_cong_r3 (pF, pow pF (suc ZeroC), pF) pS1b]
                  (* oeq (pow p 2)(mult p p) *)
    (* lt 2n (pow p 2) : rewrite mult p p back to pow p 2 in hpp *)
    val lt2n_pow2 = le_cong_r3 (suc twoN, mult pF pF, pow pF twoNum) (oeq_sym OF [pow2_pp]) hpp
                    (* lt 2n (pow p 2) *)
    (* assume lt 1 V (= le 2 V); derive False *)
    val hltV  = Thm.assume (ctermV3 (jT (lt (suc ZeroC) V)))   (* le 2 V *)
    val le2V  = hltV                                            (* le (Suc(Suc 0)) V = le 2 V *)
    val lePow = pow_le_exp_3 (pF, twoNum, V) lt0p le2V          (* le (pow p 2)(pow p V) *)
    (* le (pow p 2)(2n) via le (pow p V)(2n) *)
    val lePow2_2n = le_trans3_at (pow pF twoNum, pow pF V, twoN) lePow vple   (* le (pow p 2)(2n) *)
    (* lt2n_pow2 : le (Suc 2n)(pow p 2) ; lePow2_2n : le (pow p 2)(2n) ;
       le (pow p 2)(2n) -> le (Suc(pow p 2))(Suc 2n)  [le_suc_mono] ;
       le (Suc 2n)(pow p 2) [lt2n_pow2] ; trans -> le (Suc(pow p 2))(pow p 2) = lt (pow p2)(pow p2) *)
    val leSuc = le_suc_mono3_at (pow pF twoNum, twoN) lePow2_2n   (* le (Suc(pow p 2))(Suc 2n) *)
    val ltpp  = le_trans3_at (suc (pow pF twoNum), suc twoN, pow pF twoNum) leSuc lt2n_pow2
                (* le (Suc(pow p 2))(pow p 2) = lt (pow p 2)(pow p 2) *)
    val ff    = (lt_irrefl3_at (pow pF twoNum)) OF [ltpp]    (* oFalse *)
    (* neg (lt 1 V) -> le V 1 :  nlt_le (d=1,c=V) : neg(lt 1 V) -> le V 1 *)
    val negMeta = Thm.implies_intr (ctermV3 (jT (lt (suc ZeroC) V))) ff
    val negLt   = impI_3 (lt (suc ZeroC) V, oFalseC) negMeta   (* jT (neg (lt 1 V)) *)
    val g       = nlt_le_3 (suc ZeroC, V) negLt               (* le V (Suc 0) *)
    val d3 = Thm.implies_intr (ctermV3 (jT (lt (add nF nF)(mult pF pF)))) g
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC nF))) d3
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("sqrt_split 0hyp=" ^ Bool.toString (zhV3 sqrt_split) ^ "\n");
val i_sqrt_split =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC nVz),
         Logic.mk_implies (jT (lt (add nVz nVz)(mult pVz pVz)),
           jT (le (vp pVz (binom (add nVz nVz) nVz))(suc ZeroC))))) end;
val r_ss = (Thm.prop_of sqrt_split) aconv i_sqrt_split;
val () = out ("sqrt_split aconv=" ^ Bool.toString r_ss ^ "\n");
val () = if zhV3 sqrt_split andalso r_ss then out "SQRT_SPLIT_OK\n" else out "SQRT_SPLIT_FAIL\n";
val () = out "F4_S_DONE\n";

(* ============================================================================
   BERTRAND F4 (E) — empty_interval.
     prime2 p ==> lt 0 n ==> le p n
       ==> lt (add n n)(mult threeNum p)     (* 2n < 3p,  i.e.  2n/3 < p *)
       ==> lt (add n n)(mult p p)            (* p^2 > 2n  (the load-bearing guard) *)
       ==> oeq (vp p (binom (add n n) n)) Zero.
   ============================================================================ *)
val () = out "F4_E_BEGIN\n";

(* ---- add monotonicity lemmas onto ctxtV3 ---- *)
val le_add_mono_v3   = varify le_add_mono;
fun le_add_mono_3 (aT,bT,cT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV3
        [(("a",0), ctermV3 aT),(("b",0), ctermV3 bT),(("c",0), ctermV3 cT)] le_add_mono_v3)) h;
val add_le_mono2_v3  = varify add_le_mono2;
fun add_le_mono2_3 (aT,bT,cT,dT) hab hcd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV3
        [(("a",0), ctermV3 aT),(("b",0), ctermV3 bT),(("c",0), ctermV3 cT),(("d",0), ctermV3 dT)] add_le_mono2_v3)
  in Thm.implies_elim (Thm.implies_elim inst hab) hcd end;
val add_left_cancel_v3 = varify add_left_cancel;
fun add_left_cancel3 (mT,aT,bT) h = (beta_norm (Drule.infer_instantiate ctxtV3
        [(("m",0), ctermV3 mT),(("a",0), ctermV3 aT),(("b",0), ctermV3 bT)] add_left_cancel_v3)) OF [h];

(* le_add_cancel_left : le (add k a)(add k b) ==> le a b.
   le (add k a)(add k b) = Ex w. oeq (add k b)(add (add k a) w).
   For witness w : add (add k a) w = add k (add a w) [assoc] ; cancel k -> oeq b (add a w) ; le_intro (a,b,w). *)
fun le_add_cancel_left_3 (kT,aT,bT) hle =
  let
    val Pabs = Abs("w", natT, oeq (add kT bT)(add (add kT aT)(Bound 0)))
    val goalC = le aT bT
    fun body wF (hw : thm) =     (* hw : oeq (add k b)(add (add k a) w) *)
      let
        val asc = addassoc3_at (kT, aT, wF)   (* oeq (add (add k a) w)(add k (add a w)) *)
        val eqA = oeq_trans OF [hw, asc]      (* oeq (add k b)(add k (add a w)) *)
        val canc = add_left_cancel3 (kT, bT, add aT wF) eqA  (* oeq b (add a w) *)
        val g = le_intro3 (aT, bT, wF) canc   (* le a b *)
      in g end
  in exE_elim3 (Pabs, goalC) hle "w_lac" body end;

(* generic exact-floor : p>0, quotient q, remainder term r, eqn hEQ : oeq N (add (mult p q) r), r<p
     ==> oeq (rdiv N p) q. *)
fun rdiv_exact_3 (NT, pT, qT, rT) hpos hEQ hrlt =
  let
    val divEq = div_mod_eq_3 (NT, pT) hpos
    val rlt   = rmod_lt_3 (NT, pT) hpos
    val hEQ2  = oeq_trans OF [oeq_sym OF [divEq], hEQ]
    val uniq  = div_mod_unique_3 (rdiv NT pT, qT, rmod NT pT, rT, pT) hEQ2 rlt hrlt
  in conjunct1_3 (oeq (rdiv NT pT) qT, oeq (rmod NT pT) rT) uniq end;

val empty_interval =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hn0  = Thm.assume (ctermV3 (jT (lt ZeroC nF)))
    val hpn  = Thm.assume (ctermV3 (jT (le pF nF)))
    val h3p  = Thm.assume (ctermV3 (jT (lt (add nF nF)(mult threeNum pF))))
    val hpp  = Thm.assume (ctermV3 (jT (lt (add nF nF)(mult pF pF))))
    val lt0p = prime2_pos_3 pF hPr
    val twoN = add nF nF
    val twoP = add pF pF

    (* ---------- pow facts ---------- *)
    val pS0  = pow03_at pF
    val pS1  = powSuc3_at (pF, ZeroC)
    val powp1 = oeq_trans OF [pS1, oeq_trans OF [mult_cong_r3 (pF, pow pF ZeroC, suc ZeroC) pS0, mult1r3_at pF]]
                (* oeq (pow p (Suc 0)) p *)
    val pS2  = powSuc3_at (pF, suc ZeroC)
    val powp2 = oeq_trans OF [pS2, mult_cong_r3 (pF, pow pF (suc ZeroC), pF) powp1]
                (* oeq (pow p (Suc(Suc 0)))(mult p p) *)

    (* ---------- mult-by-numeral expansions ---------- *)
    val m1a = multSr3_at (pF, ZeroC)       (* oeq (mult p (Suc 0))(add p (mult p 0)) *)
    val m0a = mult0r3_at pF                 (* oeq (mult p 0) 0 *)
    val multP1 = oeq_trans OF [m1a, oeq_trans OF [add_cong_r3 (pF, mult pF ZeroC, ZeroC) m0a, add0r3_at pF]]
                 (* oeq (mult p (Suc 0)) p *)
    val m2a = multSr3_at (pF, suc ZeroC)   (* oeq (mult p (Suc(Suc 0)))(add p (mult p (Suc 0))) *)
    val multP2 = oeq_trans OF [m2a, add_cong_r3 (pF, mult pF (suc ZeroC), pF) multP1]
                 (* oeq (mult p (Suc(Suc 0)))(add p p) *)
    (* mult 3 p (left form, mult_Suc) = add p (add p p) *)
    val l3a = multSuc3_at (suc (suc ZeroC), pF)   (* oeq (mult 3 p)(add p (mult 2 p)) *)
    val l2a = multSuc3_at (suc ZeroC, pF)         (* oeq (mult 2 p)(add p (mult 1 p)) *)
    val l1a = multSuc3_at (ZeroC, pF)             (* oeq (mult 1 p)(add p (mult 0 p)) *)
    val l0a = mult03_at pF
    val lmult1 = oeq_trans OF [l1a, oeq_trans OF [add_cong_r3 (pF, mult ZeroC pF, ZeroC) l0a, add0r3_at pF]]  (* mult 1 p = p *)
    val lmult2 = oeq_trans OF [l2a, add_cong_r3 (pF, mult (suc ZeroC) pF, pF) lmult1]  (* mult 2 p = add p p *)
    val mult3pE = oeq_trans OF [l3a, add_cong_r3 (pF, mult (suc (suc ZeroC)) pF, twoP) lmult2]
                  (* oeq (mult 3 p)(add p (add p p)) *)

    (* ---------- 2p <= 2n ---------- *)
    val le_2p_2n = add_le_mono2_3 (pF, nF, pF, nF) hpn hpn   (* le (add p p)(add n n) *)

    (* ---------- n < 2p ---------- *)
    val n_lt_2p =
      let
        val hAssume = Thm.assume (ctermV3 (jT (le twoP nF)))      (* 2p <= n *)
        val le4p2n  = add_le_mono2_3 (twoP, nF, twoP, nF) hAssume hAssume  (* le (2p+2p)(n+n) *)
        (* 3p <= 4p, where 3p = add p (add p p), 4p = add (add p p)(add p p) *)
        val assoc4 = addassoc3_at (pF, pF, twoP)   (* oeq (add (add p p)(add p p))(add p (add p (add p p))) *)
        val le_2p_3p_raw = le_add3_at (twoP, pF)   (* le (add p p)(add (add p p) p) *)
        val cmm = addcomm3_at (twoP, pF)           (* oeq (add (add p p) p)(add p (add p p)) *)
        val le_2p_3p = le_cong_r3 (twoP, add twoP pF, add pF twoP) cmm le_2p_3p_raw  (* le (add p p)(add p (add p p)) *)
        val lam = le_add_mono_3 (twoP, add pF twoP, pF) le_2p_3p
                  (* le (add (add p p) p)(add (add p (add p p)) p) *)
        val cL  = addcomm3_at (twoP, pF)                  (* add (add p p) p = add p (add p p) *)
        val cR  = addcomm3_at (add pF twoP, pF)           (* add (add p (add p p)) p = add p (add p (add p p)) *)
        val le3p4pA = le_cong_l3 (add twoP pF, add pF twoP, add (add pF twoP) pF) cL lam
        val le3p4pB = le_cong_r3 (add pF twoP, add (add pF twoP) pF, add pF (add pF twoP)) cR le3p4pA
                      (* le (add p (add p p))(add p (add p (add p p))) *)
        val le3p4p = le_cong_r3 (add pF twoP, add pF (add pF twoP), add twoP twoP) (oeq_sym OF [assoc4]) le3p4pB
                     (* le (add p (add p p))(add (add p p)(add p p)) *)
        val le3p2n_raw = le_trans3_at (add pF twoP, add twoP twoP, add nF nF) le3p4p le4p2n
        val le3p2n = le_cong_l3 (add pF twoP, mult threeNum pF, add nF nF) (oeq_sym OF [mult3pE]) le3p2n_raw
                     (* le (mult 3 p)(2n) *)
        val leSucWrong = le_trans3_at (suc twoN, mult threeNum pF, twoN) h3p le3p2n  (* le (Suc 2n)(2n) *)
        val ff = (lt_irrefl3_at twoN) OF [leSucWrong]
        val negMeta = Thm.implies_intr (ctermV3 (jT (le twoP nF))) ff
        val negLt   = impI_3 (le twoP nF, oFalseC) negMeta   (* neg (le (2p) n) *)
        val em = ex_middle_3 (lt nF twoP)
        val casePos = Thm.implies_intr (ctermV3 (jT (lt nF twoP))) (Thm.assume (ctermV3 (jT (lt nF twoP))))
        val caseNeg =
          let val hneg = Thm.assume (ctermV3 (jT (neg (lt nF twoP))))
              val le2pn = nlt_le_3 (nF, twoP) hneg                  (* le (2p) n *)
              val ffx = mp_3 (le twoP nF, oFalseC) negLt le2pn
              val anyg = oFalse_elim_3 (lt nF twoP) OF [ffx]
          in Thm.implies_intr (ctermV3 (jT (neg (lt nF twoP)))) anyg end
      in disjE_3 (lt nF twoP, neg (lt nF twoP), lt nF twoP) em casePos caseNeg end;
      (* n_lt_2p : lt n (add p p) *)

    (* ---------- rdiv n p = 1 ---------- *)
    (* equation : n = p*1 + (n-p) ;  p*1 = p ; p + (n-p) = n [le_add_sub] *)
    val recov_n = le_add_sub_3 (pF, nF) hpn      (* oeq (add p (sub n p)) n *)
    (* eqn : oeq n (add (mult p (Suc 0))(sub n p)) :  add (mult p 1)(n-p) = add p (n-p) = n ; sym *)
    val eqn1 = oeq_sym OF [oeq_trans OF [add_cong_l3 (mult pF (suc ZeroC), pF, sub nF pF) multP1, recov_n]]
               (* oeq n (add (mult p (Suc 0))(sub n p)) *)
    (* bound : lt (sub n p) p :  lt (add p (sub n p))(add p p) [rewrite n] -> cancel left p *)
    val sub_n_p_lt_p =
      let
        val ltrw0 = le_cong_l3 (suc nF, suc (add pF (sub nF pF)), twoP) (Suc_cong OF [oeq_sym OF [recov_n]]) n_lt_2p
                    (* le (Suc (add p (sub n p)))(add p p) *)
        val sucIn = addSr3_at (pF, sub nF pF)    (* oeq (add p (Suc (sub n p)))(Suc (add p (sub n p))) *)
        val ltrw1 = le_cong_l3 (suc (add pF (sub nF pF)), add pF (suc (sub nF pF)), twoP) (oeq_sym OF [sucIn]) ltrw0
                    (* le (add p (Suc (sub n p)))(add p p) *)
        val canc = le_add_cancel_left_3 (pF, suc (sub nF pF), pF) ltrw1   (* le (Suc (sub n p)) p = lt (sub n p) p *)
      in canc end;
    val rdivn1 = rdiv_exact_3 (nF, pF, suc ZeroC, sub nF pF) lt0p eqn1 sub_n_p_lt_p  (* oeq (rdiv n p)(Suc 0) *)

    (* ---------- rdiv 2n p = 2 ---------- *)
    val recov_2n = le_add_sub_3 (twoP, twoN) le_2p_2n   (* oeq (add (add p p)(sub 2n (add p p))) 2n *)
    (* eqn : oeq 2n (add (mult p 2)(sub 2n 2p)) :  mult p 2 = 2p [multP2] ; 2p + (2n-2p) = 2n ; sym *)
    val eqn2 = oeq_sym OF [oeq_trans OF [add_cong_l3 (mult pF (suc (suc ZeroC)), twoP, sub twoN twoP) multP2, recov_2n]]
               (* oeq 2n (add (mult p (Suc(Suc 0)))(sub 2n 2p)) *)
    (* bound : lt (sub 2n 2p) p : from lt 2n (3p) ; 3p = add (2p) p ; rewrite 2n -> add 2p (2n-2p) ; cancel 2p *)
    (* mult 3 p = add p (add p p) [mult3pE] ; need add (2p) p : (add (add p p) p) = comm? add p (add p p) = add (add p p) p? NO.
       add p (add p p) by assoc-sym = add (add p p) p?  add_assoc: (a+b)+c = a+(b+c). So (p+p)+p = p+(p+p). Yes! addassoc gives add(add p p)p = add p (add p p). So add (2p) p = add p (add p p) = mult 3 p. *)
    val threeP_assoc = addassoc3_at (pF, pF, pF)   (* oeq (add (add p p) p)(add p (add p p)) *)
    val sub_2n_2p_lt_p =
      let
        (* lt 2n (mult 3 p) ; rewrite mult 3 p -> add (2p) p :  mult3pE: mult 3 p = add p (add p p) ; sym threeP_assoc: add p (add p p) = add (2p) p *)
        val h3p_a = le_cong_r3 (suc twoN, mult threeNum pF, add pF twoP) mult3pE h3p   (* le (Suc 2n)(add p (add p p)) *)
        val h3p_b = le_cong_r3 (suc twoN, add pF twoP, add twoP pF) (oeq_sym OF [threeP_assoc]) h3p_a  (* le (Suc 2n)(add (2p) p) *)
        (* rewrite 2n -> add 2p (2n-2p) on the Suc side *)
        val ltrw0 = le_cong_l3 (suc twoN, suc (add twoP (sub twoN twoP)), add twoP pF)
                       (Suc_cong OF [oeq_sym OF [recov_2n]]) h3p_b
                    (* le (Suc (add 2p (2n-2p)))(add (2p) p) *)
        val sucIn = addSr3_at (twoP, sub twoN twoP)   (* oeq (add 2p (Suc (2n-2p)))(Suc (add 2p (2n-2p))) *)
        val ltrw1 = le_cong_l3 (suc (add twoP (sub twoN twoP)), add twoP (suc (sub twoN twoP)), add twoP pF)
                       (oeq_sym OF [sucIn]) ltrw0
                    (* le (add 2p (Suc (2n-2p)))(add (2p) p) *)
        val canc = le_add_cancel_left_3 (twoP, suc (sub twoN twoP), pF) ltrw1  (* le (Suc (2n-2p)) p = lt (2n-2p) p *)
      in canc end;
    val rdiv2n2 = rdiv_exact_3 (twoN, pF, suc (suc ZeroC), sub twoN twoP) lt0p eqn2 sub_2n_2p_lt_p
                  (* oeq (rdiv 2n p)(Suc(Suc 0)) *)

    (* ---------- tflo n p = 0 ---------- *)
    (* tflo n p = sub (rdiv 2n p)(add (rdiv n p)(rdiv n p)) ; rewrite rdiv 2n p -> 2 , rdiv n p -> 1 (both) ;
         sub 2 (1+1) = sub 2 2 = 0. *)
    val tfloP0 =
      let
        val s1 = sub_cong_l3 (rdiv twoN pF, suc (suc ZeroC), add (rdiv nF pF)(rdiv nF pF)) rdiv2n2
                 (* oeq (sub (rdiv 2n p)(add (rdiv n p)(rdiv n p)))(sub 2 (add (rdiv n p)(rdiv n p))) *)
        (* add (rdiv n p)(rdiv n p) -> add 1 1 = 2 *)
        val innL = add_cong_l3 (rdiv nF pF, suc ZeroC, rdiv nF pF) rdivn1   (* oeq (add (rdiv n p)(rdiv n p))(add 1 (rdiv n p)) *)
        val innR = add_cong_r3 (suc ZeroC, rdiv nF pF, suc ZeroC) rdivn1    (* oeq (add 1 (rdiv n p))(add 1 1) *)
        (* add 1 1 = Suc(add 0 1) = Suc 1 = 2 *)
        val a11  = oeq_trans OF [addSuc3_at (ZeroC, suc ZeroC), Suc_cong OF [add03_at (suc ZeroC)]]  (* oeq (add 1 1)(Suc(Suc 0)) *)
        val innF = oeq_trans OF [innL, oeq_trans OF [innR, a11]]   (* oeq (add (rdiv n p)(rdiv n p))(Suc(Suc 0)) *)
        val s2 = sub_cong_r3 (suc (suc ZeroC), add (rdiv nF pF)(rdiv nF pF), suc (suc ZeroC)) innF
                 (* oeq (sub 2 (add (rdiv n p)(rdiv n p)))(sub 2 2) *)
        val s3 = sub_self_3 (suc (suc ZeroC))   (* oeq (sub 2 2) 0 *)
      in oeq_trans OF [s1, oeq_trans OF [s2, s3]] end;
      (* tfloP0 : oeq (sub (rdiv 2n p)(add (rdiv n p)(rdiv n p))) 0 *)

    (* ---------- assemble : vp = sumf tflo 1 = (tflo@0)+(tflo@1) = (tflo n p)+(tflo n p^2).
         tflo@0 is over pow p (Suc 0), tflo@1 over pow p (Suc(Suc 0)).
         Rewrite divisors: pow p (Suc 0) -> p (powp1) ; pow p (Suc(Suc 0)) -> mult p p (powp2). ---------- *)
    val hlt2 = le_cong_r3 (suc twoN, mult pF pF, pow pF (suc (suc ZeroC))) (oeq_sym OF [powp2]) hpp
               (* lt 2n (pow p (Suc(Suc 0))) *)
    val vbe = vp_binom_eq_3 (pF, nF, suc ZeroC) hPr hn0 hlt2
              (* oeq (vp p (binom 2n n))(sumf tfloAbs (Suc 0)) *)
    val iE = Free("i_E", natT)
    val tfloAbs = Term.lambda iE (sub (rdiv twoN (pow pF (suc iE)))(add (rdiv nF (pow pF (suc iE)))(rdiv nF (pow pF (suc iE)))))
    val sfS  = beta_norm (sumfSuc_3 (tfloAbs, ZeroC))   (* oeq (sumf tflo (Suc 0))(add (sumf tflo 0)(tflo@(Suc 0))) *)
    val sf0  = beta_norm (sumf0_3 tfloAbs)              (* oeq (sumf tflo 0)(tflo@0) *)
    val t0   = Term.betapply (tfloAbs, ZeroC)     (* tflo @ 0 : divisor pow p (Suc 0) *)
    val t1   = Term.betapply (tfloAbs, suc ZeroC) (* tflo @ 1 : divisor pow p (Suc(Suc 0)) *)
    val sumEq = oeq_trans OF [sfS, add_cong_l3 (sumf tfloAbs ZeroC, t0, t1) sf0]
                (* oeq (sumf tflo (Suc 0))(add (tflo@0)(tflo@1)) *)

    (* t0 -> 0 : divisor pow p (Suc 0).  Rewrite pow p (Suc 0) -> p (powp1) throughout t0 to get tflo over p, then tfloP0. *)
    (* t0 = sub (rdiv 2n (pow p (Suc 0)))(add (rdiv n (pow p (Suc 0)))(rdiv n (pow p (Suc 0)))). *)
    val q1 = pow pF (suc ZeroC)
    val t0_to_p =
      let
        (* rdiv 2n (pow p (Suc 0)) -> rdiv 2n p *)
        val a = (let val zF = Free("zt0a", natT) val Pb = Term.lambda zF (oeq (rdiv twoN q1)(rdiv twoN zF))
                 in substPred3 (Pb, q1, pF) powp1 (oeqrefl3_at (rdiv twoN q1)) end)  (* oeq (rdiv 2n (pow p (Suc 0)))(rdiv 2n p) *)
        val b = (let val zF = Free("zt0b", natT) val Pb = Term.lambda zF (oeq (rdiv nF q1)(rdiv nF zF))
                 in substPred3 (Pb, q1, pF) powp1 (oeqrefl3_at (rdiv nF q1)) end)    (* oeq (rdiv n (pow p (Suc 0)))(rdiv n p) *)
        (* t0 = sub A (add B B) where A=rdiv 2n q1, B=rdiv n q1 ; rewrite to sub (rdiv 2n p)(add (rdiv n p)(rdiv n p)) *)
        val sA = sub_cong_l3 (rdiv twoN q1, rdiv twoN pF, add (rdiv nF q1)(rdiv nF q1)) a
                 (* oeq t0 (sub (rdiv 2n p)(add (rdiv n q1)(rdiv n q1))) *)
        val innB = oeq_trans OF [add_cong_l3 (rdiv nF q1, rdiv nF pF, rdiv nF q1) b,
                                 add_cong_r3 (rdiv nF pF, rdiv nF q1, rdiv nF pF) b]
                   (* oeq (add (rdiv n q1)(rdiv n q1))(add (rdiv n p)(rdiv n p)) *)
        val sB = sub_cong_r3 (rdiv twoN pF, add (rdiv nF q1)(rdiv nF q1), add (rdiv nF pF)(rdiv nF pF)) innB
      in oeq_trans OF [sA, sB] end;
      (* t0_to_p : oeq t0 (sub (rdiv 2n p)(add (rdiv n p)(rdiv n p))) *)
    val t0z = oeq_trans OF [t0_to_p, tfloP0]   (* oeq t0 0 *)

    (* t1 -> 0 : divisor pow p (Suc(Suc 0)) = q2.  2n < q2 (=hlt2) ; rdiv vanish. *)
    val q2 = pow pF (suc (suc ZeroC))
    val rd2nq2 = rdiv_zero_of_lt3 (twoN, q2) hlt2   (* oeq (rdiv 2n q2) 0 *)
    val le_n_2n = le_add3_at (nF, nF)
    val lt_n_q2 = le_trans3_at (suc nF, suc twoN, q2) (le_suc_mono3_at (nF, twoN) le_n_2n) hlt2
    val rdnq2  = rdiv_zero_of_lt3 (nF, q2) lt_n_q2  (* oeq (rdiv n q2) 0 *)
    val t1z =
      let
        val s1 = sub_cong_l3 (rdiv twoN q2, ZeroC, add (rdiv nF q2)(rdiv nF q2)) rd2nq2
        val innF = oeq_trans OF [add_cong_l3 (rdiv nF q2, ZeroC, rdiv nF q2) rdnq2,
                     oeq_trans OF [add_cong_r3 (ZeroC, rdiv nF q2, ZeroC) rdnq2, add03_at ZeroC]]
                   (* oeq (add (rdiv n q2)(rdiv n q2)) 0 *)
        val s2 = sub_cong_r3 (ZeroC, add (rdiv nF q2)(rdiv nF q2), ZeroC) innF
        val s3 = sub_self_3 ZeroC
      in oeq_trans OF [s1, oeq_trans OF [s2, s3]] end;
      (* t1z : oeq t1 0 *)

    (* sumf tflo (Suc 0) = add t0 t1 = add 0 0 = 0 ; vbe : vp = sumf ; so vp = 0 *)
    val sum0 = oeq_trans OF [sumEq,
                 oeq_trans OF [add_cong_l3 (t0, ZeroC, t1) t0z,
                   oeq_trans OF [add_cong_r3 (ZeroC, t1, ZeroC) t1z, add03_at ZeroC]]]
               (* oeq (sumf tflo (Suc 0)) 0 *)
    val g = oeq_trans OF [vbe, sum0]   (* oeq (vp p (binom 2n n)) 0 *)

    val d5 = Thm.implies_intr (ctermV3 (jT (lt (add nF nF)(mult pF pF)))) g
    val d4 = Thm.implies_intr (ctermV3 (jT (lt (add nF nF)(mult threeNum pF)))) d5
    val d3 = Thm.implies_intr (ctermV3 (jT (le pF nF))) d4
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC nF))) d3
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("empty_interval 0hyp=" ^ Bool.toString (zhV3 empty_interval) ^ "\n");
val i_empty_interval =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC nVz),
         Logic.mk_implies (jT (le pVz nVz),
           Logic.mk_implies (jT (lt (add nVz nVz)(mult threeNum pVz)),
             Logic.mk_implies (jT (lt (add nVz nVz)(mult pVz pVz)),
               jT (oeq (vp pVz (binom (add nVz nVz) nVz)) ZeroC)))))) end;
val r_ei = (Thm.prop_of empty_interval) aconv i_empty_interval;
val () = out ("empty_interval aconv=" ^ Bool.toString r_ei ^ "\n");
val () = if zhV3 empty_interval andalso r_ei then out "EMPTY_INTERVAL_OK\n" else out "EMPTY_INTERVAL_FAIL\n";
val () = out "F4_E_DONE\n";

(* ============================================================================
   vp_zero_above : prime2 p ==> lt 0 n ==> lt (add n n) p
                     ==> oeq (vp p (binom (add n n) n)) Zero.
   For a prime p > 2n : floor(2n/p)=0, floor(n/p)=0, so the only legendre term
   (i=0) is tflo n p = 0 - 0 = 0, and p^2 > 2n kills higher terms (M=0 suffices).
   Proved on ctxtV3 (uses vp_binom_eq).  Then varified onto ctxtV4.
   ============================================================================ *)
val () = out "F4_VZA_BEGIN\n";

val vp_zero_above =
  let
    val pF = Free("p", natT); val nF = Free("n", natT)
    val hPr  = Thm.assume (ctermV3 (jT (prime2 pF)))
    val hn0  = Thm.assume (ctermV3 (jT (lt ZeroC nF)))
    val hgt  = Thm.assume (ctermV3 (jT (lt (add nF nF) pF)))   (* 2n < p *)
    val lt0p = prime2_pos_3 pF hPr
    val twoN = add nF nF
    (* pow p (Suc 0) = p *)
    val pS0  = pow03_at pF
    val pS1  = powSuc3_at (pF, ZeroC)
    val powp1 = oeq_trans OF [pS1, oeq_trans OF [mult_cong_r3 (pF, pow pF ZeroC, suc ZeroC) pS0, mult1r3_at pF]]
                (* oeq (pow p (Suc 0)) p *)
    (* hyp for vp_binom_eq with M=0 : lt (2n)(pow p (Suc 0)) = lt 2n p [rewrite p -> pow p (Suc 0)] *)
    val hlt2 = le_cong_r3 (suc twoN, pF, pow pF (suc ZeroC)) (oeq_sym OF [powp1]) hgt   (* lt 2n (pow p (Suc 0)) *)
    val vbe = vp_binom_eq_3 (pF, nF, ZeroC) hPr hn0 hlt2
              (* oeq (vp p (binom 2n n))(sumf tfloAbs 0) *)
    val iV = Free("i_vza", natT)
    val tfloAbs = Term.lambda iV (sub (rdiv twoN (pow pF (suc iV)))(add (rdiv nF (pow pF (suc iV)))(rdiv nF (pow pF (suc iV)))))
    (* sumf tfloAbs 0 = tfloAbs 0 = tflo over (pow p (Suc 0)) *)
    val sf0 = beta_norm (sumf0_3 tfloAbs)   (* oeq (sumf tflo 0)(tflo @ 0) *)
    val t0  = Term.betapply (tfloAbs, ZeroC)   (* sub (rdiv 2n (pow p (Suc 0)))(add (rdiv n (pow p (Suc 0)))(rdiv n (pow p (Suc 0)))) *)
    (* rewrite divisor pow p (Suc 0) -> p, then rdiv 2n p = 0 (2n < p), rdiv n p = 0 (n <= 2n < p) *)
    val q1 = pow pF (suc ZeroC)
    (* rdiv 2n q1 -> rdiv 2n p ; rdiv n q1 -> rdiv n p *)
    val a = (let val zF = Free("zva", natT) val Pb = Term.lambda zF (oeq (rdiv twoN q1)(rdiv twoN zF))
             in substPred3 (Pb, q1, pF) powp1 (oeqrefl3_at (rdiv twoN q1)) end)   (* oeq (rdiv 2n q1)(rdiv 2n p) *)
    val b = (let val zF = Free("zvb", natT) val Pb = Term.lambda zF (oeq (rdiv nF q1)(rdiv nF zF))
             in substPred3 (Pb, q1, pF) powp1 (oeqrefl3_at (rdiv nF q1)) end)     (* oeq (rdiv n q1)(rdiv n p) *)
    val sA = sub_cong_l3 (rdiv twoN q1, rdiv twoN pF, add (rdiv nF q1)(rdiv nF q1)) a
    val innB = oeq_trans OF [add_cong_l3 (rdiv nF q1, rdiv nF pF, rdiv nF q1) b,
                             add_cong_r3 (rdiv nF pF, rdiv nF q1, rdiv nF pF) b]
    val sB = sub_cong_r3 (rdiv twoN pF, add (rdiv nF q1)(rdiv nF q1), add (rdiv nF pF)(rdiv nF pF)) innB
    val t0_to_p = oeq_trans OF [sA, sB]
                  (* oeq t0 (sub (rdiv 2n p)(add (rdiv n p)(rdiv n p))) *)
    (* rdiv 2n p = 0 (2n < p) ; rdiv n p = 0 (n < p) *)
    val rd2n = rdiv_zero_of_lt3 (twoN, pF) hgt   (* oeq (rdiv 2n p) 0 *)
    val le_n_2n = le_add3_at (nF, nF)
    val lt_n_p = le_trans3_at (suc nF, suc twoN, pF) (le_suc_mono3_at (nF, twoN) le_n_2n) hgt  (* lt n p *)
    val rdn   = rdiv_zero_of_lt3 (nF, pF) lt_n_p (* oeq (rdiv n p) 0 *)
    val tfloP0 =
      let
        val s1 = sub_cong_l3 (rdiv twoN pF, ZeroC, add (rdiv nF pF)(rdiv nF pF)) rd2n
        val innF = oeq_trans OF [add_cong_l3 (rdiv nF pF, ZeroC, rdiv nF pF) rdn,
                     oeq_trans OF [add_cong_r3 (ZeroC, rdiv nF pF, ZeroC) rdn, add03_at ZeroC]]
        val s2 = sub_cong_r3 (ZeroC, add (rdiv nF pF)(rdiv nF pF), ZeroC) innF
        val s3 = sub_self_3 ZeroC
      in oeq_trans OF [s1, oeq_trans OF [s2, s3]] end;   (* oeq (sub (rdiv 2n p)(...)) 0 *)
    val t0z = oeq_trans OF [t0_to_p, tfloP0]   (* oeq t0 0 *)
    (* vp = sumf tflo 0 = t0 = 0 *)
    val g = oeq_trans OF [vbe, oeq_trans OF [sf0, t0z]]   (* oeq (vp p (binom 2n n)) 0 *)
    val d3 = Thm.implies_intr (ctermV3 (jT (lt (add nF nF) pF))) g
    val d2 = Thm.implies_intr (ctermV3 (jT (lt ZeroC nF))) d3
    val d1 = Thm.implies_intr (ctermV3 (jT (prime2 pF))) d2
  in varify d1 end;
val () = out ("vp_zero_above 0hyp=" ^ Bool.toString (zhV3 vp_zero_above) ^ "\n");
val i_vp_zero_above =
  let val pVz = Var(("p",0),natT); val nVz = Var(("n",0),natT)
  in Logic.mk_implies (jT (prime2 pVz),
       Logic.mk_implies (jT (lt ZeroC nVz),
         Logic.mk_implies (jT (lt (add nVz nVz) pVz),
           jT (oeq (vp pVz (binom (add nVz nVz) nVz)) ZeroC)))) end;
val r_vza = (Thm.prop_of vp_zero_above) aconv i_vp_zero_above;
val () = out ("vp_zero_above aconv=" ^ Bool.toString r_vza ^ "\n");
val () = if zhV3 vp_zero_above andalso r_vza then out "VP_ZERO_ABOVE_OK\n" else out "VP_ZERO_ABOVE_FAIL\n";
val () = out "F4_VZA_DONE\n";

(* ============================================================================
   BERTRAND F4 (F) — the prime-power FACTORIZATION of C(2n,n).
   New theory thyV4 extending thyV3 with a conservative prime-power-product const
      cpf : nat => nat => nat       (cpf B m = prod_{prime p < B} p^(vp p m))
        cpf 0 m            = 1
        cpf_step_prime  : prime2 b      ==> cpf (Suc b) m = mult (cpf b m)(pow b (vp b m))
        cpf_step_nonprime: ~(prime2 b)  ==> cpf (Suc b) m = cpf b m
   Final context : ctxtV4 / ctermV4 / thyV4.
   ============================================================================ *)
val () = out "F4_F_BEGIN\n";

val thyV4_0 = Sign.add_consts
  [(Binding.name "cpf", natT --> natT --> natT, NoSyn)] thyV3;
val cpfC = Const (Sign.full_name thyV4_0 (Binding.name "cpf"), natT --> natT --> natT);
fun cpf b m = cpfC $ b $ m;
val bV4 = Free("b", natT); val mV4 = Free("m", natT);
val ((_,cpf_0_ax), thyV4_1) = Thm.add_axiom_global (Binding.name "cpf_0",
      jT (oeq (cpf ZeroC mV4)(suc ZeroC))) thyV4_0;                    (* cpf 0 m = 1 *)
val ((_,cpf_sp_ax), thyV4_2) = Thm.add_axiom_global (Binding.name "cpf_step_prime",
      Logic.mk_implies (jT (prime2 bV4),
        jT (oeq (cpf (suc bV4) mV4)(mult (cpf bV4 mV4)(pow bV4 (vp bV4 mV4)))))) thyV4_1;
val ((_,cpf_sn_ax), thyV4) = Thm.add_axiom_global (Binding.name "cpf_step_nonprime",
      Logic.mk_implies (jT (neg (prime2 bV4)),
        jT (oeq (cpf (suc bV4) mV4)(cpf bV4 mV4)))) thyV4_2;

