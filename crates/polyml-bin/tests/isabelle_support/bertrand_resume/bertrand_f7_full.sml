fun add_Suc_at4 (mt,nt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0), ctermV4 mt),(("n",0), ctermV4 nt)] add_Suc_v4);
fun allE_4 Pabs at hForall =
