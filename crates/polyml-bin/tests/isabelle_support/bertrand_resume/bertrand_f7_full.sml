(* oeq cong helpers on ctxtF *)
fun add_cong_lF (pT, qT, kT) hpq =
  let val Pabs = Abs("z", natT, oeq (add pT kT) (add (Bound 0) kT))
  in substPredF (Pabs, pT, qT) hpq (oeqreflF_at (add pT kT)) end;
fun add_cong_rF (hT, pT, qT) hpq =
  let val Pabs = Abs("z", natT, oeq (add hT pT) (add hT (Bound 0)))
  in substPredF (Pabs, pT, qT) hpq (oeqreflF_at (add hT pT)) end;
fun mult_cong_lF (pT, qT, kT) hpq =
  let val Pabs = Abs("z", natT, oeq (mult pT kT) (mult (Bound 0) kT))
  in substPredF (Pabs, pT, qT) hpq (oeqreflF_at (mult pT kT)) end;
fun mult_cong_rF (hT, pT, qT) hpq =
  let val Pabs = Abs("z", natT, oeq (mult hT pT) (mult hT (Bound 0)))
  in substPredF (Pabs, pT, qT) hpq (oeqreflF_at (mult hT pT)) end;
(* disjE / le helpers on ctxtF *)
fun disjE_elimF (At, Bt, Ct) dThm caseA caseB =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("A",0), ctermF At),(("B",0), ctermF Bt),(("C",0), ctermF Ct)] disjE_vF)
  in Thm.implies_elim (Thm.implies_elim (Thm.implies_elim inst dThm) caseA) caseB end;
fun dzosF_at t = beta_norm (Drule.infer_instantiate ctxtF [(("p",0), ctermF t)] disj_zero_or_suc_vF);
fun le_reflF_at t = beta_norm (Drule.infer_instantiate ctxtF [(("n",0), ctermF t)] le_refl_vF);
fun le_Suc_cases_atF (jT_,xT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("j",0), ctermF jT_),(("x",0), ctermF xT)] le_Suc_cases_vF)) h;

(* le on ctxtF : le uses mkEx ; we need le_zero_imp_eq + le witnesses.  Reproduce le_zero_imp_eq:
   h : le j 0 = Ex p. oeq 0 (add j p) ; exE -> p with oeq 0 (add j p) ; add_eq_zero_left -> oeq j 0. *)
val exE_vF = varify exE_ax;
val add_eq_zero_left_vF = varify add_eq_zero_left;
fun exE_elimF (Pabs, goalC) exThm wName bodyFn =
  let
    val wF = Free(wName, natT)
    val body = bodyFn wF (Thm.assume (ctermF (jT (betapply (Pabs, wF)))))
    val disch = Thm.implies_intr (ctermF (jT (betapply (Pabs, wF)))) body
    val allm = Thm.forall_intr (ctermF wF) disch
    val inst = beta_norm (Drule.infer_instantiate ctxtF
          [(("P",0), ctermF Pabs),(("Q",0), ctermF goalC)] exE_vF)
  in Thm.implies_elim (Thm.implies_elim inst exThm) allm end;
fun le_zero_imp_eqF jT_ h =
  let
    val Pabs = Abs("p", natT, oeq ZeroC (add jT_ (Bound 0)))
    fun pbody pF (hp : thm) =     (* hp : oeq 0 (add j p) *)
      let val sym = oeq_sym OF [hp]   (* oeq (add j p) 0 *)
      in add_eq_zero_left_vF OF [sym] end;
  in exE_elimF (Pabs, oeq jT_ ZeroC) h "p" pbody end;

val () = out "FACT_CTX_OK\n";
val () = out ("fact_0 0hyp=" ^ Bool.toString (zhF fact_0_vF) ^ "\n");

(* ---- more ctxtF helpers needed for binom_fact ---- *)
val exI_vF    = varify exI_ax;
val disjI1_vF = varify disjI1_ax;
val disjI2_vF = varify disjI2_ax;
val allI_vF   = varify allI_ax;
val allE_vF   = varify allE_ax;
val impI_vF   = varify impI_ax;
val mp_vF     = varify mp_ax;
fun le_introF (mT, nT, w) hyp =   (* hyp : oeq n (add m w) -> le m n *)
  let val Pabs = Abs("p", natT, oeq nT (add mT (Bound 0)))
  in beta_norm (Drule.infer_instantiate ctxtF [(("P",0), ctermF Pabs),(("a",0), ctermF w)] exI_vF) OF [hyp] end;
fun disjI1F_at (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("A",0), ctermF At),(("B",0), ctermF Bt)] disjI1_vF)) h;
fun disjI2F_at (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("A",0), ctermF At),(("B",0), ctermF Bt)] disjI2_vF)) h;
fun mkExSucF t = mkEx (Abs("q", natT, oeq t (suc (Bound 0))));
fun allI_F Pabs hAll =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF [(("P",0), ctermF Pabs)] allI_vF)
  in Thm.implies_elim inst hAll end;
fun allE_F Pabs at hForall =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF [(("P",0), ctermF Pabs),(("a",0), ctermF at)] allE_vF)
  in Thm.implies_elim inst hForall end;
fun impI_F (At, Bt) hImpThm =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF [(("A",0), ctermF At),(("B",0), ctermF Bt)] impI_vF)
  in Thm.implies_elim inst hImpThm end;
fun mp_F (At, Bt) hImp hA =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF [(("A",0), ctermF At),(("B",0), ctermF Bt)] mp_vF)
  in Thm.implies_elim (Thm.implies_elim inst hImp) hA end;

(* le_eq_or_succ_le : le k n ==> Disj (oeq k n)(le (Suc k) n)
   from le k n = Ex p. oeq n (add k p) ; case p : 0 -> k=n ; Suc q -> le (Suc k) n. *)
val le_eq_or_succ_le =
  let
    val kF = Free("k",natT); val nF = Free("n",natT);
    val hyp = jT (le kF nF);
    val H = Thm.assume (ctermF hyp);
    val goalC = mkDisj (oeq kF nF)(le (suc kF) nF);
    val Pabs = Abs("p", natT, oeq nF (add kF (Bound 0)));
    fun bodyFn pF (hp : thm) =       (* hp : oeq n (add k p) *)
      let
        val dz = dzosF_at pF;        (* Disj (oeq p 0)(Ex(q. oeq p (Suc q))) *)
        val caseA =
          let
            val hp0 = Thm.assume (ctermF (jT (oeq pF ZeroC)));
            val cong = add_cong_rF (kF, pF, ZeroC) hp0;   (* oeq (add k p)(add k 0) *)
            val a0r = add0rF_at kF;                       (* oeq (add k 0) k *)
            val akp_k = oeq_trans OF [cong, a0r];         (* oeq (add k p) k *)
            val n_k = oeq_trans OF [hp, akp_k];           (* oeq n k *)
            val k_n = oeq_sym OF [n_k];                   (* oeq k n *)
            val g = disjI1F_at (oeq kF nF, le (suc kF) nF) k_n;
          in Thm.implies_intr (ctermF (jT (oeq pF ZeroC))) g end;
        val exTerm = mkExSucF pF;
        val caseB =
          let
            val hB = jT exTerm;
            val PabsE = Abs("q", natT, oeq pF (suc (Bound 0)));
            fun qbody qF (hq : thm) =      (* hq : oeq p (Suc q) *)
              let
                val cong = add_cong_rF (kF, pF, suc qF) hq;     (* oeq (add k p)(add k (Suc q)) *)
                val aSr  = addSrF_at (kF, qF);                  (* oeq (add k (Suc q))(Suc(add k q)) *)
                val akp_S = oeq_trans OF [cong, aSr];           (* oeq (add k p)(Suc(add k q)) *)
                val n_S  = oeq_trans OF [hp, akp_S];            (* oeq n (Suc(add k q)) *)
                (* Suc(add k q) = add (Suc k) q [addSuc sym]; so n = add (Suc k) q -> le (Suc k) n *)
                val aSk  = addSucF_at (kF, qF);                 (* oeq (add (Suc k) q)(Suc(add k q)) *)
                val n_aSk= oeq_trans OF [n_S, oeq_sym OF [aSk]];(* oeq n (add (Suc k) q) *)
                val le_Sk_n = le_introF (suc kF, nF, qF) n_aSk; (* le (Suc k) n *)
                val g = disjI2F_at (oeq kF nF, le (suc kF) nF) le_Sk_n;
              in g end;
            val elimd = exE_elimF (PabsE, goalC) (Thm.assume (ctermF hB)) "q" qbody;
          in Thm.implies_intr (ctermF hB) elimd end;
        val bodyK = disjE_elimF (oeq pF ZeroC, exTerm, goalC) dz caseA caseB;
      in bodyK end;
    val concl = exE_elimF (Pabs, goalC) H "p" bodyFn;
    val d1 = Thm.implies_intr (ctermF hyp) concl;
  in varify d1 end;
val () = out ("le_eq_or_succ_le 0hyp=" ^ Bool.toString (zhF le_eq_or_succ_le) ^ "\n");
fun le_eq_or_succ_le_at (kT,nT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("k",0), ctermF kT),(("n",0), ctermF nT)] (varify le_eq_or_succ_le))) h;
val () = out "LE_EQ_OR_SUCC_OK\n";

(* ---- additional reused lemmas on ctxtF ---- *)
val le_Suc_Suc_rev_vF = varify le_Suc_Suc_rev;
fun le_Suc_Suc_rev_atF (aT,bT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("a",0), ctermF aT),(("b",0), ctermF bT)] le_Suc_Suc_rev_vF)) h;
val binom_n_Suc_n_vF = varify binom_n_Suc_n;
fun binomNSn_atF t = beta_norm (Drule.infer_instantiate ctxtF [(("n",0), ctermF t)] binom_n_Suc_n_vF);
val sub_Suc_le_vF = varify sub_Suc_le;
fun subSucLe_atF (kt,nt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("k",0), ctermF kt),(("n",0), ctermF nt)] sub_Suc_le_vF)) h;
val sub_add_l_vF = varify sub_add_l;
fun subAddL_atF (kt,jt) = beta_norm (Drule.infer_instantiate ctxtF
        [(("k",0), ctermF kt),(("j",0), ctermF jt)] sub_add_l_vF);

(* le_add_sub : le k n ==> oeq (add k (sub n k)) n
   from le k n = Ex p. oeq n (add k p) ; sub n k = sub (add k p) k = p [sub_add_l] ;
        add k (sub n k) = add k p = n. *)
val le_add_sub =
  let
    val kF = Free("k",natT); val nF = Free("n",natT);
    val hyp = jT (le kF nF);
    val H = Thm.assume (ctermF hyp);
    val goalC = oeq (add kF (sub nF kF)) nF;
    val Pabs = Abs("p", natT, oeq nF (add kF (Bound 0)));
    fun pbody pF (hp : thm) =      (* hp : oeq n (add k p) *)
      let
        (* sub n k = sub (add k p) k [cong on hp at 1st sub arg] = p [sub_add_l] *)
        val congSub = (let val zF = Free("zsub",natT)
                           val Pabs2 = Term.lambda zF (oeq (sub nF kF)(sub zF kF))
                       in substPredF (Pabs2, nF, add kF pF) hp (oeqreflF_at (sub nF kF)) end);
                      (* oeq (sub n k)(sub (add k p) k) *)
        val sal = subAddL_atF (kF, pF);    (* oeq (sub (add k p) k) p *)
        val subnk_p = oeq_trans OF [congSub, sal];   (* oeq (sub n k) p *)
        (* add k (sub n k) = add k p [cong] = n [sym hp] *)
        val congAdd = add_cong_rF (kF, sub nF kF, pF) subnk_p;   (* oeq (add k (sub n k))(add k p) *)
        val g = oeq_trans OF [congAdd, oeq_sym OF [hp]];   (* oeq (add k (sub n k)) n *)
      in g end;
    val concl = exE_elimF (Pabs, goalC) H "p" pbody;
    val d1 = Thm.implies_intr (ctermF hyp) concl;
  in varify d1 end;
val () = out ("le_add_sub 0hyp=" ^ Bool.toString (zhF le_add_sub) ^ "\n");
fun le_add_sub_atF (kT,nT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("k",0), ctermF kT),(("n",0), ctermF nT)] (varify le_add_sub))) h;

(* ============================================================================
   binom_fact : le k n ==> oeq (mult (binom n k)(mult (fact k)(fact (sub n k)))) (fact n)
     induction on n ; k object-universal.
   ============================================================================ *)
fun Bf nt kt = mult (binom nt kt)(mult (fact kt)(fact (sub nt kt)));

val binom_fact =
  let
    val kFV = Free("k", natT);
    fun obody nT kT = mkImp (le kT nT) (oeq (Bf nT kT)(fact nT));
    fun predAbs nT  = Term.lambda kFV (obody nT kFV);
    val zV = Free("z", natT);
    val Qpred = Term.lambda zV (mkForall (predAbs zV));
    val nIndV = Free("n", natT);
    val ind = nat_induct_atF (Qpred, nIndV);

    (* ---- BASE n=0 : Forall k. le k 0 ==> B 0 k = fact 0 ---- *)
    (* compute  oeq (Bf 0 0)(fact 0)  once *)
    val Bf00_f0 =
      let
        val b00 = binomN0F_at ZeroC;             (* oeq (binom 0 0) 1 *)
        val f0  = fact_0_vF;                      (* oeq (fact 0) 1 *)
        val sub00 = subN0F_at ZeroC;             (* oeq (sub 0 0) 0 *)
        val fsub = oeq_trans OF [(let val zF = Free("zfs",natT)
                                      val Pabs = Term.lambda zF (oeq (fact (sub ZeroC ZeroC))(fact zF))
                                  in substPredF (Pabs, sub ZeroC ZeroC, ZeroC) sub00 (oeqreflF_at (fact (sub ZeroC ZeroC))) end), f0];
                   (* oeq (fact (sub 0 0)) 1 *)
        val inner = oeq_trans OF [mult_cong_lF (fact ZeroC, suc ZeroC, fact (sub ZeroC ZeroC)) f0,
                                  oeq_trans OF [mult_cong_rF (suc ZeroC, fact (sub ZeroC ZeroC), suc ZeroC) fsub,
                                                mult1lF_at (suc ZeroC)]];
                   (* oeq (mult (fact 0)(fact(sub 0 0)))(Suc 0) *)
        val full = oeq_trans OF [mult_cong_lF (binom ZeroC ZeroC, suc ZeroC, mult (fact ZeroC)(fact (sub ZeroC ZeroC))) b00,
                                 oeq_trans OF [mult_cong_rF (suc ZeroC, mult (fact ZeroC)(fact (sub ZeroC ZeroC)), suc ZeroC) inner,
                                               mult1lF_at (suc ZeroC)]];
                   (* oeq (Bf 0 0)(Suc 0) *)
      in oeq_trans OF [full, oeq_sym OF [f0]] end;   (* oeq (Bf 0 0)(fact 0) *)
    val base =
      let
        val kF = Free("k", natT);
        val hLe = Thm.assume (ctermF (jT (le kF ZeroC)));
        val k0  = le_zero_imp_eqF kF hLe;        (* oeq k 0 *)
        val BfCong =
          let val zF = Free("zB",natT)
              val Pabs = Term.lambda zF (oeq (Bf ZeroC kF)(Bf ZeroC zF))
          in substPredF (Pabs, kF, ZeroC) k0 (oeqreflF_at (Bf ZeroC kF)) end;  (* oeq (Bf 0 k)(Bf 0 0) *)
        val goalEq = oeq_trans OF [BfCong, Bf00_f0];   (* oeq (Bf 0 k)(fact 0) *)
        val dis = Thm.implies_intr (ctermF (jT (le kF ZeroC))) goalEq;
        val imp = impI_F (le kF ZeroC, oeq (Bf ZeroC kF)(fact ZeroC)) dis;   (* jT (obody 0 k) *)
        val allm = Thm.forall_intr (ctermF kF) imp;   (* !!k. jT (obody 0 k) *)
      in allI_F (predAbs ZeroC) allm end;
    val () = out "BF_BASE_OK\n";

    (* ---- STEP n=Suc n' ; IH : Forall k. le k n' ==> B n' k = fact n' ---- *)
    val xF = Free("x", natT);     (* n' *)
    val ihprop = jT (mkForall (predAbs xF));
    val IH = Thm.assume (ctermF ihprop);
    (* extract IH at a term : le t x ==> oeq (Bf x t)(fact x) *)
    fun IH_at t hle =
      let val impThm = allE_F (predAbs xF) t IH    (* jT (le t x ==> oeq (Bf x t)(fact x)) *)
      in mp_F (le t xF, oeq (Bf xF t)(fact xF)) impThm hle end;
    val Sx = suc xF;
    val stepConcl =
      let
        (* prove Forall k. le k (Suc x) ==> oeq (Bf (Suc x) k)(fact (Suc x)) *)
        val kF = Free("k", natT);
        val hLeK = Thm.assume (ctermF (jT (le kF Sx)));
        (* case on k : dzos k -> oeq k 0  OR  Ex q. oeq k (Suc q) *)
        val dz = dzosF_at kF;       (* Disj (oeq k 0)(Ex(q. oeq k (Suc q))) *)
        val goalK = oeq (Bf Sx kF)(fact Sx);
        (* ===== CASE k = 0 ===== *)
        val caseK0 =
          let
            val hk0 = Thm.assume (ctermF (jT (oeq kF ZeroC)));   (* oeq k 0 *)
            (* Bf (Sx) 0 = binom (Sx) 0 * (fact 0 * fact (sub (Sx) 0))
                        = 1 * (1 * fact (Sx)) = fact (Sx) *)
            val bSx0 = binomN0F_at Sx;            (* oeq (binom (Sx) 0) 1 *)
            val f0   = fact_0_vF;                  (* oeq (fact 0) 1 *)
            val subSx0 = subN0F_at Sx;            (* oeq (sub (Sx) 0)(Sx) *)
            val fsub = (let val zF = Free("zfk0",natT)
                            val Pabs = Term.lambda zF (oeq (fact (sub Sx ZeroC))(fact zF))
                        in substPredF (Pabs, sub Sx ZeroC, Sx) subSx0 (oeqreflF_at (fact (sub Sx ZeroC))) end);
                       (* oeq (fact (sub (Sx) 0))(fact (Sx)) *)
            (* inner: fact 0 * fact(sub Sx 0) = 1 * fact(Sx) ... -> fact (Sx) *)
            val inner1 = mult_cong_lF (fact ZeroC, suc ZeroC, fact (sub Sx ZeroC)) f0;  (* oeq (mult (fact 0) X)(mult 1 X) *)
            val inner2 = mult_cong_rF (suc ZeroC, fact (sub Sx ZeroC), fact Sx) fsub;   (* oeq (mult 1 (fact(sub..)))(mult 1 (fact Sx)) *)
            val inner3 = mult1lF_at (fact Sx);     (* oeq (mult 1 (fact Sx))(fact Sx) *)
            val inner = oeq_trans OF [inner1, oeq_trans OF [inner2, inner3]];
                        (* oeq (mult (fact 0)(fact(sub (Sx) 0)))(fact (Sx)) *)
            val full1 = mult_cong_lF (binom Sx ZeroC, suc ZeroC, mult (fact ZeroC)(fact (sub Sx ZeroC))) bSx0;
                        (* oeq (mult (binom (Sx) 0) Y)(mult 1 Y) *)
            val full2 = mult_cong_rF (suc ZeroC, mult (fact ZeroC)(fact (sub Sx ZeroC)), fact Sx) inner;
                        (* oeq (mult 1 Y)(mult 1 (fact Sx)) *)
            val full3 = mult1lF_at (fact Sx);      (* oeq (mult 1 (fact Sx))(fact Sx) *)
            val Bf_Sx0 = oeq_trans OF [full1, oeq_trans OF [full2, full3]];
                         (* oeq (Bf (Sx) 0)(fact (Sx)) *)
            (* transport k -> 0 (sym) : Bf (Sx) k = Bf (Sx) 0 *)
            val congK = (let val zF = Free("zk0c",natT)
                             val Pabs = Term.lambda zF (oeq (Bf Sx kF)(Bf Sx zF))
                         in substPredF (Pabs, kF, ZeroC) hk0 (oeqreflF_at (Bf Sx kF)) end);  (* oeq (Bf Sx k)(Bf Sx 0) *)
            val g = oeq_trans OF [congK, Bf_Sx0];   (* oeq (Bf Sx k)(fact Sx) *)
          in Thm.implies_intr (ctermF (jT (oeq kF ZeroC))) g end;
        (* ===== CASE k = Suc k' ===== *)
        val exTermK = mkExSucF kF;     (* Ex(q. oeq k (Suc q)) *)
        val caseKS =
          let
            val hKS = jT exTermK;
            val PabsE = Abs("q", natT, oeq kF (suc (Bound 0)));
            fun qbody kp (hkp : thm) =     (* hkp : oeq k (Suc k') ; kp = k' *)
              let
                val Skp = suc kp;          (* Suc k' *)
                (* le (Suc k')(Suc x) : transport hLeK along hkp at proposition  %z. le z (Suc x) *)
                val hLe_SkpSx = (let val zF = Free("zlek",natT)
                                     val Plp = Term.lambda zF (le zF Sx)
                                 in substPredF (Plp, kF, Skp) hkp hLeK end);   (* jT (le (Suc k')(Suc x)) *)
                val hLe_kp_x  = le_Suc_Suc_rev_atF (kp, xF) hLe_SkpSx;          (* le k' x *)

                (* ---- the goal at k = Suc k' : oeq (Bf (Sx)(Skp))(fact (Sx)). prove it, then transport back. *)
                (* (a) sub (Sx)(Skp) = sub x k' [subSS] *)
                val subSS = subSSF_at (xF, kp);              (* oeq (sub (Sx)(Skp))(sub x k') *)
                (* (b) Pascal : binom (Sx)(Skp) = add (binom x k')(binom x (Skp)) *)
                val pasc = binomSSF_at (xF, kp);            (* oeq (binom (Sx)(Skp))(add (binom x k')(binom x (Skp))) *)
                (* (c) fact (Skp) = mult (Skp)(fact k') *)
                val fSkp = factSucF_at kp;                  (* oeq (fact (Skp))(mult (Skp)(fact k')) *)

                (* Bf (Sx)(Skp) = binom(Sx)(Skp) * (fact(Skp) * fact(sub (Sx)(Skp)))
                   rewrite fact(sub (Sx)(Skp)) -> fact(sub x k') via subSS cong. *)
                val fsubEq = (let val zF = Free("zfsub",natT)
                                  val Pabs = Term.lambda zF (oeq (fact (sub Sx Skp))(fact zF))
                              in substPredF (Pabs, sub Sx Skp, sub xF kp) subSS (oeqreflF_at (fact (sub Sx Skp))) end);
                             (* oeq (fact (sub (Sx)(Skp)))(fact (sub x k')) *)
                (* innerC : fact(Skp) * fact(sub (Sx)(Skp)) = fact(Skp) * fact(sub x k') *)
                val innerC = mult_cong_rF (fact Skp, fact (sub Sx Skp), fact (sub xF kp)) fsubEq;
                (* Bstep1 : Bf (Sx)(Skp) = binom(Sx)(Skp) * (fact(Skp) * fact(sub x k')) *)
                val Bstep1 = mult_cong_rF (binom Sx Skp, mult (fact Skp)(fact (sub Sx Skp)), mult (fact Skp)(fact (sub xF kp))) innerC;
                (* rewrite binom(Sx)(Skp) -> add(binom x k')(binom x (Skp)) [Pascal] *)
                val P = add (binom xF kp)(binom xF Skp);    (* the Pascal sum *)
                val Inn = mult (fact Skp)(fact (sub xF kp)); (* fact(Skp)*fact(x-k') *)
                val Bstep2 = mult_cong_lF (binom Sx Skp, P, Inn) pasc;   (* oeq (mult (binom..) Inn)(mult P Inn) *)
                (* rdist : mult P Inn = add (mult (binom x k') Inn)(mult (binom x (Skp)) Inn) = T1 + T2 *)
                val T1 = mult (binom xF kp) Inn;
                val T2 = mult (binom xF Skp) Inn;
                val rd = rdistF_at (binom xF kp, binom xF Skp, Inn);    (* oeq (mult P Inn)(add T1 T2) *)
                (* Bf (Sx)(Skp) = T1 + T2 *)
                val Bf_eq_T = oeq_trans OF [Bstep1, oeq_trans OF [Bstep2, rd]];   (* oeq (Bf (Sx)(Skp))(add T1 T2) *)

                (* ---- T1 = (Skp) * fact x ----
                   T1 = binom x k' * (fact(Skp) * fact(x-k')).  rewrite fact(Skp)=mult(Skp)(fact k'):
                   fact(Skp)*fact(x-k') = (Skp)*fact k' * fact(x-k') = (Skp)*(fact k' * fact(x-k')) [assoc]
                   binom x k' * [(Skp)*(fact k' * fact(x-k'))] = (Skp)*[binom x k' * (fact k' * fact(x-k'))]
                       = (Skp)*(Bf x k') = (Skp)*fact x  [IH at k'] *)
                val fkfk = mult (fact kp)(fact (sub xF kp));    (* fact k' * fact(x-k') *)
                (* Inn = fact(Skp)*fact(x-k') -> (mult (Skp)(fact k'))*fact(x-k') [fSkp cong] -> (Skp)*(fact k'*fact(x-k')) [assoc] *)
                val Inn1 = mult_cong_lF (fact Skp, mult Skp (fact kp), fact (sub xF kp)) fSkp;
                           (* oeq Inn (mult (mult (Skp)(fact k')) (fact(x-k'))) *)
                val Inn2 = multassocF_at (Skp, fact kp, fact (sub xF kp));
                           (* oeq (mult (mult (Skp)(fact k'))(fact(x-k')))(mult (Skp)(mult (fact k')(fact(x-k')))) = oeq .. (mult (Skp) fkfk) *)
                val InnEq = oeq_trans OF [Inn1, Inn2];   (* oeq Inn (mult (Skp) fkfk) *)
                (* T1 = binom x k' * Inn = binom x k' * (mult (Skp) fkfk) [cong]
                       = mult (Skp)(mult (binom x k') fkfk) [comm/assoc rearrange] *)
                val T1a = mult_cong_rF (binom xF kp, Inn, mult Skp fkfk) InnEq;   (* oeq T1 (mult (binom x k')(mult (Skp) fkfk)) *)
                (* mult (binom x k')(mult (Skp) fkfk) = mult (Skp)(mult (binom x k') fkfk) :
                   = mult (mult (binom x k') (Skp)) fkfk [assoc sym] ; comm inside ; reassoc.  Use:
                   a*(b*c) = (a*b)*c [assoc sym] = (b*a)*c [comm] = b*(a*c) [assoc].
                   a=binom x k', b=Skp, c=fkfk. *)
                val asL = oeq_sym OF [multassocF_at (binom xF kp, Skp, fkfk)];   (* oeq (mult (binom x k')(mult (Skp) fkfk))(mult (mult (binom x k')(Skp)) fkfk) *)
                val cmIn = mult_cong_lF (mult (binom xF kp) Skp, mult Skp (binom xF kp), fkfk) (multcommF_at (binom xF kp, Skp));
                           (* oeq (mult (mult (binom x k')(Skp)) fkfk)(mult (mult (Skp)(binom x k')) fkfk) *)
                val asR = multassocF_at (Skp, binom xF kp, fkfk);   (* oeq (mult (mult (Skp)(binom x k')) fkfk)(mult (Skp)(mult (binom x k') fkfk)) *)
                val T1rearr = oeq_trans OF [T1a, oeq_trans OF [asL, oeq_trans OF [cmIn, asR]]];
                              (* oeq T1 (mult (Skp)(mult (binom x k') fkfk)) ; note mult (binom x k') fkfk = Bf x k' *)
                (* mult (binom x k') fkfk IS Bf x k' (fkfk = fact k' * fact(sub x k')) -> definitionally equal *)
                val ih_kp = IH_at kp hLe_kp_x;    (* oeq (Bf x k')(fact x) *)
                val T1eq = oeq_trans OF [T1rearr, mult_cong_rF (Skp, mult (binom xF kp) fkfk, fact xF) ih_kp];
                           (* oeq T1 (mult (Skp)(fact x)) *)

                (* ---- T2 = (sub x k') * fact x ---- (case split k'=x vs le (Skp) x) *)
                val sxk = sub xF kp;    (* sub x k' *)
                val splt = le_eq_or_succ_le_at (kp, xF) hLe_kp_x;   (* Disj (oeq k' x)(le (Skp) x) *)
                val T2goal = oeq T2 (mult sxk (fact xF));
                val caseEq =
                  let
                    val heq = Thm.assume (ctermF (jT (oeq kp xF)));   (* oeq k' x *)
                    (* binom x (Skp) = binom x (Suc k').  with k'=x : binom x (Suc x) = 0 [binom_n_Suc_n]
                       rewrite Skp -> Suc x via heq, then binom x (Suc x) = 0 *)
                    val congSk = (let val zF = Free("zsk",natT)
                                      val Pabs = Term.lambda zF (oeq (binom xF (suc kp))(binom xF (suc zF)))
                                  in substPredF (Pabs, kp, xF) heq (oeqreflF_at (binom xF (suc kp))) end);
                                 (* oeq (binom x (Suc k'))(binom x (Suc x)) *)
                    val bz = binomNSn_atF xF;    (* oeq (binom x (Suc x)) 0 *)
                    val bSk0 = oeq_trans OF [congSk, bz];   (* oeq (binom x (Skp)) 0 *)
                    (* T2 = mult (binom x (Skp)) Inn = mult 0 Inn = 0 *)
                    val t2a = mult_cong_lF (binom xF Skp, ZeroC, Inn) bSk0;   (* oeq T2 (mult 0 Inn) *)
                    val t2b = mult0F_at Inn;     (* oeq (mult 0 Inn) 0 *)
                    val t2_0 = oeq_trans OF [t2a, t2b];   (* oeq T2 0 *)
                    (* sub x k' = sub x x = 0 [k'=x] ; mult 0 (fact x) = 0 ; so mult sxk (fact x) = 0 *)
                    val congSub = (let val zF = Free("zsubx",natT)
                                       val Pabs = Term.lambda zF (oeq (sub xF kp)(sub xF zF))
                                   in substPredF (Pabs, kp, xF) heq (oeqreflF_at (sub xF kp)) end);  (* oeq (sub x k')(sub x x) *)
                    (* sub x x = 0 : subAddL_atF (x,0) : sub (add x 0) x = 0 ; add x 0 = x [add0r] ;
                       rewrite LHS sub (add x 0) x -> sub x x via cong on first arg. *)
                    val sal0 = subAddL_atF (xF, ZeroC);   (* oeq (sub (add x 0) x) 0 *)
                    val ax0  = add0rF_at xF;              (* oeq (add x 0) x *)
                    val congSxx =
                      let val zF = Free("zsxx",natT)
                          val Pabs = Term.lambda zF (oeq (sub (add xF ZeroC) xF)(sub zF xF))
                      in substPredF (Pabs, add xF ZeroC, xF) ax0 (oeqreflF_at (sub (add xF ZeroC) xF)) end;
                      (* oeq (sub (add x 0) x)(sub x x) *)
                    val subxx0 = oeq_trans OF [oeq_sym OF [congSxx], sal0];   (* oeq (sub x x) 0 *)
                    val sxk_0 = oeq_trans OF [congSub, subxx0];   (* oeq (sub x k') 0 *)
                    val rhs0a = mult_cong_lF (sxk, ZeroC, fact xF) sxk_0;   (* oeq (mult sxk (fact x))(mult 0 (fact x)) *)
                    val rhs0b = mult0F_at (fact xF);   (* oeq (mult 0 (fact x)) 0 *)
                    val rhs_0 = oeq_trans OF [rhs0a, rhs0b];   (* oeq (mult sxk (fact x)) 0 *)
                    val g = oeq_trans OF [t2_0, oeq_sym OF [rhs_0]];   (* oeq T2 (mult sxk (fact x)) *)
                  in Thm.implies_intr (ctermF (jT (oeq kp xF))) g end;
                val caseLt =
                  let
                    val hlt = Thm.assume (ctermF (jT (le Skp xF)));   (* le (Suc k') x *)
                    (* sub x k' = Suc(sub x (Skp)) :
                       sub_Suc_le (k:=Skp, n:=x) @ le (Skp) x : sub (Suc x)(Skp) = Suc(sub x (Skp))
                       and sub (Suc x)(Skp) = sub x k' [subSS].  so sub x k' = Suc(sub x (Skp)). *)
                    val ssl = subSucLe_atF (Skp, xF) hlt;   (* oeq (sub (Suc x)(Skp))(Suc(sub x (Skp))) *)
                    val ssS = subSSF_at (xF, kp);           (* oeq (sub (Suc x)(Skp))(sub x k') *)
                    val sxk_eq = oeq_trans OF [oeq_sym OF [ssS], ssl];   (* oeq (sub x k')(Suc(sub x (Skp))) *)
                    (* fact(sub x k') = fact(Suc(sub x (Skp))) = mult (Suc(sub x (Skp)))(fact (sub x (Skp)))
                       and Suc(sub x (Skp)) = sub x k' [sym sxk_eq] so = mult sxk (fact(sub x (Skp))). *)
                    val factsxk = (let val zF = Free("zfx",natT)
                                       val Pabs = Term.lambda zF (oeq (fact (sub xF kp))(fact zF))
                                   in substPredF (Pabs, sub xF kp, suc (sub xF Skp)) sxk_eq (oeqreflF_at (fact (sub xF kp))) end);
                                  (* oeq (fact (sub x k'))(fact (Suc(sub x (Skp)))) *)
                    val fSucD = factSucF_at (sub xF Skp);   (* oeq (fact (Suc(sub x (Skp))))(mult (Suc(sub x (Skp)))(fact(sub x (Skp)))) *)
                    (* mult (Suc(sub x (Skp)))(...) -> mult sxk (...) via sym sxk_eq cong on 1st arg *)
                    val congM = mult_cong_lF (suc (sub xF Skp), sxk, fact (sub xF Skp)) (oeq_sym OF [sxk_eq]);
                                (* oeq (mult (Suc(sub x (Skp)))(fact(sub x (Skp))))(mult sxk (fact(sub x (Skp)))) *)
                    val factsxk2 = oeq_trans OF [factsxk, oeq_trans OF [fSucD, congM]];
                                   (* oeq (fact (sub x k'))(mult sxk (fact (sub x (Skp)))) *)
                    (* Inn = fact(Skp) * fact(sub x k') -> fact(Skp) * (mult sxk (fact(sub x (Skp)))) [cong]
                       T2 = binom x (Skp) * Inn *)
                    val fSx2 = fact (sub xF Skp);    (* fact(sub x (Skp)) *)
                    val InnD = mult_cong_rF (fact Skp, fact (sub xF kp), mult sxk fSx2) factsxk2;
                               (* oeq Inn (mult (fact Skp)(mult sxk fSx2)) *)
                    (* mult (fact Skp)(mult sxk fSx2) = mult sxk (mult (fact Skp) fSx2) [comm/assoc rearrange]
                       a*(b*c) with a=fact Skp, b=sxk, c=fSx2 -> b*(a*c) *)
                    val asL2 = oeq_sym OF [multassocF_at (fact Skp, sxk, fSx2)];   (* a*(b*c) = (a*b)*c *)
                    val cm2 = mult_cong_lF (mult (fact Skp) sxk, mult sxk (fact Skp), fSx2) (multcommF_at (fact Skp, sxk));
                              (* (a*b)*c = (b*a)*c *)
                    val asR2 = multassocF_at (sxk, fact Skp, fSx2);   (* (b*a)*c = b*(a*c) *)
                    val InnRe = oeq_trans OF [InnD, oeq_trans OF [asL2, oeq_trans OF [cm2, asR2]]];
                                (* oeq Inn (mult sxk (mult (fact Skp) fSx2)) ; note mult (fact Skp) fSx2 = Bf-inner of (x,Skp) *)
                    (* T2 = binom x (Skp) * Inn -> binom x (Skp) * (mult sxk (mult (fact Skp) fSx2)) [cong]
                          = mult sxk (binom x (Skp) * (mult (fact Skp) fSx2)) [rearrange] = mult sxk (Bf x (Skp)) *)
                    val InnBf = mult (fact Skp) fSx2;   (* = fact(Skp)*fact(sub x (Skp)) ; binom x (Skp) * InnBf = Bf x (Skp) *)
                    val t2a = mult_cong_rF (binom xF Skp, Inn, mult sxk InnBf) InnRe;   (* oeq T2 (mult (binom x (Skp))(mult sxk InnBf)) *)
                    val t2asL = oeq_sym OF [multassocF_at (binom xF Skp, sxk, InnBf)];   (* = (mult (binom x (Skp)) sxk)*InnBf *)
                    val t2cm  = mult_cong_lF (mult (binom xF Skp) sxk, mult sxk (binom xF Skp), InnBf) (multcommF_at (binom xF Skp, sxk));
                    val t2asR = multassocF_at (sxk, binom xF Skp, InnBf);   (* = mult sxk (mult (binom x (Skp)) InnBf) *)
                    val t2rearr = oeq_trans OF [t2a, oeq_trans OF [t2asL, oeq_trans OF [t2cm, t2asR]]];
                                  (* oeq T2 (mult sxk (mult (binom x (Skp)) InnBf)) ; mult (binom x (Skp)) InnBf = Bf x (Skp) *)
                    val ih_Skp = IH_at Skp hlt;    (* oeq (Bf x (Skp))(fact x) *)
                    val g = oeq_trans OF [t2rearr, mult_cong_rF (sxk, mult (binom xF Skp) InnBf, fact xF) ih_Skp];
                            (* oeq T2 (mult sxk (fact x)) *)
                  in Thm.implies_intr (ctermF (jT (le Skp xF))) g end;
                val T2eq = disjE_elimF (oeq kp xF, le Skp xF, T2goal) splt caseEq caseLt;
                           (* oeq T2 (mult sxk (fact x)) *)

                (* ---- T1 + T2 = (Skp + sxk) * fact x = (Suc x) * fact x = fact (Sx) ---- *)
                (* add T1 T2 = add (mult Skp (fact x))(mult sxk (fact x)) [cong both] *)
                val sumCong = (let val s1 = add_cong_lF (T1, mult Skp (fact xF), T2) T1eq
                                   val s2 = add_cong_rF (mult Skp (fact xF), T2, mult sxk (fact xF)) T2eq
                               in oeq_trans OF [s1, s2] end);
                              (* oeq (add T1 T2)(add (mult Skp (fact x))(mult sxk (fact x))) *)
                (* rdist sym : add (mult Skp (fact x))(mult sxk (fact x)) = mult (add Skp sxk)(fact x) *)
                val rdSym = oeq_sym OF [rdistF_at (Skp, sxk, fact xF)];   (* oeq (add (mult Skp fx)(mult sxk fx))(mult (add Skp sxk)(fact x)) *)
                (* add Skp sxk = add (Suc k')(sub x k') = Suc(add k' (sub x k')) = Suc x  [addSuc + le_add_sub] *)
                val addS = addSucF_at (kp, sxk);   (* oeq (add (Suc k')(sub x k'))(Suc(add k' (sub x k'))) *)
                val las  = le_add_sub_atF (kp, xF) hLe_kp_x;   (* oeq (add k' (sub x k')) x *)
                val addSx = oeq_trans OF [addS, Suc_cong OF [las]];   (* oeq (add (Skp) sxk)(Suc x) = oeq .. Sx *)
                (* mult (add Skp sxk)(fact x) = mult (Suc x)(fact x) [cong] = fact (Sx) [sym fact_Suc] *)
                val multSx = mult_cong_lF (add Skp sxk, Sx, fact xF) addSx;   (* oeq (mult (add Skp sxk)(fact x))(mult (Sx)(fact x)) *)
                val fSucX  = factSucF_at xF;   (* oeq (fact (Sx))(mult (Sx)(fact x)) *)
                val multSx_fact = oeq_trans OF [multSx, oeq_sym OF [fSucX]];   (* oeq (mult (add Skp sxk)(fact x))(fact (Sx)) *)
                (* chain : Bf (Sx)(Skp) = add T1 T2 = add(mult Skp fx)(mult sxk fx) = mult(add Skp sxk)(fact x) = fact (Sx) *)
                val goalSkp = oeq_trans OF [Bf_eq_T, oeq_trans OF [sumCong, oeq_trans OF [rdSym, multSx_fact]]];
                              (* oeq (Bf (Sx)(Skp))(fact (Sx)) *)
                (* transport k = Suc k' back : goalK = oeq (Bf (Sx) k)(fact (Sx)).  k = Suc k' [hkp]. *)
                val congKback = (let val zF = Free("zkb",natT)
                                     val Pabs = Term.lambda zF (oeq (Bf Sx kF)(Bf Sx zF))
                                 in substPredF (Pabs, kF, Skp) hkp (oeqreflF_at (Bf Sx kF)) end);  (* oeq (Bf Sx k)(Bf Sx (Skp)) *)
                val g = oeq_trans OF [congKback, goalSkp];   (* oeq (Bf Sx k)(fact (Sx)) *)
              in g end;
            val elimd = exE_elimF (PabsE, goalK) (Thm.assume (ctermF hKS)) "kp" qbody;
          in Thm.implies_intr (ctermF hKS) elimd end;
        val bodyK = disjE_elimF (oeq kF ZeroC, exTermK, goalK) dz caseK0 caseKS;
        val dis = Thm.implies_intr (ctermF (jT (le kF Sx))) bodyK;
        val imp = impI_F (le kF Sx, goalK) dis;
        val allm = Thm.forall_intr (ctermF kF) imp;
      in allI_F (predAbs Sx) allm end;
    val () = out "BF_STEP_BUILT\n";
    val step1 = Thm.forall_intr (ctermF xF) (Thm.implies_intr (ctermF ihprop) stepConcl);
    val r1 = Thm.implies_elim ind base;          (* Forall .. -> jT (Forall (predAbs n)) given step ; actually ind : base ==> step ==> jT (Q n) *)
    val r2 = Thm.implies_elim r1 step1;          (* jT (Forall (predAbs n)) = jT (Forall (%k. le k n ==> Bf n k = fact n)) *)
    (* meta-fy at k : allE then mp on the assumed le k n *)
    val kFV2 = Free("k", natT);
    val impAtK = allE_F (predAbs nIndV) kFV2 r2;   (* jT (le k n ==> oeq (Bf n k)(fact n)) *)
    val hLeKN  = Thm.assume (ctermF (jT (le kFV2 nIndV)));
    val applied = mp_F (le kFV2 nIndV, oeq (Bf nIndV kFV2)(fact nIndV)) impAtK hLeKN;
    val meta = Thm.implies_intr (ctermF (jT (le kFV2 nIndV))) applied;   (* le k n ==> oeq (Bf n k)(fact n) *)
  in varify meta end;
val () = out ("binom_fact 0hyp=" ^ Bool.toString (zhF binom_fact) ^ "\n");
val i_binom_fact =
  let val nV = Var(("n",0),natT); val kV = Var(("k",0),natT)
  in Logic.mk_implies (jT (le kV nV), jT (oeq (Bf nV kV)(fact nV))) end;
val r_bf = (Thm.prop_of binom_fact) aconv i_binom_fact;
val () = out ("binom_fact aconv=" ^ Bool.toString r_bf ^ "\n");
val () = if zhF binom_fact andalso r_bf then out "BINOM_FACT_OK\n" else out "BINOM_FACT_FAIL\n";
val binom_fact_vF = varify binom_fact;
fun binom_fact_at (nT,kT) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("n",0), ctermF nT),(("k",0), ctermF kT)] binom_fact_vF)) h;

(* ============================================================================
   BERTRAND F2 — STAGE (B)  PRIME-DIVIDES-FACTORIAL
     fact_dvd_fwd  : le (Suc k0) N ==> dvd (Suc k0) (fact N)     [p<=N, p>=1 ==> p | N!]
     prime_ndvd_fact : prime2 p ==> lt N p ==> (dvd p (fact N) ==> oFalse)  [N<p ==> p does not divide N!]
   ============================================================================ *)
val () = out "STAGE_B_BEGIN\n";

(* ---- re-varify dvd / euclid / prime machinery onto ctxtF ---- *)
val dvd_refl_vF        = varify dvd_refl;
val dvd_mult_right_vF  = varify dvd_mult_right;   (* dvd a b ==> dvd a (mult b c) *)
val dvd_trans_vF       = varify dvd_trans;
val euclid_lemma_vF    = varify euclid_lemma;     (* prime2 p ==> dvd p (a*b) ==> Disj (dvd p a)(dvd p b) *)
val prime_not_dvd_pos_lt_vF = varify prime_not_dvd_pos_lt;  (* dvd p r ==> lt 0 r ==> lt r p ==> oFalse *)
val conjunct1_vF       = varify conjunct1_ax;
val conjunct2_vF       = varify conjunct2_ax;
val mp_vF2             = varify mp_ax;
val allE_vF2           = varify allE_ax;

fun dvd_refl_atF t = beta_norm (Drule.infer_instantiate ctxtF [(("a",0), ctermF t)] dvd_refl_vF);
fun dvd_mult_right_atF (aT,bT,cT) h =     (* dvd a b ==> dvd a (mult b c) *)
  Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("a",0), ctermF aT),(("b",0), ctermF bT),(("c",0), ctermF cT)] dvd_mult_right_vF)) h;
fun euclid_atF (pT,aT,bT) hP hD =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("p",0), ctermF pT),(("a",0), ctermF aT),(("b",0), ctermF bT)] euclid_lemma_vF)
  in Thm.implies_elim (Thm.implies_elim inst hP) hD end;
fun prime_not_dvd_pos_lt_atF (pT,rT) hd h0 hlt =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("p",0), ctermF pT),(("r",0), ctermF rT)] prime_not_dvd_pos_lt_vF)
  in Thm.implies_elim (Thm.implies_elim (Thm.implies_elim inst hd) h0) hlt end;
fun conjunct1_atF (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("A",0), ctermF At),(("B",0), ctermF Bt)] conjunct1_vF)) h;
fun conjunct2_atF (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
        [(("A",0), ctermF At),(("B",0), ctermF Bt)] conjunct2_vF)) h;

(* prime2 destructors on ctxtF *)
fun prime2_gt1_atF p hPrime = conjunct1_atF (lt (suc ZeroC) p, mkForall (ppAbs p)) hPrime;  (* lt 1 p *)
fun prime2_div_atF (p, d) hPrime hDvdDP =     (* dvd d p -> Disj (oeq d 1)(oeq d p) *)
  let val faThm = conjunct2_atF (lt (suc ZeroC) p, mkForall (ppAbs p)) hPrime
      val impAt = allE_F (ppAbs p) d faThm        (* Imp (dvd d p)(Disj (oeq d 1)(oeq d p)) *)
  in mp_F (dvd d p, mkDisj (oeq d (suc ZeroC))(oeq d p)) impAt hDvdDP end;

(* ============================================================================
   fact_dvd_fwd : le (Suc k0) N ==> dvd (Suc k0) (fact N)
     induction on N.  p := Suc k0 (>=1).
       N=0 : le p 0 impossible (p>=1) -> anything.
       N=Sx: le p (Sx) ; cases le_eq_or_succ_le on (le p (Sx))? we have le (Suc k0)(Sx).
         le_eq_or_succ_le needs le k0 ... hmm.  Use le_Suc_cases-ish: from le p (Sx):
           oeq p (Sx)  OR  le p x.
         oeq p (Sx) : fact (Sx) = (Sx)*fact x = p * fact x [p=Sx] -> dvd p (fact (Sx)) (witness fact x).
         le p x : IH -> dvd p (fact x) ; fact (Sx) = (Sx)*fact x ; dvd p (fact x) -> dvd p (fact x * (Sx))
                  -> rewrite to dvd p ((Sx)*fact x) = dvd p (fact (Sx)).
   ============================================================================ *)
val fact_dvd_fwd =
  let
    val k0 = Free("k0", natT);
    val p  = suc k0;     (* >= 1 *)
    fun concBody nt = dvd p (fact nt);
    val zPV = Free("zP",natT);
    val Qpred = Term.lambda zPV (mkImp (le p zPV)(concBody zPV));
    val nIndV = Free("N", natT);
    val ind = nat_induct_atF (Qpred, nIndV);
    (* BASE N=0 : le p 0 impossible *)
    val base =
      let
        val h0 = Thm.assume (ctermF (jT (le p ZeroC)));
        val eqp0 = le_zero_imp_eqF p h0;          (* oeq (Suc k0) 0 *)
        val fls  = (Suc_neq_Zero_atF k0) OF [eqp0];   (* oFalse *)
        val anyG = Thm.implies_elim (oFalse_elim_atF (concBody ZeroC)) fls;
        val dis = Thm.implies_intr (ctermF (jT (le p ZeroC))) anyG;
      in impI_F (le p ZeroC, concBody ZeroC) dis end;
    (* STEP N=Sx *)
    val xF = Free("x",natT);
    val ihprop = jT (mkImp (le p xF)(concBody xF));
    val IH = Thm.assume (ctermF ihprop);
    val Sx = suc xF;
    val stepConcl =
      let
        val hSx = Thm.assume (ctermF (jT (le p Sx)));    (* le p (Sx) *)
        val cases = le_Suc_cases_atF (p, xF) hSx;         (* Disj (oeq p (Sx))(le p x) *)
        val fSucX = factSucF_at xF;     (* oeq (fact (Sx))(mult (Sx)(fact x)) *)
        (* CASE oeq p (Sx) : dvd p (fact (Sx)) : fact (Sx) = (Sx)*fact x = p*fact x [p=Sx] ; witness fact x. *)
        val caseEq =
          let
            val hpeq = Thm.assume (ctermF (jT (oeq p Sx)));   (* oeq p (Sx) *)
            (* fact (Sx) = mult (Sx)(fact x) -> mult p (fact x) [sym hpeq cong on 1st] *)
            val cong = mult_cong_lF (Sx, p, fact xF) (oeq_sym OF [hpeq]);  (* oeq (mult (Sx)(fact x))(mult p (fact x)) *)
            val fSx_pfx = oeq_trans OF [fSucX, cong];   (* oeq (fact (Sx))(mult p (fact x)) *)
            (* dvd p (mult p (fact x)) [witness fact x] : dvd p (mult p c) via dvd_mult_right (dvd p p) ... or exI directly *)
            val dvd_p_pfx =
              let val Pabs = Abs("k", natT, oeq (mult p (fact xF))(mult p (Bound 0)))
              in beta_norm (Drule.infer_instantiate ctxtF
                   [(("P",0), ctermF Pabs),(("a",0), ctermF (fact xF))] exI_vF) OF [oeqreflF_at (mult p (fact xF))] end;
              (* dvd p (mult p (fact x)) *)
            (* rewrite (mult p (fact x)) -> fact (Sx) via sym fSx_pfx : dvd p (fact (Sx)) *)
            val g = (let val zF = Free("zd",natT)
                         val Pabs = Term.lambda zF (dvd p zF)
                     in substPredF (Pabs, mult p (fact xF), fact Sx) (oeq_sym OF [fSx_pfx]) dvd_p_pfx end);
          in Thm.implies_intr (ctermF (jT (oeq p Sx))) g end;
        (* CASE le p x : IH -> dvd p (fact x) ; dvd p (mult (fact x)(Sx)) [dvd_mult_right]
             ; mult (fact x)(Sx) = mult (Sx)(fact x) = fact (Sx) [comm + sym fSucX] ; rewrite. *)
        val caseLe =
          let
            val hle = Thm.assume (ctermF (jT (le p xF)));   (* le p x *)
            val ih  = mp_F (le p xF, concBody xF) IH hle;   (* dvd p (fact x) *)
            val dmr = dvd_mult_right_atF (p, fact xF, Sx) ih;   (* dvd p (mult (fact x)(Sx)) *)
            (* mult (fact x)(Sx) = mult (Sx)(fact x) [comm] = fact (Sx) [sym fSucX] *)
            val cm  = multcommF_at (fact xF, Sx);   (* oeq (mult (fact x)(Sx))(mult (Sx)(fact x)) *)
            val eqf = oeq_trans OF [cm, oeq_sym OF [fSucX]];   (* oeq (mult (fact x)(Sx))(fact (Sx)) *)
            val g = (let val zF = Free("zd2",natT)
                         val Pabs = Term.lambda zF (dvd p zF)
                     in substPredF (Pabs, mult (fact xF) Sx, fact Sx) eqf dmr end);
          in Thm.implies_intr (ctermF (jT (le p xF))) g end;
        val concl = disjE_elimF (oeq p Sx, le p xF, concBody Sx) cases caseEq caseLe;
        val dis = Thm.implies_intr (ctermF (jT (le p Sx))) concl;
      in impI_F (le p Sx, concBody Sx) dis end;
    val step1 = Thm.forall_intr (ctermF xF) (Thm.implies_intr (ctermF ihprop) stepConcl);
    val r1 = Thm.implies_elim ind base;
    val r2 = Thm.implies_elim r1 step1;
    val hN = Thm.assume (ctermF (jT (le p nIndV)));
    val applied = mp_F (le p nIndV, concBody nIndV) r2 hN;
    val meta = Thm.implies_intr (ctermF (jT (le p nIndV))) applied;
  in varify meta end;
val () = out ("fact_dvd_fwd 0hyp=" ^ Bool.toString (zhF fact_dvd_fwd) ^ "\n");
val i_fact_dvd_fwd =
  let val kV = Var(("k0",0),natT); val NV = Var(("N",0),natT)
  in Logic.mk_implies (jT (le (suc kV) NV), jT (dvd (suc kV)(fact NV))) end;
val r_fdf = (Thm.prop_of fact_dvd_fwd) aconv i_fact_dvd_fwd;
val () = out ("fact_dvd_fwd aconv=" ^ Bool.toString r_fdf ^ "\n");
val () = if zhF fact_dvd_fwd andalso r_fdf then out "FACT_DVD_FWD_OK\n" else out "FACT_DVD_FWD_FAIL\n";

(* ---- le helpers on ctxtF for the reverse direction ---- *)
val le_trans_vF = varify le_trans;
fun le_trans_atF (mt,nt,kt) h1 h2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("m",0), ctermF mt),(("n",0), ctermF nt),(("k",0), ctermF kt)] le_trans_vF)
  in Thm.implies_elim (Thm.implies_elim inst h1) h2 end;
(* le_suc_self on ctxtF : le b (Suc b) ; witness Suc 0 : Suc b = add b (Suc 0). *)
fun le_suc_selfF_at bT =
  let val hyp = oeq_sym OF [oeq_trans OF [addSrF_at (bT, ZeroC), Suc_cong OF [add0rF_at bT]]]
                (* addSrF: add b (Suc 0) = Suc(add b 0) ; add0r: add b 0 = b ; so add b (Suc 0) = Suc b ; sym *)
  in le_introF (bT, suc bT, suc ZeroC) hyp end;
(* le 1 (Suc b) : witness b ; Suc b = add (Suc 0) b = Suc(add 0 b) = Suc b. *)
fun le_one_SucF_at bT =
  let val hyp = oeq_sym OF [oeq_trans OF [addSucF_at (ZeroC, bT), Suc_cong OF [add0F_at bT]]]
                (* add (Suc 0) b = Suc(add 0 b) ; add 0 b = b ; so = Suc b ; sym : oeq (Suc b)(add (Suc 0) b) *)
  in le_introF (suc ZeroC, suc bT, bT) hyp end;

(* prime_ndvd_fact : prime2 p ==> lt N p ==> (dvd p (fact N) ==> oFalse)
   induction on N. *)
val prime_ndvd_fact =
  let
    val pF = Free("p", natT);
    fun concBody nt = mkImp (lt nt pF)(mkImp (dvd pF (fact nt)) oFalseC);
    (* we carry prime2 p as an outer meta-hyp ; predicate over N : Imp (lt N p)(Imp (dvd p (fact N)) oFalse) *)
    val hP = Thm.assume (ctermF (jT (prime2 pF)));
    val lt1p = prime2_gt1_atF pF hP;     (* lt 1 p = le (Suc 1) p *)
    val zPV = Free("zP",natT);
    val Qpred = Term.lambda zPV (concBody zPV);
    val nIndV = Free("N", natT);
    val ind = nat_induct_atF (Qpred, nIndV);
    (* BASE N=0 : lt 0 p ==> dvd p (fact 0) ==> oFalse.  fact 0 = 1 ; dvd p 1 + lt 0 1 + lt 1 p -> oFalse. *)
    val base =
      let
        val hlt0 = Thm.assume (ctermF (jT (lt ZeroC pF)));        (* lt 0 p (unused but in scope) *)
        val hdvd = Thm.assume (ctermF (jT (dvd pF (fact ZeroC)))); (* dvd p (fact 0) *)
        val f0 = fact_0_vF;       (* oeq (fact 0) 1 *)
        (* dvd p (fact 0) -> dvd p 1 via cong *)
        val hdvd1 = (let val zF = Free("zd0",natT)
                         val Pabs = Term.lambda zF (dvd pF zF)
                     in substPredF (Pabs, fact ZeroC, suc ZeroC) f0 hdvd end);   (* dvd p 1 *)
        val lt01 = le_reflF_at (suc ZeroC);    (* lt 0 1 = le (Suc 0)(Suc 0) = refl *)
        val fls  = prime_not_dvd_pos_lt_atF (pF, suc ZeroC) hdvd1 lt01 lt1p;  (* oFalse *)
        val di = Thm.implies_intr (ctermF (jT (dvd pF (fact ZeroC)))) fls;
        val ii = impI_F (dvd pF (fact ZeroC), oFalseC) di;
        val dl = Thm.implies_intr (ctermF (jT (lt ZeroC pF))) ii;
      in impI_F (lt ZeroC pF, mkImp (dvd pF (fact ZeroC)) oFalseC) dl end;
    (* STEP N=Sx *)
    val xF = Free("x",natT);
    val ihprop = jT (concBody xF);
    val IH = Thm.assume (ctermF ihprop);
    val Sx = suc xF;
    val stepConcl =
      let
        val hltSx = Thm.assume (ctermF (jT (lt Sx pF)));          (* lt (Sx) p = le (Suc(Sx)) p *)
        val hdvd  = Thm.assume (ctermF (jT (dvd pF (fact Sx))));   (* dvd p (fact (Sx)) *)
        val fSucX = factSucF_at xF;     (* oeq (fact (Sx))(mult (Sx)(fact x)) *)
        (* dvd p (mult (Sx)(fact x)) via cong *)
        val hdvdM = (let val zF = Free("zds",natT)
                         val Pabs = Term.lambda zF (dvd pF zF)
                     in substPredF (Pabs, fact Sx, mult Sx (fact xF)) fSucX hdvd end);  (* dvd p (mult (Sx)(fact x)) *)
        val eu = euclid_atF (pF, Sx, fact xF) hP hdvdM;   (* Disj (dvd p (Sx))(dvd p (fact x)) *)
        (* CASE dvd p (Sx) : prime_not_dvd_pos_lt (p, Sx) : dvd p (Sx) -> lt 0 (Sx) -> lt (Sx) p -> oFalse.
           lt 0 (Sx) = le 1 (Sx) ; lt (Sx) p = hltSx. *)
        val caseA =
          let
            val hda = Thm.assume (ctermF (jT (dvd pF Sx)));   (* dvd p (Sx) *)
            val lt0Sx = le_one_SucF_at xF;     (* le 1 (Sx) = lt 0 (Sx) *)
            val fls = prime_not_dvd_pos_lt_atF (pF, Sx) hda lt0Sx hltSx;   (* oFalse *)
          in Thm.implies_intr (ctermF (jT (dvd pF Sx))) fls end;
        (* CASE dvd p (fact x) : IH at x needs lt x p ; from lt (Sx) p = le (Suc(Sx)) p :
             le (Suc x) p via le_trans (le (Suc x)(Suc(Sx))) (le (Suc(Sx)) p).
             le (Suc x)(Suc(Sx)) = le (Suc x)(Suc(Suc x)) = le_suc_self (Suc x). *)
        val caseB =
          let
            val hdb = Thm.assume (ctermF (jT (dvd pF (fact xF))));   (* dvd p (fact x) *)
            (* lt x p = le (Suc x) p *)
            val le_Sx_SSx = le_suc_selfF_at Sx;   (* le (Suc x)(Suc(Suc x)) = le (Suc x)(Suc(Sx)) *)
            val ltxp = le_trans_atF (suc xF, suc Sx, pF) le_Sx_SSx hltSx;   (* le (Suc x) p = lt x p *)
            (* IH : Imp (lt x p)(Imp (dvd p (fact x)) oFalse) *)
            val ih1 = mp_F (lt xF pF, mkImp (dvd pF (fact xF)) oFalseC) IH ltxp;   (* Imp (dvd p (fact x)) oFalse *)
            val fls = mp_F (dvd pF (fact xF), oFalseC) ih1 hdb;   (* oFalse *)
          in Thm.implies_intr (ctermF (jT (dvd pF (fact xF)))) fls end;
        val fls = disjE_elimF (dvd pF Sx, dvd pF (fact xF), oFalseC) eu caseA caseB;  (* oFalse *)
        val di = Thm.implies_intr (ctermF (jT (dvd pF (fact Sx)))) fls;
        val ii = impI_F (dvd pF (fact Sx), oFalseC) di;
        val dl = Thm.implies_intr (ctermF (jT (lt Sx pF))) ii;
      in impI_F (lt Sx pF, mkImp (dvd pF (fact Sx)) oFalseC) dl end;
    val step1 = Thm.forall_intr (ctermF xF) (Thm.implies_intr (ctermF ihprop) stepConcl);
    val r1 = Thm.implies_elim ind base;
    val r2 = Thm.implies_elim r1 step1;     (* jT (concBody N) = Imp (lt N p)(Imp (dvd p (fact N)) oFalse) *)
    (* meta-fy : lt N p ==> dvd p (fact N) ==> oFalse, under prime2 p *)
    val hltN = Thm.assume (ctermF (jT (lt nIndV pF)));
    val s1 = mp_F (lt nIndV pF, mkImp (dvd pF (fact nIndV)) oFalseC) r2 hltN;   (* Imp (dvd p (fact N)) oFalse *)
    val hdvdN = Thm.assume (ctermF (jT (dvd pF (fact nIndV))));
    val s2 = mp_F (dvd pF (fact nIndV), oFalseC) s1 hdvdN;   (* oFalse *)
    val d1 = Thm.implies_intr (ctermF (jT (dvd pF (fact nIndV)))) s2;
    val d2 = Thm.implies_intr (ctermF (jT (lt nIndV pF))) d1;
    val d3 = Thm.implies_intr (ctermF (jT (prime2 pF))) d2;
  in varify d3 end;
val () = out ("prime_ndvd_fact 0hyp=" ^ Bool.toString (zhF prime_ndvd_fact) ^ "\n");
val i_prime_ndvd_fact =
  let val pV = Var(("p",0),natT); val NV = Var(("N",0),natT)
  in Logic.mk_implies (jT (prime2 pV),
       Logic.mk_implies (jT (lt NV pV),
         Logic.mk_implies (jT (dvd pV (fact NV)), jT oFalseC))) end;
val r_pndf = (Thm.prop_of prime_ndvd_fact) aconv i_prime_ndvd_fact;
val () = out ("prime_ndvd_fact aconv=" ^ Bool.toString r_pndf ^ "\n");
val () = if zhF prime_ndvd_fact andalso r_pndf then out "PRIME_NDVD_FACT_OK\n" else out "PRIME_NDVD_FACT_FAIL\n";
val () = if zhF fact_dvd_fwd andalso r_fdf andalso zhF prime_ndvd_fact andalso r_pndf
         then out "PRIME_FACT_OK\n" else out "PRIME_FACT_PARTIAL\n";

(* ============================================================================
   BERTRAND F2 — STAGE (C)  MIDDLE-BINOM DIVISIBILITY
     mid_dvd : prime2 p ==> lt (Suc m) p ==> le p (add (add m m)(Suc 0)) ==>
               dvd p (binom (add (add m m)(Suc 0)) m)        [ p | C(2m+1, m) ]
   via binom_fact at (2m+1, m) + fact_dvd_fwd (p<=2m+1) + euclid (twice) +
       prime_ndvd_fact on fact m and fact (m+1).
   ============================================================================ *)
val () = out "STAGE_C_BEGIN\n";

val sub_Suc_add_l_vF = varify sub_Suc_add_l;
fun subSucAddL_atF (kt,pt) = beta_norm (Drule.infer_instantiate ctxtF
        [(("k",0), ctermF kt),(("p",0), ctermF pt)] sub_Suc_add_l_vF);
val fact_dvd_fwd_vF = varify fact_dvd_fwd;
val prime_ndvd_fact_vF = varify prime_ndvd_fact;
fun prime_ndvd_fact_atF (pT,NT) hP hlt hdvd =
  let val inst = beta_norm (Drule.infer_instantiate ctxtF
        [(("p",0), ctermF pT),(("N",0), ctermF NT)] prime_ndvd_fact_vF)
  in Thm.implies_elim (Thm.implies_elim (Thm.implies_elim inst hP) hlt) hdvd end;

val mid_dvd =
  let
    val pF = Free("p", natT); val mF = Free("m", natT);
    val mm = add mF mF;                            (* 2m *)
    val Mform = add mm (suc ZeroC);              (* 2m+1 stated form *)
    val M = suc mm;                              (* 2m+1 = Suc(2m) *)
    val hP   = Thm.assume (ctermF (jT (prime2 pF)));
    val hLt  = Thm.assume (ctermF (jT (lt (suc mF) pF)));   (* m+1 < p *)
    val hLeP = Thm.assume (ctermF (jT (le pF Mform)));       (* p <= 2m+1 (stated form) *)

    (* ---- convert Mform <-> M ---- *)
    val MformM = oeq_trans OF [addSrF_at (mm, ZeroC), Suc_cong OF [add0rF_at mm]];   (* oeq Mform M *)
    (* le p M from le p Mform via cong *)
    val hLeP_M = (let val zF = Free("zlp",natT)
                      val Pabs = Term.lambda zF (le pF zF)
                  in substPredF (Pabs, Mform, M) MformM hLeP end);   (* le p M *)

    (* ---- p = Suc p0  (from prime2 p : lt 1 p) ---- *)
    val lt1p = prime2_gt1_atF pF hP;     (* lt 1 p = le (Suc 1) p *)
    (* dzos p -> p=0 or Ex p0. p=0 contradicts le 2 p. *)
    val dzp = dzosF_at pF;
    (* We'll obtain p=Suc p0 and the divisibility goal via exE on the Suc-case;
       the 0-case is impossible. Goal = dvd p (binom Mform m). *)
    val goalC = dvd pF (binom Mform mF);

    (* ---- core proof, GIVEN p = Suc p0 : derive dvd p (binom Mform m). ---- *)
    fun core p0 (hp0 : thm) =     (* hp0 : oeq p (Suc p0) *)
      let
        (* le (Suc p0) M : from le p M rewrite p -> Suc p0 *)
        val hLe_Sp0_M = (let val zF = Free("zsp",natT)
                             val Pabs = Term.lambda zF (le zF M)
                         in substPredF (Pabs, pF, suc p0) hp0 hLeP_M end);   (* le (Suc p0) M *)
        (* fact_dvd_fwd (k0:=p0, N:=M) : dvd (Suc p0)(fact M) *)
        val dvd_p_factM_raw = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
              [(("k0",0), ctermF p0),(("N",0), ctermF M)] fact_dvd_fwd_vF)) hLe_Sp0_M;
              (* dvd (Suc p0)(fact M) *)
        (* rewrite Suc p0 -> p via sym hp0 *)
        val dvd_p_factM = (let val zF = Free("zdp",natT)
                               val Pabs = Term.lambda zF (dvd zF (fact M))
                           in substPredF (Pabs, suc p0, pF) (oeq_sym OF [hp0]) dvd_p_factM_raw end);
                          (* dvd p (fact M) *)

        (* ---- binom_fact at (n:=M, k:=m) needs le m M ---- *)
        (* le m (add m m) via le_introF witness m : oeq (add m m)(add m m) refl. *)
        val le_m_mm2 = le_introF (mF, mm, mF) (oeqreflF_at mm);   (* le m (add m m) *)
        val le_mm_M  = le_suc_selfF_at mm;                        (* le (add m m) M *)
        val le_m_M   = le_trans_atF (mF, mm, M) le_m_mm2 le_mm_M; (* le m M *)
        val bf = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtF
              [(("n",0), ctermF M),(("k",0), ctermF mF)] binom_fact_vF)) le_m_M;
              (* oeq (mult (binom M m)(mult (fact m)(fact (sub M m))))(fact M) *)
        (* sub M m = Suc m  [sub_Suc_add_l (m,m)] : sub (Suc(add m m)) m = Suc m *)
        val subEq = subSucAddL_atF (mF, mF);   (* oeq (sub M m)(Suc m) *)
        (* rewrite fact (sub M m) -> fact (Suc m) *)
        val factSubEq = (let val zF = Free("zfsm",natT)
                             val Pabs = Term.lambda zF (oeq (fact (sub M mF))(fact zF))
                         in substPredF (Pabs, sub M mF, suc mF) subEq (oeqreflF_at (fact (sub M mF))) end);
                        (* oeq (fact (sub M m))(fact (Suc m)) *)
        val innerEq = mult_cong_rF (fact mF, fact (sub M mF), fact (suc mF)) factSubEq;
                      (* oeq (mult (fact m)(fact(sub M m)))(mult (fact m)(fact (Suc m))) *)
        val bfCong = mult_cong_rF (binom M mF, mult (fact mF)(fact (sub M mF)), mult (fact mF)(fact (suc mF))) innerEq;
                     (* oeq (mult (binom M m)(mult(fact m)(fact(sub M m))))(mult (binom M m)(mult (fact m)(fact (Suc m)))) *)
        val bf2 = oeq_trans OF [oeq_sym OF [bfCong], bf];
                  (* oeq (mult (binom M m)(mult (fact m)(fact (Suc m))))(fact M) *)

        (* dvd p (mult (binom M m)(mult (fact m)(fact (Suc m)))) : rewrite dvd_p_factM RHS -> LHS via sym bf2 *)
        val dvd_p_prod = (let val zF = Free("zdpp",natT)
                              val Pabs = Term.lambda zF (dvd pF zF)
                          in substPredF (Pabs, fact M, mult (binom M mF)(mult (fact mF)(fact (suc mF)))) (oeq_sym OF [bf2]) dvd_p_factM end);
                         (* dvd p (mult (binom M m)(mult (fact m)(fact (Suc m)))) *)

        (* euclid (p, binom M m, (fact m * fact(Suc m))) : Disj (dvd p (binom M m))(dvd p (fact m * fact(Suc m))) *)
        val Inn = mult (fact mF)(fact (suc mF));
        val eu1 = euclid_atF (pF, binom M mF, Inn) hP dvd_p_prod;   (* Disj (dvd p (binom M m))(dvd p Inn) *)
        (* CASE dvd p (binom M m) : that's the goal (modulo M -> Mform) *)
        val caseA1 =
          let
            val hd = Thm.assume (ctermF (jT (dvd pF (binom M mF))));   (* dvd p (binom M m) *)
            (* rewrite binom M m -> binom Mform m via sym MformM (cong on 1st binom arg) *)
            val congBM = (let val zF = Free("zbm",natT)
                              val Pabs = Term.lambda zF (oeq (binom M mF)(binom zF mF))
                          in substPredF (Pabs, M, Mform) (oeq_sym OF [MformM]) (oeqreflF_at (binom M mF)) end);
                         (* oeq (binom M m)(binom Mform m) *)
            val g = (let val zF = Free("zdm",natT)
                         val Pabs = Term.lambda zF (dvd pF zF)
                     in substPredF (Pabs, binom M mF, binom Mform mF) congBM hd end);  (* dvd p (binom Mform m) *)
          in Thm.implies_intr (ctermF (jT (dvd pF (binom M mF)))) g end;
        (* CASE dvd p Inn : euclid again -> dvd p (fact m) or dvd p (fact (Suc m)) ; both contradict prime_ndvd_fact. *)
        val caseB1 =
          let
            val hd = Thm.assume (ctermF (jT (dvd pF Inn)));   (* dvd p (mult (fact m)(fact (Suc m))) *)
            val eu2 = euclid_atF (pF, fact mF, fact (suc mF)) hP hd;   (* Disj (dvd p (fact m))(dvd p (fact (Suc m))) *)
            (* lt m p : from lt (Suc m) p = le (Suc(Suc m)) p ; le (Suc m)(Suc(Suc m)) [le_suc_self] trans -> le (Suc m) p = lt m p *)
            val le_Sm_SSm = le_suc_selfF_at (suc mF);   (* le (Suc m)(Suc(Suc m)) *)
            val ltmp = le_trans_atF (suc mF, suc (suc mF), pF) le_Sm_SSm hLt;   (* le (Suc m) p = lt m p *)
            (* lt (Suc m) p = hLt *)
            val caseFm =
              let val hf = Thm.assume (ctermF (jT (dvd pF (fact mF))));   (* dvd p (fact m) *)
                  val fls = prime_ndvd_fact_atF (pF, mF) hP ltmp hf       (* oFalse *)
                  val g = Thm.implies_elim (oFalse_elim_atF (dvd pF (binom Mform mF))) fls
              in Thm.implies_intr (ctermF (jT (dvd pF (fact mF)))) g end;
            val caseFsm =
              let val hf = Thm.assume (ctermF (jT (dvd pF (fact (suc mF)))));   (* dvd p (fact (Suc m)) *)
                  val fls = prime_ndvd_fact_atF (pF, suc mF) hP hLt hf      (* oFalse *)
                  val g = Thm.implies_elim (oFalse_elim_atF (dvd pF (binom Mform mF))) fls
              in Thm.implies_intr (ctermF (jT (dvd pF (fact (suc mF))))) g end;
            val g = disjE_elimF (dvd pF (fact mF), dvd pF (fact (suc mF)), dvd pF (binom Mform mF)) eu2 caseFm caseFsm;
          in Thm.implies_intr (ctermF (jT (dvd pF Inn))) g end;
        val g = disjE_elimF (dvd pF (binom M mF), dvd pF Inn, dvd pF (binom Mform mF)) eu1 caseA1 caseB1;
      in g end;   (* dvd p (binom Mform m) *)

    (* ---- extract p = Suc p0 ---- *)
    val caseP0 =
      let
        val hp0 = Thm.assume (ctermF (jT (oeq pF ZeroC)));   (* oeq p 0 *)
        (* lt1p : le (Suc(Suc 0)) p ; with p=0 -> le (Suc(Suc 0)) 0 -> oeq (Suc(Suc 0)) 0 -> oFalse *)
        val lt1p0 = (let val zF = Free("zlp0",natT)
                         val Pabs = Term.lambda zF (le (suc (suc ZeroC)) zF)
                     in substPredF (Pabs, pF, ZeroC) hp0 lt1p end);   (* le (Suc(Suc 0)) 0 *)
        val eqz = le_zero_imp_eqF (suc (suc ZeroC)) lt1p0;   (* oeq (Suc(Suc 0)) 0 *)
        val fls = (Suc_neq_Zero_atF (suc ZeroC)) OF [eqz];   (* oFalse *)
        val g = Thm.implies_elim (oFalse_elim_atF (dvd pF (binom Mform mF))) fls;
      in Thm.implies_intr (ctermF (jT (oeq pF ZeroC))) g end;
    val casePS =
      let
        val exT = mkExSucF pF;   (* Ex(q. oeq p (Suc q)) *)
        val PabsE = Abs("q", natT, oeq pF (suc (Bound 0)));
        fun qb p0 (hp0 : thm) = core p0 hp0;   (* hp0 : oeq p (Suc p0) *)
        val elimd = exE_elimF (PabsE, goalC) (Thm.assume (ctermF (jT exT))) "p0" qb;
      in Thm.implies_intr (ctermF (jT exT)) elimd end;
    val body = disjE_elimF (oeq pF ZeroC, mkExSucF pF, goalC) dzp caseP0 casePS;
    val d1 = Thm.implies_intr (ctermF (jT (le pF Mform))) body;
    val d2 = Thm.implies_intr (ctermF (jT (lt (suc mF) pF))) d1;
    val d3 = Thm.implies_intr (ctermF (jT (prime2 pF))) d2;
  in varify d3 end;
val () = out ("mid_dvd 0hyp=" ^ Bool.toString (zhF mid_dvd) ^ "\n");
val i_mid_dvd =
  let val pV = Var(("p",0),natT); val mV = Var(("m",0),natT)
  in Logic.mk_implies (jT (prime2 pV),
       Logic.mk_implies (jT (lt (suc mV) pV),
         Logic.mk_implies (jT (le pV (add (add mV mV)(suc ZeroC))),
           jT (dvd pV (binom (add (add mV mV)(suc ZeroC)) mV))))) end;
val r_mid = (Thm.prop_of mid_dvd) aconv i_mid_dvd;
val () = out ("mid_dvd aconv=" ^ Bool.toString r_mid ^ "\n");
val () = if zhF mid_dvd andalso r_mid then out "MID_DVD_OK\n" else out "MID_DVD_FAIL\n";

(* ============================================================================
   BERTRAND F2 — STAGE (E)  PRIMORIAL PRIMITIVE
   Add a NEW const  primorial : nat => nat  (conservative recursion), extending
   thyF -> thyPr.  Re-init ONE final context ctxtPr/ctermPr and re-varify the
   reused lemmas.  Bank the primitive (def axioms + basic computation).
     primorial_0          : primorial 0 = 1
     primorial_Suc_prime  : prime2 (Suc n) ==> primorial (Suc n) = mult (Suc n)(primorial n)
     primorial_Suc_nonprime: ~(prime2 (Suc n)) ==> primorial (Suc n) = primorial n
   ============================================================================ *)
val () = out "STAGE_E_BEGIN\n";

(* ---- primorial const + conservative recursion axioms ---- *)
val thyPr0 = Sign.add_consts
  [(Binding.name "primorial", natT --> natT, NoSyn)] thyF;
val primorialC = Const (Sign.full_name thyPr0 (Binding.name "primorial"), natT --> natT);
fun primorial t = primorialC $ t;
val nPr = Free("n", natT);
val ((_,primorial_0_ax), thyPr1) = Thm.add_axiom_global (Binding.name "primorial_0",
      jT (oeq (primorial ZeroC) (suc ZeroC))) thyPr0;                 (* primorial 0 = 1 *)
val ((_,primorial_Suc_prime_ax), thyPr2) = Thm.add_axiom_global (Binding.name "primorial_Suc_prime",
      Logic.mk_implies (jT (prime2 (suc nPr)),
        jT (oeq (primorial (suc nPr)) (mult (suc nPr) (primorial nPr))))) thyPr1;
val ((_,primorial_Suc_nonprime_ax), thyPr) = Thm.add_axiom_global (Binding.name "primorial_Suc_nonprime",
      Logic.mk_implies (jT (mkImp (prime2 (suc nPr)) oFalseC),
        jT (oeq (primorial (suc nPr)) (primorial nPr)))) thyPr2;

(* ---- THE ONE FINAL CONTEXT ctxtPr / ctermPr ---- *)
val ctxtPr  = Proof_Context.init_global thyPr;
val ctermPr = Thm.cterm_of ctxtPr;
fun zhPr th = (length (Thm.hyps_of th) = 0) andalso (null (Thm.extra_shyps th));

val primorial_0_vPr           = varify primorial_0_ax;
val primorial_Suc_prime_vPr   = varify primorial_Suc_prime_ax;
val primorial_Suc_nonprime_vPr= varify primorial_Suc_nonprime_ax;

(* basic soundness/0-hyp: the def axioms are 0-hyp (they are axioms, schematic after varify) *)
val () = out ("primorial_0 0hyp=" ^ Bool.toString (zhPr primorial_0_vPr) ^ "\n");

(* ground applicators *)
fun primorial_Suc_prime_atPr nt h =
  Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtPr
        [(("n",0), ctermPr nt)] primorial_Suc_prime_vPr)) h;
fun primorial_Suc_nonprime_atPr nt h =
  Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtPr
        [(("n",0), ctermPr nt)] primorial_Suc_nonprime_vPr)) h;

(* soundness probe : the recursion axioms must be conditional (not the unconditional eqs).
   primorial_Suc_prime must NOT be aconv the prime-free unconditional version. *)
val i_psp_bad =
  let val nV = Var(("n",0),natT)
  in jT (oeq (primorial (suc nV)) (mult (suc nV)(primorial nV))) end;
val psp_needs_prime = not ((Thm.prop_of primorial_Suc_prime_vPr) aconv i_psp_bad);
val () = out ("primorial_Suc_prime-needs-prime=" ^ Bool.toString psp_needs_prime ^ "\n");

val () = if zhPr primorial_0_vPr andalso psp_needs_prime
         then out "PRIMORIAL_DEF_OK\n" else out "PRIMORIAL_DEF_FAIL\n";

(* ============================================================================
   BERTRAND F2 — FINALE : banked-lemma gate + soundness audit
   Banked toward the PRIMORIAL BOUND prod_{p<=n} p <= 4^n :
     (A) binom_fact         : le k n ==> binom n k * (fact k * fact(n-k)) = fact n
     (B) fact_dvd_fwd       : le (Suc k0) N ==> dvd (Suc k0)(fact N)
         prime_ndvd_fact    : prime2 p ==> lt N p ==> dvd p (fact N) ==> oFalse
     (C) mid_dvd            : prime2 p ==> Suc m < p ==> p <= 2m+1 ==> p | C(2m+1, m)
     (D) odd_mid_bound      : C(2m+1, m) <= 4^m
     (E) primorial primitive: const + conservative recursion (primorial_0/Suc_prime/Suc_nonprime)
   OPEN (the hard remainder): the coprime upper-range product divides C(2m+1,m),
   and the final strong induction (primorial_bound).
   ============================================================================ *)
val () = out "F2_FINALE_BEGIN\n";

(* soundness probes : the kernel must REJECT false variants *)
val s_omb_reject =
  let val mV = Var(("m",0),natT)
  in not ((Thm.prop_of odd_mid_bound) aconv
       (jT (le (binom (add (add mV mV)(suc ZeroC)) mV)(pow (suc (suc (suc ZeroC))) mV)))) end;  (* 3^m *)
val s_mid_needs_prime =
  let val pV = Var(("p",0),natT); val mV = Var(("m",0),natT)
  in not ((Thm.prop_of mid_dvd) aconv
       (Logic.mk_implies (jT (lt (suc mV) pV),
          Logic.mk_implies (jT (le pV (add (add mV mV)(suc ZeroC))),
            jT (dvd pV (binom (add (add mV mV)(suc ZeroC)) mV)))))) end;  (* drops prime2 p *)
val () = out ("PROBE odd_mid-rejects-3=" ^ Bool.toString s_omb_reject
            ^ " mid_dvd-needs-prime=" ^ Bool.toString s_mid_needs_prime ^ "\n");

val allF2 =
  zhF binom_fact andalso r_bf
  andalso zhF fact_dvd_fwd andalso r_fdf
  andalso zhF prime_ndvd_fact andalso r_pndf
  andalso zhF mid_dvd andalso r_mid
  andalso zh1 odd_mid_bound andalso r_omb
  andalso zhPr primorial_0_vPr andalso psp_needs_prime
  andalso s_omb_reject andalso s_mid_needs_prime;

(* axiom audit : the only classical axiom should be ex_middle ; report the count and
   the NEW conservative const axioms (fact and primorial families) introduced by F2. *)
val () =
  let
    val thy = Proof_Context.theory_of ctxtPr
    val axs = Theory.all_axioms_of thy
    val names = map fst axs
    val hasEM = List.exists (fn s => String.isSubstring "ex_middle" s
                                     orelse String.isSubstring "excluded" s) names
    val nFact = length (List.filter (fn s => String.isSubstring "fact" s) names)
    val nPrim = length (List.filter (fn s => String.isSubstring "primorial" s) names)
  in out ("AXIOM_AUDIT total=" ^ Int.toString (length names)
          ^ " ex_middle_present=" ^ Bool.toString hasEM
          ^ " fact_axioms=" ^ Int.toString nFact
          ^ " primorial_axioms=" ^ Int.toString nPrim ^ "\n") end;

val () = if allF2 then out "BERTRAND_F2_ALL_OK\n" else out "BERTRAND_F2_PARTIAL\n";
val () = out "F2_FINALE_DONE\n";

(* ============================================================================
   ============================================================================
   BERTRAND F2b — CLOSE THE PRIMORIAL BOUND   primorial n <= 4^n
   ----------------------------------------------------------------------------
   On the ONE FINAL CONTEXT ctxtPr / ctermPr / thyPr (the F2 base).  Re-port the
   needed lemmas onto ctxtPr, prove:
     (G1) prime_prod_dvd : prime2 p ==> dvd p N ==> ~(dvd p U) ==> dvd U N
                              ==> dvd (mult p U) N
     (G2) upper_prod      : the upper-range product U_k divides C(2m+1,m), with
                              primorial k = mult (primorial (Suc m)) U_k, by gap
                              induction; conclude primorial_split.
     (H)  primorial_bound : le (primorial n)(pow 4 n)   [strong induction]
   ============================================================================ *)
val () = out "F2B_SCAFFOLD_BEGIN\n";

(* ----------------------------------------------------------------------------
   Re-varify EVERY reused axiom/lemma onto ctxtPr (schematic; thyPr extends all).
   ---------------------------------------------------------------------------- *)
val oeq_refl_vPr      = varify oeq_refl;
val oeq_subst_vPr     = varify oeq_subst;
val nat_induct_vPr    = varify nat_induct;
val add_0_vPr         = varify add_0;
val add_Suc_vPr       = varify add_Suc;
val add_0_right_vPr   = varify add_0_right;
val add_Suc_right_vPr = varify add_Suc_right;
val add_comm_vPr      = varify add_comm;
val add_assoc_vPr     = varify add_assoc;
val mult_0_vPr        = varify mult_0;
val mult_Suc_vPr      = varify mult_Suc;
val mult_0_right_vPr  = varify mult_0_right;
val mult_Suc_right_vPr= varify mult_Suc_right;
val mult_comm_vPr     = varify mult_comm;
val mult_assoc_vPr    = varify mult_assoc;
val mult_1_left_vPr   = varify mult_1_left;
val mult_1_right_vPr  = varify mult_1_right;
val left_distrib_vPr  = varify left_distrib;
val right_distrib_vPr = varify right_distrib;
val exI_vPr           = varify exI_ax;
val exE_vPr           = varify exE_ax;
val disjI1_vPr        = varify disjI1_ax;
val disjI2_vPr        = varify disjI2_ax;
val disjE_vPr         = varify disjE_ax;
val conjI_vPr         = varify conjI_ax;
val conjunct1_vPr     = varify conjunct1_ax;
val conjunct2_vPr     = varify conjunct2_ax;
val impI_vPr          = varify impI_ax;
val mp_vPr            = varify mp_ax;
val allI_vPr          = varify allI_ax;
val allE_vPr          = varify allE_ax;
val ex_middle_vPr     = varify ex_middle_ax;
val oFalse_elim_vPr   = varify oFalse_elim_ax;
val le_refl_vPr       = varify le_refl;
val le_trans_vPr      = varify le_trans;
val le_antisym_vPr    = varify le_antisym;
val le_add_vPr        = varify le_add;
val le_total_vPr      = varify le_total;
val Suc_neq_Zero_vPr  = varify Suc_neq_Zero_ax;
val Suc_inj_vPr       = varify Suc_inj_ax;
val disj_zero_or_suc_vPr = varify disj_zero_or_suc;
(* dvd preorder *)
val dvd_refl_vPr      = varify dvd_refl;
val dvd_trans_vPr     = varify dvd_trans;
val dvd_add_vPr       = varify dvd_add;
val dvd_mult_right_vPr = varify dvd_mult_right;
val dvd_le_vPr        = varify dvd_le;
val dvd_zero_vPr      = varify dvd_zero;
(* euclid + prime helpers *)
val euclid_lemma_vPr  = varify euclid_lemma;
val prime_not_dvd_pos_lt_vPr = varify prime_not_dvd_pos_lt;
(* pow *)
val pow_Zero_vPr      = varify pow_Zero_ax;
val pow_Suc_vPr       = varify pow_Suc_ax;
val pow_add_vPr       = varify pow_add;
(* div_mod *)
val div_mod_exists_vPr = varify div_mod_exists;
(* F2 toplevel lemmas *)
val mid_dvd_vPr       = varify mid_dvd;
val odd_mid_bound_vPr = varify odd_mid_bound;
val binom_fact_vPr    = varify binom_fact;
(* strong induction *)
val strong_induct_vPr = varify strong_induct;

(* ---- ground instantiators on ctxtPr (mirror the ctxtF/ctxtS2 patterns) ---- *)
fun oeqreflPr_at t      = beta_norm (Drule.infer_instantiate ctxtPr [(("a",0), ctermPr t)] oeq_refl_vPr);
fun substPredPr (Pabs, aT, bT) hab hPa =
  let val inst = beta_norm (Drule.infer_instantiate ctxtPr
        [(("P",0), ctermPr Pabs), (("a",0), ctermPr aT), (("b",0), ctermPr bT)] oeq_subst_vPr)
  in inst OF [hab, hPa] end;
val oeq_sym_Pr = oeq_sym;     (* schematic, context-agnostic *)
val oeq_trans_Pr = oeq_trans;
fun add0Pr_at t         = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] add_0_vPr);
fun addSucPr_at (mt,nt) = beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt)] add_Suc_vPr);
fun add0rPr_at t        = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] add_0_right_vPr);
fun addSrPr_at (mt,nt)  = beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt)] add_Suc_right_vPr);
fun addcommPr_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt)] add_comm_vPr);
fun addassocPr_at (mt,nt,kt)= beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt),(("k",0), ctermPr kt)] add_assoc_vPr);
fun mult0Pr_at t        = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] mult_0_vPr);
fun multSucPr_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt)] mult_Suc_vPr);
fun mult0rPr_at t       = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] mult_0_right_vPr);
fun multSrPr_at (nt,mt) = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr nt),(("m",0), ctermPr mt)] mult_Suc_right_vPr);
fun multcommPr_at (mt,nt)= beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt)] mult_comm_vPr);
fun multassocPr_at (mt,nt,kt)= beta_norm (Drule.infer_instantiate ctxtPr [(("m",0), ctermPr mt),(("n",0), ctermPr nt),(("k",0), ctermPr kt)] mult_assoc_vPr);
fun mult1lPr_at t       = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] mult_1_left_vPr);
fun mult1rPr_at t       = beta_norm (Drule.infer_instantiate ctxtPr [(("n",0), ctermPr t)] mult_1_right_vPr);

(* oeq congruences on ctxtPr *)
fun add_cong_lPr (pT, qT, kT) hpq =
  let val Pabs = Abs("z", natT, oeq (add pT kT) (add (Bound 0) kT))
  in substPredPr (Pabs, pT, qT) hpq (oeqreflPr_at (add pT kT)) end;
fun add_cong_rPr (hT, pT, qT) hpq =
  let val Pabs = Abs("z", natT, oeq (add hT pT) (add hT (Bound 0)))
