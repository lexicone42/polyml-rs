val mult_Suc_right_v4_   = varify mult_Suc_right;

(* at-helpers *)
fun le_total_4 (mt,nt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0),ctermV4 mt),(("n",0),ctermV4 nt)] le_total_v4);
fun lt_trans_4 (at,bt,ct) h1 h2 =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("a",0),ctermV4 at),(("b",0),ctermV4 bt),(("c",0),ctermV4 ct)] lt_trans_v4)
