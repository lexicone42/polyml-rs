(* ============================================================================
   BERTRAND F5 — delta 3 : the LOWER-BOUND product lemma.
     cpf_pow_bound : lt 0 n ==> le (cpf B (binom 2n n)) (pow (add n n) B).
   Each factor in cpf is either a prime power p^(vp p R) <= 2n [vp_le], or 1
   (nonprime) <= 2n.  Product of B such factors <= (2n)^B.  nat_induct on B.
   ============================================================================ *)
val () = out "F5_D3_BEGIN\n";

(* le 1 (add n n) from lt 0 (add n n) : same term (lt 0 x = le (Suc 0) x = le 1 x) *)
(* hn0 : lt 0 n .  We derive lt 0 (2n) internally. *)
fun cpf_pow_bound (BT, nT) hn0 =
  let
    val twoN = add nT nT
    val R    = binom twoN nT
    (* lt 0 (2n) : 0 < n <= n+n.  le 1 n [hn0] ; le n (n+n) [le_add] ; le_trans -> le 1 (2n) = lt 0 (2n) *)
    val le_n_2n = le_add4_at (nT, nT)            (* le n (add n n) *)
    val h2N0 = le_trans4_at (suc ZeroC, nT, twoN) hn0 le_n_2n  (* le 1 (2n) = lt 0 (2n) *)
    (* predicate over B : le (cpf B R)(pow (2n) B) *)
    val zB = Free("z_lb", natT)
    val Pabs = Term.lambda zB (le (cpf zB R)(pow twoN zB))
    val ind = nat_induct_4 (Pabs, BT)
    (* base B=0 : cpf 0 R = 1 ; pow 2n 0 = 1 ; le 1 1 *)
    val base =
      let val c0 = cpf0_at R              (* oeq (cpf 0 R) 1 *)
          val p0 = pow04_at twoN          (* oeq (pow 2n 0) 1 *)
          val le11 = le_refl4_at (suc ZeroC)
          val l1 = le_cong_l4 (suc ZeroC, cpf ZeroC R, suc ZeroC) (oeq_sym OF [c0]) le11  (* le (cpf 0 R) 1 *)
          val l2 = le_cong_r4 (cpf ZeroC R, suc ZeroC, pow twoN ZeroC) (oeq_sym OF [p0]) l1
      in l2 end
    val xF = Free("x_lb", natT)
    val ihP = jT (le (cpf xF R)(pow twoN xF))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = le (cpf (suc xF) R)(pow twoN (suc xF))
    (* pow 2n (Suc x) = 2n * pow 2n x *)
    val pSx = powSuc4_at (twoN, xF)        (* oeq (pow 2n (Suc x))(mult 2n (pow 2n x)) *)
    val em = ex_middle_4 (prime2 xF)
    (* CASE prime2 x : cpf (Suc x) R = (cpf x R)*(pow x (vp x R)) ;
       (cpf x R) <= 2n^x [IH] ; (pow x (vp x R)) <= 2n [vp_le] ;
       product <= 2n^x * 2n = mult (pow 2n x) 2n.  We want <= mult 2n (pow 2n x) = pow 2n (Suc x). *)
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 xF)))
          val L = cpf_sp_at (xF, R) hpr    (* oeq (cpf (Suc x) R)(mult (cpf x R)(pow x (vp x R))) *)
          val hvple = vp_le_4 (xF, nT) hpr hn0   (* le (pow x (vp x R)) 2n *)
          (* mult_le_mono2 : le (cpf x R)(pow 2n x), le (pow x (vp x R)) 2n
             -> le (mult (cpf x R)(pow x (vp x R)))(mult (pow 2n x) 2n) *)
          val mlm = mult_le_mono2_4_at (cpf xF R, pow twoN xF, pow xF (vp xF R), twoN) IH hvple
                    (* le (mult (cpf x R)(pow x (vp x R)))(mult (pow 2n x) 2n) *)
          (* rewrite LHS via L (sym) : le (cpf (Suc x) R)(mult (pow 2n x) 2n) *)
          val s1 = le_cong_l4 (mult (cpf xF R)(pow xF (vp xF R)), cpf (suc xF) R, mult (pow twoN xF) twoN) (oeq_sym OF [L]) mlm
          (* mult (pow 2n x) 2n = mult 2n (pow 2n x) [comm] = pow 2n (Suc x) [pSx sym] *)
          val cmm = multcomm4_at (pow twoN xF, twoN)   (* oeq (mult (pow 2n x) 2n)(mult 2n (pow 2n x)) *)
          val s2 = le_cong_r4 (cpf (suc xF) R, mult (pow twoN xF) twoN, mult twoN (pow twoN xF)) cmm s1
          val s3 = le_cong_r4 (cpf (suc xF) R, mult twoN (pow twoN xF), pow twoN (suc xF)) (oeq_sym OF [pSx]) s2
      in Thm.implies_intr (ctermV4 (jT (prime2 xF))) s3 end
    (* CASE ~prime2 x : cpf (Suc x) R = cpf x R <= 2n^x <= 2n^(Suc x) *)
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 xF))))
          val L = cpf_sn_at (xF, R) hnp    (* oeq (cpf (Suc x) R)(cpf x R) *)
          (* le (pow 2n x)(pow 2n (Suc x)) : pow_le_exp needs lt 0 2n, le x (Suc x) *)
          val le_x_Sx = le_self_suc_4 xF
          val plle = pow_le_exp_4 (twoN, xF, suc xF) h2N0 le_x_Sx   (* le (pow 2n x)(pow 2n (Suc x)) *)
          val cle  = le_trans4_at (cpf xF R, pow twoN xF, pow twoN (suc xF)) IH plle  (* le (cpf x R)(pow 2n (Suc x)) *)
          val s1 = le_cong_l4 (cpf xF R, cpf (suc xF) R, pow twoN (suc xF)) (oeq_sym OF [L]) cle
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 xF)))) s1 end
    val stepC = disjE_4 (prime2 xF, neg (prime2 xF), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

val () =
  let val nF = Free("n_lb_sm", natT) val BF = Free("B_lb_sm", natT)
      val hn0 = Thm.assume (ctermV4 (jT (lt ZeroC nF)))
      val th = cpf_pow_bound (BF, nF) hn0
  in out ("cpf_pow_bound smoke : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n") end;

val () = out "F5_D3_DONE\n";
(* ============================================================================
   BERTRAND F5 — delta 4 : UPPER telescope (un-refined) + CBND-family bound.

   UI2 (cpf_upper_tele) : indexed by j, with s = floor_sqrt(2n) :
     prime2/sqrt guards give, for every b in (s, 2n], vp b R <= 1 so b^vp <= b.
     le (cpf (add (Suc s) j) R) (mult (cpf (Suc s) R) (primorial (add s j)))
   PROVIDED  j stays within range so that every new index b=add(Suc s) i (i<j)
   has b <= 2n  (i.e. add (Suc s) j <= Suc 2n).  We carry that as a hyp on the
   top index via a meta-universal guard Hsq:  !!b. le (Suc s) b ==> le b 2n ==>
       prime2 b ==> le (pow b (vp b R)) b   [from sqrt_split: b>s => b^2>2n => vp<=1].
   Simplest: bake the guard as Hub: !!i. lt i j ==> le (pow (add (Suc s) i)(vp ...)) (add (Suc s) i).
   ============================================================================ *)
val () = out "F5_D4_BEGIN\n";

(* primorial axioms onto ctxtV4 *)
val primorial_0_v4            = varify primorial_0_ax;
val primorial_Suc_prime_v4    = varify primorial_Suc_prime_ax;
val primorial_Suc_nonprime_v4 = varify primorial_Suc_nonprime_ax;
fun primorial0_at4 () = beta_norm primorial_0_v4;
val primorial_0_thm4 = primorial_0_v4;  (* oeq (primorial 0) 1 *)
fun primorial_Sp_4 nt h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 nt)] primorial_Suc_prime_v4)) h;
fun primorial_Sn_4 nt h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 nt)] primorial_Suc_nonprime_v4)) h;

val () = out "F5_D4_PRIMORIAL_OK\n";

(* primorial_pos : le 1 (primorial B).  nat_induct on B. *)
fun primorial_pos_4 BT =
  let
    val zP = Free("z_prp", natT)
    val Pabs = Term.lambda zP (le (suc ZeroC) (primorial zP))
    val ind = nat_induct_4 (Pabs, BT)
    val base =
      let val p0 = primorial_0_thm4   (* oeq (primorial 0) 1 *)
          val le11 = le_refl4_at (suc ZeroC)
      in le_cong_r4 (suc ZeroC, suc ZeroC, primorial ZeroC) (oeq_sym OF [p0]) le11 end
    val xF = Free("x_prp", natT)
    val ihP = jT (le (suc ZeroC)(primorial xF))
    val IH = Thm.assume (ctermV4 ihP)
    val goalStep = le (suc ZeroC)(primorial (suc xF))
    val em = ex_middle_4 (prime2 (suc xF))
    val casePr =
      let val hpr = Thm.assume (ctermV4 (jT (prime2 (suc xF))))
          val L = primorial_Sp_4 xF hpr   (* oeq (primorial (Suc x))(mult (Suc x)(primorial x)) *)
          (* le 1 (mult (Suc x)(primorial x)) : le 1 (Suc x) [le_suc of le 0 x], le 1 (primorial x) [IH] *)
          val le1Sx = le_suc_mono4_at (ZeroC, xF) (le_zero4_at xF)  (* le 1 (Suc x) *)
          val m11 = mult1l4_at (suc ZeroC)
          val mlm = mult_le_mono2_4_at (suc ZeroC, suc xF, suc ZeroC, primorial xF) le1Sx IH
          val l1 = le_cong_l4 (mult (suc ZeroC)(suc ZeroC), suc ZeroC, mult (suc xF)(primorial xF)) m11 mlm
          val g = le_cong_r4 (suc ZeroC, mult (suc xF)(primorial xF), primorial (suc xF)) (oeq_sym OF [L]) l1
      in Thm.implies_intr (ctermV4 (jT (prime2 (suc xF)))) g end
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 (suc xF)))))
          val L = primorial_Sn_4 xF hnp   (* oeq (primorial (Suc x))(primorial x) *)
          val g = le_cong_r4 (suc ZeroC, primorial xF, primorial (suc xF)) (oeq_sym OF [L]) IH
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 xF)))) g end
    (* NB caseNp discharges neg(prime2 (Suc x)) ; fix term *)
    val caseNp =
      let val hnp = Thm.assume (ctermV4 (jT (neg (prime2 (suc xF)))))
          val L = primorial_Sn_4 xF hnp
          val g = le_cong_r4 (suc ZeroC, primorial xF, primorial (suc xF)) (oeq_sym OF [L]) IH
      in Thm.implies_intr (ctermV4 (jT (neg (prime2 (suc xF))))) g end
    val stepC = disjE_4 (prime2 (suc xF), neg (prime2 (suc xF)), goalStep) em casePr caseNp
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) stepC)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

