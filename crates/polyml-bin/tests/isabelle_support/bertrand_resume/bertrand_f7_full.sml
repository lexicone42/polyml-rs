(* exE on ctxtV3 *)
fun exE_elim3 (Pabs, goalC) exThm wName bodyFn =
  let
    val wF = Free(wName, natT)
    val hypTerm = jT (Term.betapply (Pabs, wF))
    val hypThm  = Thm.assume (ctermV3 hypTerm)
    val body    = bodyFn wF hypThm
    val minor   = Thm.forall_intr (ctermV3 wF) (Thm.implies_intr (ctermV3 hypTerm) body)
    val inst    = beta_norm (Drule.infer_instantiate ctxtV3
                    [(("P",0), ctermV3 Pabs),(("Q",0), ctermV3 goalC)] exE_v3)
  in Thm.implies_elim (Thm.implies_elim inst exThm) minor end;

