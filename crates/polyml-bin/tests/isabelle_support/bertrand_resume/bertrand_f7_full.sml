(* ============================================================================
   floor_sqrt on ctxtV4 :  !N. ?s. le (mult s s) N /\ lt N (mult (Suc s)(Suc s))
   nat_induct on N.  Witness s grows by 1 exactly when N+1 hits (Suc s)^2.
   ============================================================================ *)
val () = out "F5_FLOORSQRT_BEGIN\n";

(* sq_lt_succ : lt (mult s s)(mult (Suc s)(Suc s))   [s^2 < (s+1)^2]
   (Suc s)^2 = s*s + (s + s + 1) ; need s*s < that, i.e. 0 < s+s+1. *)
(* le_self_suc : le x (Suc x) *)
fun le_self_suc_4 t = le_suc_self4_at t;  (* le t (Suc t) *)

(* helper : oeq (mult (Suc s)(Suc s)) (Suc (add (add (mult s s) s) s))
   (Suc s)*(Suc s) = (Suc s)*s + (Suc s) = (s*s + s) + (Suc s) = Suc((s*s + s) + s) *)
fun sq_succ_expand s =
  let
    (* mult (Suc s)(Suc s) = add (mult s (Suc s))(Suc s)  [mult_Suc : mult (Suc m) n = add n (mult m n)] *)
    val mS  = multSuc4_at (s, suc s)   (* oeq (mult (Suc s)(Suc s))(add (Suc s)(mult s (Suc s))) *)
    (* mult s (Suc s) = add s (mult s s)  [mult_Suc_right : mult m (Suc n) = add m (mult m n)] *)
    val mSr = beta_norm (Drule.infer_instantiate ctxtV4 [(("m",0),ctermV4 s),(("n",0),ctermV4 s)] mult_Suc_right_v4_)
              (* oeq (mult s (Suc s))(add s (mult s s)) *)
  in (mS, mSr) end;

(* I'll prove sq_lt_succ structurally: lt (mult s s)(mult (Suc s)(Suc s)).
   lt a b == le (Suc a) b.  Want le (Suc (s*s))((Suc s)*(Suc s)).
   (Suc s)*(Suc s) = add (Suc s)(mult s (Suc s)) [mS]
                   = add (Suc s)(add s (mult s s)) [mSr cong]
   so it = Suc (add s (add s (mult s s)))  via add_Suc on the (Suc s) head.
   le (Suc (s*s)) (Suc (add s (add s (s*s)))) <= via le_suc_mono of le (s*s)(add s (add s (s*s))).
   le (s*s)(add s (add s (s*s))) : s*s = add 0 (s*s) <= add (..)(s*s) by le_add_mono with le 0 (s+s)?
   Simpler: le x (add c x) for any c. We have le_add : le m (add m p). Need le (s*s)(add (add s s)(s*s)).
   add (add s s)(s*s) ; le (s*s)(add (s*s) anything) needs commutation. Use: le_add gives le (s*s)(add (s*s) k).
   Then commute add (s*s)(add s s) = add (add s s)(s*s). *)
fun sq_lt_succ_4 s =
  let
    val sq = mult s s
    val ss = add s s
    (* le (s*s)(add (s*s)(s+s)) *)
    val le1 = le_add4_at (sq, ss)                 (* le (s*s)(add (s*s)(s+s)) *)
    (* commute : oeq (add (s*s)(s+s))(add (s+s)(s*s)) *)
    val cm  = addcomm4_at (sq, ss)                (* oeq (add (s*s)(s+s))(add (s+s)(s*s)) *)
    val le2 = le_cong_r4 (sq, add sq ss, add ss sq) cm le1   (* le (s*s)(add (s+s)(s*s)) *)
    (* le_suc_mono : le m n -> le (Suc m)(Suc n) *)
    val le3 = le_suc_mono4_at (sq, add ss sq) le2  (* le (Suc (s*s))(Suc (add (s+s)(s*s))) *)
    (* now rewrite RHS (Suc (add (s+s)(s*s))) into (Suc s)*(Suc s) *)
    (* (Suc s)*(Suc s) = add (Suc s)(mult s (Suc s)) [mS] *)
    val (mS, mSr) = sq_succ_expand s
    (* add (Suc s)(mult s (Suc s)) = add (Suc s)(add s (s*s)) [cong on 2nd arg via mSr] *)
    val congInner = add_cong_r4 (suc s, mult s (suc s), add s sq) mSr  (* oeq (add (Suc s)(mult s (Suc s)))(add (Suc s)(add s (s*s))) *)
    (* add (Suc s) X = Suc (add s X)  [add_Suc] ; X = add s (s*s) *)
    val aS = add_Suc_at4 (s, add s sq)            (* oeq (add (Suc s)(add s (s*s)))(Suc (add s (add s (s*s)))) *)
    (* chain : (Suc s)*(Suc s) = add (Suc s)(mult s (Suc s)) = add (Suc s)(add s (s*s)) = Suc(add s (add s (s*s))) *)
    val sqSS_eq = oeq_trans OF [mS, oeq_trans OF [congInner, aS]]  (* oeq ((Suc s)*(Suc s))(Suc(add s (add s (s*s)))) *)
    (* and Suc(add (s+s)(s*s)) : add (s+s)(s*s) = add (add s s)(s*s) = add s (add s (s*s)) [assoc] *)
    val assoc = addassoc4_at (s, s, sq)            (* oeq (add (add s s)(s*s))(add s (add s (s*s))) *)
    val sucAssoc = Suc_cong OF [assoc]             (* oeq (Suc(add (s+s)(s*s)))(Suc(add s (add s (s*s)))) *)
    (* le3 : le (Suc(s*s))(Suc(add (s+s)(s*s))) ; rewrite RHS via sucAssoc then via (sqSS_eq sym) *)
    val le4 = le_cong_r4 (suc sq, suc (add ss sq), suc (add s (add s sq))) sucAssoc le3  (* le (Suc(s*s))(Suc(add s (add s (s*s)))) *)
    val le5 = le_cong_r4 (suc sq, suc (add s (add s sq)), mult (suc s)(suc s)) (oeq_sym OF [sqSS_eq]) le4
              (* le (Suc(s*s))((Suc s)*(Suc s)) = lt (s*s)((Suc s)*(Suc s)) *)
  in le5 end;

(* smoke : print sq_lt_succ at a Free s *)
val () =
  let val sF = Free("s_smk", natT)
      val th = sq_lt_succ_4 sF
  in out ("sq_lt_succ smoke 0hyp=" ^ Bool.toString (zhV4 th) ^ " : "
          ^ Syntax.string_of_term ctxtV4 (Thm.prop_of th) ^ "\n") end;

(* floor_sqrt : !N. ?s. le (mult s s) N /\ lt N (mult (Suc s)(Suc s)) *)
val floor_sqrt =
  let
    val NF = Free("N_fs", natT)
    fun fsBody k = Term.lambda (Free("s_fs", natT))
        (mkConj (le (mult (Free("s_fs",natT)) (Free("s_fs",natT))) k)
                (lt k (mult (suc (Free("s_fs",natT))) (suc (Free("s_fs",natT))))))
    val Pabs = Term.lambda NF (mkEx (fsBody NF))
    val ind = nat_induct_4 (Pabs, NF)
    (* base N=0 : witness s=0 ; le (0*0) 0 /\ lt 0 ((Suc 0)*(Suc 0)) *)
    val base =
      let
        val m00 = mult04_at ZeroC                 (* oeq (mult 0 0) 0 *)
        val le00 = le_refl4_at ZeroC              (* le 0 0 *)
        val le_m00_0 = le_cong_l4 (ZeroC, mult ZeroC ZeroC, ZeroC) (oeq_sym OF [m00]) le00 (* le (mult 0 0) 0 *)
        (* lt 0 (mult (Suc 0)(Suc 0)) : sq_lt_succ at s=0 gives lt (0*0)((Suc 0)^2);
           rewrite lower (0*0)->0 : lt x y = le (Suc x) y ; rewrite x via oeq_subst on %z. le (Suc z) y *)
        val lt00 = sq_lt_succ_4 ZeroC             (* lt (mult 0 0)(mult (Suc 0)(Suc 0)) = le (Suc(mult 0 0))(..) *)
        val zlt = Free("zltb", natT)
        val Plt = Term.lambda zlt (le (suc zlt)(mult (suc ZeroC)(suc ZeroC)))
        val lt_0_sq = substPred4 (Plt, mult ZeroC ZeroC, ZeroC) m00 lt00  (* le (Suc 0)(..) = lt 0 (..) *)
        val cj = conjI_4 (le (mult ZeroC ZeroC) ZeroC, lt ZeroC (mult (suc ZeroC)(suc ZeroC))) le_m00_0 lt_0_sq
      in exI_4 (fsBody ZeroC, ZeroC) cj end
    (* step : P x -> P (Suc x) *)
    val xF = Free("x_fs", natT)
    val ihP = jT (mkEx (fsBody xF))
    val IH = Thm.assume (ctermV4 ihP)
    val goalC = mkEx (fsBody (suc xF))
    val PabsE = Term.lambda (Free("s_fs", natT))
        (mkConj (le (mult (Free("s_fs",natT)) (Free("s_fs",natT))) xF)
                (lt xF (mult (suc (Free("s_fs",natT))) (suc (Free("s_fs",natT))))))
    fun body sF (hs:thm) =      (* hs : le (s*s) x /\ lt x ((Suc s)^2) *)
      let
        val sq  = mult sF sF
        val sqS = mult (suc sF)(suc sF)
        val hle = conjunct1_4 (le sq xF, lt xF sqS) hs   (* le (s*s) x *)
        val hlt = conjunct2_4 (le sq xF, lt xF sqS) hs   (* lt x ((Suc s)^2) = le (Suc x)((Suc s)^2) *)
        (* le (s*s)(Suc x) *)
        val le_x_Sx = le_self_suc_4 xF                   (* le x (Suc x) *)
        val le_sq_Sx = le_trans4_at (sq, xF, suc xF) hle le_x_Sx  (* le (s*s)(Suc x) *)
        (* split lt x ((Suc s)^2) = le (Suc x)((Suc s)^2) into = or < *)
        val dj = le_eq_or_succ_le_4 (suc xF, sqS) hlt    (* Disj (oeq (Suc x)((Suc s)^2)) (le (Suc(Suc x))((Suc s)^2)) *)
        fun PabsE_of k = Term.lambda (Free("s_fs", natT))
              (mkConj (le (mult (Free("s_fs",natT)) (Free("s_fs",natT))) k)
                      (lt k (mult (suc (Free("s_fs",natT))) (suc (Free("s_fs",natT))))))
        (* case lt : le (Suc(Suc x))((Suc s)^2) means lt (Suc x)((Suc s)^2) ; keep s *)
        val caseLt =
          let val hL = Thm.assume (ctermV4 (jT (le (suc (suc xF)) sqS)))  (* = lt (Suc x)((Suc s)^2) *)
              val cj = conjI_4 (le sq (suc xF), lt (suc xF) sqS) le_sq_Sx hL
              val ex = exI_4 (PabsE_of (suc xF), sF) cj
          in Thm.implies_intr (ctermV4 (jT (le (suc (suc xF)) sqS))) ex end
        (* case eq : oeq (Suc x)((Suc s)^2) ; use s' = Suc s *)
        val caseEq =
          let val heq = Thm.assume (ctermV4 (jT (oeq (suc xF) sqS)))  (* Suc x = (Suc s)^2 *)
              (* le ((Suc s)^2)(Suc x) : le_refl (Suc x), rewrite first via heq sym ; le (Suc s)^2 (Suc x) *)
              val leR = le_refl4_at (suc xF)
              val le_sqS_Sx = le_cong_l4 (suc xF, sqS, suc xF) heq leR  (* le ((Suc s)^2)(Suc x) *)
              (* lt (Suc x)((Suc(Suc s))^2) : (Suc s)^2 < (Suc(Suc s))^2 [sq_lt_succ at Suc s],
                 and Suc x = (Suc s)^2 so lt (Suc x)((Suc(Suc s))^2) by rewriting. *)
              val sqLt = sq_lt_succ_4 (suc sF)     (* lt ((Suc s)^2)((Suc(Suc s))^2) = le (Suc((Suc s)^2))((Suc(Suc s))^2) *)
              (* rewrite lower : le (Suc((Suc s)^2))(..) ; need le (Suc(Suc x))(..) ? No:
                 we want lt (Suc x)((Suc(Suc s))^2) = le (Suc(Suc x))((Suc(Suc s))^2).
                 sqLt = le (Suc((Suc s)^2))((Suc(Suc s))^2). rewrite (Suc s)^2 -> Suc x in the Suc(..):
                 oeq (Suc s)^2 (Suc x) = heq sym. *)
              val sqSS = mult (suc (suc sF))(suc (suc sF))
              val zr = Free("zreq", natT)
              val Pr = Term.lambda zr (le (suc zr) sqSS)
              val lt_Sx = substPred4 (Pr, sqS, suc xF) (oeq_sym OF [heq]) sqLt  (* le (Suc(Suc x)) sqSS = lt (Suc x) sqSS *)
              val cj = conjI_4 (le (mult (suc sF)(suc sF)) (suc xF), lt (suc xF) sqSS) le_sqS_Sx lt_Sx
              val ex = exI_4 (PabsE_of (suc xF), suc sF) cj
          in Thm.implies_intr (ctermV4 (jT (oeq (suc xF) sqS))) ex end
        val g = disjE_4 (oeq (suc xF) sqS, le (suc (suc xF)) sqS, goalC) dj caseEq caseLt
      in g end
    val concl = exE_elim4 (PabsE, goalC) IH "s_ih" body
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) concl)
    val r1 = Thm.implies_elim ind base
  in varify (Thm.implies_elim r1 step) end;
val () = out ("floor_sqrt 0hyp=" ^ Bool.toString (zhV4 floor_sqrt) ^ "\n");
