(* ============================================================================
   prime2_concrete : given a concrete prime p (SML int), build jT (prime2 (mkNum p)).
   Uses numeral evaluators + ndvd_between certificate + le-cascade enumeration.
   ============================================================================ *)
val () = out "P2C_BEGIN\n";

(* --- numeral infra --- *)
fun mkNum 0 = ZeroC | mkNum k = suc (mkNum (k-1));
fun numOf t = case t of Const _ => 0 | (Const _ $ x) => 1 + numOf x | _ => raise Fail "numOf";
fun add_eval aT bT =
  case aT of Const _ => (bT, add04_at bT)
  | (Const _ $ a') => let val (r', th') = add_eval a' bT
        in (suc r', oeq_trans OF [add_Suc4_at (a', bT), Suc_cong OF [th']]) end
  | _ => raise Fail "add_eval";
fun mult_eval aT bT =
  case aT of Const _ => (ZeroC, mult04_at bT)
  | (Const _ $ a') => let val (r', th') = mult_eval a' bT
        val congInner = add_cong_r4 (bT, mult a' bT, r') th'
        val (rr, addth) = add_eval bT r'
        in (rr, oeq_trans OF [multSuc4_at (a', bT), oeq_trans OF [congInner, addth]]) end
  | _ => raise Fail "mult_eval";
fun le_eval ai bi =
  let val aT = mkNum ai val w = mkNum (bi - ai)
      val (r, th) = add_eval aT w
  in le_intro4 (aT, r, w) (oeq_sym OF [th]) end;
fun lt_eval ai bi = le_eval (ai+1) bi;

(* --- V4 logical helpers --- *)
val allI_v4_l = varify allI_ax;
fun allI_4_pre Pabs hAllThm =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("P",0), ctermV4 Pabs)] allI_v4_l)
  in Thm.implies_elim inst hAllThm end;
fun allI_4 Pabs bodyThmFn =
  let val dF = Free("d_ai", natT) val body = bodyThmFn dF
  in allI_4_pre Pabs (Thm.forall_intr (ctermV4 dF) body) end;
val disjI1_v4 = varify disjI1_ax; val disjI2_v4 = varify disjI2_ax;
fun disjI1_4 (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("A",0), ctermV4 At),(("B",0), ctermV4 Bt)] disjI1_v4)) h;
fun disjI2_4 (At,Bt) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtV4
        [(("A",0), ctermV4 At),(("B",0), ctermV4 Bt)] disjI2_v4)) h;
fun sucNeqZero4 t = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0), ctermV4 t)] Suc_neq_Zero_v4);
fun zero_dvd_4 mT hdvd =
  let val Pabs = Abs("k", natT, oeq mT (mult ZeroC (Bound 0))) val goalC = oeq mT ZeroC
      fun body kF (hk:thm) = oeq_trans OF [hk, mult04_at kF]
  in exE_elim4 (Pabs, goalC) hdvd "k_zd" body end;
fun nzNum pi = (* meta : (oeq (mkNum pi) 0 ==> oFalse) for pi>0 ; mkNum pi = suc(mkNum(pi-1)) *)
  let val t = mkNum (pi-1)
  in Thm.implies_intr (ctermV4 (jT (oeq (suc t) ZeroC))) (sucNeqZero4 t OF [Thm.assume (ctermV4 (jT (oeq (suc t) ZeroC)))]) end;

(* ndvd_between : lt (mult k q) p ==> lt p (mult k (Suc q)) ==> neg (dvd k p) *)
fun ndvd_between (kT, qT, pT) hk1 hk2 =
  let val hdvd = Thm.assume (ctermV4 (jT (dvd kT pT)))
      val Pabs = Abs("j", natT, oeq pT (mult kT (Bound 0)))
      fun body jF (hj:thm) =
        let val djt = le_total_4 (jF, qT)
            val caseJleQ =
              let val hjq = Thm.assume (ctermV4 (jT (le jF qT)))
                  val lemul = mult_le_mono_4 (kT, jF, qT) hjq
                  val lep = le_cong_l4 (mult kT jF, pT, mult kT qT) (oeq_sym OF [hj]) lemul
                  val leSuc = le_trans4_at (suc (mult kT qT), pT, mult kT qT) hk1 lep
                  val ff = (lt_irrefl4_at (mult kT qT)) OF [leSuc]
              in Thm.implies_intr (ctermV4 (jT (le jF qT))) ff end
            val caseQleJ =
              let val hqj = Thm.assume (ctermV4 (jT (le qT jF)))
                  val dje = le_eq_or_succ_le_4 (qT, jF) hqj
                  val caseEq =
                    let val heq = Thm.assume (ctermV4 (jT (oeq qT jF)))
                        val kjq = mult_cong_r4 (kT, jF, qT) (oeq_sym OF [heq])
                        val pkq = oeq_trans OF [hj, kjq]
                        val leSuc = le_cong_r4 (suc (mult kT qT), pT, mult kT qT) pkq hk1
                        val ff = (lt_irrefl4_at (mult kT qT)) OF [leSuc]
                    in Thm.implies_intr (ctermV4 (jT (oeq qT jF))) ff end
                  val caseSucQ =
                    let val hsq = Thm.assume (ctermV4 (jT (le (suc qT) jF)))
                        val lemul = mult_le_mono_4 (kT, suc qT, jF) hsq
                        val lekp = le_cong_r4 (mult kT (suc qT), mult kT jF, pT) (oeq_sym OF [hj]) lemul
                        val leSp = le_trans4_at (suc pT, mult kT (suc qT), pT) hk2 lekp
                        val ff = (lt_irrefl4_at pT) OF [leSp]
                    in Thm.implies_intr (ctermV4 (jT (le (suc qT) jF))) ff end
                  val ff = disjE_4 (oeq qT jF, le (suc qT) jF, oFalseC) dje caseEq caseSucQ
              in Thm.implies_intr (ctermV4 (jT (le qT jF))) ff end
            val ff = disjE_4 (le jF qT, le qT jF, oFalseC) djt caseJleQ caseQleJ
        in ff end
      val ffinal = exE_elim4 (Pabs, oFalseC) hdvd "j_nd" body
  in impI_4 (dvd kT pT, oFalseC) (Thm.implies_intr (ctermV4 (jT (dvd kT pT))) ffinal) end;

(* ndvd_eval : for concrete k,p with k not dividing p (1<k<p), build neg (dvd k p). *)
fun ndvd_eval ki pi =     (* SML ints *)
  let val q = pi div ki
      val kT = mkNum ki val qT = mkNum q val pT = mkNum pi
      (* hk1 : lt (mult k q) p  i.e. le (Suc (mult k q)) p *)
      val (kqT, kqEq) = mult_eval kT qT       (* oeq (mult k q) kq , kq = k*q *)
      val kq = numOf kqT
      val lt_kq_p_raw = lt_eval kq pi          (* le (Suc (mkNum kq)) (mkNum p) *)
      (* rewrite Suc(mkNum kq) -> Suc (mult k q) : le_cong_l on lower via Suc_cong(sym kqEq) *)
      val hk1 = le_cong_l4 (suc kqT, suc (mult kT qT), pT) (Suc_cong OF [oeq_sym OF [kqEq]]) lt_kq_p_raw
      (* hk2 : lt p (mult k (Suc q)) i.e. le (Suc p)(mult k (Suc q)) *)
      val (kq1T, kq1Eq) = mult_eval kT (suc qT)    (* oeq (mult k (Suc q)) kq1 *)
      val kq1 = numOf kq1T
      val lt_p_kq1_raw = lt_eval pi kq1            (* le (Suc p)(mkNum kq1) *)
      val hk2 = le_cong_r4 (suc pT, kq1T, mult kT (suc qT)) (oeq_sym OF [kq1Eq]) lt_p_kq1_raw
  in ndvd_between (kT, qT, pT) hk1 hk2 end;

(* prime2_concrete pi : build jT (prime2 (mkNum pi)) for a concrete prime pi. *)
val () = out "HELPERS_LOADED\n";

(* ============================================================================
   prime2_check : the sqrt-bounded primality criterion.
     lt 1 p ==> (!d. lt 1 d ==> le (mult d d) p ==> neg (dvd d p)) ==> prime2 p
   Proof: take d|p (p = d*e).  le_total(d,e):
     d<=e : d*d <= d*e = p, so d*d<=p.  If 1<d, Hbc gives ~dvd d p, contra.  So
            ~(1<d) i.e. le d 1 -> d=0 (->p=0 contra) or d=1.  -> d=1.
     e<=d : e*e <= e*d = d*e = p, so e*e<=p.  e|p (p=e*d).  If 1<e, ~dvd e p contra.
            So le e 1 -> e=0 (p=0 contra) or e=1 -> p=d -> d=p.
   ============================================================================ *)
val () = out "P2CHECK_BEGIN\n";

(* helpers (assume numeval/logical helpers already in scope from p2c delta) *)

(* le_one_cases : le d 1 ==> Disj (oeq d 0)(oeq d 1)   [via le_eq_or_succ_le twice] *)
fun le_one_cases dT hle1 =     (* hle1 : le d 1 ; -> Disj (oeq d 0)(oeq d 1) *)
  let
    (* le 0 d always ; le_eq_or_succ_le (0,d): Disj (oeq 0 d)(le 1 d) *)
    val le0d = le_zero4_at dT
    val dj = le_eq_or_succ_le_4 (ZeroC, dT) le0d   (* Disj (oeq 0 d)(le 1 d) *)
    val goal = mkDisj (oeq dT ZeroC)(oeq dT (suc ZeroC))
    val caseEq0 =
      let val h = Thm.assume (ctermV4 (jT (oeq ZeroC dT)))
          val g = disjI1_4 (oeq dT ZeroC, oeq dT (suc ZeroC)) (oeq_sym OF [h])
      in Thm.implies_intr (ctermV4 (jT (oeq ZeroC dT))) g end
    val caseLe1 =
      let val h = Thm.assume (ctermV4 (jT (le (suc ZeroC) dT)))   (* le 1 d *)
          (* with hle1 : le d 1 -> antisym d=1 *)
          val deq1 = le_antisym_4 (dT, suc ZeroC) hle1 h          (* oeq d 1 *)
          val g = disjI2_4 (oeq dT ZeroC, oeq dT (suc ZeroC)) deq1
      in Thm.implies_intr (ctermV4 (jT (le (suc ZeroC) dT))) g end
  in disjE_4 (oeq ZeroC dT, le (suc ZeroC) dT, goal) dj caseEq0 caseLe1 end;

val prime2_check =
  let
    val pF = Free("p_chk", natT)
    val oneN = suc ZeroC
    val hgt1 = Thm.assume (ctermV4 (jT (lt oneN pF)))    (* lt 1 p = le 2 p *)
    (* hypothesis : !d. lt 1 d ==> le (d*d) p ==> ~dvd d p  (object Forall) *)
    val chkAbs = Term.lambda (Free("d_c", natT))
        (mkImp (lt oneN (Free("d_c",natT)))
               (mkImp (le (mult (Free("d_c",natT))(Free("d_c",natT))) pF)
                      (neg (dvd (Free("d_c",natT)) pF))))
    val hChk = Thm.assume (ctermV4 (jT (mkForall chkAbs)))   (* jT (Forall chkAbs) *)
    (* derive : !d. d|p ==> d=1 \/ d=p *)
    val faBody = ppAbs pF
    fun perD dF =
      let
        val hdvd = Thm.assume (ctermV4 (jT (dvd dF pF)))   (* dvd d p *)
        val goalDisj = mkDisj (oeq dF oneN)(oeq dF pF)
        (* p = d*e *)
        val Pabs = Abs("e", natT, oeq pF (mult dF (Bound 0)))
        fun body eF (he:thm) =    (* he : oeq p (mult d e) *)
          let
            (* le_total d e *)
            val djt = le_total_4 (dF, eF)
            val caseDleE =
              let val hde = Thm.assume (ctermV4 (jT (le dF eF)))   (* le d e *)
                  (* d*d <= d*e *)
                  val ddle = mult_le_mono2_4_at (dF, dF, dF, eF) (le_refl4_at dF) hde  (* le (d*d)(d*e) *)
                  (* d*e = p (sym he) -> le (d*d) p *)
                  val ddp = le_cong_r4 (mult dF dF, mult dF eF, pF) (oeq_sym OF [he]) ddle  (* le (d*d) p *)
                  (* chk at d : lt 1 d -> le (d*d) p -> ~dvd d p *)
                  val chkD = allE_4 chkAbs dF hChk      (* jT (Imp (lt 1 d)(Imp (le (d*d) p)(neg (dvd d p)))) *)
                  (* if 1<d : contradiction. else le d 1 -> d=0 (p=0 contra) or d=1. ex_middle on lt 1 d *)
                  val em = ex_middle_4 (lt oneN dF)     (* Disj (lt 1 d)(neg (lt 1 d)) *)
                  val caseGt1 =
                    let val hg = Thm.assume (ctermV4 (jT (lt oneN dF)))
                        val s1 = mp_4 (lt oneN dF, mkImp (le (mult dF dF) pF)(neg (dvd dF pF))) chkD hg
                        val s2 = mp_4 (le (mult dF dF) pF, neg (dvd dF pF)) s1 ddp
                        val ff = mp_4 (dvd dF pF, oFalseC) s2 hdvd
                        val g = oFalse_elim_4 goalDisj OF [ff]
                    in Thm.implies_intr (ctermV4 (jT (lt oneN dF))) g end
                  val caseNgt1 =
                    let val hng = Thm.assume (ctermV4 (jT (neg (lt oneN dF))))   (* ~lt 1 d *)
                        (* nlt_le : ~ lt 1 d -> le d 1 *)
                        val led1 = nlt_le_4 (oneN, dF) hng     (* le d 1 *)
                        val dj01 = le_one_cases dF led1        (* Disj (oeq d 0)(oeq d 1) *)
                        val caseD0 =
                          let val hd0 = Thm.assume (ctermV4 (jT (oeq dF ZeroC)))
                              (* p = d*e = 0*e = 0 -> contra lt 1 p (le 2 p -> le 2 0) *)
                              val deq = mult_cong_l4 (dF, ZeroC, eF) hd0       (* oeq (mult d e)(mult 0 e) *)
                              val m0 = mult04_at eF                            (* oeq (mult 0 e) 0 *)
                              val pe0 = oeq_trans OF [he, oeq_trans OF [deq, m0]]  (* oeq p 0 *)
                              (* hgt1 : le 2 p ; rewrite p->0 : le 2 0 *)
                              val le20 = le_cong_r4 (suc oneN, pF, ZeroC) pe0 hgt1  (* le 2 0 = le (Suc 1) 0 *)
                              (* le (Suc 1) 0 is Ex q. 0 = (Suc 1) + q ; exE -> 0 = Suc(1+q) -> Suc_neq_Zero *)
                              val ffMeta =
                                let val Qa = Abs("q", natT, oeq ZeroC (add (suc oneN) (Bound 0)))
                                    fun qb qF (hq:thm) =   (* oeq 0 (add 2 q) *)
                                      let val aS = add_Suc4_at (oneN, qF)   (* oeq (add (Suc 1) q)(Suc(add 1 q)) *)
                                          val e0 = oeq_trans OF [hq, aS]    (* oeq 0 (Suc(add 1 q)) *)
                                          val e0s = oeq_sym OF [e0]         (* oeq (Suc(add 1 q)) 0 *)
                                      in (sucNeqZero4 (add oneN qF)) OF [e0s] end
                                in exE_elim4 (Qa, oFalseC) le20 "q_p0" qb end
                              val g = oFalse_elim_4 goalDisj OF [ffMeta]
                          in Thm.implies_intr (ctermV4 (jT (oeq dF ZeroC))) g end
                        val caseD1 =
                          let val hd1 = Thm.assume (ctermV4 (jT (oeq dF oneN)))
                              val g = disjI1_4 (oeq dF oneN, oeq dF pF) hd1
                          in Thm.implies_intr (ctermV4 (jT (oeq dF oneN))) g end
                        val g = disjE_4 (oeq dF ZeroC, oeq dF oneN, goalDisj) dj01 caseD0 caseD1
                    in Thm.implies_intr (ctermV4 (jT (neg (lt oneN dF)))) g end
                  val g = disjE_4 (lt oneN dF, neg (lt oneN dF), goalDisj) em caseGt1 caseNgt1
              in Thm.implies_intr (ctermV4 (jT (le dF eF))) g end
            val caseEleD =
              let val hed = Thm.assume (ctermV4 (jT (le eF dF)))   (* le e d *)
                  (* e*e <= e*d ; e*d = d*e = p *)
                  val eele = mult_le_mono2_4_at (eF, eF, eF, dF) (le_refl4_at eF) hed  (* le (e*e)(e*d) *)
                  val edDe = multcomm4_at (eF, dF)                  (* oeq (mult e d)(mult d e) *)
                  val edp = oeq_trans OF [edDe, oeq_sym OF [he]]    (* oeq (mult e d) p *)
                  val eep = le_cong_r4 (mult eF eF, mult eF dF, pF) edp eele  (* le (e*e) p *)
                  (* dvd e p : p = e*d (commute he) *)
                  val pEd = oeq_trans OF [he, multcomm4_at (dF, eF)]  (* oeq p (mult e d) *)
                  val hdvdE = dvd_intro4 (eF, pF, dF) pEd            (* dvd e p *)
                  val chkE = allE_4 chkAbs eF hChk
                  val em = ex_middle_4 (lt oneN eF)
                  val caseGt1 =
                    let val hg = Thm.assume (ctermV4 (jT (lt oneN eF)))
                        val s1 = mp_4 (lt oneN eF, mkImp (le (mult eF eF) pF)(neg (dvd eF pF))) chkE hg
                        val s2 = mp_4 (le (mult eF eF) pF, neg (dvd eF pF)) s1 eep
                        val ff = mp_4 (dvd eF pF, oFalseC) s2 hdvdE
                        val g = oFalse_elim_4 goalDisj OF [ff]
                    in Thm.implies_intr (ctermV4 (jT (lt oneN eF))) g end
                  val caseNgt1 =
                    let val hng = Thm.assume (ctermV4 (jT (neg (lt oneN eF))))
                        val lee1 = nlt_le_4 (oneN, eF) hng         (* le e 1 *)
                        val dj01 = le_one_cases eF lee1            (* Disj (oeq e 0)(oeq e 1) *)
                        val caseE0 =
                          let val he0 = Thm.assume (ctermV4 (jT (oeq eF ZeroC)))
                              (* p = d*e = d*0 = 0 *)
                              val deq = mult_cong_r4 (dF, eF, ZeroC) he0  (* oeq (mult d e)(mult d 0) *)
                              val m0 = mult0r4_at dF                       (* oeq (mult d 0) 0 *)
                              val pe0 = oeq_trans OF [he, oeq_trans OF [deq, m0]]  (* oeq p 0 *)
                              val le20 = le_cong_r4 (suc oneN, pF, ZeroC) pe0 hgt1
                              val ffMeta =
                                let val Qa = Abs("q", natT, oeq ZeroC (add (suc oneN) (Bound 0)))
                                    fun qb qF (hq:thm) =
                                      let val aS = add_Suc4_at (oneN, qF)
                                          val e0 = oeq_trans OF [hq, aS]
                                          val e0s = oeq_sym OF [e0]
                                      in (sucNeqZero4 (add oneN qF)) OF [e0s] end
                                in exE_elim4 (Qa, oFalseC) le20 "q_p0e" qb end
                              val g = oFalse_elim_4 goalDisj OF [ffMeta]
                          in Thm.implies_intr (ctermV4 (jT (oeq eF ZeroC))) g end
                        val caseE1 =
                          let val he1 = Thm.assume (ctermV4 (jT (oeq eF oneN)))   (* e=1 *)
                              (* p = d*e = d*1 = d -> d = p *)
                              val deq = mult_cong_r4 (dF, eF, oneN) he1   (* oeq (mult d e)(mult d 1) *)
                              val m1 = mult1r4_at dF                       (* oeq (mult d 1) d *)
                              val pEqD = oeq_trans OF [he, oeq_trans OF [deq, m1]]  (* oeq p d *)
                              val dEqP = oeq_sym OF [pEqD]                  (* oeq d p *)
                              val g = disjI2_4 (oeq dF oneN, oeq dF pF) dEqP
                          in Thm.implies_intr (ctermV4 (jT (oeq eF oneN))) g end
                        val g = disjE_4 (oeq eF ZeroC, oeq eF oneN, goalDisj) dj01 caseE0 caseE1
                    in Thm.implies_intr (ctermV4 (jT (neg (lt oneN eF)))) g end
                  val g = disjE_4 (lt oneN eF, neg (lt oneN eF), goalDisj) em caseGt1 caseNgt1
              in Thm.implies_intr (ctermV4 (jT (le eF dF))) g end
            val g = disjE_4 (le dF eF, le eF dF, goalDisj) djt caseDleE caseEleD
          in g end
        val gDisj = exE_elim4 (Pabs, goalDisj) hdvd "e_chk" body
      in impI_4 (dvd dF pF, goalDisj) (Thm.implies_intr (ctermV4 (jT (dvd dF pF))) gDisj) end
    val fa = allI_4 faBody perD     (* jT (Forall faBody) *)
    val conj = conjI_4 (lt oneN pF, mkForall faBody) hgt1 fa  (* jT (prime2 p) *)
    val d2 = Thm.implies_intr (ctermV4 (jT (mkForall chkAbs))) conj
    val d1 = Thm.implies_intr (ctermV4 (jT (lt oneN pF))) d2
  in varify d1 end;

val () = out ("prime2_check 0hyp=" ^ Bool.toString (zhV4 prime2_check) ^ "\n");
val () = out ("prime2_check : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of prime2_check) ^ "\n");
val () = out "P2CHECK_DONE\n";

(* ============================================================================
   prime2_via_check pi : prove jT (prime2 (mkNum pi)) for a concrete prime pi
   using prime2_check, discharging the bounded hypothesis by a cascade only up
   to floor_sqrt(pi).  O(sqrt p) work instead of O(p).
   ============================================================================ *)
val () = out "P2VIA_BEGIN\n";

(* integer sqrt floor *)
fun isqrt n = let fun go k = if (k+1)*(k+1) <= n then go (k+1) else k in go 0 end;

(* prime2_check varified instantiator *)
val prime2_check_v = varify prime2_check;
fun prime2_check_at pT hgt1 hChk =    (* hgt1 : lt 1 p ; hChk : jT (Forall chkAbs at p) ; -> prime2 p *)
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p_chk",0), ctermV4 pT)] prime2_check_v)
  in (inst OF [hgt1]) OF [hChk] end;

fun prime2_via_check pi =
  let
    val pT = mkNum pi
    val oneN = suc ZeroC
    val S = isqrt pi
    val gt1 = lt_eval 1 pi      (* lt 1 p *)
    (* chk body abstraction (must match prime2_check's chkAbs exactly) *)
    val chkAbs = Term.lambda (Free("d_c", natT))
        (mkImp (lt oneN (Free("d_c",natT)))
               (mkImp (le (mult (Free("d_c",natT))(Free("d_c",natT))) pT)
                      (neg (dvd (Free("d_c",natT)) pT))))
    (* prove !d. chkAbs d *)
    fun perD dF =
      let
        (* object impl : lt 1 d -> le (d*d) p -> neg (dvd d p) *)
        val h1 = Thm.assume (ctermV4 (jT (lt oneN dF)))       (* lt 1 d = le 2 d *)
        val h2 = Thm.assume (ctermV4 (jT (le (mult dF dF) pT)))  (* le (d*d) p *)
        val goalN = neg (dvd dF pT)
        (* cascade from le 2 d : handle d=2..S explicitly, d>=S+1 vacuously via d*d>p. *)
        fun cascade k0 hLe =     (* hLe : le (mkNum k0) d , k0 >= 2 *)
          if k0 > S then
            (* d >= k0 > S, so d >= S+1, so d*d >= (S+1)^2 > p, contra h2 *)
            let
              val sp1 = mkNum (S+1)
              (* le (S+1) d : k0 > S means k0 >= S+1 ; hLe : le (mkNum k0) d ; le (S+1)(mkNum k0) [le_eval] ; trans *)
              val leS1k0 = le_eval (S+1) k0     (* le (S+1)(mkNum k0) *)
              val leS1d = le_trans4_at (sp1, mkNum k0, dF) leS1k0 hLe   (* le (S+1) d *)
              (* le ((S+1)*(S+1))(d*d) *)
              val leSq = mult_le_mono2_4_at (sp1, dF, sp1, dF) leS1d leS1d  (* le ((S+1)^2)(d*d) *)
              (* le ((S+1)^2) p : trans with h2 *)
              val leSqp = le_trans4_at (mult sp1 sp1, mult dF dF, pT) leSq h2  (* le ((S+1)^2) p *)
              (* but lt p ((S+1)^2) : (S+1)^2 > p concretely *)
              val (sq1T, sq1Eq) = mult_eval sp1 sp1     (* oeq ((S+1)^2) <num> *)
              val sq1 = numOf sq1T
              val lt_p_sq1_raw = lt_eval pi sq1         (* le (Suc p)(mkNum sq1) *)
              val lt_p_sq1 = le_cong_r4 (suc pT, sq1T, mult sp1 sp1) (oeq_sym OF [sq1Eq]) lt_p_sq1_raw  (* lt p ((S+1)^2) = le (Suc p)((S+1)^2) *)
              (* le (Suc p)((S+1)^2) [lt_p_sq1] and le ((S+1)^2) p [leSqp] -> le (Suc p) p -> lt_irrefl p *)
              val leSucP = le_trans4_at (suc pT, mult sp1 sp1, pT) lt_p_sq1 leSqp  (* le (Suc p) p = lt p p *)
              val ff = (lt_irrefl4_at pT) OF [leSucP]
            in oFalse_elim_4 goalN OF [ff] end
          else
            let
              val kT = mkNum k0
              val dj = le_eq_or_succ_le_4 (kT, dF) hLe    (* Disj (oeq (mkNum k0) d)(le (Suc(mkNum k0)) d) *)
              val caseEqK =
                let val he = Thm.assume (ctermV4 (jT (oeq kT dF)))   (* k0 = d *)
                    (* d = k0 -> neg (dvd d p) from ndvd_eval k0 p (rewrite d->k0) *)
                    val ndvdK = ndvd_eval k0 pi          (* neg (dvd k0 p) *)
                    (* neg (dvd k0 p) -> neg (dvd d p) : rewrite k0 -> d via he ; neg X = Imp X oFalse *)
                    (* easier: prove dvd d p -> oFalse using ndvdK and he. *)
                    val hdp = Thm.assume (ctermV4 (jT (dvd dF pT)))
                    val hdK = oeq_sym OF [he]             (* oeq d k0 *)
                    val zP = Free("zndv", natT) val PdvdAbs = Term.lambda zP (dvd zP pT)
                    val dvdK0 = substPred4 (PdvdAbs, dF, kT) hdK hdp    (* dvd k0 p *)
                    val ff = mp_4 (dvd kT pT, oFalseC) ndvdK dvdK0
                    val negD = impI_4 (dvd dF pT, oFalseC) (Thm.implies_intr (ctermV4 (jT (dvd dF pT))) ff)
                in Thm.implies_intr (ctermV4 (jT (oeq kT dF))) negD end
              val caseLeNext =
                let val hNext = Thm.assume (ctermV4 (jT (le (suc kT) dF)))
                    val g = cascade (k0+1) hNext
                in Thm.implies_intr (ctermV4 (jT (le (suc kT) dF))) g end
              val g = disjE_4 (oeq kT dF, le (suc kT) dF, goalN) dj caseEqK caseLeNext
            in g end
        (* h1 : lt 1 d = le 2 d = le (mkNum 2) d ; start cascade at 2 *)
        val negDvd = cascade 2 h1
        (* build object implication : lt 1 d -> (le (d*d) p -> neg (dvd d p)) *)
        val inner = impI_4 (le (mult dF dF) pT, neg (dvd dF pT)) (Thm.implies_intr (ctermV4 (jT (le (mult dF dF) pT))) negDvd)
        val outer = impI_4 (lt oneN dF, mkImp (le (mult dF dF) pT)(neg (dvd dF pT))) (Thm.implies_intr (ctermV4 (jT (lt oneN dF))) inner)
      in outer end
    val allI_v4_lv = varify allI_ax
    fun allI_4b Pabs bodyFn =
      let val dF = Free("d_via", natT) val body = bodyFn dF
          val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("P",0), ctermV4 Pabs)] allI_v4_lv)
      in Thm.implies_elim inst (Thm.forall_intr (ctermV4 dF) body) end
    val hChk = allI_4b chkAbs perD     (* jT (Forall chkAbs) *)
  in prime2_check_at pT gt1 hChk end;

val () = out "P2VIA_FN_OK\n";

(* ============================================================================
   SMALL-N CHAIN : for 0<n<=162, exhibit a prime in (n, 2n].
   Chain primes (each < 2x previous): 2,3,5,7,13,23,43,83,163.
     2<2*1? no; chain coverage: for n in [p_{k-1}, p_k - 1], witness p_k.
     2 covers n=1 ; 3 covers n=2 ; 5 covers n in[3,4]; 7 covers n in[5,6];
     13 covers n in[7,12]; 23 covers n in[13,22]; 43 covers n in[23,42];
     83 covers n in[43,82]; 163 covers n in[83,162].
   For interval [lo, hi]=[p_{k-1}, p_k-1] (n with le lo n and le n hi i.e. lt n p_k):
     witness p_k : lt n p_k (n<=hi<p_k) ; le p_k (2n) (p_k<=2*lo<=2*n).
   We split n by le_eq_or_succ_le on le 1 n cascading the lower bound up the chain.
   ============================================================================ *)
val () = out "SMALLN_BEGIN\n";

(* le_double_4 : le a b ==> le (add a a)(add b b) *)
fun le_double_4 (aT,bT) hab =
  let val l1 = le_add_mono_4 (aT,bT,aT) hab          (* le (a+a)(b+a) *)
      val l2 = le_add_mono_4 (aT,bT,bT) hab          (* le (a+b)(b+b) *)
      val cm = addcomm4_at (bT,aT)                    (* oeq (b+a)(a+b) *)
      val l1' = le_cong_r4 (add aT aT, add bT aT, add aT bT) cm l1   (* le (a+a)(a+b) *)
  in le_trans4_at (add aT aT, add aT bT, add bT bT) l1' l2 end;     (* le (a+a)(b+b) *)

(* chain primes (feasible range) and cached prime2 proofs *)
val chainPrimes = [2,3,5,7,13,23,43,83];
val () = out "SMALLN: proving chain prime2 facts (via sqrt-check)...\n";
val chainThms = map (fn pi => (pi, prime2_via_check pi)) chainPrimes;
val () = out ("SMALLN: chain prime2 all-0hyp=" ^
              Bool.toString (List.all (fn (_,th) => zhV4 th) chainThms) ^ "\n");
fun primeThmOf pi =
  case List.find (fn (q,_) => q = pi) chainThms of
    SOME (_, th) => th
  | NONE => raise Fail ("primeThmOf: no chain prime " ^ Int.toString pi);

(* bertrand existential body (matches MAIN goal) :
   %p. Conj (prime2 p)(Conj (lt n p)(le p (2n))) *)
fun bertBodyAbs nF = Term.lambda (Free("p_bw", natT))
   (mkConj (prime2 (Free("p_bw",natT)))
           (mkConj (lt nF (Free("p_bw",natT)))(le (Free("p_bw",natT)) (add nF nF))));

(* mkBertWitness : given chain prime pk (concrete) with hPrime: prime2 pk,
   hLtnpk: lt n pk, hLe2: le pk (2n) -> Ex (bertBodyAbs n) *)
fun mkBertWitness nF pi hLtnpk hLe2 =
  let val pkT = mkNum pi
      val twoN = add nF nF
      val hPrime = primeThmOf pi
      val inner = conjI_4 (lt nF pkT, le pkT twoN) hLtnpk hLe2
      val full  = conjI_4 (prime2 pkT, mkConj (lt nF pkT)(le pkT twoN)) hPrime inner
  in exI_4 (bertBodyAbs nF, pkT) full end;

(* For interval witness : need le pk (2n) from (le lo n).
   le pk (2*lo) [le_eval concrete] ; le (2*lo)(2*n) [le_double from le lo n] ; trans.
   2*lo computed concretely. *)
fun mkLe2 nF lo pi hLoN =     (* hLoN : le (mkNum lo) n ; -> le (mkNum pi)(add n n) *)
  let val loT = mkNum lo
      val twoLo = lo + lo
      val pkT = mkNum pi
      (* le pk (2*lo) : pi <= 2*lo *)
      val le_pk_2lo = le_eval pi twoLo                       (* le (mkNum pi)(mkNum (2*lo)) *)
      (* le (2*lo)(2*n) = le (add lo lo)(add n n) ; but mkNum(2*lo) vs add lo lo : need oeq *)
      val (sumT, sumEq) = add_eval loT loT                  (* oeq (add lo lo) (mkNum (2*lo)) *)
      (* le_double : le (add lo lo)(add n n) *)
      val leDouble = le_double_4 (loT, nF) hLoN              (* le (add lo lo)(add n n) *)
      (* rewrite le_pk_2lo RHS (mkNum 2lo) -> (add lo lo) via sumEq sym *)
      val le_pk_addll = le_cong_r4 (pkT, mkNum twoLo, add loT loT) (oeq_sym OF [sumEq]) le_pk_2lo  (* le pk (add lo lo) *)
  in le_trans4_at (pkT, add loT loT, add nF nF) le_pk_addll leDouble end;  (* le pk (2n) *)

val () = out "SMALLN_INFRA_OK\n";

(* the small-n theorem : lt 0 n ==> lt n 163 ==> Ex (bertBodyAbs n)
   (covers n in [1,162]).  Cascade lower bound from le 1 n up the chain. *)
val bertrand_small =
  let
    val nF = Free("n_sm", natT)
    val oneN = suc ZeroC
    val n83 = mkNum 83
    val hn0  = Thm.assume (ctermV4 (jT (lt ZeroC nF)))    (* lt 0 n = le 1 n *)
    val hlt163 = Thm.assume (ctermV4 (jT (lt nF n83)))   (* lt n 163 = le (Suc n) 163 *)
    val goalEx = mkEx (bertBodyAbs nF)
    (* intervals: (lo, pk) pairs ; lo = lower bound numeral, pk = witness prime.
       boundaries b_k where we split : we have le lo n ; le_eq_or_succ_le (lo, n):
         oeq lo n  -> n = lo (concrete) -> use witness for this value
         le (Suc lo) n -> recurse with lo+1.
       Simpler: cascade value-by-value is O(163) (too slow). Use the chain intervals.
       Plan: from le 1 n, for each chain prime pk in order, split:
         if n < pk : use pk as witness (need le 1<=lo<=n with pk<=2*lo... but lo=prev).
       We track : at step k we KNOW (le prev n) where prev=p_{k-1} (or 1 initially),
       and we case on lt n pk vs le pk n.
         lt n pk : witness pk. need le pk (2n). pk <= 2*prev <= 2*n (le prev n). OK.
         le pk n : recurse with prev:=pk (we now know le pk n). *)
    (* chain with the "previous lower bound" : (lo, pk) where lo is the lower bound
       guaranteeing pk<=2*lo. lo = previous prime (or 1 for pk=2). *)
    val intervals = [(1,2),(2,3),(3,5),(5,7),(7,13),(13,23),(23,43),(43,83)];
    (* recursive cascade over intervals; hLoN : le (mkNum lo_cur) n *)
    fun cascade ivs loCur hLoN =
      case ivs of
        [] =>
          (* exhausted chain : le 163 n (hLoN) ; with hlt163 : le (Suc n) 163 -> le (Suc n) n -> lt_irrefl *)
          let val le163n = hLoN     (* le 163 n *)
          in oFalse_elim_4 goalEx OF [ (lt_irrefl4_at nF) OF [ le_trans4_at (suc nF, n83, nF) hlt163 le163n ] ] end
      | (lo,pk)::rest =>
          let
            val pkT = mkNum pk
            (* le_total n pk -> case lt n pk OR le pk n ; use le_eq_or_succ_le? We need lt n pk vs le pk n.
               le_total (n, pk) : Disj (le n pk)(le pk n). le n pk includes n=pk (pk prime, but n=pk allowed? then witness fails lt n pk).
               Use : le_total (pk, n) : Disj (le pk n)(le n pk).
                 le pk n -> recurse rest with loCur:=pk.
                 le n pk -> n<=pk ; need lt n pk (n<pk). but n=pk possible. Since pk prime and...
               Cleaner: split via le_eq_or_succ_le on (n, pk-1)? messy.
               BEST: le_total (Suc n, pk): Disj (le (Suc n) pk)(le pk (Suc n)).
                 le (Suc n) pk = lt n pk : witness pk.
                 le pk (Suc n) : pk <= Suc n. combine with... hmm n could be pk-1.
               Use le_total (pk, n) and handle le n pk via le_eq_or_succ_le. *)
            val djt = le_total_4 (pkT, nF)    (* Disj (le pk n)(le n pk) *)
            val caseGE =   (* le pk n : recurse *)
              let val hpkn = Thm.assume (ctermV4 (jT (le pkT nF)))
                  val g = cascade rest pk hpkn
              in Thm.implies_intr (ctermV4 (jT (le pkT nF))) g end
            val caseLT =   (* le n pk : n <= pk ; need n < pk (lt n pk). split n=pk vs n<pk. *)
              let val hnpk = Thm.assume (ctermV4 (jT (le nF pkT)))
                  (* le_eq_or_succ_le (n, pk): Disj (oeq n pk)(le (Suc n) pk) *)
                  val dje = le_eq_or_succ_le_4 (nF, pkT) hnpk
                  val caseEqNpk =
                    (* n = pk : then pk is itself > n? no, n=pk. Witness next prime?
                       Actually n=pk : we need prime in (pk, 2pk]. The NEXT chain prime pk' <=2pk works,
                       since pk' <= 2*pk (chain) and pk' > pk = n. Use rest's head prime. *)
                    let val heq = Thm.assume (ctermV4 (jT (oeq nF pkT)))   (* n = pk *)
                        val g =
                          case rest of
                            ((lo2,pk2)::_) =>
                              (* witness pk2 : lt n pk2 (n=pk<pk2) ; le pk2 (2n) (pk2<=2*pk=2*n since n=pk). *)
                              let val pk2T = mkNum pk2
                                  (* lt n pk2 : le (Suc n) pk2 ; n=pk so Suc n = Suc pk ; le (Suc pk) pk2 [lt_eval pk pk2] ; rewrite *)
                                  val lt_pk_pk2 = lt_eval pk pk2     (* le (Suc pk) pk2 *)
                                  val hpkn = oeq_sym OF [heq]        (* oeq pk n *)
                                  val lt_n_pk2 = le_cong_l4 (suc pkT, suc nF, pk2T) (Suc_cong OF [hpkn]) lt_pk_pk2  (* le (Suc n) pk2 = lt n pk2 *)
                                  (* le pk2 (2n) : pk2 <= 2*pk ; 2*pk = 2*n (n=pk) ; *)
                                  val le_pk2_2pk = le_eval pk2 (pk+pk)    (* le pk2 (mkNum (2pk)) *)
                                  val (sumT, sumEq) = add_eval pkT pkT    (* oeq (add pk pk)(mkNum 2pk) *)
                                  (* add n n = add pk pk via heq : oeq (add n n)(add pk pk) *)
                                  val ann_app = oeq_trans OF [ add_cong_l4 (nF, pkT, nF) heq,   (* oeq (add n n)(add pk n) *)
                                                               add_cong_r4 (pkT, nF, pkT) heq ] (* oeq (add pk n)(add pk pk) *)
                                  (* le pk2 (add pk pk) : rewrite le_pk2_2pk RHS *)
                                  val le_pk2_addpp = le_cong_r4 (pk2T, mkNum (pk+pk), add pkT pkT) (oeq_sym OF [sumEq]) le_pk2_2pk
                                  (* le pk2 (add n n) : rewrite (add pk pk)->(add n n) via ann_app sym *)
                                  val le_pk2_2n = le_cong_r4 (pk2T, add pkT pkT, add nF nF) (oeq_sym OF [ann_app]) le_pk2_addpp
                                  val hPrime2 = primeThmOf pk2
                                  val inner = conjI_4 (lt nF pk2T, le pk2T (add nF nF)) lt_n_pk2 le_pk2_2n
                                  val fullc = conjI_4 (prime2 pk2T, mkConj (lt nF pk2T)(le pk2T (add nF nF))) hPrime2 inner
                              in exI_4 (bertBodyAbs nF, pk2T) fullc end
                          | [] =>
                              (* n = 163 : but hlt163 lt n 163 -> le (Suc 163) 163 contra *)
                              let val leSn163 = le_cong_l4 (suc nF, suc pkT, n83) (Suc_cong OF [heq]) hlt163  (* le (Suc pk) 163, pk=163 *)
                                  (* le (Suc 163) 163 = lt 163 163 -> lt_irrefl *)
                                  val ff = (lt_irrefl4_at n83) OF [leSn163]
                              in oFalse_elim_4 goalEx OF [ff] end
                    in Thm.implies_intr (ctermV4 (jT (oeq nF pkT))) g end
                  val caseLtNpk =
                    let val hlt = Thm.assume (ctermV4 (jT (le (suc nF) pkT)))   (* lt n pk *)
                        (* witness pk : le pk (2n) via mkLe2 with lo=loCur (le loCur n) *)
                        val hLe2 = mkLe2 nF loCur pk hLoN
                        val g = mkBertWitness nF pk hlt hLe2
                    in Thm.implies_intr (ctermV4 (jT (le (suc nF) pkT))) g end
                  val g = disjE_4 (oeq nF pkT, le (suc nF) pkT, goalEx) dje caseEqNpk caseLtNpk
              in Thm.implies_intr (ctermV4 (jT (le nF pkT))) g end
            val g = disjE_4 (le pkT nF, le nF pkT, goalEx) djt caseGE caseLT
          in g end
    val concl = cascade intervals 1 hn0    (* hn0 : le 1 n = lt 0 n *)
    val d2 = Thm.implies_intr (ctermV4 (jT (lt nF n83))) concl
    val d1 = Thm.implies_intr (ctermV4 (jT (lt ZeroC nF))) d2
  in varify d1 end;

val () = out ("bertrand_small 0hyp=" ^ Bool.toString (zhV4 bertrand_small) ^ "\n");
val () = out ("bertrand_small : " ^ Syntax.string_of_term ctxtV4 (Thm.prop_of bertrand_small) ^ "\n");
