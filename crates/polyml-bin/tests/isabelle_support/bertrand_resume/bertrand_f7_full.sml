(* ---- binom recursion axioms onto V4 ---- *)
val binom_n_0_v4    = varify binom_n_0_ax;
val binom_0_Suc_v4  = varify binom_0_Suc_ax;
val binom_Suc_Suc_v4= varify binom_Suc_Suc_ax;
fun binomN0_4 t = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 t)] binom_n_0_v4);   (* C(t,0)=1 *)
fun binom0S_4 t = beta_norm (Drule.infer_instantiate ctxtV4 [(("k",0),ctermV4 t)] binom_0_Suc_v4); (* C(0,Suc t)=0 *)
fun binomSS_4 (nt,kt) = beta_norm (Drule.infer_instantiate ctxtV4 [(("n",0),ctermV4 nt),(("k",0),ctermV4 kt)] binom_Suc_Suc_v4); (* C(Suc n,Suc k)=C(n,k)+C(n,Suc k) *)

(* binom_n_1 : oeq (binom m (Suc Zero)) m.   nat_induct on m. *)
fun binom_n_1 mT =
  let
    val zB = Free("z_b1", natT)
    val Pabs = Term.lambda zB (oeq (binom zB (suc ZeroC)) zB)
    val ind = nat_induct_4 (Pabs, mT)
    (* base : C(0,1)=0 *)
    val base = binom0S_4 ZeroC   (* oeq (binom 0 (Suc 0)) 0 *)
    val xF = Free("x_b1", natT)
    val ihP = jT (oeq (binom xF (suc ZeroC)) xF)
    val IH = Thm.assume (ctermV4 ihP)
    (* C(Suc x, 1) = C(Suc x, Suc 0) = C(x,0)+C(x,Suc 0) = 1 + C(x,1) = 1 + x = Suc x *)
    val pasc = binomSS_4 (xF, ZeroC)   (* oeq (binom (Suc x)(Suc 0))(add (binom x 0)(binom x (Suc 0))) *)
    val cx0  = binomN0_4 xF             (* oeq (binom x 0) 1 *)
    (* add (binom x 0)(binom x 1) = add 1 (binom x 1) [cong l] = add 1 x [cong r via IH] = Suc x *)
    val r1 = add_cong_l4 (binom xF ZeroC, suc ZeroC, binom xF (suc ZeroC)) cx0   (* oeq (add (binom x 0)(binom x 1))(add 1 (binom x 1)) *)
    val r2 = add_cong_r4 (suc ZeroC, binom xF (suc ZeroC), xF) IH                (* oeq (add 1 (binom x 1))(add 1 x) *)
    val a1x = oeq_trans OF [add_Suc4_at (ZeroC, xF), Suc_cong OF [add04_at xF]]  (* oeq (add 1 x)(Suc x) *)
    val chain = oeq_trans OF [pasc, oeq_trans OF [r1, oeq_trans OF [r2, a1x]]]    (* oeq (binom (Suc x)(Suc 0))(Suc x) *)
    val step = Thm.forall_intr (ctermV4 xF) (Thm.implies_intr (ctermV4 ihP) chain)
  in Thm.implies_elim (Thm.implies_elim ind base) step end;

