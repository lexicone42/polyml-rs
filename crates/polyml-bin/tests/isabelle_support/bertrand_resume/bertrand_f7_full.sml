  in (inst OF [hle]) OF [hneq] end;
fun pow_le_exp_4 (pt,it,jt_) hpos hle =
  let val inst = beta_norm (Drule.infer_instantiate ctxtV4 [(("p",0),ctermV4 pt),(("i",0),ctermV4 it),(("j",0),ctermV4 jt_)] pow_le_exp_v4)
  in (inst OF [hpos]) OF [hle] end;
fun pow_le_mono_base_4 (at,bt,nt) hle =
