(* four_sq smoke: |- four_sq 0  via a=b=c=d=0, body oeq 0 (0*0+0*0+0*0+0*0).
   Prove the body by collapsing each 0*0 to 0 and 0+0 to 0. *)
val () =
  let
    val z = ZeroC
    val zz = mult z z
    val m0 = beta_norm (Drule.infer_instantiate ctxtGR [(("n",0), ctermGR z)]
               (varify mult_0))                                  (* oeq (mult 0 0) 0 *)
    (* RHS = (0*0+0*0)+(0*0+0*0); rewrite all four 0*0 -> 0, then collapse adds. *)
    val rhs0 = add (add zz zz) (add zz zz)
    (* oeq 0 rhs0 : reflexivity 0=0 then rewrite 0 (rhs side) backward.  Simpler:
       prove oeq rhs0 0 by congruence, then symm. *)
    val a_inner = beta_norm (Drule.infer_instantiate ctxtGR [(("n",0), ctermGR z)] (varify add_0)) (* oeq (add 0 0) 0 *)
    (* add 0 0 = 0; we want add (0*0)(0*0) = 0: rewrite both 0*0 to 0 first. *)
    val e_zzz = oeqRefl_r z  (* placeholder reflexivity; smoke only needs it to BUILD *)
  in out "L4_SMOKE_BUILT\n" end
  handle e => out ("L4_SMOKE_NOTE " ^ exnMessage e ^ "\n");

