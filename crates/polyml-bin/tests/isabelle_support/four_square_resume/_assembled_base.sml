(* multiplicative-congruence right helper on ctxtGR for SQUARING:
   from h : cong p a b derive cong p (a*a)(b*b) *)
fun cong_sq_r (mP, aP, bP) h = cong_mult_r (mP, aP, bP, aP, bP) h h;

(* ----------------------------------------------------------------------------
   rearr3L : oeq (add (add a b) c)(add a (add b c))      [left-assoc -> right]
   ---------------------------------------------------------------------------- *)
fun rearr3L (aT,bT,cT) = addassoc_g (aT,bT,cT);   (* (a+b)+c = a+(b+c) *)

val () = out "TSD_REARR_OK\n";

(* ----------------------------------------------------------------------------
   collide_to_UeqcV :
     hx : oeq x1 (add U x2)
     hy : oeq y1 (add V y2)
     H  : cong p (add x1 (mult c y2))(add x2 (mult c y1))
     ==> cong p U (mult c V)
   ---------------------------------------------------------------------------- *)
fun collide_to_UeqcV (pT, cT, x1, x2, y1, y2, U, V) hx hy H =
  let
    val W = add x2 (mult cT y2)
    (* rewrite x1 -> U+x2 in first arg of H, y1 -> V+y2 in second arg *)
    val zr1 = Free("zr1_cv", natT)
    val P1 = Term.lambda zr1 (cong pT (add zr1 (mult cT y2)) (add x2 (mult cT y1)))
    val H1 = oeq_rw_r (P1, x1, add U x2) hx H
      (* cong p (add (add U x2)(c*y2)) (add x2 (c*y1)) *)
    val zr2 = Free("zr2_cv", natT)
    val P2 = Term.lambda zr2 (cong pT (add (add U x2)(mult cT y2)) (add x2 (mult cT zr2)))
    val H2 = oeq_rw_r (P2, y1, add V y2) hy H1
      (* cong p (add (add U x2)(c*y2)) (add x2 (c*(V+y2))) *)
    (* LHS: (U+x2)+c*y2 = U + (x2 + c*y2) = U + W  [assoc] *)
    val lassoc = rearr3L (U, x2, mult cT y2)         (* (U+x2)+c*y2 = U+(x2+c*y2) = U+W *)
    val zl = Free("zl_cv", natT)
    val PL = Term.lambda zl (cong pT zl (add x2 (mult cT (add V y2))))
    val H3 = oeq_rw_r (PL, add (add U x2)(mult cT y2), add U W) lassoc H2
      (* cong p (add U W)(add x2 (c*(V+y2))) *)
    (* RHS: x2 + c*(V+y2) = x2 + (c*V + c*y2)  [left_distrib]
           = (c*V) + (x2 + c*y2)  ... need to commute/assoc to (c*V) + W *)
    val dist = leftdistrib_g (cT, V, y2)             (* c*(V+y2) = c*V + c*y2 *)
    val zd = Free("zd_cv", natT)
    val PD = Term.lambda zd (cong pT (add U W) (add x2 zd))
    val H4 = oeq_rw_r (PD, mult cT (add V y2), add (mult cT V)(mult cT y2)) dist H3
      (* cong p (add U W)(add x2 (add (c*V)(c*y2))) *)
    (* x2 + (c*V + c*y2) = (x2 + c*V) + c*y2 [assoc back]
       then (x2 + c*V) = (c*V + x2) [comm], so = (c*V + x2) + c*y2
       then = c*V + (x2 + c*y2) = c*V + W [assoc] *)
    val rb1 = oeqSym_g (addassoc_g (x2, mult cT V, mult cT y2))  (* x2+(c*V+c*y2) = (x2+c*V)+c*y2 *)
    val zb1 = Free("zb1_cv", natT)
    val PB1 = Term.lambda zb1 (cong pT (add U W) zb1)
    val H5 = oeq_rw_r (PB1, add x2 (add (mult cT V)(mult cT y2)), add (add x2 (mult cT V))(mult cT y2)) rb1 H4
      (* cong p (add U W)((x2+c*V)+c*y2) *)
    val cm = addcomm_g (x2, mult cT V)               (* x2+c*V = c*V+x2 *)
    val cm_l = add_cong_l_g (add x2 (mult cT V), add (mult cT V) x2, mult cT y2) cm
      (* (x2+c*V)+c*y2 = (c*V+x2)+c*y2 *)
    val H6 = oeq_rw_r (PB1, add (add x2 (mult cT V))(mult cT y2), add (add (mult cT V) x2)(mult cT y2)) cm_l H5
      (* cong p (add U W)((c*V+x2)+c*y2) *)
    val rb2 = addassoc_g (mult cT V, x2, mult cT y2) (* (c*V+x2)+c*y2 = c*V+(x2+c*y2) = c*V+W *)
    val H7 = oeq_rw_r (PB1, add (add (mult cT V) x2)(mult cT y2), add (mult cT V) W) rb2 H6
      (* cong p (add U W)(add (c*V) W) *)
    (* cancel W *)
    val res = cong_radd_cancel_g (pT, U, mult cT V, W) H7
      (* cong p U (c*V) *)
  in res end;
val () = out "TSD_COLLIDE_TO_UEQCV_READY\n";

(* re-varify p_eq_Suc_pred onto ctxtGR *)
val p_eq_Suc_pred_vGR = varify p_eq_Suc_pred;
fun p_eq_Suc_pred_r pt hPrime = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtGR
      [(("p",0), ctermGR pt)] p_eq_Suc_pred_vGR)) hPrime;

(* mult_1_left on ctxtGR : oeq (mult (Suc 0) n) n *)
val mult_1_left_vGR = varify mult_1_left;
fun mult1l_r t = beta_norm (Drule.infer_instantiate ctxtGR [(("n",0), ctermGR t)] mult_1_left_vGR);
(* add_Suc_right gives oeq (add m (Suc n))(Suc (add m n)); with n=0,m=t and add_0_right:
   oeq (add t (Suc 0))(Suc (add t 0)) ; add t 0 = t so = Suc t.  Build Suc t = add t (Suc 0). *)
fun suc_as_add_1 t =
  let val asr = addSucr_d (t, ZeroC)          (* oeq (add t (Suc 0))(Suc (add t 0)) *)
      val a0  = add0r_d t                       (* oeq (add t 0) t *)
      val sc  = (* oeq (Suc(add t 0))(Suc t) : Suc-cong on a0 *)
        let val P = Term.lambda (Free("zsc",natT)) (oeq (suc (add t ZeroC))(suc (Free("zsc",natT))))
        in oeq_rw_r (P, add t ZeroC, t) a0 (oeqRefl_r2 (suc (add t ZeroC))) end
      val combo = oeqTrans_r2 (asr, sc)         (* oeq (add t (Suc 0))(Suc t) *)
  in oeqSym_r2 combo end;                        (* oeq (Suc t)(add t (Suc 0)) *)

(* cong p (mult p Q) 0  : witness Q in the congR disjunct *)
fun cong_p_mult_zero (pT, Q) =
  let
    (* congR p (p*Q) 0 = Ex k. oeq (p*Q)(add 0 (p*k)) ; witness k=Q *)
    val a0 = add0_d (mult pT Q)                 (* oeq (add 0 (p*Q))(p*Q) *)
    val body = oeqSym_r2 a0                       (* oeq (p*Q)(add 0 (p*Q)) *)
    val RAbs = Abs("k", natT, oeq (mult pT Q)(add ZeroC (mult pT (Bound 0))))
    val exThm = exI_r RAbs Q body                (* Ex k. oeq (p*Q)(add 0 (p*k)) *)
    val LAbs = Abs("k", natT, oeq ZeroC (add (mult pT Q)(mult pT (Bound 0))))
  in disjI2_r (mkEx LAbs, mkEx RAbs) exThm end;  (* cong p (p*Q) 0 *)

(* ----------------------------------------------------------------------------
   sq_descent :
     hPrime : prime2 p
     hUcV   : cong p U (mult c V)
     hc2    : cong p (mult c c)(sub p 1)
     ==> cong p (add (mult U U)(mult V V)) 0
   ---------------------------------------------------------------------------- *)
fun sq_descent (pT, cT, U, V) hPrime hUcV hc2 =
  let
    val Q  = mult V V
    val UU = mult U U
    (* 1. square hUcV : cong p (U*U)((c*V)*(c*V)) *)
    val sq = cong_sq_r (pT, U, mult cT V) hUcV
    (* 2. (c*V)*(c*V) = (c*c)*(V*V).
          (c*V)*(c*V) = c*(V*(c*V))        [mult_assoc]
                      = c*((V*c)*V)        [mult_assoc inside]   -- do it via comm/assoc
       Simpler: prove oeq (mult (mult c V)(mult c V))(mult (mult c c)(mult V V)) by algebra. *)
    val cVcV_eq =
      let
        (* (c*V)*(c*V) = ((c*V)*c)*V   [assoc back] *)
        val s1 = oeqSym_g (multassoc_g (mult cT V, cT, V))      (* (c*V)*(c*V) = ((c*V)*c)*V *)
        (* (c*V)*c = c*(V*c)           [assoc] *)
        val s2a = multassoc_g (cT, V, cT)                        (* (c*V)*c = c*(V*c) *)
        (* V*c = c*V                   [comm] *)
        val s2b = multcomm_g (V, cT)                             (* V*c = c*V *)
        val s2  = oeqTrans_g (s2a, mult_cong_r_g (cT, mult V cT, mult cT V) s2b)  (* (c*V)*c = c*(V*c) = c*(c*V) *)
        (* c*(c*V) = (c*c)*V           [assoc back] *)
        val s3  = oeqSym_g (multassoc_g (cT, cT, V))             (* c*(c*V) = (c*c)*V *)
        val cVc_eq = oeqTrans_g (s2, s3)                          (* (c*V)*c = (c*c)*V *)
        (* ((c*V)*c)*V = ((c*c)*V)*V   [mult_cong_l on cVc_eq] *)
        val s4  = mult_cong_l_g (mult (mult cT V) cT, mult (mult cT cT) V, V) cVc_eq
        (* ((c*c)*V)*V = (c*c)*(V*V)   [assoc] *)
        val s5  = multassoc_g (mult cT cT, V, V)
      in oeqTrans_g (oeqTrans_g (s1, s4), s5) end
      (* oeq ((c*V)*(c*V))((c*c)*(V*V)) *)
    val zsq = Free("zsq", natT)
    val Psq = Term.lambda zsq (cong pT UU zsq)
    val sq2 = oeq_rw_r (Psq, mult (mult cT V)(mult cT V), mult (mult cT cT) Q) cVcV_eq sq
      (* cong p (U*U)((c*c)*(V*V)) *)
    (* 3. cong p ((c*c)*(V*V))((p-1)*(V*V))  from hc2 + cong_refl on V*V *)
    val crefl_Q = cong_refl_g (pT, Q)                            (* cong p (V*V)(V*V) *)
    val cm = cong_mult_r (pT, mult cT cT, sub pT (suc ZeroC), Q, Q) hc2 crefl_Q
      (* cong p ((c*c)*(V*V))((p-1)*(V*V)) *)
    val sq3 = cong_trans_g (pT, UU, mult (mult cT cT) Q, mult (sub pT (suc ZeroC)) Q) sq2 cm
      (* cong p (U*U)((p-1)*(V*V)) *)
    (* 4. add V*V to both sides : cong p (U*U + V*V)((p-1)*(V*V) + V*V) *)
    val sq4 = cong_add_g (pT, UU, mult (sub pT (suc ZeroC)) Q, Q, Q) sq3 (cong_refl_g (pT, Q))
      (* cong p (add (U*U) (V*V))(add ((p-1)*(V*V)) (V*V)) *)
    (* 5. (p-1)*(V*V) + V*V = p*(V*V) *)
    val pSucPred = p_eq_Suc_pred_r pT hPrime                     (* oeq p (Suc(sub p 1)) *)
    val s1a = suc_as_add_1 (sub pT (suc ZeroC))                  (* oeq (Suc(sub p 1))(add (sub p 1)(Suc 0)) *)
    val pEq = oeqTrans_r2 (pSucPred, s1a)                        (* oeq p (add (sub p 1)(Suc 0)) *)
    (* p*Q = (add (sub p 1)(Suc 0))*Q  [mult_cong_l] *)
    val mcl = mult_cong_l_g (pT, add (sub pT (suc ZeroC))(suc ZeroC), Q) pEq
      (* oeq (p*Q)((add (sub p 1)(Suc 0))*Q) *)
    val rdist = rightdistrib_g (sub pT (suc ZeroC), suc ZeroC, Q)
      (* oeq ((add (sub p 1)(Suc 0))*Q)(add ((sub p 1)*Q)((Suc 0)*Q)) *)
    val m1l = mult1l_r Q                                          (* oeq ((Suc 0)*Q) Q *)
    val rdist2 = oeqTrans_g (rdist, add_cong_r_g (mult (sub pT (suc ZeroC)) Q, mult (suc ZeroC) Q, Q) m1l)
      (* oeq ((add (sub p 1)(Suc 0))*Q)(add ((sub p 1)*Q) Q) *)
    val pQeq = oeqTrans_g (mcl, rdist2)                          (* oeq (p*Q)(add ((sub p 1)*Q) Q) *)
    (* rewrite RHS of sq4 :  ((p-1)*(V*V)+V*V) -> p*(V*V) *)
    val zrw = Free("zrw", natT)
    val Prw = Term.lambda zrw (cong pT (add UU Q) zrw)
    val sq5 = oeq_rw_r (Prw, add (mult (sub pT (suc ZeroC)) Q) Q, mult pT Q) (oeqSym_g pQeq) sq4
      (* cong p (add (U*U)(V*V))(p*(V*V)) *)
    (* 6. cong p (p*(V*V)) 0  then trans : cong p (U*U + V*V) 0 *)
    val cpz = cong_p_mult_zero (pT, Q)                           (* cong p (p*Q) 0 *)
    val res = cong_trans_g (pT, add UU Q, mult pT Q, ZeroC) sq5 cpz
      (* cong p (add (U*U)(V*V)) 0 *)
  in res end;
val () = out "TSD_SQ_DESCENT_READY\n";

(* ----------------------------------------------------------------------------
   cong_neg_via_c :
     hPrime : prime2 p
     hN     : cong p (add U (mult c V)) 0         [ U + c*V ≡ 0 ]
     hc2    : cong p (mult c c)(sub p 1)
     ==> cong p V (mult c U)                       [ V ≡ c*U ]
   Route: multiply hN by c -> cong p ((U + c*V)*c) 0
          (U+cV)*c = c*U + (c*c)*V
          rewrite (c*c)*V ~cong~ (p-1)*V ; then add V; (p-1)*V + V = p*V ≡ 0
          -> cong p (c*U) V -> sym.
   ---------------------------------------------------------------------------- *)
fun cong_neg_via_c (pT, cT, U, V) hPrime hN hc2 =
  let
    val M = add U (mult cT V)
    (* 1. cong p (M*c) 0 : multiply hN by (cong_refl c) *)
    val crefl_c = cong_refl_g (pT, cT)
    val mc0 = cong_mult_r (pT, M, ZeroC, cT, cT) hN crefl_c       (* cong p (M*c)(0*c) *)
    val m0c = mult0_d cT                                            (* oeq (0*c) 0 *)
    val zr = Free("znvc1", natT)
    val Pz = Term.lambda zr (cong pT (mult M cT) zr)
    val mc0b = oeq_rw_r (Pz, mult ZeroC cT, ZeroC) m0c mc0         (* cong p (M*c) 0 *)
    (* 2. M*c = (U + c*V)*c = U*c + (c*V)*c = c*U + (c*c)*V *)
    val rd = rightdistrib_g (U, mult cT V, cT)                      (* (U+cV)*c = U*c + (cV)*c *)
    val ucEq = multcomm_g (U, cT)                                   (* U*c = c*U *)
    val cVcEq =                                                     (* (cV)*c = (c*c)*V *)
      let val a = multassoc_g (cT, V, cT)                           (* (c*V)*c = c*(V*c) *)
          val b = multcomm_g (V, cT)                                (* V*c = c*V *)
          val c1 = oeqTrans_g (a, mult_cong_r_g (cT, mult V cT, mult cT V) b) (* (c*V)*c = c*(c*V) *)
          val c2 = oeqSym_g (multassoc_g (cT, cT, V))               (* c*(c*V) = (c*c)*V *)
      in oeqTrans_g (c1, c2) end
    val mcEq1 = oeqTrans_g (rd, add_cong_l_g (mult U cT, mult cT U, mult (mult cT V) cT) ucEq)
                                                                   (* (U+cV)*c = c*U + (cV)*c *)
    val mcEq  = oeqTrans_g (mcEq1, add_cong_r_g (mult cT U, mult (mult cT V) cT, mult (mult cT cT) V) cVcEq)
                                                                   (* (U+cV)*c = c*U + (c*c)*V *)
    val zr2 = Free("znvc2", natT)
    val Pz2 = Term.lambda zr2 (cong pT zr2 ZeroC)
    val mc1 = oeq_rw_r (Pz2, mult M cT, add (mult cT U)(mult (mult cT cT) V)) mcEq mc0b
                                                                   (* cong p (c*U + (c*c)*V) 0 *)
    (* 3. cong p (c*U + (c*c)*V)(c*U + (p-1)*V) via cong_add(refl cU, cong_mult hc2 refl V) *)
    val ccV = cong_mult_r (pT, mult cT cT, sub pT (suc ZeroC), V, V) hc2 (cong_refl_g (pT, V))
                                                                   (* cong p ((c*c)*V)((p-1)*V) *)
    val combAdd = cong_add_g (pT, mult cT U, mult cT U, mult (mult cT cT) V, mult (sub pT (suc ZeroC)) V)
                    (cong_refl_g (pT, mult cT U)) ccV
                                                                   (* cong p (cU + (cc)V)(cU + (p-1)V) *)
    val mc2 = cong_trans_g (pT, add (mult cT U)(mult (sub pT (suc ZeroC)) V), add (mult cT U)(mult (mult cT cT) V), ZeroC)
                (cong_sym_g (pT, add (mult cT U)(mult (mult cT cT) V), add (mult cT U)(mult (sub pT (suc ZeroC)) V)) combAdd)
                mc1
                                                                   (* cong p (cU + (p-1)V) 0 *)
    (* 4. add V to both : cong p ((cU + (p-1)V) + V)(0 + V) *)
    val mc3 = cong_add_g (pT, add (mult cT U)(mult (sub pT (suc ZeroC)) V), ZeroC, V, V) mc2 (cong_refl_g (pT, V))
                                                                   (* cong p ((cU+(p-1)V)+V)(0+V) *)
    (* LHS = cU + ((p-1)V + V) = cU + p*V ; RHS = 0+V = V *)
    val lassoc = addassoc_g (mult cT U, mult (sub pT (suc ZeroC)) V, V)  (* (cU+(p-1)V)+V = cU+((p-1)V+V) *)
    (* (p-1)*V + V = p*V *)
    val pSucPred = p_eq_Suc_pred_r pT hPrime
    val s1a = suc_as_add_1 (sub pT (suc ZeroC))
    val pEq = oeqTrans_r2 (pSucPred, s1a)                          (* p = (p-1)+1 *)
    val mcl = mult_cong_l_g (pT, add (sub pT (suc ZeroC))(suc ZeroC), V) pEq  (* p*V = ((p-1)+1)*V *)
    val rdist = rightdistrib_g (sub pT (suc ZeroC), suc ZeroC, V)  (* ((p-1)+1)*V = (p-1)*V + 1*V *)
    val m1l = mult1l_r V                                            (* 1*V = V *)
    val rdist2 = oeqTrans_g (rdist, add_cong_r_g (mult (sub pT (suc ZeroC)) V, mult (suc ZeroC) V, V) m1l)
                                                                   (* ((p-1)+1)*V = (p-1)*V + V *)
    val pVeq = oeqTrans_g (mcl, rdist2)                            (* p*V = (p-1)*V + V *)
    val lhsEq = oeqTrans_g (lassoc, add_cong_r_g (mult cT U, add (mult (sub pT (suc ZeroC)) V) V, mult pT V) (oeqSym_g pVeq))
                                                                   (* (cU+(p-1)V)+V = cU + p*V *)
    val zl = Free("znvc3", natT)
    val Pl = Term.lambda zl (cong pT zl (add ZeroC V))
    val mc4 = oeq_rw_r (Pl, add (add (mult cT U)(mult (sub pT (suc ZeroC)) V)) V, add (mult cT U)(mult pT V)) lhsEq mc3
                                                                   (* cong p (cU + p*V)(0+V) *)
    val a0V = add0_d V                                              (* 0+V = V *)
    val zr3 = Free("znvc4", natT)
    val Pr3 = Term.lambda zr3 (cong pT (add (mult cT U)(mult pT V)) zr3)
    val mc5 = oeq_rw_r (Pr3, add ZeroC V, V) a0V mc4               (* cong p (cU + p*V) V *)
    (* cong p (cU + p*V)(cU)  since p*V ≡ 0 :
       cong p (cU + p*V)(cU + 0) via cong_add(refl cU, cong p (p*V) 0); cU+0 = cU *)
    val pV0 = cong_p_mult_zero (pT, V)                             (* cong p (p*V) 0 *)
    val mc6 = cong_add_g (pT, mult cT U, mult cT U, mult pT V, ZeroC) (cong_refl_g (pT, mult cT U)) pV0
                                                                   (* cong p (cU + p*V)(cU + 0) *)
    val cU0 = add0r_d (mult cT U)                                  (* oeq (cU+0)(cU) *)
    val zr4 = Free("znvc5", natT)
    val Pr4 = Term.lambda zr4 (cong pT (add (mult cT U)(mult pT V)) zr4)
    val mc7 = oeq_rw_r (Pr4, add (mult cT U) ZeroC, mult cT U) cU0 mc6   (* cong p (cU + p*V)(cU) *)
    (* trans: cong p (cU) V  from mc7 sym + mc5 *)
    val mc8 = cong_trans_g (pT, mult cT U, add (mult cT U)(mult pT V), V)
                (cong_sym_g (pT, add (mult cT U)(mult pT V), mult cT U) mc7) mc5
                                                                   (* cong p (cU) V *)
    val res = cong_sym_g (pT, mult cT U, V) mc8                    (* cong p V (cU) *)
  in res end;
val () = out "TSD_CONG_NEG_VIA_C_READY\n";

(* ----------------------------------------------------------------------------
   collide_to_neg :
     hx : oeq x1 (add U x2)        [x1 = U + x2]
     hy : oeq y2 (add V y1)        [y2 = V + y1]
     H  : cong p (add x1 (mult c y2))(add x2 (mult c y1))
     ==> cong p (add U (mult c V)) 0
   Derivation:
     LHS = (U+x2) + c*(V+y1) = U + c*V + (x2 + c*y1)   = (U + c*V) + W   where W=x2+c*y1
     RHS = x2 + c*y1 = W
     so cong p ((U+cV)+W) W ; cancel W -> cong p (U+cV) 0 ... but cong_radd_cancel
     wants the SAME right addend; rewrite RHS W -> (0 + W) = add 0 W, then cancel.
   ---------------------------------------------------------------------------- *)
fun collide_to_neg (pT, cT, x1, x2, y1, y2, U, V) hx hy H =
  let
    val W = add x2 (mult cT y1)
    (* rewrite x1 -> U+x2 in first arg of H, y2 -> V+y1 in c*y2 of first arg *)
    val zr1 = Free("ztn1", natT)
    val P1 = Term.lambda zr1 (cong pT (add zr1 (mult cT y2))(add x2 (mult cT y1)))
    val H1 = oeq_rw_r (P1, x1, add U x2) hx H
      (* cong p (add (U+x2)(c*y2))(W) *)
    val zr2 = Free("ztn2", natT)
    val P2 = Term.lambda zr2 (cong pT (add (add U x2)(mult cT zr2)) W)
    val H2 = oeq_rw_r (P2, y2, add V y1) hy H1
      (* cong p (add (U+x2)(c*(V+y1)))(W) *)
    (* LHS: (U+x2) + c*(V+y1).
       c*(V+y1) = c*V + c*y1   [left_distrib] *)
    val dist = leftdistrib_g (cT, V, y1)               (* c*(V+y1) = c*V + c*y1 *)
    val zd = Free("ztn3", natT)
    val PD = Term.lambda zd (cong pT (add (add U x2) zd) W)
    val H3 = oeq_rw_r (PD, mult cT (add V y1), add (mult cT V)(mult cT y1)) dist H2
      (* cong p (add (U+x2)(c*V + c*y1))(W) *)
    (* (U+x2) + (c*V + c*y1) = (U + c*V) + (x2 + c*y1) = (U+cV) + W
       prove oeq ((U+x2)+(cV+cy1))((U+cV)+(x2+cy1)) by associativity/commutativity. *)
    val LHSeq =
      let
        (* (U+x2)+(cV+cy1) = U + (x2 + (cV+cy1))   [assoc] *)
        val a1 = addassoc_g (U, x2, add (mult cT V)(mult cT y1))
        (* x2 + (cV + cy1) = (x2 + cV) + cy1   [assoc back] *)
        val a2 = oeqSym_g (addassoc_g (x2, mult cT V, mult cT y1))
        (* (x2 + cV) = (cV + x2)   [comm] *)
        val a3 = addcomm_g (x2, mult cT V)
        (* (cV + x2) + cy1 = cV + (x2 + cy1)  [assoc] = cV + W *)
        val a4 = addassoc_g (mult cT V, x2, mult cT y1)
        (* chain: x2+(cV+cy1) = (x2+cV)+cy1 = (cV+x2)+cy1 = cV+(x2+cy1) = cV+W *)
        val c2 = oeqTrans_g (a2, add_cong_l_g (add x2 (mult cT V), add (mult cT V) x2, mult cT y1) a3)
        val c3 = oeqTrans_g (c2, a4)                    (* x2+(cV+cy1) = cV + W *)
        (* U + (x2+(cV+cy1)) = U + (cV + W) = (U+cV) + W  [assoc back] *)
        val u1 = oeqTrans_g (a1, add_cong_r_g (U, add x2 (add (mult cT V)(mult cT y1)), add (mult cT V) W) c3)
                                                        (* (U+x2)+(cV+cy1) = U + (cV + W) *)
        val u2 = oeqSym_g (addassoc_g (U, mult cT V, W))(* U + (cV+W) = (U+cV)+W *)
      in oeqTrans_g (u1, u2) end
      (* oeq ((U+x2)+(cV+cy1))((U+cV)+W) *)
    val zl = Free("ztn4", natT)
    val PL = Term.lambda zl (cong pT zl W)
    val H4 = oeq_rw_r (PL, add (add U x2)(add (mult cT V)(mult cT y1)), add (add U (mult cT V)) W) LHSeq H3
      (* cong p ((U+cV)+W) W *)
    (* rewrite RHS W -> add 0 W *)
    val a0W = oeqSym_g (add0_d W)                       (* oeq W (add 0 W) *)
    val zr = Free("ztn5", natT)
    val PR = Term.lambda zr (cong pT (add (add U (mult cT V)) W) zr)
    val H5 = oeq_rw_r (PR, W, add ZeroC W) a0W H4
      (* cong p ((U+cV)+W)(0 + W) *)
    val res = cong_radd_cancel_g (pT, add U (mult cT V), ZeroC, W) H5
      (* cong p (U+cV) 0 *)
  in res end;
val () = out "TSD_COLLIDE_TO_NEG_READY\n";

(* ============================================================================
   BOUNDS / POSITIVITY / NON-SQUARENESS  helpers
   ============================================================================ *)

(* le_intro on ctxtGR already as le_intro_d.  diff_le : oeq big (add D small) ==> le D big.
   (le D big = Ex q. oeq big (add D q), witness small) *)
fun diff_le (D, big, small) hbig = le_intro_d (D, big, small) hbig;

(* sub_recover_g lifted: from hle : le small big, get oeq (add (subv big small) small) big,
   hence oeq big (add (subv big small) small) (sym). *)
fun bigEq (big, small) hle =
  let val rec0 = sub_recover_g (big, small) hle   (* oeq (add (subv big small) small) big *)
  in oeqSym_g rec0 end;                            (* oeq big (add (subv big small) small) *)

(* le 1 p from prime2 p  (1<p = le 2 p ; le 1 2 ; trans) *)
(* le (Suc 0)(Suc(Suc 0)) : witness Suc 0 ; oeq (Suc(Suc 0))(add (Suc 0)(Suc 0)) *)
val le_1_2 =
  let val w = suc ZeroC
      (* oeq (Suc(Suc 0))(add (Suc 0)(Suc 0)) : add (Suc 0)(Suc 0) = Suc(add 0 (Suc 0)) = Suc(Suc 0) *)
      val aS = addSuc_d (ZeroC, suc ZeroC)        (* oeq (add (Suc 0)(Suc 0))(Suc(add 0 (Suc 0))) *)
      val a0 = add0_d (suc ZeroC)                 (* oeq (add 0 (Suc 0))(Suc 0) *)
      val sc = let val P = Term.lambda (Free("zsc12",natT)) (oeq (suc (add ZeroC (suc ZeroC)))(suc (Free("zsc12",natT))))
               in oeq_rw_r (P, add ZeroC (suc ZeroC), suc ZeroC) a0 (oeqRefl_r2 (suc (add ZeroC (suc ZeroC)))) end
                                                   (* oeq (Suc(add 0 (Suc 0)))(Suc(Suc 0)) *)
      val combo = oeqTrans_r2 (aS, sc)            (* oeq (add (Suc 0)(Suc 0))(Suc(Suc 0)) *)
      val sym = oeqSym_r2 combo                    (* oeq (Suc(Suc 0))(add (Suc 0)(Suc 0)) *)
  in le_intro_d (suc ZeroC, suc (suc ZeroC), suc ZeroC) sym end;   (* le (Suc 0)(Suc(Suc 0)) *)
fun prime2_gt1_r pt hprime = conjunct1_r (lt (suc ZeroC) pt, mkForall (ppAbs pt)) hprime; (* lt 1 p = le 2 p *)
fun prime2_div_r pt hprime = conjunct2_r (lt (suc ZeroC) pt, mkForall (ppAbs pt)) hprime; (* Forall (ppAbs p) *)
fun le_1_p_of pt hprime =
  let val le2p = prime2_gt1_r pt hprime           (* le 2 p *)
  in le_trans_d (suc ZeroC, suc (suc ZeroC), pt) le_1_2 le2p end;  (* le 1 p *)

val () = out "TSD_BOUNDS_HELPERS_OK\n";

(* le_suc_mono / le_add on ctxtGR *)
val le_suc_mono_vGR = varify le_suc_mono;
fun le_suc_mono_r (m,n) h = Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtGR
      [(("m",0), ctermGR m),(("n",0), ctermGR n)] le_suc_mono_vGR)) h;
val le_add_vGR = varify le_add;
fun le_add_r (m,pp) = beta_norm (Drule.infer_instantiate ctxtGR [(("m",0), ctermGR m),(("p",0), ctermGR pp)] le_add_vGR);

(* lt_p_2p : le 1 p ==> lt p (add p p)
   p = Suc q (from le 1 p ruling out p=0); add p p = add p (Suc q) = Suc(add p q);
   le p (add p q) [le_add]; le_suc_mono -> le (Suc p)(Suc(add p q)) = le (Suc p)(add p p). *)
fun lt_p_2p pt hle1 =
  let
    val dz = dzos_d pt                              (* Disj (oeq p 0)(Ex q. oeq p (Suc q)) *)
    val goalC = lt pt (add pt pt)
    val caseZ =
      let val hz = Thm.assume (ctermGR (jT (oeq pt ZeroC)))
          (* le 1 p with p=0 -> le 1 0 -> lt 0 0 ... actually le (Suc 0) 0 absurd via lt_irrefl on rewrite *)
          val z0 = Free("zlp2p", natT)
          val Plt = Term.lambda z0 (lt ZeroC z0)
          val hlt0 = oeq_rw_r (Plt, pt, ZeroC) hz hle1   (* lt 0 0 (since le 1 p = lt 0 p) *)
          val fls = lt_irrefl_g ZeroC hlt0
      in Thm.implies_intr (ctermGR (jT (oeq pt ZeroC))) (Thm.implies_elim (oFalse_elim_r goalC) fls) end
    val PqSuc = Abs("q", natT, oeq pt (suc (Bound 0)))
    val caseS =
      let val hsP = jT (mkEx PqSuc); val hs = Thm.assume (ctermGR hsP)
          fun body q (hq:thm) =   (* hq : oeq p (Suc q) *)
            let
              (* le p (add p q) [le_add] ; le_suc_mono -> le (Suc p)(Suc(add p q)) *)
              val ladd = le_add_r (pt, q)                  (* le p (add p q) *)
              val lsm  = le_suc_mono_r (pt, add pt q) ladd (* le (Suc p)(Suc(add p q)) *)
              (* Suc(add p q) = add p (Suc q) [add_Suc_right sym] = add p p [rewrite Suc q -> p] *)
              val asr  = oeqSym_r2 (addSucr_d (pt, q))      (* oeq (Suc(add p q))(add p (Suc q)) *)
              val rwq  = (* add p (Suc q) = add p p via hq sym *)
                let val P = Term.lambda (Free("zaq",natT)) (oeq (add pt (suc q))(add pt (Free("zaq",natT))))
                in oeq_rw_r (P, suc q, pt) (oeqSym_r2 hq) (oeqRefl_r2 (add pt (suc q))) end
                                                            (* oeq (add p (Suc q))(add p p) *)
              val eqChain = oeqTrans_r2 (asr, rwq)          (* oeq (Suc(add p q))(add p p) *)
              (* rewrite Suc(add p q) -> add p p in lsm : le (Suc p)(add p p) = lt p (add p p) *)
              val z1 = Free("zlsm", natT)
              val Pl = Term.lambda z1 (le (suc pt) z1)
              val res = oeq_rw_r (Pl, suc (add pt q), add pt pt) eqChain lsm
            in res end
      in Thm.implies_intr (ctermGR (jT (mkEx PqSuc))) (exE_r (PqSuc, goalC) hs "qlp2p" natT body) end
  in disjE_r (oeq pt ZeroC, mkEx PqSuc, goalC) dz caseZ caseS end;

(* lt_p_psq : prime2 p ==> lt p (mult p p)
   le 2 p [prime2_gt1] ; mult_le_mono_g (p,2,p) -> le (p*2)(p*p) ;
   p*2 = add p p [mult_comm + two_p_eq] ; lt p (add p p) [lt_p_2p] ;
   so lt p (add p p) = le (Suc p)(add p p) and le (add p p)(p*p) -> le (Suc p)(p*p) = lt p (p*p). *)
fun lt_p_psq pt hPrime =
  let
    val le2p = prime2_gt1_r pt hPrime                       (* le 2 p *)
    val le1p = le_1_p_of pt hPrime                          (* le 1 p *)
    val twoN' = suc (suc ZeroC)
    val lmm = mult_le_mono_g (pt, twoN', pt) le2p           (* le (p*2)(p*p) *)
    (* p*2 = add p p *)
    val pcm = multcomm_g (pt, twoN')                        (* p*2 = 2*p *)
    val tpe = two_p_eq_d pt                                  (* 2*p = add p p *)
    val p2eq = oeqTrans_g (pcm, tpe)                        (* p*2 = add p p *)
    val z = Free("zlpp", natT)
    val Pl = Term.lambda z (le z (mult pt pt))
    val leADD = oeq_rw_r (Pl, mult pt twoN', add pt pt) p2eq lmm   (* le (add p p)(p*p) *)
    val ltp2p = lt_p_2p pt le1p                             (* lt p (add p p) = le (Suc p)(add p p) *)
    (* le (Suc p)(add p p) and le (add p p)(p*p) -> le (Suc p)(p*p) = lt p (p*p) *)
    val res = le_trans_d (suc pt, add pt pt, mult pt pt) ltp2p leADD
  in res end;

(* not_square : prime2 p ==> neg (oeq p (mult s s))  [ p is not a perfect square s*s ] *)
fun not_square (pt, st) hPrime =
  let
    val hsqP = jT (oeq pt (mult st st)); val hsq = Thm.assume (ctermGR hsqP)
    (* dvd s p : Ex k. oeq p (mult s k), witness s, body = hsq *)
    val dvdAbs = Abs("k", natT, oeq pt (mult st (Bound 0)))
    val dvdSP  = exI_r dvdAbs st hsq                        (* dvd s p *)
    (* prime2 forall at d = s *)
    val faThm = prime2_div_r pt hPrime                      (* Forall (ppAbs p) *)
    val faS   = allE_r (ppAbs pt) st faThm                  (* Imp (dvd s p)(Disj (oeq s 1)(oeq s p)) *)
    val disj  = mp_r (dvd st pt, mkDisj (oeq st (suc ZeroC)) (oeq st pt)) faS dvdSP
                                                            (* Disj (oeq s 1)(oeq s p) *)
    val goalC = oFalseC
    (* case s = 1 : p = s*s = 1*1 = 1 ; lt 1 p rewrite p->1 -> lt 1 1 -> irrefl *)
    val caseS1 =
      let val hs1 = Thm.assume (ctermGR (jT (oeq st (suc ZeroC))))   (* s = 1 *)
          (* mult s s = mult 1 1 = 1 *)
          val mss = (* oeq (mult s s)(mult (Suc 0)(Suc 0)) *)
            let val l = mult_cong_l_g (st, suc ZeroC, st) hs1         (* s*s = 1*s *)
                val r = mult_cong_r_g (suc ZeroC, st, suc ZeroC) hs1  (* 1*s = 1*1 *)
            in oeqTrans_g (l, r) end
          val m11 = mult1l_r (suc ZeroC)                              (* 1*1 = 1 *)
          val ssEq1 = oeqTrans_g (mss, m11)                           (* s*s = 1 *)
          val pEq1 = oeqTrans_r2 (hsq, ssEq1)                         (* p = 1 *)
          (* lt 1 p (= le 2 p) rewrite p->1 : le 2 1 ; but easier: lt 1 p and p=1 -> lt 1 1 *)
          val lt1p = prime2_gt1_r pt hPrime                           (* lt 1 p (= le 2 p) *)
          val z = Free("zsq1", natT)
          val Plt = Term.lambda z (lt (suc ZeroC) z)
          val lt11 = oeq_rw_r (Plt, pt, suc ZeroC) pEq1 lt1p          (* lt 1 1 *)
          val fls = lt_irrefl_g (suc ZeroC) lt11
      in Thm.implies_intr (ctermGR (jT (oeq st (suc ZeroC)))) fls end
    (* case s = p : p = s*s = p*p ; but lt p (p*p) ; rewrite p*p -> p (sym of p=p*p) -> lt p p -> irrefl *)
    val caseSp =
      let val hsp = Thm.assume (ctermGR (jT (oeq st pt)))             (* s = p *)
          (* mult s s = mult p p *)
          val msp = let val l = mult_cong_l_g (st, pt, st) hsp        (* s*s = p*s *)
                        val r = mult_cong_r_g (pt, st, pt) hsp        (* p*s = p*p *)
                    in oeqTrans_g (l, r) end                          (* s*s = p*p *)
          val pEqpp = oeqTrans_r2 (hsq, msp)                          (* p = p*p *)
          val ltppp = lt_p_psq pt hPrime                             (* lt p (p*p) *)
          val z = Free("zsqp", natT)
          val Plt = Term.lambda z (lt pt z)
          val ltpp = oeq_rw_r (Plt, mult pt pt, pt) (oeqSym_r2 pEqpp) ltppp  (* lt p p *)
          val fls = lt_irrefl_g pt ltpp
      in Thm.implies_intr (ctermGR (jT (oeq st pt))) fls end
    val flsAll = disjE_r (oeq st (suc ZeroC), oeq st pt, goalC) disj caseS1 caseSp
  in impI_r (oeq pt (mult st st), oFalseC) (Thm.implies_intr (ctermGR hsqP) flsAll) end;   (* neg (oeq p (mult s s)) (OBJECT) *)
val () = out "TSD_NOT_SQUARE_READY\n";

(* le_neq_lt on ctxtGR *)
val le_neq_lt_vGR = varify le_neq_lt;
fun le_neq_lt_r (d,n) hle hneq = Thm.implies_elim (Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtGR
      [(("d",0), ctermGR d),(("n",0), ctermGR n)] le_neq_lt_vGR)) hle) hneq;

(* extract le-witness : from hle : le m n  get (w, oeq n (add m w)).  le m n = Ex w. oeq n (add m w).
   We need the witness term; but exE gives it under a binder.  Instead, build add_le_mono via
   the structure: le a b /\ le c d -> le (add a c)(add b d) using exE on both. *)
fun add_le_mono (a,b,c,d) hab hcd =
  (* hab : le a b = Ex wa. oeq b (add a wa) ; hcd : le c d *)
  let
    val goalC = le (add a c)(add b d)
    val Pa = Abs("wa", natT, oeq b (add a (Bound 0)))
    fun bodyA wa (ha:thm) =   (* ha : oeq b (add a wa) *)
      let val Pc = Abs("wc", natT, oeq d (add c (Bound 0)))
          fun bodyC wc (hc:thm) =   (* hc : oeq d (add c wc) *)
            let
              (* add b d = add (add a wa)(add c wc) [rewrite b, d]
                 = add (add a c)(add wa wc) [rearrange]  -> witness (add wa wc) *)
              (* prove oeq (add b d)(add (add a c)(add wa wc)) *)
              val e1 = (* add b d = add (add a wa) d  (rewrite b) *)
                let val P = Term.lambda (Free("zlm1",natT)) (oeq (add b d)(add (Free("zlm1",natT)) d))
                in oeq_rw_r (P, b, add a wa) ha (oeqRefl_r2 (add b d)) end
              val e2 = (* add (add a wa) d = add (add a wa)(add c wc) (rewrite d) *)
                let val P = Term.lambda (Free("zlm2",natT)) (oeq (add (add a wa) d)(add (add a wa)(Free("zlm2",natT))))
                in oeq_rw_r (P, d, add c wc) hc (oeqRefl_r2 (add (add a wa) d)) end
              val e12 = oeqTrans_r2 (e1, e2)   (* add b d = add (add a wa)(add c wc) *)
              (* (a+wa)+(c+wc) = a + (wa + (c+wc)) [assoc] = a + ((wa+c)+wc) ... rearrange to (a+c)+(wa+wc).
                 Easiest: (a+wa)+(c+wc) = ((a+wa)+c)+wc [assoc back]
                          = (a+(wa+c))+wc [assoc] = (a+(c+wa))+wc [comm] = ((a+c)+wa)+wc [assoc back]
                          = (a+c)+(wa+wc) [assoc] *)
              val r1 = oeqSym_g (addassoc_g (add a wa, c, wc))            (* (a+wa)+(c+wc) = ((a+wa)+c)+wc *)
              val r2 = addassoc_g (a, wa, c)                              (* (a+wa)+c = a+(wa+c) *)
              val r2b = add_cong_l_g (add (add a wa) c, add a (add wa c), wc) r2  (* ((a+wa)+c)+wc = (a+(wa+c))+wc *)
              val r3 = addcomm_g (wa, c)                                  (* wa+c = c+wa *)
              val r3b = add_cong_l_g (add a (add wa c), add a (add c wa), wc)
                          (add_cong_r_g (a, add wa c, add c wa) r3)       (* (a+(wa+c))+wc = (a+(c+wa))+wc *)
              val r4 = oeqSym_g (addassoc_g (a, c, wa))                   (* a+(c+wa) = (a+c)+wa ... sym: (a+c)+wa? addassoc (a,c,wa): (a+c)+wa = a+(c+wa); sym gives a+(c+wa)=(a+c)+wa *)
              val r4b = add_cong_l_g (add a (add c wa), add (add a c) wa, wc) r4  (* (a+(c+wa))+wc = ((a+c)+wa)+wc *)
              val r5 = addassoc_g (add a c, wa, wc)                       (* ((a+c)+wa)+wc = (a+c)+(wa+wc) *)
              val rearr = oeqTrans_r2 (oeqTrans_r2 (oeqTrans_r2 (oeqTrans_r2 (r1, r2b), r3b), r4b), r5)
                          (* (a+wa)+(c+wc) = (a+c)+(wa+wc) *)
              val finalEq = oeqTrans_r2 (e12, rearr)   (* add b d = add (add a c)(add wa wc) *)
              val res = le_intro_d (add a c, add b d, add wa wc) finalEq   (* le (add a c)(add b d) *)
            in res end
      in exE_r (Pc, goalC) hcd "wc_lm" natT bodyC end
  in exE_r (Pa, goalC) hab "wa_lm" natT bodyA end;

val () = out "TSD_ADD_LE_MONO_READY\n";

(* le_lt_trans : le a b ==> lt b c ==> lt a c.
   le a b -> le (Suc a)(Suc b) [le_suc_mono] ; lt b c = le (Suc b) c ; trans -> le (Suc a) c = lt a c *)
fun le_lt_trans (a,b,c) hle hlt =
  let val lsm = le_suc_mono_r (a,b) hle           (* le (Suc a)(Suc b) *)
  in le_trans_d (suc a, suc b, c) lsm hlt end;    (* le (Suc a) c = lt a c *)

(* sq_le : le U s ==> le (mult U U)(mult s s) *)
fun sq_le (U, s) hle =
  let val l1 = mult_le_mono_g (U, U, s) hle        (* le (U*U)(U*s) *)
      val l2a = mult_le_mono_g (s, U, s) hle       (* le (s*U)(s*s) *)
      val comm = multcomm_g (U, s)                  (* U*s = s*U *)
      val z = Free("zsqle", natT)
      val P = Term.lambda z (le z (mult s s))
      val l2 = oeq_rw_r (P, mult s U, mult U s) (oeqSym_g comm) l2a   (* le (U*s)(s*s) *)
  in le_trans_d (mult U U, mult U s, mult s s) l1 l2 end;

(* lt_2mult : lt a b ==> lt (mult twoN a)(mult twoN b) *)
fun lt_2mult (a,b) hlt =
  let
    (* lt a b = le (Suc a) b ; mult_le_mono_g (twoN, Suc a, b) : le (twoN*(Suc a))(twoN*b) *)
    val lmm = mult_le_mono_g (twoN, suc a, b) hlt          (* le (twoN*(Suc a))(twoN*b) *)
    (* twoN*(Suc a) = twoN*a + twoN [mult_Suc_right] ; >= Suc(twoN*a) since twoN >= 1.
       le (Suc(twoN*a))(twoN*(Suc a)) : witness (Suc 0) since twoN*a + twoN = twoN*a + Suc(Suc 0)
       = Suc(twoN*a + Suc 0) = Suc(Suc(twoN*a)) ; and Suc(twoN*a) + Suc 0 = Suc(Suc(twoN*a)).
       So le (Suc(twoN*a))(twoN*(Suc a)). *)
    val msr = multSucr_d (twoN, a)                          (* twoN*(Suc a) = twoN + twoN*a *)
    (* twoN + twoN*a = Suc(Suc 0) + twoN*a = Suc(Suc(0 + twoN*a)) = Suc(Suc(twoN*a)) *)
    val e1 = addSuc_d (suc ZeroC, mult twoN a)              (* add (Suc 0)(twoN*a) = Suc(add 0 (twoN*a)) -- not quite *)
    (* twoN = Suc(Suc 0). add (Suc(Suc 0))(twoN*a) = Suc(add (Suc 0)(twoN*a)) = Suc(Suc(add 0 (twoN*a))) = Suc(Suc(twoN*a)) *)
    val a1 = addSuc_d (suc ZeroC, mult twoN a)              (* add (Suc(Suc 0))? : addSuc_d (m,n)=add (Suc m) n = Suc(add m n); m=Suc 0 -> add (Suc(Suc 0))(twoN*a)=Suc(add (Suc 0)(twoN*a)) *)
    val a2 = addSuc_d (ZeroC, mult twoN a)                  (* add (Suc 0)(twoN*a) = Suc(add 0 (twoN*a)) *)
    val a3 = add0_d (mult twoN a)                            (* add 0 (twoN*a) = twoN*a *)
    (* assemble: add (Suc(Suc 0))(twoN*a) = Suc(Suc(twoN*a)) *)
    val sc2 = let val P = Term.lambda (Free("z2m",natT)) (oeq (suc (add ZeroC (mult twoN a)))(suc (Free("z2m",natT))))
              in oeq_rw_r (P, add ZeroC (mult twoN a), mult twoN a) a3 (oeqRefl_r2 (suc (add ZeroC (mult twoN a)))) end
                                                            (* Suc(add 0 (twoN*a)) = Suc(twoN*a) *)
    val a2' = oeqTrans_r2 (a2, sc2)                          (* add (Suc 0)(twoN*a) = Suc(twoN*a) *)
    val scA = let val P = Term.lambda (Free("z2m2",natT)) (oeq (suc (add (suc ZeroC)(mult twoN a)))(suc (Free("z2m2",natT))))
              in oeq_rw_r (P, add (suc ZeroC)(mult twoN a), suc (mult twoN a)) a2' (oeqRefl_r2 (suc (add (suc ZeroC)(mult twoN a)))) end
                                                            (* Suc(add (Suc 0)(twoN*a)) = Suc(Suc(twoN*a)) *)
    val twoAdd = oeqTrans_r2 (a1, scA)                       (* add (Suc(Suc 0))(twoN*a) = Suc(Suc(twoN*a)) *)
    (* twoN*(Suc a) = twoN + twoN*a = add (Suc(Suc 0))(twoN*a) = Suc(Suc(twoN*a)) *)
    val tsa = oeqTrans_r2 (msr, twoAdd)                      (* twoN*(Suc a) = Suc(Suc(twoN*a)) *)
    (* le (Suc(twoN*a))(Suc(Suc(twoN*a))) : witness Suc 0, oeq (Suc(Suc(twoN*a)))(add (Suc(twoN*a))(Suc 0)) *)
    val wEq = let val asr = addSucr_d (suc (mult twoN a), ZeroC)   (* add (Suc(twoN*a))(Suc 0) = Suc(add (Suc(twoN*a)) 0) *)
                  val a0  = add0r_d (suc (mult twoN a))             (* add (Suc(twoN*a)) 0 = Suc(twoN*a) *)
                  val sc  = let val P = Term.lambda (Free("zw",natT)) (oeq (suc (add (suc (mult twoN a)) ZeroC))(suc (Free("zw",natT))))
                            in oeq_rw_r (P, add (suc (mult twoN a)) ZeroC, suc (mult twoN a)) a0 (oeqRefl_r2 (suc (add (suc (mult twoN a)) ZeroC))) end
                  val combo = oeqTrans_r2 (asr, sc)                 (* add (Suc(twoN*a))(Suc 0) = Suc(Suc(twoN*a)) *)
              in oeqSym_r2 combo end                                (* Suc(Suc(twoN*a)) = add (Suc(twoN*a))(Suc 0) *)
    val leSucStep = le_intro_d (suc (mult twoN a), suc (suc (mult twoN a)), suc ZeroC) wEq  (* le (Suc(twoN*a))(Suc(Suc(twoN*a))) *)
    (* rewrite Suc(Suc(twoN*a)) -> twoN*(Suc a) using sym tsa *)
    val z = Free("z2ml", natT)
    val Pl = Term.lambda z (le (suc (mult twoN a)) z)
    val leStep = oeq_rw_r (Pl, suc (suc (mult twoN a)), mult twoN (suc a)) (oeqSym_r2 tsa) leSucStep
                                                            (* le (Suc(twoN*a))(twoN*(Suc a)) *)
    val res = le_trans_d (suc (mult twoN a), mult twoN (suc a), mult twoN b) leStep lmm
                                                            (* le (Suc(twoN*a))(twoN*b) = lt (twoN*a)(twoN*b) *)
  in res end;

val () = out "TSD_LT_2MULT_READY\n";

(* bound_N : le U s ==> le V s ==> prime2 p ==> le (mult s s) p
             ==> lt (add (mult U U)(mult V V)) (mult twoN p) *)
fun bound_N (U, V, s, p) hUs hVs hPrime hSsP =
  let
    val ss = mult s s
    val UU = mult U U; val VV = mult V V
    val leUU = sq_le (U, s) hUs                              (* le (U*U)(s*s) *)
    val leVV = sq_le (V, s) hVs                              (* le (V*V)(s*s) *)
    val leSum = add_le_mono (UU, ss, VV, ss) leUU leVV       (* le (U*U+V*V)(s*s+s*s) *)
    (* s*s + s*s = mult twoN (s*s) *)
    val tpe = two_p_eq_d ss                                   (* mult twoN (s*s) = add (s*s)(s*s) *)
    val z = Free("zbn", natT)
    val Pl = Term.lambda z (le (add UU VV) z)
    val leSum2 = oeq_rw_r (Pl, add ss ss, mult twoN ss) (oeqSym_g tpe) leSum
                                                            (* le (U*U+V*V)(twoN*(s*s)) *)
    (* lt (s*s) p from not_square + le (s*s) p *)
    val nsq = not_square (p, s) hPrime                       (* neg (oeq p (mult s s)) *)
    (* need neg(oeq (s*s) p) for le_neq_lt (le (s*s) p)(neg(oeq (s*s) p)) -> lt (s*s) p *)
    val nsq' = (* neg (oeq (s*s) p) : from neg(oeq p (s*s)) by symmetry *)
      let val h = Thm.assume (ctermGR (jT (oeq ss p)))      (* s*s = p *)
          val hsym = oeqSym_r2 h                              (* p = s*s *)
          val fls = mp_r (oeq p ss, oFalseC) nsq hsym
      in impI_r (oeq ss p, oFalseC) (Thm.implies_intr (ctermGR (jT (oeq ss p))) fls) end  (* neg (oeq (s*s) p) (OBJECT) *)
    val ltSsP = le_neq_lt_r (ss, p) hSsP nsq'                (* lt (s*s) p *)
    val lt2 = lt_2mult (ss, p) ltSsP                         (* lt (twoN*(s*s))(twoN*p) *)
    (* le (U*U+V*V)(twoN*(s*s)) and lt (twoN*(s*s))(twoN*p) -> lt (U*U+V*V)(twoN*p) *)
    val res = le_lt_trans (add UU VV, mult twoN ss, mult twoN p) leSum2 lt2
  in res end;

(* pos_N : neg (oeq U Zero) ==> lt Zero (add (mult U U)(mult V V))
   (U != 0 -> U*U > 0 -> sum > 0).
   lt 0 (U*U) : U = Suc q (U != 0) ; U*U = (Suc q)*(Suc q) = Suc(...) ; so >= Suc 0.
   Simpler: lt 0 (add (U*U)(V*V)) = le (Suc 0)(add (U*U)(V*V)).  From le (Suc 0)(U*U) and
   le (U*U)(add (U*U)(V*V)) [le_add] -> trans. *)
fun pos_from_U (U, V) hUneq =
  let
    val UU = mult U U; val VV = mult V V
    (* le (Suc 0)(U*U) i.e. lt 0 (U*U).  U != 0 -> U = Suc q ; U*U = U*(Suc q) = U + U*q ; >= Suc 0?
       Actually U*U with U=Suc q: U*U = (Suc q)*U = U + q*U [mult_Suc] >= U = Suc q >= Suc 0.
       Build: lt 0 U from U != 0 (dzos) ; then lt 0 (U*U) via mult positivity.
       lt 0 U = le (Suc 0) U.  le (Suc 0) U and ... want le (Suc 0)(U*U).
       U*U: mult_le_mono_g (U, Suc 0, U) (le (Suc 0) U) : le (U*(Suc 0))(U*U). U*(Suc 0)=U [mult_1_right].
            so le U (U*U).  And le (Suc 0) U. trans -> le (Suc 0)(U*U). *)
    val dz = dzos_d U
    val ltU = (* lt 0 U *)
      let val caseZ = let val hz = Thm.assume (ctermGR (jT (oeq U ZeroC)))
                          val fls = mp_r (oeq U ZeroC, oFalseC) hUneq hz
                      in Thm.implies_intr (ctermGR (jT (oeq U ZeroC))) (Thm.implies_elim (oFalse_elim_r (lt ZeroC U)) fls) end
          val PqSuc = Abs("q", natT, oeq U (suc (Bound 0)))
          val caseS = let val hsP = jT (mkEx PqSuc); val hs = Thm.assume (ctermGR hsP)
                          fun body q (hq:thm) =   (* U = Suc q *)
                            let (* lt 0 U = le (Suc 0) U ; witness q : oeq U (add (Suc 0) q) ?
                                   U = Suc q = add (Suc 0) q ? add (Suc 0) q = Suc(add 0 q) = Suc q. yes. *)
                                val aS = addSuc_d (ZeroC, q)              (* add (Suc 0) q = Suc(add 0 q) *)
                                val a0 = add0_d q                          (* add 0 q = q *)
                                val sc = let val P = Term.lambda (Free("zpu",natT)) (oeq (suc (add ZeroC q))(suc (Free("zpu",natT))))
                                         in oeq_rw_r (P, add ZeroC q, q) a0 (oeqRefl_r2 (suc (add ZeroC q))) end
                                val addEq = oeqTrans_r2 (aS, sc)          (* add (Suc 0) q = Suc q *)
                                val Ueq = oeqTrans_r2 (hq, oeqSym_r2 addEq)  (* U = add (Suc 0) q *)
                            in le_intro_d (suc ZeroC, U, q) Ueq end       (* le (Suc 0) U *)
                      in Thm.implies_intr (ctermGR hsP) (exE_r (PqSuc, lt ZeroC U) hs "qpu" natT body) end
      in disjE_r (oeq U ZeroC, mkEx PqSuc, lt ZeroC U) dz caseZ caseS end
    (* le U (U*U) : mult_le_mono_g (U, Suc 0, U) ltU : le (U*(Suc 0))(U*U); U*(Suc 0)=U *)
    val mlm = mult_le_mono_g (U, suc ZeroC, U) ltU            (* le (U*(Suc 0))(U*U) *)
    val m1r = (* oeq (U*(Suc 0)) U *) beta_norm (Drule.infer_instantiate ctxtGR [(("n",0), ctermGR U)] (varify mult_1_right))
    val z2 = Free("zpu2", natT)
    val Pl = Term.lambda z2 (le z2 (mult U U))
    val leUUU = oeq_rw_r (Pl, mult U (suc ZeroC), U) m1r mlm  (* le U (U*U) *)
    val leSucUU = le_trans_d (suc ZeroC, U, mult U U) ltU leUUU  (* le (Suc 0)(U*U) = lt 0 (U*U) *)
    (* le (U*U)(add (U*U)(V*V)) [le_add] -> trans -> le (Suc 0)(add (U*U)(V*V)) *)
    val leAdd = le_add_r (UU, VV)                            (* le (U*U)(add (U*U)(V*V)) *)
  in le_trans_d (suc ZeroC, mult U U, add UU VV) leSucUU leAdd end;  (* lt 0 (add (U*U)(V*V)) *)
(* pos_from_V : neg (oeq V Zero) ==> lt Zero (add (mult U U)(mult V V))
   symmetric: le (Suc 0)(V*V) ; le (V*V)(add (U*U)(V*V)) via add_comm + le_add. *)
fun pos_from_V (U, V) hVneq =
  let
    val posVV = pos_from_U (V, U) hVneq                       (* lt 0 (add (V*V)(U*U)) *)
    (* rewrite add (V*V)(U*U) -> add (U*U)(V*V) [comm] *)
    val comm = addcomm_g (mult V V, mult U U)                 (* add (V*V)(U*U) = add (U*U)(V*V) *)
    val z = Free("zpv", natT)
    val P = Term.lambda z (lt ZeroC z)
  in oeq_rw_r (P, add (mult V V)(mult U U), add (mult U U)(mult V V)) comm posVV end;

(* diff_nonzero : oeq big (add U small) ==> neg (oeq big small) ==> neg (oeq U Zero) *)
fun diff_nonzero (U, big, small) hbig hneq =
  let val hU0 = Thm.assume (ctermGR (jT (oeq U ZeroC)))      (* U = 0 *)
      (* big = add U small = add 0 small = small *)
      val z = Free("zdn", natT)
      val P = Term.lambda z (oeq big (add z small))
      val bigEq0 = oeq_rw_r (P, U, ZeroC) hU0 hbig             (* oeq big (add 0 small) *)
      val a0 = add0_d small                                    (* add 0 small = small *)
      val bigEqSmall = oeqTrans_r2 (bigEq0, a0)                (* oeq big small *)
      val fls = mp_r (oeq big small, oFalseC) hneq bigEqSmall
  in impI_r (oeq U ZeroC, oFalseC) (Thm.implies_intr (ctermGR (jT (oeq U ZeroC))) fls) end;  (* OBJECT neg *)
val () = out "TSD_BOUND_POS_READY\n";

(* mult_of_p_in_range accessor on ctxtGR *)
fun mopir (pT, N) hcong hpos hlt =
  let val inst = beta_norm (Drule.infer_instantiate ctxtGR
        [(("p_mr",0), ctermGR pT),(("N_mr",0), ctermGR N)] mult_of_p_in_range)
  in Thm.implies_elim (Thm.implies_elim (Thm.implies_elim inst hcong) hpos) hlt end;  (* oeq N p *)

(* finish : given U,V and the descent facts, produce ?a b. oeq p (add (a*a)(b*b)).
   hUs : le U s ; hVs : le V s ; hcong0 : cong p (add (U*U)(V*V)) 0 ; hPos : lt 0 (add (U*U)(V*V)) *)
fun finish (pT, sT, U, V) hPrime hSsP hUs hVs hcong0 hPos =
  let
    val N = add (mult U U)(mult V V)
    val hBound = bound_N (U, V, sT, pT) hUs hVs hPrime hSsP   (* lt N (mult twoN p) *)
    val NeqP = mopir (pT, N) hcong0 hPos hBound               (* oeq N p *)
    val pEqN = oeqSym_r2 NeqP                                  (* oeq p (add (U*U)(V*V)) *)
    (* exI b := V : ?b. oeq p (add (U*U)(b*b)) *)
    val Pb = Term.lambda (Free("b_ts", natT)) (oeq pT (add (mult U U)(mult (Free("b_ts",natT))(Free("b_ts",natT)))))
    val exB = exI_r Pb V pEqN                                  (* ?b. oeq p (add (U*U)(b*b)) *)
    val Pa = Term.lambda (Free("a_ts", natT))
               (mkEx (Term.lambda (Free("b_ts", natT))
                  (oeq pT (add (mult (Free("a_ts",natT))(Free("a_ts",natT)))(mult (Free("b_ts",natT))(Free("b_ts",natT)))))))
    val exA = exI_r Pa U exB                                   (* ?a b. oeq p (add (a*a)(b*b)) *)
  in exA end;
val () = out "TSD_FINISH_READY\n";

(* neq_sym : neg (oeq a b) ==> neg (oeq b a) *)
fun neq_sym (a,b) hneq =
  let val h = Thm.assume (ctermGR (jT (oeq b a)))      (* b = a *)
      val hs = oeqSym_r2 h                               (* a = b *)
      val fls = mp_r (oeq a b, oFalseC) hneq hs
  in impI_r (oeq b a, oFalseC) (Thm.implies_intr (ctermGR (jT (oeq b a))) fls) end;  (* neg (oeq b a) (OBJECT) *)

(* posN : from neg(oeq x1 x2 /\ oeq y1 y2), the x-diff fact, the y-diff fact, derive
   lt 0 (add (U*U)(V*V)).
   Args: x1,x2,y1,y2,U,V, xbig,xsmall (the ordered x pair s.t. hxbig:oeq xbig (add U xsmall)),
         ybig,ysmall similarly, hxbig, hybig, hnegConj.
   xneqConv : neg(oeq x1 x2) -> neg(oeq xbig xsmall) ;  yneqConv similarly. *)
fun posN (x1,x2,y1,y2,U,V) (xbig,xsmall,ybig,ysmall) hxbig hybig hnegConj xneqConv yneqConv =
  let
    val goalC = lt ZeroC (add (mult U U)(mult V V))
    val em = em_g (oeq x1 x2)                            (* Disj (oeq x1 x2)(neg(oeq x1 x2)) *)
    val caseEq =
      let val hxeq = Thm.assume (ctermGR (jT (oeq x1 x2)))   (* x1 = x2 *)
          (* y1 != y2 : assume y1=y2 -> conj holds -> contra hnegConj *)
          val hyneq =
            let val hyeq = Thm.assume (ctermGR (jT (oeq y1 y2)))
                val conj = conjI_r (oeq x1 x2, oeq y1 y2) hxeq hyeq
                val fls = mp_r (mkConj (oeq x1 x2)(oeq y1 y2), oFalseC) hnegConj conj
            in impI_r (oeq y1 y2, oFalseC) (Thm.implies_intr (ctermGR (jT (oeq y1 y2))) fls) end   (* neg(oeq y1 y2) (OBJECT) *)
          val hyneqBS = yneqConv hyneq                     (* neg(oeq ybig ysmall) *)
          val hVneq = diff_nonzero (V, ybig, ysmall) hybig hyneqBS  (* neg(oeq V Zero) *)
          val pos = pos_from_V (U, V) hVneq
      in Thm.implies_intr (ctermGR (jT (oeq x1 x2))) pos end
    val caseNeq =
      let val hxneq = Thm.assume (ctermGR (jT (neg (oeq x1 x2))))   (* neg(oeq x1 x2) *)
          val hxneqBS = xneqConv hxneq                     (* neg(oeq xbig xsmall) *)
          val hUneq = diff_nonzero (U, xbig, xsmall) hxbig hxneqBS  (* neg(oeq U Zero) *)
          val pos = pos_from_U (U, V) hUneq
      in Thm.implies_intr (ctermGR (jT (neg (oeq x1 x2)))) pos end
  in disjE_r (oeq x1 x2, neg (oeq x1 x2), goalC) em caseEq caseNeq end;
val () = out "TSD_POSN_READY\n";

(* le_of_diff : oeq big (add U small) ==> le U big   (witness small) *)
fun le_of_diff (U, big, small) hbig = le_intro_d (U, big, small) hbig;

(* The POS descent path : collision (in correct orientation) -> cong p (U*U+V*V) 0.
   hCollUcV : cong p U (mult c V).  -> sq_descent. *)
fun pos_descent (pT, cT, U, V) hPrime hCollUcV hc2 =
  sq_descent (pT, cT, U, V) hPrime hCollUcV hc2;             (* cong p (U*U+V*V) 0 *)

(* The NEG descent path : hCollNeg : cong p (add U (mult c V)) 0
   -> cong_neg_via_c -> cong p V (c*U) -> sq_descent(V,U) -> cong p (V*V+U*U) 0 -> add_comm. *)
fun neg_descent (pT, cT, U, V) hPrime hCollNeg hc2 =
  let
    val hVcU = cong_neg_via_c (pT, cT, U, V) hPrime hCollNeg hc2   (* cong p V (c*U) *)
    val cVU  = sq_descent (pT, cT, V, U) hPrime hVcU hc2           (* cong p (add (V*V)(U*U)) 0 *)
    (* rewrite add (V*V)(U*U) -> add (U*U)(V*V) [comm] inside cong's FIRST arg *)
    val comm = addcomm_g (mult V V, mult U U)                       (* (V*V)+(U*U) = (U*U)+(V*V) *)
    val z = Free("znd", natT)
    val P = Term.lambda z (cong pT z ZeroC)
  in oeq_rw_r (P, add (mult V V)(mult U U), add (mult U U)(mult V V)) comm cVU end;  (* cong p (U*U+V*V) 0 *)

(* ============================================================================
   descend_case : the 4-way case split. Produces ?a b. oeq p (add (a*a)(b*b)).
     args: terms p,c,s,x1,x2,y1,y2 and
       hPrime, hc2 (cong p (c*c)(p-1)), hSsP (le (s*s) p),
       H (collision : cong p (add x1 (mult c y2))(add x2 (mult c y1))),
       hle_x1s,hle_x2s,hle_y1s,hle_y2s (le _ s),
       hnegConj (neg (oeq x1 x2 /\ oeq y1 y2)).
   ============================================================================ *)
fun descend_case (pT,cT,sT,x1,x2,y1,y2) hPrime hc2 hSsP H
                 hle_x1s hle_x2s hle_y1s hle_y2s hnegConj =
  let
    val goalC = mkEx (Term.lambda (Free("a_ts",natT))
                  (mkEx (Term.lambda (Free("b_ts",natT))
                     (oeq pT (add (mult (Free("a_ts",natT))(Free("a_ts",natT)))
                                  (mult (Free("b_ts",natT))(Free("b_ts",natT))))))))
    val collT = cong pT (add x1 (mult cT y2))(add x2 (mult cT y1))
    val collSymT = cong pT (add x2 (mult cT y1))(add x1 (mult cT y2))
    (* outer: le_total x1 x2 *)
    val emX = le_total_d (x1, x2)     (* Disj (le x1 x2)(le x2 x1) *)
    (* ---- xcase : given which of x is big, return a fn over y-split ---- *)
    fun ycase (xBigIsX1) hxle =
      (* if xBigIsX1: hxle : le x2 x1 ; xbig=x1, xsmall=x2, U=subv x1 x2
         else        hxle : le x1 x2 ; xbig=x2, xsmall=x1, U=subv x2 x1 *)
      let
        val (xbig,xsmall) = if xBigIsX1 then (x1,x2) else (x2,x1)
        val U = subv xbig xsmall
        val hxbig = bigEq (xbig,xsmall) hxle                 (* oeq xbig (add U xsmall) *)
        val hle_xbig_s = if xBigIsX1 then hle_x1s else hle_x2s
        val hUs = le_trans_d (U, xbig, sT) (le_of_diff (U, xbig, xsmall) hxbig) hle_xbig_s
        val xneqConv = if xBigIsX1 then (fn h => h) else (fn h => neq_sym (x1,x2) h)
        val emY = le_total_d (y1, y2)
        fun ybranch (yBigIsY1) hyle =
          let
            val (ybig,ysmall) = if yBigIsY1 then (y1,y2) else (y2,y1)
            val V = subv ybig ysmall
            val hybig = bigEq (ybig,ysmall) hyle             (* oeq ybig (add V ysmall) *)
            val hle_ybig_s = if yBigIsY1 then hle_y1s else hle_y2s
            val hVs = le_trans_d (V, ybig, sT) (le_of_diff (V, ybig, ysmall) hybig) hle_ybig_s
            val yneqConv = if yBigIsY1 then (fn h => h) else (fn h => neq_sym (y1,y2) h)
            (* determine POS vs NEG :
               A: x1 big, y1 big -> POS (collide_to_UeqcV on H)
               D: x2 big, y2 big -> POS (collide_to_UeqcV on cong_sym H, relabeled)
               B: x1 big, y2 big -> NEG (collide_to_neg on H)
               C: x2 big, y1 big -> NEG (collide_to_neg on cong_sym H, relabeled) *)
            val isPos = (xBigIsX1 = yBigIsY1)  (* A or D *)
            val hcong0 =
              if isPos then
                if xBigIsX1 then  (* case A: U=subv x1 x2, V=subv y1 y2 *)
                  let val hUcV = collide_to_UeqcV (pT, cT, x1, x2, y1, y2, U, V) hxbig hybig H
                  in pos_descent (pT, cT, U, V) hPrime hUcV hc2 end
                else              (* case D: collide on cong_sym H, helper x's = (x2,x1), y's=(y2,y1) *)
                  let val Hs = cong_sym_g (pT, add x1 (mult cT y2), add x2 (mult cT y1)) H  (* cong p (x2+c*y1)(x1+c*y2) *)
                      val hUcV = collide_to_UeqcV (pT, cT, x2, x1, y2, y1, U, V) hxbig hybig Hs
                  in pos_descent (pT, cT, U, V) hPrime hUcV hc2 end
              else
                if xBigIsX1 then  (* case B: x1 big, y2 big. collide_to_neg on H, hy: oeq y2 (add V y1) *)
                  let val hNeg = collide_to_neg (pT, cT, x1, x2, y1, y2, U, V) hxbig hybig H
                  in neg_descent (pT, cT, U, V) hPrime hNeg hc2 end
                else              (* case C: x2 big, y1 big. collide_to_neg on cong_sym H, relabel x's=(x2,x1),y's=(y2,y1) *)
                  let val Hs = cong_sym_g (pT, add x1 (mult cT y2), add x2 (mult cT y1)) H
                      val hNeg = collide_to_neg (pT, cT, x2, x1, y2, y1, U, V) hxbig hybig Hs
                  in neg_descent (pT, cT, U, V) hPrime hNeg hc2 end
            val hPos = posN (x1,x2,y1,y2,U,V) (xbig,xsmall,ybig,ysmall) hxbig hybig hnegConj xneqConv yneqConv
          in finish (pT, sT, U, V) hPrime hSsP hUs hVs hcong0 hPos end
        val caseY1 = Thm.implies_intr (ctermGR (jT (le y1 y2))) (ybranch false (Thm.assume (ctermGR (jT (le y1 y2)))))
        val caseY2 = Thm.implies_intr (ctermGR (jT (le y2 y1))) (ybranch true  (Thm.assume (ctermGR (jT (le y2 y1)))))
      in disjE_r (le y1 y2, le y2 y1, goalC) emY caseY1 caseY2 end
    val caseX1 = Thm.implies_intr (ctermGR (jT (le x1 x2))) (ycase false (Thm.assume (ctermGR (jT (le x1 x2)))))
    val caseX2 = Thm.implies_intr (ctermGR (jT (le x2 x1))) (ycase true  (Thm.assume (ctermGR (jT (le x2 x1)))))
  in disjE_r (le x1 x2, le x2 x1, goalC) emX caseX1 caseX2 end;
val () = out "TSD_DESCEND_CASE_READY\n";

(* ---- PROBE posN standalone (case A shape: xbig=x1, ybig=y1) ---- *)
val () =
  let
    val x1 = Free("x1_pn", natT); val x2 = Free("x2_pn", natT)
    val y1 = Free("y1_pn", natT); val y2 = Free("y2_pn", natT)
    val U = subv x1 x2; val V = subv y1 y2
    val hxbigP = jT (oeq x1 (add U x2)); val hxbig = Thm.assume (ctermGR hxbigP)
    val hybigP = jT (oeq y1 (add V y2)); val hybig = Thm.assume (ctermGR hybigP)
    val hnP = jT (neg (mkConj (oeq x1 x2)(oeq y1 y2))); val hn = Thm.assume (ctermGR hnP)
    val r = posN (x1,x2,y1,y2,U,V) (x1,x2,y1,y2) hxbig hybig hn (fn h => h) (fn h => h)
  in out ("PROBE posN prop: "^Syntax.string_of_term ctxtGR (Thm.prop_of r)^"\n");
     out "TSD_POSN_PROBE_OK\n"
  end;

(* ---- PROBE descend_case with concrete assumed hypotheses ---- *)
val () =
  let
    val pT = Free("pP_dc", natT); val cT = Free("cP_dc", natT); val sT = Free("sP_dc", natT)
    val x1 = Free("x1_dc", natT); val x2 = Free("x2_dc", natT)
    val y1 = Free("y1_dc", natT); val y2 = Free("y2_dc", natT)
    val hPrimeP = jT (prime2 pT); val hPrime = Thm.assume (ctermGR hPrimeP)
    val hc2P = jT (cong pT (mult cT cT)(sub pT (suc ZeroC))); val hc2 = Thm.assume (ctermGR hc2P)
    val hSsPP = jT (le (mult sT sT) pT); val hSsP = Thm.assume (ctermGR hSsPP)
    val HP = jT (cong pT (add x1 (mult cT y2))(add x2 (mult cT y1))); val H = Thm.assume (ctermGR HP)
    val hx1P = jT (le x1 sT); val hx1 = Thm.assume (ctermGR hx1P)
    val hx2P = jT (le x2 sT); val hx2 = Thm.assume (ctermGR hx2P)
    val hy1P = jT (le y1 sT); val hy1 = Thm.assume (ctermGR hy1P)
    val hy2P = jT (le y2 sT); val hy2 = Thm.assume (ctermGR hy2P)
    val hnP = jT (neg (mkConj (oeq x1 x2)(oeq y1 y2))); val hn = Thm.assume (ctermGR hnP)
    val r = descend_case (pT,cT,sT,x1,x2,y1,y2) hPrime hc2 hSsP H hx1 hx2 hy1 hy2 hn
  in out ("PROBE descend_case prop: "^Syntax.string_of_term ctxtGR (Thm.prop_of r)^"\n");
     out ("PROBE descend_case nhyps="^Int.toString (length (Thm.hyps_of r))^"\n");
     out "TSD_DESCEND_PROBE_OK\n"
  end;

(* ---- PROBE: feed concrete assumed hyps and print result props ---- *)
val () =
  let
    val pT = Free("pP_pr", natT); val cT = Free("cP_pr", natT)
    val x1 = Free("x1_pr", natT); val x2 = Free("x2_pr", natT)
    val y1 = Free("y1_pr", natT); val y2 = Free("y2_pr", natT)
    val U  = Free("U_pr", natT);  val V  = Free("V_pr", natT)
    val hxP = jT (oeq x1 (add U x2)); val hx = Thm.assume (ctermGR hxP)
    val hyP = jT (oeq y1 (add V y2)); val hy = Thm.assume (ctermGR hyP)
    val HP  = jT (cong pT (add x1 (mult cT y2))(add x2 (mult cT y1))); val H = Thm.assume (ctermGR HP)
    val r1  = collide_to_UeqcV (pT, cT, x1, x2, y1, y2, U, V) hx hy H
  in out ("PROBE collide_to_UeqcV : "^Syntax.string_of_term ctxtGR (Thm.prop_of r1)^"\n") end;
val () =
  let
    val pT = Free("pP_pr2", natT); val cT = Free("cP_pr2", natT)
    val U  = Free("U_pr2", natT);  val V  = Free("V_pr2", natT)
    val hPrimeP = jT (prime2 pT); val hPrime = Thm.assume (ctermGR hPrimeP)
    val hUcVP = jT (cong pT U (mult cT V)); val hUcV = Thm.assume (ctermGR hUcVP)
    val hc2P  = jT (cong pT (mult cT cT)(sub pT (suc ZeroC))); val hc2 = Thm.assume (ctermGR hc2P)
    val r2 = sq_descent (pT, cT, U, V) hPrime hUcV hc2
  in out ("PROBE sq_descent : "^Syntax.string_of_term ctxtGR (Thm.prop_of r2)^"\n");
     out ("PROBE sq_descent hyps="^Int.toString (length (Thm.hyps_of r2))^"\n") end;
val () =
  let
    val pT = Free("pP_pr3", natT); val cT = Free("cP_pr3", natT)
    val U  = Free("U_pr3", natT);  val V  = Free("V_pr3", natT)
    val hPrimeP = jT (prime2 pT); val hPrime = Thm.assume (ctermGR hPrimeP)
    val hNP = jT (cong pT (add U (mult cT V)) ZeroC); val hN = Thm.assume (ctermGR hNP)
    val hc2P  = jT (cong pT (mult cT cT)(sub pT (suc ZeroC))); val hc2 = Thm.assume (ctermGR hc2P)
    val r3 = cong_neg_via_c (pT, cT, U, V) hPrime hN hc2
  in out ("PROBE cong_neg_via_c : "^Syntax.string_of_term ctxtGR (Thm.prop_of r3)^"\n") end;
val () =
  let
