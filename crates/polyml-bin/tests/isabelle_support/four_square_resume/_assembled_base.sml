    val L = mult (add a b) c
    val R = add (mult c a) (mult c b)
    val h = proveIdentityG L R
  in out ("SMOKE proveIdentityG : "^Syntax.string_of_term ctxtG (Thm.prop_of h)^" hyps="^Int.toString(length(Thm.hyps_of h))^"\n") end
