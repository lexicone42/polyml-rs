  in not ((Thm.prop_of mem_remove_bwd) aconv bogus) end;
val () = if probe_mrb_cond then out "PROBE_OK mem_remove_bwd conditional on y<>x\n"
         else out "PROBE_FAIL mem_remove_bwd\n";

