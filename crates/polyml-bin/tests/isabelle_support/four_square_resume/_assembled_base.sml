      [(("a",0), ctermW at),(("b",0), ctermW bt)] le_cases)) hle;

(* ============================================================================
   TARGET 4 : finv_neq :
     prime2 p ==> lmem x (upto (sub p 1)) ==> ~(oeq x 1) ==> ~(oeq x (sub p 1))
