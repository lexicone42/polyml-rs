(* ============================================================================
   LAGRANGE FOUR-SQUARE BASE — helpers appended onto the two-square foundation.
   Final context: ctxtGR / ctermGR on thyGR. exI_r/exE_r are the GR-context
   existential intro/elim; oeqRefl_r the GR reflexivity; all term constructors
   (add, mult, oeq, sub, dvd, cong, le, lt, mkEx, suc, ZeroC, oneN) are global
   SML funcs in scope.
   ============================================================================ *)

(* four_sq n  :=  ?a b c d. oeq n (a*a + b*b + c*c + d*d)  (object existential). *)
fun fourSqBody n a b c d =
  oeq n (add (add (mult a a) (mult b b)) (add (mult c c) (mult d d)));
fun four_sq n =
  mkEx (Term.lambda (Free("a_fs",natT))
    (mkEx (Term.lambda (Free("b_fs",natT))
      (mkEx (Term.lambda (Free("c_fs",natT))
        (mkEx (Term.lambda (Free("d_fs",natT))
          (fourSqBody n (Free("a_fs",natT)) (Free("b_fs",natT)) (Free("c_fs",natT)) (Free("d_fs",natT))))))))));

(* four_sq_witness (n,a,b,c,d) hbody : from |- oeq n (a*a+b*b+c*c+d*d) build |- four_sq n. *)
fun four_sq_witness (nT, aT, bT, cT, dT) (hbody : thm) =
  let
    val Pd = Term.lambda (Free("d_fs",natT)) (fourSqBody nT aT bT cT (Free("d_fs",natT)))
    val e1 = exI_r Pd dT hbody
    val Pc = Term.lambda (Free("c_fs",natT))
               (mkEx (Term.lambda (Free("d_fs",natT)) (fourSqBody nT aT bT (Free("c_fs",natT)) (Free("d_fs",natT)))))
    val e2 = exI_r Pc cT e1
    val Pb = Term.lambda (Free("b_fs",natT))
               (mkEx (Term.lambda (Free("c_fs",natT))
                 (mkEx (Term.lambda (Free("d_fs",natT)) (fourSqBody nT aT (Free("b_fs",natT)) (Free("c_fs",natT)) (Free("d_fs",natT)))))))
    val e3 = exI_r Pb bT e2
    val Pa = Term.lambda (Free("a_fs",natT))
               (mkEx (Term.lambda (Free("b_fs",natT))
                 (mkEx (Term.lambda (Free("c_fs",natT))
                   (mkEx (Term.lambda (Free("d_fs",natT)) (fourSqBody nT (Free("a_fs",natT)) (Free("b_fs",natT)) (Free("c_fs",natT)) (Free("d_fs",natT)))))))))
    val e4 = exI_r Pa aT e3
  in e4 end;

