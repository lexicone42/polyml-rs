fun lmemNilElim_R x = beta_norm (Drule.infer_instantiate ctxtRM [(("x",0), ctermRM x)] lmem_nil_elim_vR);
fun lmemConsFwd_R (x,y,t) = beta_norm (Drule.infer_instantiate ctxtRM
