   Goal:  twosquare : prime2 p ==> oeq (sub p 1)(add (add k k)(add k k))
                                 ==> ?a b. oeq p (add (mult a a)(mult b b)).
   ============================================================================ *)
val () = out "TSD_BEGIN\n";

(* ---- extra varifications onto ctxtGR ---- *)
