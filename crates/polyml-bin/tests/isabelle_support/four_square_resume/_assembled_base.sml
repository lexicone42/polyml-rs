    val hbody = Thm.assume (ctermGR hbodyP)
    val hN0P = jT (cong mF nF ZeroC); val hN0 = Thm.assume (ctermGR hN0P)
    val r = four_residue_sum (mF,aF,bF,cF,dF,nF) hm hbody hN0
