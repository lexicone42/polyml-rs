(* ============================================================================
   FINAL ASSEMBLY :  twosquare
     prime2 p ==> oeq (sub p 1)(add (add k k)(add k k)) ==> ?a b. oeq p (a*a + b*b)
   ============================================================================ *)
val qr_GR2   = varify qr;
val thue_GR2 = varify thue;

val twosquare =
  let
    val pF = Free("p_2sq", natT)
    val kF = Free("k_2sq", natT)
    val hPrimeP = jT (prime2 pF); val hPrime = Thm.assume (ctermGR hPrimeP)
    val h4kP = jT (oeq (sub pF (suc ZeroC)) (add (add kF kF)(add kF kF))); val h4k = Thm.assume (ctermGR h4kP)
    val goalC = mkEx (Term.lambda (Free("a_ts",natT))
                  (mkEx (Term.lambda (Free("b_ts",natT))
                     (oeq pF (add (mult (Free("a_ts",natT))(Free("a_ts",natT)))
                                  (mult (Free("b_ts",natT))(Free("b_ts",natT))))))))

    (* ---- 1. get c with cong p (c*c)(sub p 1) ---- *)
    val qr_inst = beta_norm (Drule.infer_instantiate ctxtGR
                    [(("p",0), ctermGR pF),(("k",0), ctermGR kF)] qr_GR2)
    val qr_ex = Thm.implies_elim (Thm.implies_elim qr_inst hPrime) h4k   (* Ex x. cong p (x*x)(sub p 1) *)
    val Pc = Term.lambda (Free("c_ts",natT)) (cong pF (mult (Free("c_ts",natT))(Free("c_ts",natT)))(sub pF (suc ZeroC)))
    fun afterC c (hc:thm) =   (* hc : cong p (c*c)(sub p 1) *)
      let
        val hc2 = hc   (* exactly cong p (c*c)(sub p 1) *)
        (* ---- 2. 0 < p, instantiate thue at a:=c ---- *)
        val hpos = le_1_p_of pF hPrime    (* le 1 p = lt 0 p = Ex p'. oeq p (add (Suc 0) p') *)
        val thue_inst = beta_norm (Drule.infer_instantiate ctxtGR
                          [(("a",0), ctermGR c),(("p",0), ctermGR pF)] thue_GR2)
        val thue_ex = Thm.implies_elim thue_inst hpos    (* Ex s x1 x2 y1 y2. body *)
        (* nested exE: s, x1, x2, y1, y2 *)
        (* body abstraction builders mirroring thue_intended with a := c *)
        fun bodyAt (sP) (x1,x2,y1,y2) =
          mkConj (mkConj (le (mult sP sP) pF) (lt pF (mult (suc sP)(suc sP))))
            (mkConj (le x1 sP)
              (mkConj (le x2 sP)
                (mkConj (le y1 sP)
                  (mkConj (le y2 sP)
                    (mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))
                            (cong pF (add x1 (mult c y2))(add x2 (mult c y1))))))))
        fun ex4 sP = mkEx (Term.lambda (Free("x1_th",natT))
                       (mkEx (Term.lambda (Free("x2_th",natT))
                         (mkEx (Term.lambda (Free("y1_th",natT))
                           (mkEx (Term.lambda (Free("y2_th",natT))
                             (bodyAt sP (Free("x1_th",natT),Free("x2_th",natT),Free("y1_th",natT),Free("y2_th",natT))))))))))
        val Ps = Term.lambda (Free("s_th",natT)) (ex4 (Free("s_th",natT)))
        fun afterS sP (hs:thm) =   (* hs : ex4 sP *)
          let
            val Px1 = Term.lambda (Free("x1_th",natT))
                        (mkEx (Term.lambda (Free("x2_th",natT))
                          (mkEx (Term.lambda (Free("y1_th",natT))
                            (mkEx (Term.lambda (Free("y2_th",natT))
                              (bodyAt sP (Free("x1_th",natT),Free("x2_th",natT),Free("y1_th",natT),Free("y2_th",natT)))))))))
            fun afterX1 x1 (hx1:thm) =
              let
                val Px2 = Term.lambda (Free("x2_th",natT))
                            (mkEx (Term.lambda (Free("y1_th",natT))
                              (mkEx (Term.lambda (Free("y2_th",natT))
                                (bodyAt sP (x1,Free("x2_th",natT),Free("y1_th",natT),Free("y2_th",natT)))))))
                fun afterX2 x2 (hx2:thm) =
                  let
                    val Py1 = Term.lambda (Free("y1_th",natT))
                                (mkEx (Term.lambda (Free("y2_th",natT))
                                  (bodyAt sP (x1,x2,Free("y1_th",natT),Free("y2_th",natT)))))
                    fun afterY1 y1 (hy1:thm) =
                      let
                        val Py2 = Term.lambda (Free("y2_th",natT))
                                    (bodyAt sP (x1,x2,y1,Free("y2_th",natT)))
                        fun afterY2 y2 (hbody:thm) =   (* hbody : bodyAt sP (x1,x2,y1,y2) *)
                          let
                            (* destructure hbody *)
                            val cA = mkConj (le (mult sP sP) pF) (lt pF (mult (suc sP)(suc sP)))
                            val rest1 = mkConj (le x1 sP)(mkConj (le x2 sP)(mkConj (le y1 sP)(mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1)))))))
                            val hsqConj = conjunct1_r (cA, rest1) hbody       (* Conj (le ss p)(lt p (Ss·Ss)) *)
                            val hSsP = conjunct1_r (le (mult sP sP) pF, lt pF (mult (suc sP)(suc sP))) hsqConj  (* le (s*s) p *)
                            val r1 = conjunct2_r (cA, rest1) hbody            (* rest1 *)
                            val hx1s = conjunct1_r (le x1 sP, mkConj (le x2 sP)(mkConj (le y1 sP)(mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1))))))) r1
                            val r2 = conjunct2_r (le x1 sP, mkConj (le x2 sP)(mkConj (le y1 sP)(mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1))))))) r1
                            val hx2s = conjunct1_r (le x2 sP, mkConj (le y1 sP)(mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1)))))) r2
                            val r3 = conjunct2_r (le x2 sP, mkConj (le y1 sP)(mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1)))))) r2
                            val hy1s = conjunct1_r (le y1 sP, mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1))))) r3
                            val r4 = conjunct2_r (le y1 sP, mkConj (le y2 sP)(mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1))))) r3
                            val hy2s = conjunct1_r (le y2 sP, mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1)))) r4
                            val r5 = conjunct2_r (le y2 sP, mkConj (neg (mkConj (oeq x1 x2)(oeq y1 y2)))(cong pF (add x1 (mult c y2))(add x2 (mult c y1)))) r4
                            val hneg = conjunct1_r (neg (mkConj (oeq x1 x2)(oeq y1 y2)), cong pF (add x1 (mult c y2))(add x2 (mult c y1))) r5
                            val H = conjunct2_r (neg (mkConj (oeq x1 x2)(oeq y1 y2)), cong pF (add x1 (mult c y2))(add x2 (mult c y1))) r5  (* collision *)
                          in descend_case (pF,c,sP,x1,x2,y1,y2) hPrime hc2 hSsP H hx1s hx2s hy1s hy2s hneg end
                      in exE_r (Py2, goalC) hy1 "y2_th" natT afterY2 end
                  in exE_r (Py1, goalC) hx2 "y1_th" natT afterY1 end
              in exE_r (Px2, goalC) hx1 "x2_th" natT afterX2 end
            val body = exE_r (Px1, goalC) hs "x1_th" natT afterX1
          in body end
      in exE_r (Ps, goalC) thue_ex "s_th" natT afterS end
    val mainEx = exE_r (Pc, goalC) qr_ex "c_ts" natT afterC
  in Thm.implies_intr (ctermGR hPrimeP) (Thm.implies_intr (ctermGR h4kP) mainEx) end;

val () = out ("twosquare hyps="^Int.toString (length (Thm.hyps_of twosquare))^"\n");
val () = out ("twosquare prop = "^Syntax.string_of_term ctxtGR (Thm.prop_of twosquare)^"\n");
val () = out "TWOSQ_OK\n";

(* ============================================================================
   FINAL VALIDATION : aconv against intended statement + 0-hyp confirmation.
   ============================================================================ *)
val twosquare_intended =
  let
    val pV = Free("p_2sq", natT); val kV = Free("k_2sq", natT)
    val concl = mkEx (Term.lambda (Free("a_ts",natT))
                  (mkEx (Term.lambda (Free("b_ts",natT))
                     (oeq pV (add (mult (Free("a_ts",natT))(Free("a_ts",natT)))
                                  (mult (Free("b_ts",natT))(Free("b_ts",natT))))))))
  in Logic.mk_implies (jT (prime2 pV),
       Logic.mk_implies (jT (oeq (sub pV (suc ZeroC)) (add (add kV kV)(add kV kV))),
