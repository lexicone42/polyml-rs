  Thm.implies_elim (Thm.implies_elim (beta_norm (Drule.infer_instantiate ctxtGR
    [(("m",0), ctermGR m),(("a",0), ctermGR a),(("a2",0), ctermGR a2),
     (("b",0), ctermGR b),(("b2",0), ctermGR b2)] cong_mult_vGR)) h1) h2;

(* ---- mult algebra on ctxtGR (suffix _dm) by re-instantiating the _g lemmas
        through ctxtGR cterms.  The _g combinators already work on ctxtGR (the
        note guarantees it), so we just ALIAS to the _g forms. ---- *)
