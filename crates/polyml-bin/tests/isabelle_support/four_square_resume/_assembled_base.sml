  in out ("SMOKE cong_zero_imp_mult hyps="^Int.toString(length(Thm.hyps_of r))
          ^" prop="^Syntax.string_of_term ctxtGR (Thm.prop_of r)^"\n") end
  handle e => out ("SMOKE cong_zero_imp_mult FAIL "^exnMessage e^"\n");
