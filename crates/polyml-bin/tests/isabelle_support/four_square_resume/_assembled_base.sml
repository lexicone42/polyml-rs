  in exI_r Pabs w hyp end;

(* ---- dvd_elim_gr : dvd a b ==> (meta: !!w. oeq b (mult a w) ==> R) ==> R ---- *)
fun dvd_elim_gr (aT, bT, goalC) hdvd bodyFn =
  let val Pabs = Abs("k", natT, oeq bT (mult aT (Bound 0)))
  in exE_r (Pabs, goalC) hdvd "w_dvd" natT bodyFn end;

