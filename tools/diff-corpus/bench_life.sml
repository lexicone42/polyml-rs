(* life — Conway's Game of Life on an unbounded grid, list-of-live-cells rep.
 * Classic SML/NJ "life". Deterministic: starts from an r-pentomino at the
 * origin and advances n generations. Neighbour counting is sort-then-group
 * (a tail-recursive merge sort on (x,y) pairs). checksum = population : a
 * permutation-invariant hash of the live-cell coordinates. Pure integer/list;
 * heavy on allocation, comparison, and the GC. *)

fun cmpPair ((x1, y1), (x2, y2)) =
    case Int.compare (x1, x2) of EQUAL => Int.compare (y1, y2) | ord => ord;

fun msortPairs xs =
    let
      fun merge (xs, ys) =
          let fun go ([], ys, acc) = List.revAppend (acc, ys)
                | go (xs, [], acc) = List.revAppend (acc, xs)
                | go (x :: xs, y :: ys, acc) =
                    if cmpPair (x, y) <> GREATER then go (xs, y :: ys, x :: acc)
                    else go (x :: xs, ys, y :: acc)
          in go (xs, ys, []) end
      fun mergePairs (a :: b :: rest, acc) = mergePairs (rest, merge (a, b) :: acc)
        | mergePairs ([a], acc) = a :: acc
        | mergePairs ([], acc) = acc
      fun loop [] = []
        | loop [a] = a
        | loop runs = loop (mergePairs (runs, []))
    in loop (List.foldl (fn (x, acc) => [x] :: acc) [] xs) end;

fun neighbours (x, y) =
    [(x-1, y-1), (x, y-1), (x+1, y-1), (x-1, y), (x+1, y),
     (x-1, y+1), (x, y+1), (x+1, y+1)];

fun member (_, []) = false
  | member (c, y :: ys) = c = y orelse member (c, ys);

fun step alive =
    let
      val nbrs = List.concat (List.map neighbours alive)
      val sorted = msortPairs nbrs
      (* group a sorted list into (coord, count) runs; tail-recursive *)
      fun run ([], c, cur) = ([], (cur, c))
        | run (y :: ys, c, cur) =
            if y = cur then run (ys, c + 1, cur) else (y :: ys, (cur, c))
      fun group ([], acc) = acc
        | group (x :: xs, acc) =
            let val (rest, pc) = run (xs, 1, x) in group (rest, pc :: acc) end
      val counted = group (sorted, [])
      fun willLive (c, k) = k = 3 orelse (k = 2 andalso member (c, alive))
    in List.foldl (fn (pc, acc) => if willLive pc then #1 pc :: acc else acc) [] counted end;

fun life gens =
    let
      val start = [(1,0), (2,0), (0,1), (1,1), (1,2)]   (* r-pentomino *)
      fun run (0, cells) = cells
        | run (g, cells) = run (g - 1, step cells)
      val final = run (gens, start)
      val P = 1000000007
      val K = 1000000
      val B = 2000003
      fun enc (x, y) = ((x + K) * B + (y + K)) mod P
      val h = List.foldl (fn (c, a) => (a + enc c) mod P) 0 final
    in (length final, h) end;

fun bench n = life n;
fun checksum (pop, h) = Int.toString pop ^ ":" ^ Int.toString h;

val bench_name = "bench_life";
val default_n  = 30;
(* ---- shared bench driver (identical across all bench_*.sml) ----
 * No env vars  -> faithfulness mode: prints @@<bench_name>=<checksum> at the
 *                 SMALL default size (deterministic; the differential sweep
 *                 compares this line byte-for-byte against upstream).
 * BENCH_TIME=1 -> timing mode: runs BENCH_REPS reps at size BENCH_N under an
 *                 in-SML CPU Timer, prints @@time_ms / @@reps / @@n / @@checksum.
 *)
local
  fun getenvInt name dflt =
      case OS.Process.getEnv name of
          SOME s => (case Int.fromString s of SOME i => i | NONE => dflt)
        | NONE => dflt
  val n0     = getenvInt "BENCH_N" default_n
  val reps   = getenvInt "BENCH_REPS" 1
  val timing = Option.isSome (OS.Process.getEnv "BENCH_TIME")
  fun repeat k = if k <= 1 then checksum (bench n0)
                 else (checksum (bench n0); repeat (k - 1))
in
  val () =
    if timing then
      let
        val t  = Timer.startCPUTimer ()
        val cs = repeat reps
        val {usr, sys} = Timer.checkCPUTimer t
        val ms = Time.toMilliseconds usr + Time.toMilliseconds sys
      in
