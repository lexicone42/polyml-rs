val () = print ("@@minint_plus1_inrange=" ^ Int.toString (valOf Int.minInt + 1) ^ "\n");
val s = (Int.toString (valOf Int.maxInt + 1)) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@maxint_plus1_overflow=" ^ s ^ "\n");
val s = (Int.toString (valOf Int.minInt - 1)) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@minint_minus1_overflow=" ^ s ^ "\n");
val s = (Int.toString (~(valOf Int.minInt))) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@neg_minint_overflow=" ^ s ^ "\n");
