val () = print ("@@abs_maxint_inrange=" ^ Int.toString (abs (valOf Int.maxInt)) ^ "\n");
val () = print ("@@neg_maxint_inrange=" ^ Int.toString (~(valOf Int.maxInt)) ^ "\n");
val s = (Int.toString (valOf Int.minInt div ~1)) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@minint_div_neg1_overflow=" ^ s ^ "\n");
val s = (Int.toString (Int.quot (valOf Int.minInt, ~1))) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@minint_quot_neg1_overflow=" ^ s ^ "\n");
val s = (Int.toString (valOf Int.maxInt * 2)) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@maxint_times2_overflow=" ^ s ^ "\n");
val s = (Int.toString (3037000500 * 3037000500)) handle Overflow => "CAUGHT" | _ => "OTHER"; val () = print ("@@sqrt_maxint_squared_overflow=" ^ s ^ "\n");
val () = print ("@@big_mult_inrange=" ^ Int.toString (3037000499 * 1000000000) ^ "\n");
