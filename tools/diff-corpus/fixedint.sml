val () = print ("@@quot_7_neg2=" ^ Int.toString (Int.quot (7, ~2)) ^ "\n");
val () = print ("@@rem_7_neg2=" ^ Int.toString (Int.rem (7, ~2)) ^ "\n");
val () = print ("@@rem_neg7_neg2=" ^ Int.toString (Int.rem (~7, ~2)) ^ "\n");
val () = print ("@@div_minint_2=" ^ Int.toString (valOf Int.minInt div 2) ^ "\n");
val () = print ("@@mod_minint_3=" ^ Int.toString (valOf Int.minInt mod 3) ^ "\n");
val () = print ("@@int_sign_neg=" ^ Int.toString (Int.sign (~42)) ^ "\n");
val () = print ("@@int_sign_zero=" ^ Int.toString (Int.sign 0) ^ "\n");
val () = print ("@@int_sign_minint=" ^ Int.toString (Int.sign (valOf Int.minInt)) ^ "\n");
val () = print ("@@int_samesign_negs=" ^ Bool.toString (Int.sameSign (~5, ~99)) ^ "\n");
