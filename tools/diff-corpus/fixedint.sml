(* diff-corpus category: fixedint — FixedInt/default-int arithmetic and OVERFLOW boundaries *)

val () = print ("@@maxint_value=" ^ Int.toString (valOf Int.maxInt) ^ "\n");
val () = print ("@@minint_value=" ^ Int.toString (valOf Int.minInt) ^ "\n");
val () = print ("@@int_precision=" ^ Int.toString (valOf Int.precision) ^ "\n");
