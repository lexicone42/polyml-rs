(* sort — bottom-up merge sort of a pseudo-random integer list.
 * The list is generated by a fixed LCG (constant seed) so the input is
 * identical on every run/engine. All LCG values stay < 2^31 and products stay
 * < 2^62, so arithmetic never leaves the tagged-fixnum fast path (fair timing).
 * merge and mergePairs are tail-recursive so large lists don't blow the stack.
 * checksum = length : sorted? : positional-hash : permutation-preserved?  — a
 * strong faithfulness signal (order, count, and multiset are all checked). *)

fun lcgList (n, seed) =
    let
      fun go (0, _, acc) = acc
        | go (k, s, acc) =
            let val s' = (s * 1103515245 + 12345) mod 2147483648
            in go (k - 1, s', s' :: acc) end
    in go (n, seed, []) end;

fun msort cmp xs =
    let
      fun merge (xs, ys) =
          let
            fun go ([], ys, acc) = List.revAppend (acc, ys)
              | go (xs, [], acc) = List.revAppend (acc, xs)
              | go (x :: xs, y :: ys, acc) =
                  if cmp (x, y) <> GREATER then go (xs, y :: ys, x :: acc)
                  else go (x :: xs, ys, y :: acc)
          in go (xs, ys, []) end
      fun mergePairs (a :: b :: rest, acc) = mergePairs (rest, merge (a, b) :: acc)
        | mergePairs ([a], acc) = a :: acc
        | mergePairs ([], acc) = acc
      fun loop [] = []
        | loop [a] = a
        | loop runs = loop (mergePairs (runs, []))
      val singles = List.foldl (fn (x, acc) => [x] :: acc) [] xs
    in loop singles end;

fun bench n =
    let
      val xs = lcgList (n, 1)
      val sorted = msort Int.compare xs
      val P = 1000000007
      fun sortedOK (a :: b :: rest) = a <= b andalso sortedOK (b :: rest)
        | sortedOK _ = true
      fun commHash l = List.foldl (fn (x, h) => (h + x) mod P) 0 l   (* permutation-invariant *)
      fun posHash l =
          let fun go ([], _, h) = h
                | go (x :: xs, i, h) = go (xs, i + 1, (h * 1000003 + x + i) mod P)
          in go (l, 1, 0) end
    in (length sorted, sortedOK sorted, posHash sorted, commHash xs = commHash sorted) end;

fun checksum (len, ok, ph, perm) =
    Int.toString len ^ ":" ^ Bool.toString ok ^ ":" ^ Int.toString ph ^ ":" ^ Bool.toString perm;

val bench_name = "bench_sort";
val default_n  = 5000;
